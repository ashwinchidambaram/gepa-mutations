{
    "response": "\u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u092a\u094d\u0930\u092d\u093e\u0935\u0915\u093e\u0930\u0940 \u0930\u0942\u092a\u092e\u093e \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0917\u0924 \u0935\u093f\u0924\u094d\u0924 \u0935\u094d\u092f\u0935\u0938\u094d\u0925\u093e\u092a\u0928 \u0917\u0930\u094d\u0928 \u0938\u0915\u094d\u091b\u0928\u094d \u0909\u092a\u093e\u092f\u0939\u0930\u0942 \u091b\u0928\u094c\u0902 \u091c\u0938\u092e\u093e \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0928\u093f\u092f\u092e\u0928, \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0928\u093f\u092f\u0928\u094d\u0924\u094d\u0930\u0923, \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0928\u093f\u092f\u0941\u0915\u094d\u0924\u093f \u0930 \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0928\u093f\u092f\u0928\u094d\u0924\u094d\u0930\u0923 \u091b\u0928\u094c\u0902\u0964 \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0928\u093f\u092f\u092e\u0928 \u0930 \u0928\u093f\u092f\u0928\u094d\u0924\u094d\u0930\u0923 \u0932\u0947\u0916\u093e \u0928\u093f\u092f\u092e\u0928 \u0930 \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0905\u0935\u0938\u094d\u0925\u093e \u0905\u0928\u0941\u0932\u0947\u0936\u0928 \u091b\u0928\u094c\u0902\u0964 \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0928\u093f\u092f\u0928\u094d\u0924\u094d\u0930\u0923 \u0930 \u0928\u093f\u092f\u0941\u0915\u094d\u0924\u093f \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0935\u093f\u0924\u0930\u0923 \u0930 \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0928\u093f\u092f\u0928\u094d\u0924\u094d\u0930\u0923 \u091b\u0928\u094c\u0902\u0964 \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0928\u093f\u092f\u0928\u094d\u0924\u094d\u0930\u0923 \u0930 \u0928\u093f\u092f\u0941\u0915\u094d\u0924\u093f \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0935\u093f\u0924\u0930\u0923 \u0930 \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0928\u093f\u092f\u0928\u094d\u0924\u094d\u0930\u0923 \u091b\u0928\u094c\u0902\u0964"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u5176\u4e2d\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u548c\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u5728\u672a\u4f9d\u6cd5\u9001\u8fbe\u76f8\u5173\u6cd5\u5f8b\u6587\u4e66\u7684\u60c5\u51b5\u4e0b\uff0c\u76f4\u63a5\u8d23\u4ee4\u88ab\u7533\u8bf7\u4eba\u5c65\u884c\u4e49\u52a1\uff0c\u5bfc\u81f4\u7533\u8bf7\u4eba\u672a\u80fd\u53ca\u65f6\u83b7\u5f97\u901a\u77e5\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u6848\u4ef6\u7684\u516c\u6b63\u5904\u7406\u3002\u8fd9\u79cd\u505a\u6cd5\u8fdd\u53cd\u4e86\u300a\u884c\u653f\u590d\u8bae\u6cd5\u300b\u5173\u4e8e\u9001\u8fbe\u7a0b\u5e8f\u7684\u89c4\u5b9a\uff0c\u4e5f\u66b4\u9732\u51fa\u884c\u653f\u590d\u8bae\u7a0b\u5e8f\u4e2d\u7684\u6cd5\u5f8b\u610f\u8bc6\u8584\u5f31\u3002\n\n\u6b64\u5916\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u6267\u884c\u6548\u679c\u4e0d\u4f73\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u6784\u5728\u5904\u7406\u4e00\u8d77\u6d89\u53ca\u571f\u5730\u5f81\u6536\u7684\u6848\u4ef6\u65f6\uff0c\u867d\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u672a\u5bf9\u6267\u884c\u60c5\u51b5\u8fdb\u884c\u8ddf\u8e2a\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u957f\u671f\u672a\u5c65\u884c\u4e49\u52a1\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u548c\u516c\u4fe1\u529b\u3002\u8fd9\u79cd\u6267\u884c\u4e0d\u529b\u7684\u73b0\u8c61\u53cd\u6620\u51fa\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u73af\u8282\u7684\u8584\u5f31\u73af\u8282\u3002\n\n\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u5bf9\u88ab\u7533\u8bf7\u4eba\u5c65\u884c\u4e49\u52a1\u7684\u671f\u9650\u8bbe\u5b9a\u4e0d\u591f\u660e\u786e\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u4e2d\u51fa\u73b0\u4e89\u8bae\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u4e2d\u672a\u660e\u786e\u5177\u4f53\u671f\u9650\uff0c\u81f4\u4f7f\u88ab\u7533\u8bf7\u4eba\u96be\u4ee5\u6309\u65f6\u5c65\u884c\u4e49\u52a1\uff0c\u8fdb\u800c\u5f15\u53d1\u7533\u8bf7\u4eba\u5bf9\u590d\u8bae\u673a\u5173\u7684\u4e0d\u6ee1\u3002\u8fd9\u79cd\u4e0d\u660e\u786e\u7684\u671f\u9650\u8bbe\u5b9a\uff0c\u4e0d\u4ec5\u5f71\u54cd\u4e86\u6848\u4ef6\u7684\u987a\u5229\u5904\u7406\uff0c\u4e5f\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u7684\u6cd5\u5f8b\u6548\u529b\u3002\n\nDocument\u4e2d\u63d0\u5230\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5e94\u7ed3\u5408\u5177\u4f53\u6848\u4ef6\u60c5\u51b5\uff0c\u4f9d\u6cd5\u4f5c\u51fa\uff0c\u5e76\u786e\u4fdd\u6267\u884c\u8fc7\u7a0b\u7684\u900f\u660e\u548c\u516c\u6b63\u3002\u7136\u800c\uff0c\u76ee\u524d\u5728\u5b9e\u9645\u6267\u884c\u4e2d\uff0c\u4ecd\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u5982\u590d\u8bae\u673a\u5173\u5bf9\u6848\u4ef6\u7684\u91cd\u89c6\u7a0b\u5ea6\u4e0d\u8db3\u3001\u6267\u884c\u529b\u5ea6\u4e0d\u591f\u3001\u76d1\u7763\u673a\u5236\u4e0d\u5065\u5168\u7b49\uff0c\u8fd9\u4e9b\u95ee\u9898\u9700\u8981\u5f15\u8d77\u91cd\u89c6\u5e76\u52a0\u4ee5\u6539\u8fdb\u3002"
}
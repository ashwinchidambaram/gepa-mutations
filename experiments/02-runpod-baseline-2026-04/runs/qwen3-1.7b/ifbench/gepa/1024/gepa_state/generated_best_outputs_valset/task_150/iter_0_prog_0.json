{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u3001\u7a0b\u5e8f\u4e0d\u89c4\u8303\u4ee5\u53ca\u6cd5\u5f8b\u4f9d\u636e\u4e0d\u660e\u786e\u7b49\u65b9\u9762\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u653f\u5e9c\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u590d\u8bae\u6848\u4ef6\u65f6\uff0c\u672a\u4f9d\u6cd5\u5c65\u884c\u8d23\u4ee4\u5c65\u884c\u7684\u4e49\u52a1\uff0c\u5bfc\u81f4\u590d\u8bae\u673a\u5173\u672a\u80fd\u53ca\u65f6\u7ea0\u6b63\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u6548\u7387\u3002\u8fd9\u79cd\u60c5\u51b5\u4e0b\uff0c\u590d\u8bae\u673a\u5173\u5f80\u5f80\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u7f3a\u4e4f\u900f\u660e\u5ea6\u548c\u53ef\u8ffd\u6eaf\u6027\u3002\n\n\u5728\u5177\u4f53\u64cd\u4f5c\u4e2d\uff0c\u4e00\u4e9b\u590d\u8bae\u673a\u5173\u5bf9\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u660e\u786e\u7684\u7a0b\u5e8f\u6307\u5f15\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u4e2d\u51fa\u73b0\u6df7\u4e71\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u8bb8\u53ef\u6848\u4ef6\u65f6\uff0c\u672a\u6309\u7167\u6cd5\u5f8b\u89c4\u5b9a\u53ca\u65f6\u5411\u7533\u8bf7\u4eba\u9001\u8fbe\u5c65\u884c\u901a\u77e5\u4e66\uff0c\u5bfc\u81f4\u7533\u8bf7\u4eba\u957f\u671f\u672a\u6536\u5230\u76f8\u5173\u901a\u77e5\uff0c\u5f71\u54cd\u4e86\u5176\u5408\u6cd5\u6743\u76ca\u7684\u5b9e\u73b0\u3002\u8fd9\u79cd\u7f3a\u4e4f\u89c4\u8303\u7684\u6267\u884c\u7a0b\u5e8f\uff0c\u4f7f\u5f97\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6548\u529b\u96be\u4ee5\u4fdd\u969c\u3002\n\n\u6b64\u5916\uff0c\u6cd5\u5f8b\u4f9d\u636e\u4e0d\u660e\u786e\u4e5f\u662f\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5b58\u5728\u7684\u7a81\u51fa\u95ee\u9898\u3002\u4e00\u4e9b\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u672a\u5145\u5206\u4f9d\u636e\u300a\u884c\u653f\u590d\u8bae\u6cd5\u300b\u53ca\u76f8\u5173\u53f8\u6cd5\u89e3\u91ca\uff0c\u5bfc\u81f4\u51b3\u5b9a\u5185\u5bb9\u7f3a\u4e4f\u6cd5\u5f8b\u652f\u6491\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u5904\u7f5a\u6848\u4ef6\u65f6\uff0c\u672a\u660e\u786e\u8bf4\u660e\u8d23\u4ee4\u5c65\u884c\u7684\u6cd5\u5f8b\u4f9d\u636e\uff0c\u5bfc\u81f4\u7533\u8bf7\u4eba\u5bf9\u51b3\u5b9a\u7684\u5408\u6cd5\u6027\u4ea7\u751f\u8d28\u7591\uff0c\u8fdb\u800c\u5f71\u54cd\u4e86\u590d\u8bae\u7684\u516c\u6b63\u6027\u3002\n\ndocument\n\n\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u5f80\u5f80\u9762\u4e34\u8d44\u6e90\u6709\u9650\u3001\u4eba\u5458\u4e0d\u8db3\u7b49\u95ee\u9898\uff0c\u5bfc\u81f4\u6267\u884c\u6548\u7387\u4f4e\u4e0b\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u5927\u91cf\u590d\u8bae\u6848\u4ef6\u65f6\uff0c\u7531\u4e8e\u7f3a\u4e4f\u4e13\u95e8\u7684\u6267\u884c\u961f\u4f0d\uff0c\u5bfc\u81f4\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u8fdb\u5ea6\u7f13\u6162\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u603b\u4f53\u6548\u679c\u3002\u8fd9\u79cd\u60c5\u51b5\u4e0b\uff0c\u590d\u8bae\u673a\u5173\u9700\u8981\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u52a0\u5f3a\u534f\u8c03\u4e0e\u914d\u5408\uff0c\u786e\u4fdd\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u80fd\u591f\u53ca\u65f6\u3001\u6709\u6548\u5730\u843d\u5b9e\u3002"
}
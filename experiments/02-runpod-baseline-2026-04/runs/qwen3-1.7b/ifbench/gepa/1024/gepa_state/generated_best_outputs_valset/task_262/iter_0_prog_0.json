{
    "response": "\u0623\u0646\u0627 \u0633\u0639\u064a\u062f \u0623\u0646 \u0623\u0642\u062f\u0645 \u0644\u0643 \u0625\u0642\u062a\u0631\u0627\u062d\u0627\u062a \u0644\u0639\u0645\u0644 \u0642\u0646\u0627\u0629 \u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u062a\u0645\u0627\u0645\u064b\u0627 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0625\u0635\u0637\u0646\u0627\u0639\u064a. \u064a\u0645\u0643\u0646\u0646\u064a \u0623\u0646 \u0623\u0635\u0645\u0645 \u0645\u062d\u062a\u0648\u0649\u064b \u0645\u0628\u062a\u0643\u0631\u064b\u0627 \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0623\u062f\u0648\u0627\u062a \u0645\u062b\u0644 \u062a\u0637\u0628\u064a\u0642\u0627\u062a \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a\u060c \u0648\u062a\u062d\u0644\u064a\u0644 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a\u060c \u0648\u062a\u062d\u062f\u064a\u062b \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0628\u0634\u0643\u0644 \u062f\u0648\u0631\u064a. \u0643\u0644 \u0645\u062d\u062a\u0648\u0649 \u0633\u064a\u0643\u0648\u0646 \u0645\u064f\u0639\u062f\u064b\u0627 \u0628\u0639\u0646\u0627\u064a\u0629 \u0644\u0636\u0645\u0627\u0646 \u062c\u0648\u062f\u062a\u0647 \u0648\u0627\u0644\u062a\u0641\u0627\u0639\u0644 \u0645\u0639 \u0627\u0644\u062c\u0645\u0647\u0648\u0631.\n\n\u0623\u0646\u0627 \u0623\u0624\u0645\u0646 \u0628\u0623\u0646 \u0627\u0644\u0642\u0646\u0648\u0627\u062a \u0627\u0644\u0645\u064f\u0635\u0646\u0641\u0629 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0625\u0635\u0637\u0646\u0627\u0639\u064a \u062a\u064f\u062d\u062f\u062b \u0641\u0631\u0642\u064b\u0627 \u0643\u0628\u064a\u0631\u064b\u0627 \u0641\u064a \u062a\u062c\u0631\u0628\u0629 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u060c \u0648\u0631\u0628\u0645\u0627 \u062a\u0643\u0648\u0646 \u0647\u0630\u0647 \u0627\u0644\u0642\u0646\u0627\u0629 \u0648\u0627\u062d\u062f\u0629 \u0645\u0646 \u0623\u0643\u062b\u0631 \u0627\u0644\u0642\u0646\u0648\u0627\u062a \u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u0648\u0639\u0635\u0631\u064a\u0629. \u0623\u0639\u062a\u0642\u062f \u0623\u0646 \u0647\u0630\u0627 \u0647\u0648 \u0627\u0644\u0627\u062a\u062c\u0627\u0647 \u0627\u0644\u0630\u064a \u0646\u062d\u062a\u0627\u062c \u0625\u0644\u0649 \u0627\u062a\u0628\u0627\u0639\u0647.\n\n\u0623\u0646\u0627 \u0623\u0624\u0645\u0646 \u0628\u0623\u0646 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u064a\u0645\u0643\u0646 \u0623\u0646 \u064a\u064f\u0642\u062f\u0645 \u0645\u062d\u062a\u0648\u0649\u064b \u0645\u064f\u0641\u064a\u062f\u064b\u0627 \u0648\u0645\u0644\u0647\u0645\u064b\u0627\u060c \u0648\u0631\u0628\u0645\u0627 \u062a\u0643\u0648\u0646 \u0647\u0630\u0647 \u0627\u0644\u0642\u0646\u0627\u0629 \u0645\u0646 \u0623\u0643\u062b\u0631 \u0627\u0644\u0642\u0646\u0648\u0627\u062a \u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u0648\u0639\u0635\u0631\u064a\u0629. \u0623\u0639\u062a\u0642\u062f \u0623\u0646 \u0647\u0630\u0627 \u0647\u0648 \u0627\u0644\u0627\u062a\u062c\u0627\u0647 \u0627\u0644\u0630\u064a \u0646\u062d\u062a\u0627\u062c \u0625\u0644\u0649 \u0627\u062a\u0628\u0627\u0639\u0647.\n\n\u0623\u0646\u0627 \u0623\u0624\u0645\u0646 \u0628\u0623\u0646 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u064a\u0645\u0643\u0646 \u0623\u0646 \u064a\u064f\u0642\u062f\u0645 \u0645\u062d\u062a\u0648\u0649\u064b \u0645\u064f\u0641\u064a\u062f\u064b\u0627 \u0648\u0645\u0644\u0647\u0645\u064b\u0627\u060c \u0648\u0631\u0628\u0645\u0627 \u062a\u0643\u0648\u0646 \u0647\u0630\u0647 \u0627\u0644\u0642\u0646\u0627\u0629 \u0645\u0646 \u0623\u0643\u062b\u0631 \u0627\u0644\u0642\u0646\u0648\u0627\u062a \u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u0648\u0639\u0635\u0631\u064a\u0629. \u0623\u0639\u062a\u0642\u062f \u0623\u0646 \u0647\u0630\u0627 \u0647\u0648 \u0627\u0644\u0627\u062a\u062c\u0627\u0647 \u0627\u0644\u0630\u064a \u0646\u062d\u062a\u0627\u062c \u0625\u0644\u0649 \u0627\u062a\u0628\u0627\u0639\u0647.\n\nattention"
}
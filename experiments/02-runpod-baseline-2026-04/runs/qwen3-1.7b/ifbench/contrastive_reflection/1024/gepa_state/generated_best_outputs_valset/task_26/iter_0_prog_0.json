    "response": "\u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u092a\u094d\u0930\u092d\u093e\u0935\u0915\u093e\u0930\u0940 \u0930\u0942\u092a\u092e\u093e \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0917\u0924 \u0935\u093f\u0924\u094d\u0924 \u0935\u094d\u092f\u0935\u0938\u094d\u0925\u093e\u092a\u0928 \u0917\u0930\u094d\u0928 \u0909\u092a\u093e\u092f\u0939\u0930\u0942 \u0932\u093f\u0928 \u0938\u0915\u094d\u091b\u0928\u094d \u091c\u0938\u0932\u0947 \u0909\u0928\u0915\u094b \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0938\u094d\u0925\u093f\u0924\u093f \u0930 \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0935\u093f\u0915\u093e\u0938 \u092c\u0928\u093e\u090f\u0930 \u0930\u0939\u0947\u0915\u094b \u091b\u0964 \u092f\u094b \u0909\u092a\u093e\u092f\u0939\u0930\u0942 \u091c\u093e\u0924\u093f\u0915 \u0930 \u0930\u093e\u091c\u0928\u0940\u0924\u093f\u0915 \u0905\u0935\u0938\u094d\u0925\u093e \u0930 \u0935\u094d\u092f\u0935\u0938\u093e\u092f\u093f\u0915 \u0905\u0935\u0938\u094d\u0925\u093e \u0905\u0928\u0941\u0938\u093e\u0930 \u092c\u0926\u0932\u093f\u0928 \u0938\u0915\u094d\u091b\u0928\u094d\u0964 \u092f\u094b \u0909\u092a\u093e\u092f\u0939\u0930\u0942 \u091c\u093e\u0924\u093f\u0915 \u0930 \u0930\u093e\u091c\u0928\u0940\u0924\u093f\u0915 \u0905\u0935\u0938\u094d\u0925\u093e \u0930 \u0935\u094d\u092f\u0935\u0938\u093e\u092f\u093f\u0915 \u0905\u0935\u0938\u094d\u0925\u093e \u0905\u0928\u0941\u0938\u093e\u0930 \u092c\u0926\u0932\u093f\u0928 \u0938\u0915\u094d\u091b\u0928\u094d\u0964 \u092f\u094b \u0909\u092a\u093e\u092f\u0939\u0930\u0942 \u091c\u093e\u0924\u093f\u0915 \u0930 \u0930\u093e\u091c\u0928\u0940\u0924\u093f\u0915 \u0905\u0935\u0938\u094d\u0925\u093e \u0930 \u0935\u094d\u092f\u0935\u0938\u093e\u092f\u093f\u0915 \u0905\u0935\u0938\u094d\u0925\u093e \u0905\u0928\u0941\u0938\u093e\u0930 \u092c\u0926\u0932\u093f\u0928 \u0938\u0915\u094d\u091b\u0928\u094d\u0964 \u092f\u094b \u0909\u092a\u093e\u092f\u0939\u0930\u0942 \u091c\u093e\u0924\u093f\u0915 \u09
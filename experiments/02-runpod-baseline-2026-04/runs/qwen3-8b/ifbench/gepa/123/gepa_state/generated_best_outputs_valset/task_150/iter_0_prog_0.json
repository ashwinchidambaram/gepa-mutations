{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u548c\u76d1\u7763\u673a\u5236\u4e0d\u5b8c\u5584\u65b9\u9762\u3002\u7531\u4e8e\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u4f9d\u8d56\u4e8e\u88ab\u7533\u8bf7\u4eba\u4e3b\u52a8\u5c65\u884c\uff0c\u800c\u7f3a\u4e4f\u5f3a\u5236\u6267\u884c\u624b\u6bb5\uff0c\u5bfc\u81f4\u90e8\u5206\u884c\u653f\u673a\u5173\u5bf9\u590d\u8bae\u51b3\u5b9a\u4e0d\u591f\u91cd\u89c6\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u56e0\u672a\u4f9d\u6cd5\u5c65\u884c\u5bf9\u8fdd\u6cd5\u6392\u6c61\u4f01\u4e1a\u7684\u5904\u7f5a\u804c\u8d23\uff0c\u88ab\u7533\u8bf7\u4eba\u63d0\u8d77\u884c\u653f\u590d\u8bae\u540e\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u8be5\u90e8\u95e8\u5e76\u672a\u5728\u89c4\u5b9a\u671f\u9650\u5185\u6267\u884c\uff0c\u6700\u7ec8\u5bfc\u81f4\u6848\u4ef6\u65e0\u6cd5\u6709\u6548\u89e3\u51b3\u3002\u8fd9\u79cd\u73b0\u8c61\u53cd\u6620\u51fa\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\u7f3a\u4e4f\u8db3\u591f\u7684\u7ea6\u675f\u529b\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u5b58\u5728\u4e00\u5b9a\u7684\u6a21\u7cca\u6027\uff0c\u5bfc\u81f4\u90e8\u5206\u6848\u4ef6\u672a\u80fd\u53ca\u65f6\u7eb3\u5165\u590d\u8bae\u7a0b\u5e8f\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u57ce\u7ba1\u90e8\u95e8\u5728\u5904\u7406\u5360\u9053\u7ecf\u8425\u884c\u4e3a\u65f6\uff0c\u672a\u80fd\u53ca\u65f6\u4f5c\u51fa\u884c\u653f\u5904\u7f5a\u51b3\u5b9a\uff0c\u88ab\u7533\u8bf7\u4eba\u63d0\u8d77\u590d\u8bae\u540e\uff0c\u590d\u8bae\u673a\u5173\u8ba4\u5b9a\u5176\u672a\u4f9d\u6cd5\u5c65\u884c\u804c\u8d23\u5e76\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u3002\u7136\u800c\uff0c\u7531\u4e8e\u7f3a\u4e4f\u660e\u786e\u7684\u9002\u7528\u6807\u51c6\uff0c\u7c7b\u4f3c\u6848\u4ef6\u5728\u4e0d\u540c\u5730\u533a\u53ef\u80fd\u9762\u4e34\u4e0d\u540c\u7684\u5904\u7406\u65b9\u5f0f\uff0c\u5f71\u54cd\u4e86\u590d\u8bae\u51b3\u5b9a\u7684\u7edf\u4e00\u6027\u548c\u6743\u5a01\u6027\u3002\n\n\u5728\u76d1\u7763\u673a\u5236\u65b9\u9762\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5bf9\u88ab\u7533\u8bf7\u4eba\u7684\u540e\u7eed\u5c65\u884c\u60c5\u51b5\u7f3a\u4e4f\u6709\u6548\u8ddf\u8e2a\u548c\u76d1\u7763\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u516c\u5b89\u90e8\u95e8\u56e0\u672a\u4f9d\u6cd5\u5904\u7406\u4e00\u8d77\u6cbb\u5b89\u6848\u4ef6\uff0c\u88ab\u7533\u8bf7\u4eba\u63d0\u8d77\u590d\u8bae\u540e\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u3002\u7136\u800c\uff0c\u7531\u4e8e\u7f3a\u4e4f\u540e\u7eed\u76d1\u7763\u673a\u5236\uff0c\u8be5\u90e8\u95e8\u5e76\u672a\u53ca\u65f6\u91c7\u53d6\u884c\u52a8\uff0c\u5bfc\u81f4\u6848\u4ef6\u957f\u671f\u60ac\u800c\u672a\u51b3\u3002\u8fd9\u79cd\u60c5\u51b5\u8868\u660e\uff0c\u5f53\u524d\u7684\u76d1\u7763\u4f53\u7cfb\u672a\u80fd\u6709\u6548\u4fdd\u969c\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u7684\u843d\u5b9e\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u516c\u4fe1\u529b\u3002\n\n\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u8fd8\u53d7\u5230\u5730\u65b9\u4fdd\u62a4\u4e3b\u4e49\u7684\u5f71\u54cd\u3002\u5728\u4e00\u4e9b\u5730\u65b9\uff0c\u7531\u4e8e\u90e8\u95e8\u5229\u76ca\u6216\u5730\u65b9\u5229\u76ca\u7684\u8003\u8651\uff0c\u884c\u653f\u673a\u5173\u53ef\u80fd\u5bf9\u590d\u8bae\u51b3\u5b9a\u91c7\u53d6\u56de\u907f\u6001\u5ea6\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u4ea4\u901a\u7ba1\u7406\u90e8\u95e8\u56e0\u672a\u4f9d\u6cd5\u5904\u7406\u4e00\u8d77\u4ea4\u901a\u4e8b\u6545\u8d23\u4efb\u8ba4\u5b9a\uff0c\u88ab\u7533\u8bf7\u4eba\u63d0\u8d77\u590d\u8bae\u540e\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u3002\u7136\u800c\uff0c\u7531\u4e8e\u5730\u65b9\u4fdd\u62a4\u4e3b\u4e49\u7684\u5b58\u5728\uff0c\u8be5\u90e8\u95e8\u5e76\u672a\u79ef\u6781\u6267\u884c\u51b3\u5b9a\uff0c\u5bfc\u81f4\u590d\u8bae\u51b3\u5b9a\u6d41\u4e8e\u5f62\u5f0f\u3002\u8fd9\u79cd\u73b0\u8c61\u8868\u660e\uff0c\u884c\u653f\u590d\u8bae\u5236\u5ea6\u5728\u9762\u5bf9\u5730\u65b9\u5229\u76ca\u65f6\u5b58\u5728\u4e00\u5b9a\u7684\u5c40\u9650\u6027\u3002\n\ndocument \u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u53d7\u5230\u591a\u79cd\u56e0\u7d20\u7684\u5f71\u54cd\uff0c\u5305\u62ec\u6267\u884c\u673a\u5236\u4e0d\u5065\u5168\u3001\u76d1\u7763\u4f53\u7cfb\u4e0d\u5b8c\u5584\u4ee5\u53ca\u5730\u65b9\u4fdd\u62a4\u4e3b\u4e49\u7b49\u56e0\u7d20\u3002\u4e3a\u4e86\u63d0\u9ad8\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u5b9e\u6548\u6027\uff0c\u6709\u5fc5\u8981\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\uff0c\u589e\u5f3a\u590d\u8bae\u51b3\u5b9a\u7684\u7ea6\u675f\u529b\uff0c\u5e76\u5efa\u7acb\u66f4\u52a0\u9ad8\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u4ee5\u786e\u4fdd\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u80fd\u591f\u771f\u6b63\u53d1\u6325\u4f5c\u7528\u3002"
}
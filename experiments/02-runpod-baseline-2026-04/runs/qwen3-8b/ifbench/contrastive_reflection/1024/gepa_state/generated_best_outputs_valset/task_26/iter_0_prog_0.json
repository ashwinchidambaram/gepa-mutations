    "response": "\u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0917\u0924 \u0935\u093f\u0924\u094d\u0924 \u0935\u094d\u092f\u0935\u0938\u094d\u0925\u093e\u092a\u0928 \u0917\u0930\u094d\u0928 \u0935\u093f\u092d\u093f\u0928\u094d\u0928 \u0909\u092a\u093e\u092f\u0939\u0930\u0942 \u0932\u093f\u0928 \u0938\u0915\u094d\u091b\u0928\u094d \u0924\u0940 \u0909\u092a\u093e\u092f\u0939\u0930\u0942 \u0906\u092f \u0916\u0930\u094d\u091a \u0930 \u092c\u091a\u0924 \u0915\u094b \u0928\u093f\u092f\u094b\u091c\u0928\u092e\u093e \u0938\u0939\u093e\u092f\u0924\u093e \u0917\u0930\u094d\u091b \u0906\u092f \u0915\u094b \u0938\u094d\u0930\u094b\u0924 \u0905\u0935\u0932\u094b\u0915\u0928 \u0917\u0930\u0947\u0930 \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0932\u0947 \u0906\u092b\u094d\u0928\u094b \u0906\u092f \u0915\u094b \u090f\u0915 \u0935\u093f\u0936\u093f\u0937\u094d\u091f \u092d\u093e\u0917 \u092c\u091a\u0924 \u0917\u0930\u094d\u0928 \u0938\u0915\u094d\u091b \u092f\u0938 \u092c\u091a\u0924 \u092d\u093e\u0917 \u0915\u094b \u0909\u092a\u092f\u094b\u0917 \u092d\u0935\u093f\u0937\u094d\u092f \u0915\u094b \u0906\u0935\u0936\u094d\u092f\u0915\u0924\u093e\u0915\u093e \u0932\u093e\u0917\u093f \u0917\u0930\u093f\u0928 \u0938\u0915\u094d\u091b \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0932\u0947 \u0906\u092b\u094d\u0928\u094b \u0916\u0930\u094d\u091a \u0915\u094b \u0935\u093f\u092d\u093f\u0928\u094d\u0928 \u0935\u0930\u094d\u0917 \u092c\u0928\u093e\u0909\u0928 \u0938\u0915\u094d\u091b \u091c\u0938\u092e\u093e \u0906\u0935\u0936\u094d\u092f\u0915 \u0916\u0930\u094d\u091a \u0905\u0924\u093f\u0925\u093f \u0916\u0930\u094d\u091a \u0930 \u0928\u093f\u0930\u094d\u092e\u093e\u0923 \u0916\u0930\u094d\u091a \u0906\u0926\u093f \u0936\u093e\u092e\u093f\u0932 \u0939\u0941\u0928 \u0938\u0915\u094d\u091b \u092f\u0938 \u0935\u0930\u094d\u0917 \u092c\u0928\u093e\u0909\u0928 \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0932\u0947 \u0906\u092b
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u9645\u8fd0\u884c\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\u3002\u9996\u5148\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u5f80\u5f80\u7f3a\u4e4f\u8db3\u591f\u7684\u4e13\u4e1a\u6027\u548c\u6743\u5a01\u6027\u3002\u7531\u4e8e\u590d\u8bae\u673a\u5173\u7684\u884c\u653f\u5c5e\u6027\uff0c\u5176\u5728\u5904\u7406\u5177\u4f53\u884c\u653f\u884c\u4e3a\u65f6\u53ef\u80fd\u53d7\u5230\u5730\u65b9\u4fdd\u62a4\u4e3b\u4e49\u7684\u5f71\u54cd\uff0c\u5bfc\u81f4\u51b3\u5b9a\u96be\u4ee5\u6709\u6548\u6267\u884c\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u56e0\u4f01\u4e1a\u8fdd\u89c4\u6392\u653e\u88ab\u8d23\u4ee4\u6574\u6539\u7684\u6848\u4f8b\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u867d\u7136\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u7531\u4e8e\u5730\u65b9\u5229\u76ca\u7684\u5e72\u9884\uff0c\u4f01\u4e1a\u4ecd\u7ee7\u7eed\u8fdd\u89c4\u6392\u653e\uff0c\u6700\u7ec8\u5bfc\u81f4\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u6d41\u4e8e\u5f62\u5f0f\u3002\n\n\u5176\u6b21\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\u3002\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u4f5c\u51fa\u540e\uff0c\u82e5\u88ab\u7533\u8bf7\u4eba\u672a\u5c65\u884c\u4e49\u52a1\uff0c\u590d\u8bae\u673a\u5173\u5f80\u5f80\u7f3a\u4e4f\u5f3a\u5236\u6267\u884c\u7684\u624b\u6bb5\uff0c\u5bfc\u81f4\u51b3\u5b9a\u96be\u4ee5\u843d\u5b9e\u3002\u4f8b\u5982\uff0c\u5728\u4e00\u8d77\u571f\u5730\u5f81\u6536\u7ea0\u7eb7\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u8d23\u4ee4\u76f8\u5173\u90e8\u95e8\u5c65\u884c\u8865\u507f\u4e49\u52a1\uff0c\u4f46\u7531\u4e8e\u7f3a\u4e4f\u540e\u7eed\u76d1\u7763\u548c\u6267\u884c\u63aa\u65bd\uff0c\u8865\u507f\u95ee\u9898\u957f\u671f\u672a\u5f97\u5230\u89e3\u51b3\uff0c\u635f\u5bb3\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u4fe1\u529b\u3002\n\n\u518d\u6b21\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u4e2d\uff0c\u5bf9\u88ab\u7533\u8bf7\u4eba\u7684\u8d23\u4efb\u8ba4\u5b9a\u5b58\u5728\u6a21\u7cca\u4e4b\u5904\u3002\u7531\u4e8e\u6cd5\u5f8b\u6761\u6587\u4e0d\u591f\u660e\u786e\uff0c\u5bfc\u81f4\u590d\u8bae\u673a\u5173\u5728\u5224\u65ad\u88ab\u7533\u8bf7\u4eba\u662f\u5426\u5e94\u5f53\u5c65\u884c\u4e49\u52a1\u65f6\uff0c\u5b58\u5728\u4e00\u5b9a\u7684\u4e3b\u89c2\u6027\u3002\u4f8b\u5982\uff0c\u5728\u4e00\u8d77\u884c\u653f\u5904\u7f5a\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u8ba4\u4e3a\u884c\u653f\u673a\u5173\u672a\u4f9d\u6cd5\u5c65\u884c\u544a\u77e5\u4e49\u52a1\uff0c\u4f46\u5bf9\u201c\u544a\u77e5\u201d\u8303\u56f4\u7684\u754c\u5b9a\u5b58\u5728\u4e89\u8bae\uff0c\u6700\u7ec8\u5bfc\u81f4\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u96be\u4ee5\u843d\u5b9e\u3002\n\n\u6700\u540e\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6cd5\u5f8b\u6548\u529b\u53d7\u5230\u4e00\u5b9a\u9650\u5236\u3002\u7531\u4e8e\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u672c\u8eab\u4e0d\u5177\u6709\u7ec8\u5c40\u6027\uff0c\u88ab\u7533\u8bf7\u4eba\u4ecd\u53ef\u63d0\u8d77\u8bc9\u8bbc\uff0c\u8fd9\u5728\u4e00\u5b9a\u7a0b\u5ea6\u4e0a\u524a\u5f31\u4e86\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u529b\u3002\u4f8b\u5982\uff0c\u5728\u4e00\u8d77\u884c\u653f\u8bb8\u53ef\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u88ab\u7533\u8bf7\u4eba\u63d0\u8d77\u8bc9\u8bbc\uff0c\u6cd5\u9662\u6700\u7ec8\u5224\u51b3\u64a4\u9500\u539f\u51b3\u5b9a\uff0c\u5bfc\u81f4\u884c\u653f\u590d\u8bae\u7684\u6267\u884c\u6548\u679c\u5927\u6253\u6298\u6263\u3002\n\ndocument \u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u53d7\u5230\u591a\u79cd\u56e0\u7d20\u7684\u5f71\u54cd\uff0c\u5305\u62ec\u590d\u8bae\u673a\u5173\u7684\u72ec\u7acb\u6027\u3001\u6267\u884c\u673a\u5236\u7684\u5b8c\u5584\u7a0b\u5ea6\u4ee5\u53ca\u6cd5\u5f8b\u9002\u7528\u7684\u51c6\u786e\u6027\u3002\u8981\u63d0\u9ad8\u884c\u653f\u590d\u8bae\u7684\u5b9e\u6548\u6027\uff0c\u9700\u8981\u4ece\u5236\u5ea6\u8bbe\u8ba1\u3001\u6267\u884c\u76d1\u7763\u548c\u6cd5\u5f8b\u89c4\u8303\u7b49\u65b9\u9762\u8fdb\u884c\u7cfb\u7edf\u6027\u6539\u8fdb\u3002"
}
{
    "response": "\u5927\u578b\u516c\u53f8\u6b63\u5728\u62e5\u62b1\u6570\u636e\u5206\u6790\uff0c\u4f46\u5927\u591a\u6570\u516c\u53f8\u4ecd\u672a\u5efa\u7acb\u8d77\u6570\u636e\u9a71\u52a8\u7684\u6587\u5316 \u4f5c\u8005\uff1a\u6258\u9a6c\u65af\u00b7H\u00b7\u8fbe\u6587\u6ce2\u7279\u548c\u5170\u8fea\u00b7\u6bd4\u6069\n\n\u5728\u8fc7\u53bb\u516d\u5e74\u91cc\uff0cNewVantage Partners \u6bcf\u5e74\u90fd\u4f1a\u5bf9\u5927\u578b\u516c\u53f8\u9ad8\u7ba1\u5982\u4f55\u770b\u5f85\u6570\u636e\u8fdb\u884c\u4e00\u6b21\u8c03\u67e5\u3002\u4eca\u5e74\u7684\u8c03\u67e5\u7ed3\u679c\u663e\u793a\uff0c\u51e0\u4e4e\u6240\u6709\u516c\u53f8\u90fd\u5728\u4ee5\u67d0\u79cd\u5f62\u5f0f\u6295\u8d44\u4e8e\u5206\u6790\uff0c\u800c\u4e14\u5927\u591a\u6570\u516c\u53f8\u90fd\u770b\u5230\u4e86\u4ef7\u503c\u3002\u4f46\u53ea\u6709\u4e09\u5206\u4e4b\u4e00\u7684\u516c\u53f8\u8868\u793a\u4ed6\u4eec\u5df2\u7ecf\u6210\u529f\u5730\u5efa\u7acb\u4e86\u6570\u636e\u9a71\u52a8\u7684\u6587\u5316\u3002\u8bb8\u591a\u516c\u53f8\u62c5\u5fc3\u4f1a\u88ab\u90a3\u4e9b\u66f4\u64c5\u957f\u4f7f\u7528\u4eba\u5de5\u667a\u80fd\u7684\u516c\u53f8\u6240\u98a0\u8986\u3002\n\n\u8fd1\u4e94\u5206\u4e4b\u56db\u7684\u53d7\u8bbf\u8005\u8868\u793a\uff0c\u4ed6\u4eec\u62c5\u5fc3\u88ab\u50cf\u91d1\u878d\u79d1\u6280\u516c\u53f8\u6216\u4e13\u6ce8\u4e8e\u5927\u6570\u636e\u7684\u516c\u53f8\u8fd9\u6837\u7684\u4f01\u4e1a\u6240\u98a0\u8986\u3002\u88ab\u5224\u65ad\u4e3a\u6700\u5177\u98a0\u8986\u6027\u7684\u6280\u672f\u662f\u4eba\u5de5\u667a\u80fd\uff0c\u8fdc\u8fdc\u8d85\u8fc7\u5176\u4ed6\u6280\u672f\u300272% \u7684\u53d7\u8bbf\u8005\u9009\u62e9\u4e86\u4eba\u5de5\u667a\u80fd\u4f5c\u4e3a\u6700\u5177\u5f71\u54cd\u529b\u7684\u98a0\u8986\u6027\u6280\u672f\uff0c\u8fdc\u9ad8\u4e8e\u4e91\u8ba1\u7b97\uff0813%\uff09\u6216\u533a\u5757\u94fe\uff087%\uff09\u3002\n\n\u5728\u8fc7\u53bb\u516d\u5e74\u91cc\uff0cNewVantage Partners \u6bcf\u5e74\u90fd\u4f1a\u5bf9\u5927\u578b\u516c\u53f8\u9ad8\u7ba1\u5982\u4f55\u770b\u5f85\u6570\u636e\u8fdb\u884c\u4e00\u6b21\u8c03\u67e5\u3002\u6bcf\u5e74\u7684\u56de\u590d\u7387\u90fd\u5728\u589e\u52a0\uff0c\u800c\u4e14\u6bcf\u5e74\u5bf9\u6709\u6548\u5229\u7528\u6570\u636e\u7684\u7d27\u8feb\u611f\u4e5f\u5728\u589e\u52a0\u3002\u4eca\u5e74\u7684\u8c03\u67e5\u7ed3\u679c\u6bd4\u4ee5\u5f80\u65e2\u66f4\u52a0\u4ee4\u4eba\u9f13\u821e\uff0c\u53c8\u66f4\u52a0\u4ee4\u4eba\u62c5\u5fe7\u3002\u516d\u5e74\u524d\uff0c\u8c03\u67e5\u4e2d\u7684\u4e3b\u8981\u7126\u70b9\u662f\u5927\u6570\u636e\uff0c\u5f53\u65f6\u5b83\u5728\u5546\u4e1a\u9886\u57df\u8fd8\u76f8\u5bf9\u8f83\u65b0\u3002\u800c\u5728 2018 \u5e74\u7684\u8c03\u67e5\u4e2d\uff0c\u4e3b\u8981\u5173\u6ce8\u70b9\u5df2\u7ecf\u8f6c\u79fb\u5230\u4e86\u4eba\u5de5\u667a\u80fd\u4e0a\u3002\u5982\u4eca\uff0c\u4eba\u5de5\u667a\u80fd\u5df2\u7ecf\u6210\u4e3a\u8fd9\u4e9b\u5927\u578b\u3001\u590d\u6742\u516c\u53f8\u7684\u91cd\u8981\u5173\u6ce8\u70b9\u3002\n\n\u53d7\u8bbf\u8005\u666e\u904d\u8ba4\u4e3a\uff0c\u5927\u6570\u636e\u548c\u4eba\u5de5\u667a\u80fd\u9879\u76ee\u80fd\u5e26\u6765\u4ef7\u503c\uff0c\u540c\u65f6\u4e5f\u66f4\u52a0\u62c5\u5fc3\u4f20\u7edf\u4f01\u4e1a\u4f1a\u88ab\u521d\u521b\u516c\u53f8\u98a0\u8986\u3002\u8fd9\u6b21\u8c03\u67e5\u6db5\u76d6\u4e86\u6765\u81ea 57 \u5bb6\u5927\u578b\u516c\u53f8\u7684\u9ad8\u7ea7\u7ba1\u7406\u4eba\u5458\u3002\u5728\u8c03\u67e5\u4e2d\uff0c\u4ee3\u8868\u516c\u53f8\u6700\u591a\u7684\u884c\u4e1a\u7ec4\u4e4b\u4e00\u662f\u6570\u636e\u6700\u5bc6\u96c6\u7684\u91d1\u878d\u670d\u52a1\u4e1a\u3002\u6765\u81ea\u751f\u547d\u79d1\u5b66\u3001\u5236\u9020\u4e1a\u3001\u7535\u4fe1\u548c\u5728\u7ebf\u884c\u4e1a\u7684\u516c\u53f8\u4e5f\u53c2\u4e0e\u4e86\u8c03\u67e5\u3002\n\n\u5b9e\u9645\u4e0a\uff0c\u4eca\u5e74\u7684\u53d7\u8bbf\u8005\u4e0e\u6700\u521d\u51e0\u6b21\u8c03\u67e5\u76f8\u6bd4\u6709\u6240\u53d8\u5316\uff1a\u4e00\u76f4\u4ee5\u6765\uff0c\u53d7\u8bbf\u8005\u4e2d\u90fd\u6709\u5f88\u9ad8\u6bd4\u4f8b\u7684\u8d1f\u8d23\u6570\u636e\u7684\u9ad8\u7ba1\uff0c\u4f46\u4eca\u5e74\u9996\u5e2d\u6570\u636e\u5b98\u5360\u5230\u4e86 56%\uff0c\u6bd4\u53bb\u5e74\u7684 32% \u660e\u663e\u4e0a\u5347\u3002\u5728 2012 \u5e74\u7684\u8c03\u67e5\u4e2d\uff0c\u53ea\u6709 12% \u7684\u516c\u53f8\u751a\u81f3\u4efb\u547d\u4e86\u9996\u5e2d\u6570\u636e\u5b98\u3002\n\n\u5c3d\u7ba1\u4eba\u5de5\u667a\u80fd\u5728\u8fd9\u91cc\u548c\u5176\u4ed6\u5730\u65b9\u90fd\u5907\u53d7\u5173\u6ce8\uff0c\u4f46\u8fd9\u6b21\u8c03\u67e5\u4e5f\u6d89\u53ca\u5230\u4e86\u5927\u6570\u636e\u548c\u4eba\u5de5\u667a\u80fd\u3002\u672f\u8bed\u4f1a\u6765\u6765\u53bb\u53bb\uff0c\u4f46\u4e0d\u53d8\u7684\u662f\u6570\u636e\u7206\u70b8\u548c\u7406\u89e3\u8fd9\u4e9b\u6570\u636e\u7684\u5fc5\u8981\u6027\u3002\u5927\u6570\u636e\u548c\u4eba\u5de5\u667a\u80fd\u9879\u76ee\u51e0\u4e4e\u5df2\u7ecf\u96be\u4ee5\u533a\u5206\uff0c\u5c24\u5176\u662f\u56e0\u4e3a\u673a\u5668\u5b66\u4e60\u662f\u5904\u7406\u5927\u91cf\u5feb\u901f\u6d41\u52a8\u6570\u636e\u7684\u6700\u53d7\u6b22\u8fce\u65b9\u6cd5\u4e4b\u4e00\u3002\u6b64\u5916\uff0c\u7edf\u8ba1\u65b9\u6cd5\u7684\u4eba\u5de5\u667a\u80fd\uff08\u4f8b\u5982\u6df1\u5ea6\u5b66\u4e60\uff09\u4e5f\u8d8a\u6765\u8d8a\u53d7\u6b22\u8fce\u3002\u56e0\u6b64\uff0c"
}
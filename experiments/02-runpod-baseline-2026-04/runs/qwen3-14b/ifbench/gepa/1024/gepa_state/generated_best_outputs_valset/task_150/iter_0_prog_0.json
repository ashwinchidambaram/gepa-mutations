{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u5b9a\u7684\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6cd5\u5f8b\u9002\u7528\u4e0d\u7edf\u4e00\u548c\u88c1\u91cf\u6807\u51c6\u6a21\u7cca\u3002\u4e0d\u540c\u5730\u533a\u548c\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u7c7b\u4f3c\u6848\u4ef6\u65f6\uff0c\u53ef\u80fd\u56e0\u5bf9\u6cd5\u5f8b\u6761\u6587\u7684\u7406\u89e3\u548c\u9002\u7528\u5b58\u5728\u5dee\u5f02\uff0c\u5bfc\u81f4\u88c1\u5224\u7ed3\u679c\u4e0d\u4e00\u81f4\u3002\u8fd9\u79cd\u4e0d\u7edf\u4e00\u4e0d\u4ec5\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u4fe1\u529b\uff0c\u4e5f\u589e\u52a0\u4e86\u5f53\u4e8b\u4eba\u7684\u8bc9\u8bbc\u6210\u672c\u548c\u4e0d\u786e\u5b9a\u6027\u3002\u4f8b\u5982\uff0c\u5728\u4e00\u4e9b\u6d89\u53ca\u884c\u653f\u4e0d\u4f5c\u4e3a\u7684\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u53ef\u80fd\u5bf9\u201c\u6cd5\u5b9a\u804c\u8d23\u201d\u7684\u8ba4\u5b9a\u6807\u51c6\u4e0d\u4e00\uff0c\u5bfc\u81f4\u8d23\u4ee4\u5c65\u884c\u7684\u51b3\u5b9a\u7f3a\u4e4f\u660e\u786e\u7684\u6cd5\u5f8b\u4f9d\u636e\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\uff0c\u4e5f\u662f\u5f53\u524d\u9762\u4e34\u7684\u4e00\u4e2a\u7a81\u51fa\u95ee\u9898\u3002\u5373\u4f7f\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u7684\u51b3\u5b9a\uff0c\u884c\u653f\u673a\u5173\u4ecd\u53ef\u80fd\u5b58\u5728\u62d6\u5ef6\u6267\u884c\u6216\u62d2\u4e0d\u6267\u884c\u7684\u60c5\u51b5\uff0c\u800c\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u548c\u95ee\u8d23\u673a\u5236\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u8d23\u4ee4\u67d0\u653f\u5e9c\u90e8\u95e8\u5c65\u884c\u73af\u5883\u76d1\u7ba1\u804c\u8d23\uff0c\u4f46\u8be5\u90e8\u95e8\u5728\u590d\u8bae\u51b3\u5b9a\u751f\u6548\u540e\u4ecd\u672a\u91c7\u53d6\u6709\u6548\u63aa\u65bd\uff0c\u5bfc\u81f4\u73af\u5883\u95ee\u9898\u6301\u7eed\u5b58\u5728\uff0c\u53cd\u6620\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u6267\u884c\u5c42\u9762\u7684\u8584\u5f31\u3002\n\n\u540c\u65f6\uff0c\u884c\u653f\u590d\u8bae\u7a0b\u5e8f\u4e2d\u5bf9\u8bc1\u636e\u7684\u5ba1\u67e5\u548c\u8ba4\u5b9a\u6807\u51c6\u4e0d\u660e\u786e\uff0c\u4e5f\u5f71\u54cd\u4e86\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u516c\u6b63\u6027\u548c\u51c6\u786e\u6027\u3002\u5728\u4e00\u4e9b\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u53ef\u80fd\u672a\u80fd\u5145\u5206\u5ba1\u67e5\u884c\u653f\u673a\u5173\u4e0d\u4f5c\u4e3a\u7684\u8bc1\u636e\uff0c\u5bfc\u81f4\u9519\u8bef\u5730\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u7684\u51b3\u5b9a\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u5e02\u6c11\u7533\u8bf7\u4fe1\u606f\u516c\u5f00\u88ab\u884c\u653f\u673a\u5173\u62d2\u7edd\uff0c\u590d\u8bae\u673a\u5173\u5728\u672a\u5145\u5206\u6838\u5b9e\u62d2\u7edd\u7406\u7531\u662f\u5426\u5408\u6cd5\u7684\u60c5\u51b5\u4e0b\uff0c\u76f4\u63a5\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u53ef\u80fd\u9020\u6210\u884c\u653f\u8d44\u6e90\u7684\u6d6a\u8d39\u548c\u53f8\u6cd5\u6210\u672c\u7684\u589e\u52a0\u3002\n\ndocument  \n\u4e3a\u89e3\u51b3\u4e0a\u8ff0\u95ee\u9898\uff0c\u6709\u5fc5\u8981\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\uff0c\u660e\u786e\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u6761\u4ef6\u548c\u7a0b\u5e8f\u8981\u6c42\u3002\u540c\u65f6\uff0c\u5e94\u52a0\u5f3a\u590d\u8bae\u673a\u5173\u7684\u80fd\u529b\u5efa\u8bbe\uff0c\u63d0\u5347\u5176\u6cd5\u5f8b\u9002\u7528\u548c\u8bc1\u636e\u5ba1\u67e5\u7684\u4e13\u4e1a\u6c34\u5e73\u3002\u6b64\u5916\uff0c\u5efa\u7acb\u6709\u6548\u7684\u6267\u884c\u76d1\u7763\u673a\u5236\uff0c\u786e\u4fdd\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u80fd\u591f\u5f97\u5230\u5207\u5b9e\u6267\u884c\uff0c\u4ece\u800c\u589e\u5f3a\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u6743\u5a01\u6027\u548c\u5b9e\u6548\u6027\u3002"
}
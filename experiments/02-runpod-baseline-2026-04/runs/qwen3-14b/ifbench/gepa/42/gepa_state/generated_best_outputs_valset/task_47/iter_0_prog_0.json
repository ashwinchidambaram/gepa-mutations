{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u662f\u7a7a\u6c14\u52a8\u529b\u5b66\u548c\u822a\u7a7a\u822a\u5929\u5de5\u7a0b\u4e2d\u7684\u6838\u5fc3\u7814\u7a76\u9886\u57df\uff0c\u5176\u76ee\u6807\u662f\u901a\u8fc7\u4f18\u5316\u6c14\u6d41\u7279\u6027\uff0c\u63d0\u9ad8\u98de\u884c\u5668\u7684\u6548\u7387\u3001\u901f\u5ea6\u548c\u7a33\u5b9a\u6027\u3002\u968f\u7740\u79d1\u6280\u7684\u53d1\u5c55\uff0c\u4eff\u751f\u5b66\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u548c\u65b9\u6cd5\uff0c\u4f7f\u5f97\u4eba\u7c7b\u80fd\u591f\u4ece\u81ea\u7136\u754c\u4e2d\u6c72\u53d6\u7075\u611f\uff0c\u521b\u9020\u51fa\u66f4\u52a0\u9ad8\u6548\u548c\u9002\u5e94\u6027\u5f3a\u7684\u98de\u884c\u5668\u7ed3\u6784\u3002\n\n\u81ea\u7136\u754c\u4e2d\uff0c\u9e1f\u7c7b\u3001\u6606\u866b\u548c\u9c7c\u7c7b\u7b49\u751f\u7269\u5728\u957f\u671f\u8fdb\u5316\u8fc7\u7a0b\u4e2d\uff0c\u5f62\u6210\u4e86\u9ad8\u5ea6\u9002\u5e94\u5176\u751f\u5b58\u73af\u5883\u7684\u98de\u884c\u548c\u6e38\u52a8\u7ed3\u6784\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7684\u7fc5\u8180\u5177\u6709\u72ec\u7279\u7684\u66f2\u7387\u548c\u8fb9\u7f18\u5f62\u72b6\uff0c\u4f7f\u5f97\u5b83\u4eec\u5728\u98de\u884c\u4e2d\u80fd\u591f\u6709\u6548\u5730\u51cf\u5c11\u963b\u529b\u5e76\u589e\u52a0\u5347\u529b\u3002\u8fd9\u4e9b\u7279\u5f81\u542f\u53d1\u4e86\u79d1\u5b66\u5bb6\u548c\u5de5\u7a0b\u5e08\uff0c\u4fc3\u4f7f\u4ed6\u4eec\u7814\u7a76\u5982\u4f55\u5c06\u8fd9\u4e9b\u751f\u7269\u7279\u6027\u5e94\u7528\u4e8e\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u3002\n\n\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\u7684\u6838\u5fc3\u5728\u4e8e\u6a21\u62df\u751f\u7269\u7fc5\u8180\u7684\u51e0\u4f55\u5f62\u72b6\u3001\u8868\u9762\u7eb9\u7406\u4ee5\u53ca\u8fd0\u52a8\u65b9\u5f0f\u3002\u4f8b\u5982\uff0c\u7814\u7a76\u4eba\u5458\u53d1\u73b0\uff0c\u9e1f\u7c7b\u7fc5\u8180\u8fb9\u7f18\u7684\u952f\u9f7f\u72b6\u7ed3\u6784\u80fd\u591f\u51cf\u5c11\u6e4d\u6d41\uff0c\u4ece\u800c\u63d0\u9ad8\u98de\u884c\u6548\u7387\u3002\u8fd9\u79cd\u7ed3\u6784\u88ab\u5e94\u7528\u4e8e\u73b0\u4ee3\u98de\u673a\u7684\u7ffc\u5c16\u8bbe\u8ba1\u4e2d\uff0c\u4ee5\u51cf\u5c11\u8bf1\u5bfc\u963b\u529b\u3002\u6b64\u5916\uff0c\u4e00\u4e9b\u6606\u866b\u7fc5\u8180\u8868\u9762\u7684\u5fae\u5c0f\u7ed3\u6784\u80fd\u591f\u6539\u53d8\u6c14\u6d41\u7684\u6d41\u52a8\u65b9\u5f0f\uff0c\u4ece\u800c\u63d0\u9ad8\u5347\u529b\uff0c\u8fd9\u4e00\u539f\u7406\u4e5f\u88ab\u7528\u4e8e\u5fae\u578b\u98de\u884c\u5668\u7684\u8bbe\u8ba1\u4e2d\u3002\n\n\u9664\u4e86\u51e0\u4f55\u5f62\u72b6\uff0c\u4eff\u751f\u5b66\u8fd8\u5173\u6ce8\u6750\u6599\u7684\u4f7f\u7528\u3002\u4f8b\u5982\uff0c\u67d0\u4e9b\u9e1f\u7c7b\u7684\u7fbd\u6bdb\u5177\u6709\u7279\u6b8a\u7684\u5f39\u6027\uff0c\u80fd\u591f\u5728\u98de\u884c\u4e2d\u5feb\u901f\u8c03\u6574\u5f62\u72b6\u4ee5\u9002\u5e94\u4e0d\u540c\u7684\u6c14\u6d41\u6761\u4ef6\u3002\u8fd9\u79cd\u7279\u6027\u542f\u53d1\u4e86\u7814\u7a76\u4eba\u5458\u5f00\u53d1\u5177\u6709\u81ea\u9002\u5e94\u80fd\u529b\u7684\u65b0\u578b\u590d\u5408\u6750\u6599\uff0c\u7528\u4e8e\u5236\u9020\u53ef\u53d8\u5f62\u7684\u7ffc\u578b\u7ed3\u6784\uff0c\u4ee5\u9002\u5e94\u4e0d\u540c\u7684\u98de\u884c\u73af\u5883\u3002\n\n\u5728\u5b9e\u9645\u5e94\u7528\u4e2d\uff0c\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\u5df2\u7ecf\u53d6\u5f97\u4e86\u663e\u8457\u6210\u679c\u3002\u4f8b\u5982\uff0c\u9ad8\u901f\u98de\u884c\u5668\u3001\u65e0\u4eba\u673a\u4ee5\u53ca\u6c34\u4e0b\u822a\u884c\u5668\u90fd\u5f00\u59cb\u91c7\u7528\u4eff\u751f\u7ed3\u6784\uff0c\u4ee5\u63d0\u9ad8\u5176\u6027\u80fd\u3002\u6b64\u5916\uff0c\u4eff\u751f\u5b66\u8fd8\u88ab\u7528\u4e8e\u98ce\u529b\u53d1\u7535\u673a\u53f6\u7247\u7684\u8bbe\u8ba1\uff0c\u901a\u8fc7\u6a21\u4eff\u9e1f\u7c7b\u7fc5\u8180\u7684\u5f62\u72b6\uff0c\u63d0\u9ad8\u80fd\u91cf\u8f6c\u6362\u6548\u7387\u3002\n\n\u7136\u800c\uff0c\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\u4ecd\u7136\u9762\u4e34\u8bf8\u591a\u6311\u6218\u3002\u4f8b\u5982\uff0c\u5982\u4f55\u5728\u4fdd\u6301\u751f\u7269\u7ed3\u6784\u4f18\u52bf\u7684\u540c\u65f6\uff0c\u786e\u4fdd\u6750\u6599\u7684\u5f3a\u5ea6\u548c\u8010\u4e45\u6027\uff1b\u5982\u4f55\u5728\u590d\u6742\u73af\u5883\u4e0b\u5b9e\u73b0\u4eff\u751f\u7ed3\u6784\u7684\u7a33\u5b9a\u6027\u548c\u53ef\u9760\u6027\uff1b\u4ee5\u53ca\u5982\u4f55\u5c06\u4eff\u751f\u5b66\u539f\u7406\u4e0e\u73b0\u6709\u7684\u7a7a\u6c14\u52a8\u529b\u5b66\u7406\u8bba\u76f8\u7ed3\u5408\uff0c\u4ee5\u5b9e\u73b0\u66f4\u9ad8\u6548\u7684\u7ffc\u578b\u8bbe\u8ba1\u3002\n\n\u672a\u6765\uff0c\u968f\u7740\u6750\u6599\u79d1\u5b66\u3001\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\u548c\u4eba\u5de5\u667a\u80fd\u7b49\u6280\u672f\u7684\u53d1\u5c55\uff0c\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\u6709\u671b\u53d6\u5f97\u66f4\u5927\u7684\u7a81\u7834\u3002\u901a\u8fc7\u8de8\u5b66\u79d1\u5408\u4f5c\uff0c\u4eba\u7c7b\u5c06\u80fd\u591f\u66f4\u6df1\u5165\u5730\u7406\u89e3\u751f\u7269\u98de\u884c\u7684\u673a\u5236\uff0c\u5e76\u5c06\u5176\u5e94\u7528\u4e8e\u66f4\u5e7f\u6cdb\u7684\u5de5\u7a0b\u9886\u57df\uff0c\u4ece\u800c\u63a8\u52a8\u822a\u7a7a\u822a\u5929\u3001\u80fd\u6e90\u548c\u4ea4\u901a\u7b49\u884c\u4e1a\u7684\u8fdb\u6b65\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\uff0c\u4e0d\u4ec5\u62d3\u5bbd"
}
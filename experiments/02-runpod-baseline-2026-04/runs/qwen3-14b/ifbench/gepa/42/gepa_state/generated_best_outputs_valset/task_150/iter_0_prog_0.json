{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u5b9a\u7684\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6cd5\u5f8b\u9002\u7528\u4e0d\u7edf\u4e00\u548c\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u65b9\u9762\u3002\u4e0d\u540c\u5730\u533a\u7684\u590d\u8bae\u673a\u5173\u5728\u9762\u5bf9\u7c7b\u4f3c\u6848\u4ef6\u65f6\uff0c\u53ef\u80fd\u56e0\u5bf9\u6cd5\u5f8b\u6761\u6587\u7684\u7406\u89e3\u4e0d\u540c\u800c\u4f5c\u51fa\u5dee\u5f02\u8f83\u5927\u7684\u51b3\u5b9a\uff0c\u8fd9\u5728\u4e00\u5b9a\u7a0b\u5ea6\u4e0a\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u6743\u5a01\u6027\u3002\u6b64\u5916\uff0c\u5373\u4f7f\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u4e86\u8d23\u4ee4\u5c65\u884c\u7684\u51b3\u5b9a\uff0c\u90e8\u5206\u884c\u653f\u673a\u5173\u4ecd\u5b58\u5728\u6267\u884c\u4e0d\u529b\u7684\u73b0\u8c61\uff0c\u5bfc\u81f4\u51b3\u5b9a\u96be\u4ee5\u771f\u6b63\u843d\u5b9e\uff0c\u635f\u5bb3\u4e86\u884c\u653f\u76f8\u5bf9\u4eba\u7684\u5408\u6cd5\u6743\u76ca\u3002\n\n\u5728\u5177\u4f53\u6848\u4f8b\u4e2d\uff0c\u67d0\u5730\u5e02\u6c11\u56e0\u653f\u5e9c\u672a\u4f9d\u6cd5\u516c\u5f00\u5176\u7533\u8bf7\u7684\u653f\u5e9c\u4fe1\u606f\uff0c\u5411\u590d\u8bae\u673a\u5173\u63d0\u8d77\u884c\u653f\u590d\u8bae\u3002\u590d\u8bae\u673a\u5173\u6700\u7ec8\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u7684\u51b3\u5b9a\uff0c\u8981\u6c42\u76f8\u5173\u90e8\u95e8\u5728\u89c4\u5b9a\u671f\u9650\u5185\u516c\u5f00\u4fe1\u606f\u3002\u7136\u800c\uff0c\u76f8\u5173\u90e8\u95e8\u5728\u6536\u5230\u51b3\u5b9a\u540e\uff0c\u672a\u80fd\u5728\u6cd5\u5b9a\u671f\u9650\u5185\u5c65\u884c\u4e49\u52a1\uff0c\u5bfc\u81f4\u5e02\u6c11\u7684\u5408\u6cd5\u6743\u76ca\u672a\u80fd\u5f97\u5230\u6709\u6548\u4fdd\u969c\u3002\u8fd9\u4e00\u6848\u4f8b\u53cd\u6620\u51fa\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u9645\u6267\u884c\u8fc7\u7a0b\u4e2d\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u548c\u8ffd\u8d23\u673a\u5236\uff0c\u4f7f\u5f97\u51b3\u5b9a\u7684\u7ea6\u675f\u529b\u5927\u6253\u6298\u6263\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u7a0b\u5e8f\u6027\u89c4\u5b9a\u4e5f\u5b58\u5728\u4e0d\u8db3\u3002\u4f8b\u5982\uff0c\u5728\u51b3\u5b9a\u4f5c\u51fa\u524d\uff0c\u590d\u8bae\u673a\u5173\u5f80\u5f80\u7f3a\u4e4f\u5bf9\u884c\u653f\u673a\u5173\u4e0d\u5c65\u884c\u804c\u8d23\u7684\u5145\u5206\u8c03\u67e5\u548c\u8bc1\u636e\u6536\u96c6\uff0c\u5bfc\u81f4\u51b3\u5b9a\u53ef\u80fd\u57fa\u4e8e\u4e0d\u5b8c\u6574\u7684\u4fe1\u606f\u4f5c\u51fa\u3002\u8fd9\u4e0d\u4ec5\u5f71\u54cd\u4e86\u51b3\u5b9a\u7684\u51c6\u786e\u6027\uff0c\u4e5f\u5bb9\u6613\u5f15\u53d1\u884c\u653f\u76f8\u5bf9\u4eba\u5bf9\u590d\u8bae\u7ed3\u679c\u7684\u8d28\u7591\uff0c\u8fdb\u800c\u5f71\u54cd\u653f\u5e9c\u7684\u516c\u4fe1\u529b\u3002\n\ndocument  \n\u4e3a\u89e3\u51b3\u4e0a\u8ff0\u95ee\u9898\uff0c\u6709\u5fc5\u8981\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\uff0c\u660e\u786e\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u6761\u4ef6\u548c\u7a0b\u5e8f\u8981\u6c42\uff0c\u540c\u65f6\u52a0\u5f3a\u76d1\u7763\u548c\u95ee\u8d23\u673a\u5236\uff0c\u786e\u4fdd\u51b3\u5b9a\u5f97\u5230\u6709\u6548\u6267\u884c\u3002\u6b64\u5916\uff0c\u8fd8\u53ef\u4ee5\u901a\u8fc7\u57f9\u8bad\u548c\u6307\u5bfc\u63d0\u5347\u590d\u8bae\u673a\u5173\u548c\u884c\u653f\u673a\u5173\u7684\u6cd5\u5f8b\u7d20\u517b\uff0c\u589e\u5f3a\u5176\u4f9d\u6cd5\u884c\u653f\u7684\u610f\u8bc6\u548c\u80fd\u529b\uff0c\u4ece\u800c\u63d0\u9ad8\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u6574\u4f53\u6548\u80fd\u3002"
}
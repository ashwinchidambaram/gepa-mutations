    "response": "\u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u0906\u092b\u094d\u0928\u094b \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0917\u0924 \u0935\u093f\u0924\u094d\u0924 \u0935\u094d\u092f\u0935\u0938\u094d\u0925\u093e\u092a\u0928 \u0917\u0930\u094d\u0928\u0915\u093e \u0932\u093e\u0917\u093f \u0909\u092a\u093e\u092f\u0939\u0930\u0942 \u0932\u093f\u0928 \u0938\u0915\u094d\u091b\u0928\u094d \u091c\u0938\u092e\u093e \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0932\u0915\u094d\u0937\u094d\u092f \u0928\u093f\u0930\u094d\u0927\u093e\u0930\u0923 \u0917\u0930\u094d\u0928 \u0905\u0917\u094d\u0930\u093f\u092e \u0930 \u0928\u093f\u092f\u092e\u093f\u0924 \u092c\u091c\u0947\u091f \u0924\u092f\u093e\u0930 \u0917\u0930\u094d\u0928 \u0938\u0939\u093e\u092f\u0924\u093e \u0917\u0930\u094d\u091b \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0932\u0915\u094d\u0937\u094d\u092f\u0939\u0930\u0942 \u0935\u093f\u092d\u093f\u0928\u094d\u0928 \u0935\u0930\u094d\u0917\u0939\u0930\u0942\u092e\u093e \u0935\u093f\u092d\u093e\u091c\u0928 \u0917\u0930\u094d\u0928 \u091c\u0938\u094d\u0924\u0948 \u0924\u0924\u094d\u0915\u093e\u0932 \u0932\u0915\u094d\u0937\u094d\u092f \u0926\u0940\u0930\u094d\u0918\u0915\u093e\u0932\u0940\u0928 \u0932\u0915\u094d\u0937\u094d\u092f \u0906\u0935\u0936\u094d\u092f\u0915\u0924\u093e \u0905\u0928\u0941\u0938\u093e\u0930 \u0935\u094d\u092f\u092f \u0928\u093f\u092f\u0902\u0924\u094d\u0930\u0923 \u0917\u0930\u094d\u0928 \u0906\u0935\u0936\u094d\u092f\u0915 \u0935\u094d\u092f\u092f\u0939\u0930\u0942 \u0935\u093f\u092d\u093e\u091c\u0928 \u0917\u0930\u094d\u0928 \u0906\u0935\u0936\u094d\u092f\u0915 \u0935\u094d\u092f\u092f \u0930 \u0905\u0928\u093e\u0935\u0936\u094d\u092f\u0915 \u0935\u094d\u092f\u092f\u0915\u094b \u0935\u093f\u092d\u093e\u091c\u0928 \u0917\u0930\u094d\u0928 \u0906\u0935\u0936\u094d\u092f\u0915 \u0935\u094d\u092f\u092f\u0939\u0930\u0942 \u0928\u093f\u092f\u092e\u093f\u0924 \u0930\u0942\u092a\u092e\u093e \u0935\u093f\u0936\u0
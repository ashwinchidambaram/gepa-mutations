{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u5b9a\u7684\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6cd5\u5f8b\u9002\u7528\u4e0d\u7edf\u4e00\u548c\u6267\u884c\u6548\u529b\u4e0d\u8db3\u65b9\u9762\u3002\u4e0d\u540c\u5730\u533a\u7684\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u7c7b\u4f3c\u6848\u4ef6\u65f6\uff0c\u53ef\u80fd\u56e0\u5bf9\u6cd5\u5f8b\u6761\u6587\u7684\u7406\u89e3\u4e0d\u540c\u800c\u4f5c\u51fa\u5dee\u5f02\u8f83\u5927\u7684\u51b3\u5b9a\uff0c\u8fd9\u5bfc\u81f4\u4e86\u53f8\u6cd5\u5b9e\u8df5\u4e2d\u7684\u6df7\u4e71\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u672a\u4f9d\u6cd5\u516c\u5f00\u73af\u5883\u76d1\u6d4b\u6570\u636e\u7684\u60c5\u51b5\u4e0b\uff0c\u590d\u8bae\u673a\u5173\u867d\u7136\u8ba4\u5b9a\u5176\u884c\u4e3a\u8fdd\u6cd5\uff0c\u4f46\u8d23\u4ee4\u5c65\u884c\u7684\u51b3\u5b9a\u7f3a\u4e4f\u5177\u4f53\u6267\u884c\u63aa\u65bd\uff0c\u4f7f\u5f97\u88ab\u7533\u8bf7\u673a\u5173\u96be\u4ee5\u843d\u5b9e\u3002\u8fd9\u79cd\u6cd5\u5f8b\u9002\u7528\u7684\u4e0d\u4e00\u81f4\u6027\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u6743\u5a01\u6027\u548c\u516c\u4fe1\u529b\u3002\n\n\u6b64\u5916\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u4e5f\u662f\u4e00\u5927\u95ee\u9898\u3002\u5728\u4e00\u4e9b\u6848\u4f8b\u4e2d\uff0c\u5373\u4f7f\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u4e86\u8d23\u4ee4\u5c65\u884c\u7684\u51b3\u5b9a\uff0c\u76f8\u5173\u884c\u653f\u673a\u5173\u4ecd\u53ef\u80fd\u62d6\u5ef6\u6216\u62d2\u7edd\u6267\u884c\uff0c\u800c\u590d\u8bae\u673a\u5173\u7f3a\u4e4f\u5f3a\u5236\u6267\u884c\u7684\u6743\u529b\uff0c\u96be\u4ee5\u786e\u4fdd\u51b3\u5b9a\u7684\u6709\u6548\u843d\u5b9e\u3002\u4f8b\u5982\uff0c\u67d0\u5e02\u4f4f\u5efa\u5c40\u5728\u6536\u5230\u590d\u8bae\u673a\u5173\u8d23\u4ee4\u5176\u4f9d\u6cd5\u529e\u7406\u89c4\u5212\u8bb8\u53ef\u7684\u51b3\u5b9a\u540e\uff0c\u8fdf\u8fdf\u672a\u91c7\u53d6\u884c\u52a8\uff0c\u5bfc\u81f4\u7533\u8bf7\u4eba\u6743\u76ca\u957f\u671f\u5f97\u4e0d\u5230\u4fdd\u969c\u3002\u8fd9\u79cd\u6267\u884c\u4e0d\u529b\u7684\u73b0\u8c61\u4e0d\u4ec5\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u5b9e\u6548\u6027\uff0c\u4e5f\u635f\u5bb3\u4e86\u516c\u4f17\u5bf9\u653f\u5e9c\u4f9d\u6cd5\u884c\u653f\u7684\u4fe1\u5fc3\u3002\n\n\u540c\u65f6\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u7a0b\u5e8f\u8bbe\u7f6e\u4e5f\u5b58\u5728\u4e00\u5b9a\u7684\u7f3a\u9677\uff0c\u5f71\u54cd\u4e86\u5176\u516c\u6b63\u6027\u548c\u900f\u660e\u5ea6\u3002\u5728\u90e8\u5206\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u524d\uff0c\u672a\u80fd\u5145\u5206\u542c\u53d6\u88ab\u7533\u8bf7\u673a\u5173\u7684\u9648\u8ff0\u548c\u7533\u8fa9\uff0c\u6216\u8005\u672a\u4f9d\u6cd5\u7ec4\u7ec7\u542c\u8bc1\uff0c\u5bfc\u81f4\u51b3\u5b9a\u7684\u5408\u6cd5\u6027\u53d7\u5230\u8d28\u7591\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u5e02\u573a\u76d1\u7ba1\u90e8\u95e8\u5728\u672a\u7ed9\u4e88\u5145\u5206\u8bf4\u660e\u7684\u60c5\u51b5\u4e0b\uff0c\u88ab\u590d\u8bae\u673a\u5173\u8d23\u4ee4\u5c65\u884c\u4fe1\u606f\u516c\u5f00\u4e49\u52a1\uff0c\u5f15\u53d1\u88ab\u7533\u8bf7\u673a\u5173\u5bf9\u7a0b\u5e8f\u516c\u6b63\u6027\u7684\u4e0d\u6ee1\u3002\u6b64\u7c7b\u95ee\u9898\u53cd\u6620\u51fa\u7a0b\u5e8f\u6b63\u4e49\u5728\u884c\u653f\u590d\u8bae\u8fc7\u7a0b\u4e2d\u7684\u7f3a\u5931\uff0c\u5f71\u54cd\u4e86\u51b3\u5b9a\u7684\u5408\u6cd5\u6027\u548c\u6743\u5a01\u6027\u3002\n\ndocument \u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5b8c\u5584\u9700\u8981\u4ece\u7acb\u6cd5\u3001\u7a0b\u5e8f\u548c\u6267\u884c\u673a\u5236\u7b49\u591a\u65b9\u9762\u5165\u624b\uff0c\u4ee5\u63d0\u5347\u884c\u653f\u590d\u8bae\u7684\u5b9e\u6548\u6027\u548c\u516c\u4fe1\u529b\u3002\u7acb\u6cd5\u4e0a\u5e94\u8fdb\u4e00\u6b65\u660e\u786e\u8d23\u4ee4\u5c65\u884c\u7684\u9002\u7528\u8303\u56f4\u548c\u6761\u4ef6\uff0c\u51cf\u5c11\u6cd5\u5f8b\u9002\u7528\u4e2d\u7684\u6a21\u7cca\u6027\uff1b\u7a0b\u5e8f\u4e0a\u5e94\u52a0\u5f3a\u542c\u8bc1\u548c\u544a\u77e5\u4e49\u52a1\uff0c\u4fdd\u969c\u5404\u65b9\u5f53\u4e8b\u4eba\u7684\u7a0b\u5e8f\u6743\u5229\uff1b\u6267\u884c\u4e0a\u5219\u9700\u5efa\u7acb\u6709\u6548\u7684\u76d1\u7763\u548c\u95ee\u8d23\u673a\u5236\uff0c\u786e\u4fdd\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u80fd\u591f\u5f97\u5230\u5207\u5b9e\u843d\u5b9e\u3002\u901a\u8fc7\u8fd9\u4e9b\u63aa\u65bd\uff0c\u53ef\u4ee5\u6709\u6548\u89e3\u51b3\u5f53\u524d\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u4e2d\u5b58\u5728\u7684\u95ee\u9898\uff0c\u63a8\u52a8\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u5065\u5eb7\u53d1\u5c55\u3002"
}
{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u662f\u73b0\u4ee3\u822a\u7a7a\u5de5\u7a0b\u4e0e\u751f\u7269\u79d1\u5b66\u4ea4\u53c9\u9886\u57df\u7684\u91cd\u8981\u7814\u7a76\u65b9\u5411\u3002\u7ffc\u578b\uff0c\u5373\u673a\u7ffc\u7684\u6a2a\u622a\u9762\u5f62\u72b6\uff0c\u76f4\u63a5\u5f71\u54cd\u98de\u884c\u5668\u7684\u5347\u529b\u3001\u963b\u529b\u548c\u6548\u7387\u3002\u4f20\u7edf\u7684\u7ffc\u578b\u8bbe\u8ba1\u4f9d\u8d56\u4e8e\u7a7a\u6c14\u52a8\u529b\u5b66\u7406\u8bba\u548c\u5b9e\u9a8c\u6570\u636e\uff0c\u4f46\u968f\u7740\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\uff08CFD\uff09\u7684\u53d1\u5c55\uff0c\u8bbe\u8ba1\u65b9\u6cd5\u9010\u6e10\u8d8b\u5411\u4e8e\u4f18\u5316\u548c\u667a\u80fd\u5316\u3002\u7136\u800c\uff0c\u81ea\u7136\u754c\u4e2d\u7684\u98de\u884c\u751f\u7269\uff0c\u5982\u9e1f\u7c7b\u3001\u6606\u866b\u548c\u98de\u884c\u52a8\u7269\uff0c\u7ecf\u8fc7\u6570\u767e\u4e07\u5e74\u7684\u8fdb\u5316\uff0c\u5df2\u7ecf\u53d1\u5c55\u51fa\u6781\u4e3a\u9ad8\u6548\u7684\u98de\u884c\u673a\u5236\u548c\u7ffc\u578b\u7ed3\u6784\u3002\u8fd9\u4e9b\u751f\u7269\u7684\u98de\u884c\u65b9\u5f0f\u548c\u7ffc\u578b\u7ed3\u6784\u4e3a\u4eba\u7c7b\u7684\u98de\u884c\u5668\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u5b9d\u8d35\u7684\u7075\u611f\u3002\n\n\u4eff\u751f\u5b66\uff0c\u5373\u6a21\u4eff\u81ea\u7136\u754c\u7684\u7ed3\u6784\u3001\u529f\u80fd\u548c\u8fc7\u7a0b\uff0c\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u5e26\u6765\u4e86\u65b0\u7684\u601d\u8def\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7684\u7fc5\u8180\u5728\u98de\u884c\u65f6\u80fd\u591f\u6839\u636e\u7a7a\u6c14\u6d41\u52a8\u8fdb\u884c\u52a8\u6001\u8c03\u6574\uff0c\u8fd9\u79cd\u53ef\u53d8\u5f62\u7684\u7ffc\u578b\u7ed3\u6784\u5728\u98de\u884c\u5668\u8bbe\u8ba1\u4e2d\u5177\u6709\u91cd\u8981\u610f\u4e49\u3002\u6b64\u5916\uff0c\u6606\u866b\u7684\u7fc5\u8180\u5177\u6709\u8f7b\u8d28\u3001\u9ad8\u5f3a\u5ea6\u548c\u9ad8\u7075\u6d3b\u6027\u7684\u7279\u6027\uff0c\u8fd9\u4e9b\u7279\u70b9\u5728\u5fae\u578b\u98de\u884c\u5668\u548c\u65e0\u4eba\u673a\u8bbe\u8ba1\u4e2d\u5c24\u4e3a\u91cd\u8981\u3002\n\n\u8fd1\u5e74\u6765\uff0c\u7814\u7a76\u8005\u4eec\u901a\u8fc7\u7814\u7a76\u9e1f\u7c7b\u7684\u98de\u884c\u59ff\u6001\u548c\u7ffc\u578b\u53d8\u5316\uff0c\u5f00\u53d1\u51fa\u5177\u6709\u53ef\u53d8\u5f62\u7ffc\u578b\u7684\u98de\u884c\u5668\u3002\u8fd9\u4e9b\u98de\u884c\u5668\u80fd\u591f\u6839\u636e\u98de\u884c\u72b6\u6001\u81ea\u52a8\u8c03\u6574\u7ffc\u578b\uff0c\u4ece\u800c\u63d0\u9ad8\u71c3\u6cb9\u6548\u7387\u548c\u98de\u884c\u7a33\u5b9a\u6027\u3002\u540c\u65f6\uff0c\u4eff\u751f\u7ffc\u578b\u5728\u51cf\u5c11\u566a\u58f0\u3001\u63d0\u9ad8\u5347\u529b\u548c\u964d\u4f4e\u963b\u529b\u65b9\u9762\u4e5f\u8868\u73b0\u51fa\u663e\u8457\u4f18\u52bf\u3002\n\n\u9664\u4e86\u9e1f\u7c7b\u548c\u6606\u866b\uff0c\u5176\u4ed6\u751f\u7269\u5982\u9c7c\u7c7b\u548c\u6c34\u751f\u52a8\u7269\u4e5f\u63d0\u4f9b\u4e86\u7ffc\u578b\u8bbe\u8ba1\u7684\u7075\u611f\u3002\u4f8b\u5982\uff0c\u9c7c\u7c7b\u7684\u9ccd\u5728\u6c34\u4e2d\u8fd0\u52a8\u65f6\u7684\u6d41\u4f53\u529b\u5b66\u7279\u6027\uff0c\u88ab\u5e94\u7528\u4e8e\u6c34\u4e0b\u98de\u884c\u5668\u7684\u8bbe\u8ba1\u4e2d\uff0c\u8fdb\u4e00\u6b65\u62d3\u5c55\u4e86\u4eff\u751f\u5b66\u5728\u4e0d\u540c\u73af\u5883\u4e2d\u7684\u5e94\u7528\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e0d\u4ec5\u63a8\u52a8\u4e86\u98de\u884c\u5668\u6027\u80fd\u7684\u63d0\u5347\uff0c\u4e5f\u4e3a\u672a\u6765\u7684\u822a\u7a7a\u6280\u672f\u53d1\u5c55\u63d0\u4f9b\u4e86\u65e0\u9650\u53ef\u80fd\u3002\u968f\u7740\u79d1\u5b66\u6280\u672f\u7684\u8fdb\u6b65\u548c\u5bf9\u81ea\u7136\u754c\u7684\u6df1\u5165\u7814\u7a76\uff0c\u4eff\u751f\u7ffc\u578b\u5c06\u5728\u66f4\u591a\u9886\u57df\u53d1\u6325\u91cd\u8981\u4f5c\u7528\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u662f\u73b0\u4ee3\u822a\u7a7a\u5de5\u7a0b\u4e0e\u751f\u7269\u79d1\u5b66\u4ea4\u53c9\u9886\u57df\u7684\u91cd\u8981\u7814\u7a76\u65b9\u5411\u3002\u7ffc\u578b\uff0c\u5373\u673a\u7ffc\u7684\u6a2a\u622a\u9762\u5f62\u72b6\uff0c\u76f4\u63a5\u5f71\u54cd\u98de\u884c\u5668\u7684\u5347\u529b\u3001\u963b\u529b\u548c\u6548\u7387\u3002\u4f20\u7edf\u7684\u7ffc\u578b\u8bbe\u8ba1\u4f9d\u8d56\u4e8e\u7a7a\u6c14\u52a8\u529b\u5b66\u7406\u8bba\u548c\u5b9e\u9a8c\u6570\u636e\uff0c\u4f46\u968f\u7740\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\uff08CFD\uff09\u7684\u53d1\u5c55\uff0c\u8bbe\u8ba1\u65b9\u6cd5\u9010\u6e10\u8d8b\u5411\u4e8e\u4f18\u5316\u548c\u667a\u80fd\u5316\u3002\u7136\u800c\uff0c\u81ea\u7136\u754c\u4e2d\u7684\u98de\u884c\u751f\u7269\uff0c\u5982\u9e1f\u7c7b\u3001\u6606\u866b\u548c\u98de\u884c\u52a8\u7269\uff0c\u7ecf\u8fc7\u6570\u767e\u4e07\u5e74\u7684\u8fdb\u5316\uff0c\u5df2\u7ecf\u53d1\u5c55\u51fa\u6781\u4e3a\u9ad8\u6548\u7684\u98de\u884c\u673a\u5236\u548c\u7ffc\u578b\u7ed3\u6784\u3002\u8fd9\u4e9b\u751f\u7269\u7684\u98de\u884c\u65b9\u5f0f\u548c\u7ffc"
}
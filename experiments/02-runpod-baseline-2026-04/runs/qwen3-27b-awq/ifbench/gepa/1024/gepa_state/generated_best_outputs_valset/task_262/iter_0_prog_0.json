    "response": "\u0623\u0647\u0644\u0627\u064b \u0628\u0643\u060c \u0644\u0625\u0646\u0634\u0627\u0621 \u0642\u0646\u0627\u0629 \u062a\u0639\u062a\u0645\u062f \u0643\u0644\u064a\u0627\u064b \u0639\u0644\u0649 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a\u060c \u0625\u0644\u064a\u0643 \u0628\u0639\u0636 \u0627\u0644\u0627\u0642\u062a\u0631\u0627\u062d\u0627\u062a: \u064a\u0645\u0643\u0646\u0643 \u0625\u0646\u0634\u0627\u0621 \u0645\u062d\u062a\u0648\u0649 \u062a\u0639\u0644\u064a\u0645\u064a \u064a\u0634\u0631\u062d \u0623\u062f\u0648\u0627\u062a \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a\u060c \u0623\u0648 \u0642\u0646\u0627\u0629 \u062a\u0646\u062a\u062c \u0623\u0641\u0644\u0627\u0645\u0627\u064b \u0643\u0631\u062a\u0648\u0646\u064a\u0629 \u0642\u0635\u064a\u0631\u0629 \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0645\u0648\u0644\u062f\u0627\u062a \u0627\u0644\u0641\u064a\u062f\u064a\u0648\u060c \u0623\u0648 \u062d\u062a\u0649 \u0642\u0646\u0627\u0629 \u062a\u0642\u062f\u0645 \u062a\u062d\u0644\u064a\u0644\u0627\u062a \u0631\u064a\u0627\u0636\u064a\u0629 \u0639\u0628\u0631 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a. \u062a\u0630\u0643\u0631 \u0623\u0646 \u062a\u0646\u0647\u064a \u0643\u0644 \u0641\u064a\u062f\u064a\u0648 \u0628\u062a\u0644\u062e\u064a\u0635 \u0642\u0648\u064a\u060c \u062b\u0645 finish \u0643\u0644 \u0645\u0634\u0631\u0648\u0639 \u0628\u0644\u0645\u0633\u0629 \u0625\u0628\u062f\u0627\u0639\u064a\u0629\u060c \u0648 finish \u0627\u0644\u062a\u062e\u0637\u064a\u0637 \u0642\u0628\u0644 \u0627\u0644\u0628\u062f\u0621\u060c \u0648 finish \u0627\u0644\u0645\u0631\u0627\u062c\u0639\u0629 \u0627\u0644\u0646\u0647\u0627\u0626\u064a\u0629 \u0628\u0639\u0646\u0627\u064a\u0629\u060c \u0648 finish \u0627\u0644\u0642\u0646\u0627\u0629 \u0628\u0646\u062c\u0627\u062d \u0645\u0633\u062a\u0645\u0631. finish attention"

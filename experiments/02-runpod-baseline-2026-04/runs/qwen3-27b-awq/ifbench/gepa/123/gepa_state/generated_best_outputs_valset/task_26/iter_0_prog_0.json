{
    "response": "\u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u092c\u091c\u0947\u091f \u092c\u0928\u093e\u090f\u0930 \u0916\u0930\u094d\u091a \u0928\u093f\u092f\u0928\u094d\u0924\u094d\u0930\u0923 \u0917\u0930\u094d\u0928 \u0938\u0915\u094d\u091b\u0928\u094d\u0964 \u0924\u093f\u0928\u0940\u0939\u0930\u0942\u0932\u0947 \u092c\u091a\u0924 \u0917\u0930\u094d\u0928\u0947 \u0932\u0915\u094d\u0937\u094d\u092f \u0924\u092f \u0917\u0930\u0947\u0930 \u0906\u0930\u094d\u0925\u093f\u0915 \u0938\u094d\u0925\u093f\u0930\u0924\u093e \u0932\u094d\u092f\u093e\u0909\u0928 \u0938\u0915\u094d\u091b\u0928\u094d\u0964 \u0915\u0930\u094d\u091c\u093e \u0915\u092e \u0917\u0930\u094d\u0928\u0947 \u0930 \u092c\u094d\u092f\u093e\u091c \u0926\u0930 \u0939\u0947\u0930\u094d\u0928\u0947 \u0909\u092a\u093e\u092f\u0939\u0930\u0942\u0932\u0947 \u092a\u0928\u093f \u092e\u0926\u094d\u0926\u0924 \u0917\u0930\u094d\u091b\u0964 \u0906\u0935\u0936\u094d\u092f\u0915\u0924\u093e \u0905\u0928\u0941\u0938\u093e\u0930 \u0916\u0930\u094d\u091a \u0917\u0930\u094d\u0926\u093e \u0905\u0928\u093e\u0935\u0936\u094d\u092f\u0915 \u0916\u0930\u094d\u091a \u0930\u094b\u0915\u093f\u0928\u094d\u091b\u0964 \u0935\u093f\u092d\u093f\u0928\u094d\u0928 \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0909\u0924\u094d\u092a\u093e\u0926\u0928\u0939\u0930\u0942\u0915\u094b \u0924\u0941\u0932\u0928\u093e \u0917\u0930\u0947\u0930 \u0930\u093e\u092e\u094d\u0930\u094b \u0928\u093f\u0930\u094d\u0923\u092f \u0932\u093f\u0907\u0928\u094d\u091b\u0964 \u0928\u093f\u092f\u092e\u093f\u0924 \u0930\u0942\u092a\u092e\u093e \u0906\u0930\u094d\u0925\u093f\u0915 \u0938\u094d\u0925\u093f\u0924\u093f \u0939\u0947\u0930\u094d\u0928\u0941\u0932\u0947 \u092d\u0935\u093f\u0937\u094d\u092f\u0915\u094b \u092f\u094b\u091c\u0928\u093e \u092c\u0928\u093e\u0909\u0928 \u0938\u091c\u093f\u0932\u094b \u092c\u0928\u093e\u0909\u0901\u091b\u0964"

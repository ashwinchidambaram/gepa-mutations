{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u7406\u8bba\u8bbe\u8ba1\u4e0a\u65e8\u5728\u7763\u4fc3\u884c\u653f\u673a\u5173\u4f9d\u6cd5\u5c65\u804c\uff0c\u4f46\u5728\u5b9e\u8df5\u4e2d\u5e38\u9762\u4e34\u6267\u884c\u96be\u4e0e\u6807\u51c6\u6a21\u7cca\u7684\u56f0\u5883\u3002\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u51b3\u5b9a\u65f6\u672a\u80fd\u660e\u786e\u5177\u4f53\u7684\u5c65\u884c\u671f\u9650\u6216\u884c\u4e3a\u5185\u5bb9\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u673a\u5173\u4ecd\u6709\u63a8\u8bff\u7a7a\u95f4\uff0c\u4f7f\u5f97\u884c\u653f\u76f8\u5bf9\u4eba\u7684\u5408\u6cd5\u6743\u76ca\u96be\u4ee5\u5f97\u5230\u53ca\u65f6\u6709\u6548\u7684\u6551\u6d4e\u3002\n\n\u5177\u4f53\u6848\u4f8b\u663e\u793a\uff0c\u5f53\u6d89\u53ca\u590d\u6742\u4e8b\u5b9e\u8ba4\u5b9a\u6216\u9700\u8981\u591a\u90e8\u95e8\u534f\u8c03\u7684\u5c65\u804c\u4e8b\u9879\u65f6\uff0c\u590d\u8bae\u51b3\u5b9a\u5f80\u5f80\u6d41\u4e8e\u5f62\u5f0f\u5316\u8868\u8ff0\u3002\u4f8b\u5982\u5728\u67d0\u5730\u73af\u4fdd\u6295\u8bc9\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u4ec5\u8d23\u4ee4\u73af\u4fdd\u5c40\u201c\u4f9d\u6cd5\u5904\u7406\u201d\uff0c\u5374\u672a\u6307\u660e\u9700\u91c7\u53d6\u4f55\u79cd\u5177\u4f53\u63aa\u65bd\u6216\u5b8c\u6210\u65f6\u9650\uff0c\u81f4\u4f7f\u884c\u653f\u673a\u5173\u4ee5\u6b63\u5728\u8c03\u67e5\u4e3a\u7531\u957f\u671f\u6401\u7f6e\uff0c\u6700\u7ec8\u5bfc\u81f4\u6c61\u67d3\u6301\u7eed\u6269\u5927\u3002\n\n\u7a0b\u5e8f\u8854\u63a5\u673a\u5236\u7684\u7f3a\u5931\u4e5f\u662f\u5236\u7ea6\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5b9e\u6548\u7684\u5173\u952e\u56e0\u7d20\u3002\u73b0\u884c\u6cd5\u5f8b\u5bf9\u884c\u653f\u673a\u5173\u62d2\u4e0d\u5c65\u884c\u590d\u8bae\u51b3\u5b9a\u7684\u540e\u7eed\u60e9\u6212\u624b\u6bb5\u8f83\u4e3a\u6709\u9650\uff0c\u7f3a\u4e4f\u7c7b\u4f3c\u884c\u653f\u8bc9\u8bbc\u4e2d\u7684\u53f8\u6cd5\u62d8\u7559\u6216\u7f5a\u6b3e\u7b49\u5f3a\u5236\u529b\u4fdd\u969c\uff0c\u4f7f\u5f97\u90e8\u5206\u8fdd\u6cd5\u6210\u672c\u8fc7\u4f4e\uff0c\u96be\u4ee5\u5f62\u6210\u6709\u6548\u9707\u6151\u3002\n\ndocument \u4f5c\u4e3a\u6700\u7ec8\u7684\u6cd5\u5f8b\u6587\u4e66\u8f7d\u4f53\uff0c\u5176\u89c4\u8303\u6027\u4e0e\u660e\u786e\u6027\u76f4\u63a5\u51b3\u5b9a\u4e86\u540e\u7eed\u6267\u884c\u6548\u679c\uff0c\u56e0\u6b64\u4e9f\u9700\u901a\u8fc7\u7ec6\u5316\u7acb\u6cd5\u6807\u51c6\u3001\u5f3a\u5316\u76d1\u7763\u95ee\u8d23\u4ee5\u53ca\u5b8c\u5584\u6267\u884c\u8854\u63a5\u673a\u5236\u6765\u63d0\u5347\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5b9e\u9645\u7ea6\u675f\u529b\u3002"
}
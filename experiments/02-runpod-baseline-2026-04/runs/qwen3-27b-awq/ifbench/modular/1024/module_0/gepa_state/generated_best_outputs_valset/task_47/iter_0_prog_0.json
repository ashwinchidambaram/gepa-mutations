{
    "response": "\u7ffc\u578b\n\u4eff\u751f\u5b66\u4e3a\u73b0\u4ee3\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u4e30\u5bcc\u7684\u7075\u611f\u6765\u6e90\uff0c\u81ea\u7136\u754c\u4e2d\u7684\u9e1f\u7c7b\u4e0e\u6606\u866b\u7ecf\u8fc7\u6570\u767e\u4e07\u5e74\u7684\u8fdb\u5316\uff0c\u6f14\u5316\u51fa\u4e86\u9ad8\u6548\u7684\u6c14\u52a8\u5916\u5f62\u3002\u7814\u7a76\u4eba\u5458\u901a\u8fc7\u89c2\u5bdf\u9e70\u96bc\u7684\u521d\u7ea7\u98de\u7fbd\u7ed3\u6784\uff0c\u53d1\u73b0\u5176\u8fb9\u7f18\u7684\u952f\u9f7f\u72b6\u8bbe\u8ba1\u80fd\u6709\u6548\u964d\u4f4e\u98de\u884c\u566a\u97f3\u5e76\u51cf\u5c11\u6da1\u6d41\u4ea7\u751f\u3002\u8fd9\u79cd\u751f\u7269\u7279\u5f81\u88ab\u5e94\u7528\u4e8e\u98ce\u529b\u53d1\u7535\u673a\u53f6\u7247\u53ca\u98de\u673a\u673a\u7ffc\u8bbe\u8ba1\u4e2d\uff0c\u663e\u8457\u63d0\u5347\u4e86\u80fd\u91cf\u8f6c\u6362\u6548\u7387\u3002\u540c\u65f6\uff0c\u8759\u8760\u7fc5\u8180\u7684\u67d4\u6027\u53d8\u5f62\u80fd\u529b\u542f\u53d1\u4e86\u53ef\u53d8\u51e0\u4f55\u7ffc\u578b\u7684\u5f00\u53d1\uff0c\u4f7f\u98de\u884c\u5668\u5728\u4e0d\u540c\u901f\u5ea6\u4e0b\u5747\u80fd\u4fdd\u6301\u6700\u4f73\u653b\u89d2\u3002\u9ca8\u9c7c\u76ae\u80a4\u7684\u5fae\u5c0f\u9cde\u7247\u7ed3\u6784\u4e5f\u88ab\u501f\u9274\u5230\u7ffc\u9762\u6d82\u5c42\u4e2d\uff0c\u4ee5\u6291\u5236\u8fb9\u754c\u5c42\u5206\u79bb\u5e76\u964d\u4f4e\u8868\u9762\u6469\u64e6\u963b\u529b\u3002\u8fd9\u4e9b\u8de8\u5b66\u79d1\u7684\u7814\u7a76\u6210\u679c\u8868\u660e\uff0c\u6a21\u4eff\u81ea\u7136\u4e0d\u4ec5\u662f\u7f8e\u5b66\u8ffd\u6c42\uff0c\u66f4\u662f\u89e3\u51b3\u590d\u6742\u5de5\u7a0b\u95ee\u9898\u7684\u5173\u952e\u8def\u5f84\u3002\u672a\u6765\u968f\u7740\u6750\u6599\u79d1\u5b66\u4e0e\u5236\u9020\u6280\u672f\u7684\u8fdb\u6b65\uff0c\u66f4\u591a\u4eff\u751f\u7279\u5f81\u5c06\u88ab\u6574\u5408\u5230\u65b0\u4e00\u4ee3\u822a\u7a7a\u5668\u8bbe\u8ba1\u4e2d\u3002\u7ffc\u578b"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u7684\u9996\u8981\u95ee\u9898\u5728\u4e8e\u90e8\u5206\u51b3\u5b9a\u5185\u5bb9\u8fc7\u4e8e\u7b3c\u7edf\uff0c\u7f3a\u4e4f\u5177\u4f53\u7684\u5c65\u884c\u671f\u9650\u548c\u660e\u786e\u7684\u64cd\u4f5c\u6807\u51c6\uff0c\u5bfc\u81f4\u884c\u653f\u673a\u5173\u5728\u6267\u884c\u65f6\u5b58\u5728\u81ea\u7531\u88c1\u91cf\u7a7a\u95f4\u8fc7\u5927\u7684\u73b0\u8c61\u3002\n\n\u4ee5\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u88ab\u8bc9\u672a\u4f9d\u6cd5\u516c\u5f00\u73af\u5883\u76d1\u6d4b\u6570\u636e\u4e3a\u4f8b\uff0c\u590d\u8bae\u673a\u5173\u867d\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u7684\u51b3\u5b9a\uff0c\u5374\u672a\u89c4\u5b9a\u5177\u4f53\u516c\u5f00\u7684\u65f6\u95f4\u8282\u70b9\u548c\u683c\u5f0f\u8981\u6c42\uff0c\u81f4\u4f7f\u7533\u8bf7\u4eba\u6743\u76ca\u957f\u671f\u5904\u4e8e\u4e0d\u786e\u5b9a\u72b6\u6001\u3002\n\n\u7b2c\u4e8c\u4e2a\u663e\u8457\u95ee\u9898\u662f\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u529b\u4e0d\u8db3\uff0c\u5f53\u884c\u653f\u673a\u5173\u62d2\u4e0d\u6267\u884c\u6216\u6d88\u6781\u5e94\u5bf9\u65f6\uff0c\u590d\u8bae\u51b3\u5b9a\u5f80\u5f80\u96be\u4ee5\u901a\u8fc7\u73b0\u6709\u673a\u5236\u8fc5\u901f\u8f6c\u5316\u4e3a\u5b9e\u9645\u884c\u653f\u884c\u4e3a\uff0c\u524a\u5f31\u4e86\u5236\u5ea6\u7684\u6743\u5a01\u6027\u3002\n\ndocument \u4f5c\u4e3a\u6cd5\u5f8b\u6587\u4e66\u7684\u8f7d\u4f53\u5f62\u5f0f\uff0c\u5176\u89c4\u8303\u6027\u4e0e\u5185\u5bb9\u7684\u53ef\u6267\u884c\u6027\u76f4\u63a5\u51b3\u5b9a\u4e86\u884c\u653f\u590d\u8bae\u6551\u6d4e\u529f\u80fd\u7684\u6700\u7ec8\u5b9e\u73b0\u6548\u679c\uff0c\u56e0\u6b64\u9700\u8981\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173\u7acb\u6cd5\u7ec6\u8282\u3002"
}
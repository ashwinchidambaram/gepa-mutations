{
    "response": "\u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u092c\u091c\u0947\u091f \u0924\u092f\u093e\u0930 \u092a\u093e\u0930\u094d\u0928 \u0938\u0915\u094d\u091b\u0928\u094d \u0930 \u0906\u0909\u0928\u0947 \u0916\u0930\u094d\u091a\u0932\u093e\u0908 \u0928\u093f\u092f\u0928\u094d\u0924\u094d\u0930\u0923 \u0917\u0930\u094d\u0928 \u0938\u0915\u094d\u091b\u0928\u094d\u0964 \u0924\u093f\u0928\u0940\u0939\u0930\u0942\u0932\u0947 \u092c\u091a\u0924 \u0917\u0930\u094d\u0928\u0947 \u0906\u0926\u0924 \u0905\u092a\u0928\u093e\u0909\u0901\u0926\u093e \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0938\u0941\u0930\u0915\u094d\u0937\u093e \u092a\u093e\u0909\u0901\u091b\u0928\u094d\u0964 \u090b\u0923\u0915\u094b \u092a\u094d\u0930\u092f\u094b\u0917\u0932\u093e\u0908 \u0928\u094d\u092f\u0942\u0928\u0924\u092e \u0930\u093e\u0916\u094d\u0928\u0941 \u092a\u094d\u0930\u092d\u093e\u0935\u0915\u093e\u0930\u0940 \u0939\u0941\u0928\u094d\u091b\u0964 \u0932\u0917\u093e\u0928\u0940\u0915\u094b \u0932\u093e\u0917\u093f \u0938\u093e\u0928\u094b \u0930\u0915\u092e\u092c\u093e\u091f \u0938\u0941\u0930\u0941 \u0917\u0930\u094d\u0928\u0941 \u0930\u093e\u092e\u094d\u0930\u094b \u0939\u094b\u0964 \u0906\u0930\u094d\u0925\u093f\u0915 \u0932\u0915\u094d\u0937\u094d\u092f\u0939\u0930\u0942 \u0938\u094d\u092a\u0937\u094d\u091f \u092c\u0928\u093e\u0909\u0928\u0941\u092a\u0930\u094d\u091b\u0964 \u0928\u093f\u092f\u092e\u093f\u0924 \u0930\u0942\u092a\u092e\u093e \u0916\u0930\u094d\u091a\u0915\u094b \u092a\u0941\u0928\u0930\u093e\u0935\u0932\u094b\u0915\u0928 \u0917\u0930\u094d\u0928\u0941 \u091c\u0930\u0941\u0930\u0940 \u091b\u0964 \u0935\u093f\u092d\u093f\u0928\u094d\u0928 \u0935\u093f\u0915\u0932\u094d\u092a\u0939\u0930\u0942\u0915\u094b \u0924\u0941\u0932\u0928\u093e \u0917\u0930\u0947\u0930 \u0928\u093f\u0930\u094d\u0923\u092f \u0932\u093f\u0928\u0941\u092a\u0930\u094d\u091b\u0964 \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0938\u0932\u094d\u0932\u093e\u0939\u0915\u093e\u0930\u0915\u094b \u0938\u0939\u092f\u094b\u0917 \u0932\u093f\u0928\u0941 \u092a\u0928\u093f \u0909\u092a\u092f\u094b\u0917\u0940 \u0939\u0941\u0928\u094d\u091b\u0964"

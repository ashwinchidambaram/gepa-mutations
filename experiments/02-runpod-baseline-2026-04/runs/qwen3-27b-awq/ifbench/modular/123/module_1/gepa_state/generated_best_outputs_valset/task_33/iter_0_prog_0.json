    "response": "<<Arabic Translation>>\n\u0645\u0628\u0646\u0649 \u064a\u0639\u0645\u0644 \u062e\u0627\u0631\u062c \u0627\u0644\u0647\u0648\u0627\u0621\n\u0644\u0627 \u0646\u0633\u062a\u062e\u062f\u0645 \u0627\u0644\u0647\u0648\u0627\u0621 \u0627\u0644\u062f\u0627\u062e\u0644\u064a\n\u0646\u062d\u0627\u0641\u0638 \u0639\u0644\u0649 \u0627\u0644\u0647\u0648\u0627\u0621 \u0627\u0644\u062e\u0627\u0631\u062c\u064a\n\u0645\u0628\u0646\u0649 \u0643\u0628\u064a\u0631 \u064a\u0639\u0645\u0644\n\u0644\u0627 \u0646\u0643\u0631\u0631 \u0627\u0644\u0643\u0644\u0645\u0627\u062a\n\u0646\u062d\u0627\u0641\u0638 \u0639\u0644\u0649 \u0627\u0644\u0647\u0648\u0627\u0621\n\u0645\u0628\u0646\u0649 \u064a\u0639\u0645\u0644 \u062e\u0627\u0631\u062c\n\u0644\u0627 \u0646\u0633\u062a\u062e\u062f\u0645 \u0627\u0644\u0647\u0648\u0627\u0621\n\u0646\u062d\u0627\u0641\u0638 \u0639\u0644\u0649 \u0627\u0644\u0647\u0648\u0627\u0621\n\u0645\u0628\u0646\u0649 \u0643\u0628\u064a\u0631 \u064a\u0639\u0645\u0644\n\u0644\u0627 \u0646\u0643\u0631\u0631 \u0627\u0644\u0643\u0644\u0645\u0627\u062a\n\u0646\u062d\u0627\u0641\u0638 \u0639\u0644\u0649 \u0627\u0644\u0647\u0648\u0627\u0621\n\u0645\u0628\u0646\u0649 \u064a\u0639\u0645\u0644 \u062e\u0627\u0631\u062c\n\u0644\u0627 \u0646\u0633\u062a\u062e\u062f\u0645 \u0627\u0644\u0647\u0648\u0627\u0621\n\u0646\u062d\u0627\u0641\u0638 \u0639\u0644\u0649 \u0627\u0644\u0647\u0648\u0627\u0621\n\u0645\u0628\u0646\u0649 \u0643\u0628\u064a\u0631 \u064a\u0639\u0645\u0644\n\u0644\u0627 \u0646\u0643\u0631\u0631 \u0627\u0644\u0643\u0644\u0645\u0627\u062a\n\u0646\u062d\u0627\u0641\u0638 \u0639\u0644\u0649 \u0627\u0644\u0647\u0648\u0627\u0621\n\u0645\u0628\u0646\u0649 \u064a\u0639\u0645\u0644 \u062e\u0627\u0631\u062c\n\u0644\u0627 \u0646\u0633\u062a\u062e\u062f\u0645 \u0627\u0644\u0647\u0648\u0627\u0621\n\u0646\u062d\u0627\u0641\u0638 \u0639\u0644\u0649 \u0627\u0644\u0647\u0648\u0627\u0621\n\u0645\u0628\u0646\u0649 \u0643\u0628\u064a\u0631 \u064a\u0639\u0645\u0644\n\u0644\u0627 \
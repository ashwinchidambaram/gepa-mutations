{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u52a1\u4e2d\u5e38\u9762\u4e34\u6cd5\u5f8b\u4f9d\u636e\u6a21\u7cca\u7684\u95ee\u9898\uff0c\u5bfc\u81f4\u590d\u8bae\u673a\u5173\u5728\u8ba4\u5b9a\u884c\u653f\u673a\u5173\u662f\u5426\u6784\u6210\u4e0d\u4f5c\u4e3a\u65f6\u7f3a\u4e4f\u7edf\u4e00\u6807\u51c6\u3002\u90e8\u5206\u6848\u4ef6\u4e2d\uff0c\u7533\u8bf7\u4eba\u8bf7\u6c42\u7684\u4e8b\u9879\u672c\u8eab\u5b58\u5728\u4e89\u8bae\uff0c\u590d\u8bae\u673a\u5173\u96be\u4ee5\u76f4\u63a5\u5224\u65ad\u88ab\u7533\u8bf7\u4eba\u662f\u5426\u8d1f\u6709\u6cd5\u5b9a\u804c\u8d23\uff0c\u4ece\u800c\u5f71\u54cd\u4e86\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u51c6\u786e\u6027\u548c\u6743\u5a01\u6027\u3002\n\n\u5177\u4f53\u4e8b\u4f8b\u663e\u793a\uff0c\u5f53\u884c\u653f\u673a\u5173\u4ee5\u5185\u90e8\u6d41\u7a0b\u6216\u8d44\u6e90\u4e0d\u8db3\u4e3a\u7531\u62d6\u5ef6\u5c65\u804c\u65f6\uff0c\u590d\u8bae\u673a\u5173\u5f80\u5f80\u96be\u4ee5\u6709\u6548\u754c\u5b9a\u5176\u4e0d\u4f5c\u4e3a\u7684\u6027\u8d28\u3002\u4f8b\u5982\u5728\u67d0\u73af\u4fdd\u6295\u8bc9\u6848\u4ef6\u4e2d\uff0c\u73af\u4fdd\u5c40\u56e0\u4eba\u5458\u77ed\u7f3a\u672a\u53ca\u65f6\u67e5\u5904\u6392\u6c61\u884c\u4e3a\uff0c\u590d\u8bae\u673a\u5173\u5728\u5ba1\u7406\u65f6\u4fbf\u9677\u5165\u662f\u5426\u5e94\u76f4\u63a5\u8d23\u4ee4\u5c65\u804c\u7684\u56f0\u5883\uff0c\u6700\u7ec8\u53ef\u80fd\u56e0\u8bc1\u636e\u4e0d\u8db3\u800c\u9a73\u56de\u7533\u8bf7\uff0c\u524a\u5f31\u4e86\u6551\u6d4e\u6548\u679c\u3002\n\n\u6b64\u5916\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u4e5f\u662f\u5f53\u524d\u5b58\u5728\u7684\u7a81\u51fa\u95ee\u9898\uff0c\u5373\u4fbf\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u660e\u786e\u51b3\u5b9a\uff0c\u88ab\u7533\u8bf7\u4eba\u4ecd\u53ef\u80fd\u6d88\u6781\u5e94\u5bf9\u6216\u53d8\u76f8\u62d6\u5ef6\u3002\u8fd9\u79cd\u6267\u884c\u96be\u73b0\u8c61\u4f7f\u5f97\u884c\u653f\u590d\u8bae\u7684\u7ea0\u9519\u529f\u80fd\u5927\u6253\u6298\u6263\uff0c\u5f53\u4e8b\u4eba\u5f80\u5f80\u9700\u8981\u518d\u6b21\u63d0\u8d77\u8bc9\u8bbc\u624d\u80fd\u63a8\u52a8\u95ee\u9898\u89e3\u51b3\uff0c\u589e\u52a0\u4e86\u7ef4\u6743\u6210\u672c\u548c\u65f6\u95f4\u6d88\u8017\u3002\n\ndocument \u5e94\u5f53\u6210\u4e3a\u89c4\u8303\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u91cd\u8981\u8f7d\u4f53\uff0c\u901a\u8fc7\u7ec6\u5316\u6cd5\u5f8b\u6761\u6587\u548c\u53d1\u5e03\u6307\u5bfc\u6027\u6848\u4f8b\u6765\u7edf\u4e00\u88c1\u5224\u5c3a\u5ea6\u3002\u672a\u6765\u6539\u9769\u9700\u5f3a\u5316\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u529b\uff0c\u5efa\u7acb\u76d1\u7763\u95ee\u8d23\u673a\u5236\uff0c\u786e\u4fdd\u884c\u653f\u673a\u5173\u53ca\u65f6\u5c65\u884c\u6cd5\u5b9a\u804c\u8d23\uff0c\u4ece\u800c\u63d0\u5347\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u516c\u4fe1\u529b\u548c\u5b9e\u6548\u6027\u3002"
}
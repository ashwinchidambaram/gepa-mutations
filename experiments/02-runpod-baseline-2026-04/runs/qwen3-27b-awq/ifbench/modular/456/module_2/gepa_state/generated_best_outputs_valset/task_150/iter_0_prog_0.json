{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u64cd\u4f5c\u4e2d\u5e38\u9762\u4e34\u6cd5\u5f8b\u4f9d\u636e\u6a21\u7cca\u7684\u95ee\u9898\u5bfc\u81f4\u884c\u653f\u673a\u5173\u6267\u884c\u52a8\u529b\u4e0d\u8db3\u3002\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u51b3\u5b9a\u65f6\u672a\u80fd\u660e\u786e\u5177\u4f53\u5c65\u884c\u671f\u9650\u6216\u6807\u51c6\u4f7f\u5f97\u540e\u7eed\u76d1\u7763\u7f3a\u4e4f\u53ef\u64cd\u4f5c\u4f9d\u636e\u3002\n\n\u5b9e\u9645\u6848\u4f8b\u663e\u793a\u67d0\u4e9b\u5730\u533a\u5728\u6d89\u53ca\u5f81\u5730\u8865\u507f\u6216\u793e\u4fdd\u53d1\u653e\u4e8b\u9879\u65f6\u590d\u8bae\u51b3\u5b9a\u4ec5\u8981\u6c42\u91cd\u65b0\u5904\u7406\u800c\u672a\u6307\u660e\u5177\u4f53\u5185\u5bb9\u3002\u8fd9\u79cd\u7b3c\u7edf\u7684\u8868\u8ff0\u5f80\u5f80\u5bfc\u81f4\u884c\u653f\u673a\u5173\u4ee5\u9700\u8981\u8fdb\u4e00\u6b65\u8c03\u67e5\u4e3a\u7531\u62d6\u5ef6\u5c65\u884c\u6700\u7ec8\u635f\u5bb3\u7533\u8bf7\u4eba\u5408\u6cd5\u6743\u76ca\u3002\n\n\u5236\u5ea6\u5c42\u9762\u7f3a\u4e4f\u5bf9\u62d2\u4e0d\u5c65\u884c\u590d\u8bae\u51b3\u5b9a\u7684\u6709\u6548\u60e9\u6212\u673a\u5236\u4e5f\u662f\u5f53\u524d\u5b58\u5728\u7684\u663e\u8457\u77ed\u677f\u3002\u867d\u7136\u6cd5\u5f8b\u89c4\u5b9a\u4e86\u76f8\u5173\u8d23\u4efb\u4f46\u5728\u5b9e\u9645\u8ffd\u8d23\u8fc7\u7a0b\u4e2d\u5f80\u5f80\u9762\u4e34\u53d6\u8bc1\u56f0\u96be\u6216\u5730\u65b9\u4fdd\u62a4\u4e3b\u4e49\u5e72\u6270\u5bfc\u81f4\u51b3\u5b9a\u96be\u4ee5\u843d\u5730\u3002\n\ndocument \u5e94\u5f53\u901a\u8fc7\u7ec6\u5316\u5c65\u884c\u6807\u51c6\u5f3a\u5316\u76d1\u7763\u95ee\u8d23\u5e76\u5f15\u5165\u7b2c\u4e09\u65b9\u8bc4\u4f30\u673a\u5236\u6765\u63d0\u5347\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u529b\u548c\u516c\u4fe1\u529b\u3002"
}
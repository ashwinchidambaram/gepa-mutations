{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u7406\u8bba\u8bbe\u8ba1\u4e0a\u65e8\u5728\u7763\u4fc3\u884c\u653f\u673a\u5173\u4f9d\u6cd5\u5c65\u804c\uff0c\u4f46\u5728\u5b9e\u8df5\u4e2d\u5e38\u9762\u4e34\u6cd5\u5f8b\u4f9d\u636e\u6a21\u7cca\u4e0e\u88c1\u91cf\u6743\u8fc7\u5927\u7684\u95ee\u9898\u3002\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u51b3\u5b9a\u65f6\u672a\u80fd\u660e\u786e\u5177\u4f53\u7684\u5c65\u884c\u671f\u9650\u6216\u5c65\u884c\u6807\u51c6\uff0c\u5bfc\u81f4\u540e\u7eed\u6267\u884c\u7f3a\u4e4f\u53ef\u64cd\u4f5c\u6027\uff0c\u4f7f\u5f97\u884c\u653f\u76f8\u5bf9\u4eba\u7684\u5408\u6cd5\u6743\u76ca\u96be\u4ee5\u5f97\u5230\u53ca\u65f6\u6709\u6548\u7684\u4fdd\u969c\u3002\n\n\u4ece\u5177\u4f53\u6848\u4f8b\u6765\u770b\uff0c\u67d0\u4e9b\u6d89\u53ca\u653f\u5e9c\u4fe1\u606f\u516c\u5f00\u6216\u884c\u653f\u8bb8\u53ef\u7684\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u4ec5\u7b3c\u7edf\u8981\u6c42\u88ab\u7533\u8bf7\u4eba\u91cd\u65b0\u4f5c\u51fa\u5904\u7406\uff0c\u5374\u672a\u6307\u660e\u5e94\u5f53\u5982\u4f55\u7ea0\u6b63\u539f\u8fdd\u6cd5\u884c\u653f\u884c\u4e3a\u3002\u8fd9\u79cd\u6a21\u7cca\u7684\u8d23\u4ee4\u65b9\u5f0f\u5f80\u5f80\u5f15\u53d1\u884c\u653f\u673a\u5173\u7684\u6d88\u6781\u5e94\u5bf9\u6216\u5f62\u5f0f\u5316\u6574\u6539\uff0c\u6700\u7ec8\u9020\u6210\u7a0b\u5e8f\u7a7a\u8f6c\uff0c\u4e0d\u4ec5\u6d6a\u8d39\u4e86\u884c\u653f\u8d44\u6e90\uff0c\u4e5f\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u4f5c\u4e3a\u6743\u5229\u6551\u6d4e\u6e20\u9053\u7684\u516c\u4fe1\u529b\u3002\n\n\u9020\u6210\u4e0a\u8ff0\u56f0\u5883\u7684\u6df1\u5c42\u539f\u56e0\u5728\u4e8e\u73b0\u884c\u6cd5\u5f8b\u5bf9\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u89c4\u8303\u4e0d\u591f\u7ec6\u81f4\uff0c\u7f3a\u4e4f\u7edf\u4e00\u7684\u88c1\u5224\u6307\u5f15\u548c\u91cf\u5316\u6807\u51c6\u3002\u590d\u8bae\u4eba\u5458\u5728\u5ba1\u7406\u8fc7\u7a0b\u4e2d\u5bb9\u6613\u53d7\u5230\u90e8\u95e8\u5229\u76ca\u6216\u5730\u65b9\u4fdd\u62a4\u4e3b\u4e49\u7684\u5f71\u54cd\uff0c\u503e\u5411\u4e8e\u9009\u62e9\u963b\u529b\u8f83\u5c0f\u7684\u8c03\u89e3\u65b9\u5f0f\u6216\u4f5c\u51fa\u6e29\u548c\u7684\u88c1\u51b3\uff0c\u4ece\u800c\u56de\u907f\u4e86\u5bf9\u884c\u653f\u673a\u5173\u5b9e\u8d28\u6027\u8fdd\u6cd5\u95ee\u9898\u7684\u6df1\u5165\u5ba1\u67e5\u548c\u521a\u6027\u7ea0\u6b63\u3002\n\ndocument \u9488\u5bf9\u8fd9\u4e9b\u7ed3\u6784\u6027\u7f3a\u9677\uff0c\u672a\u6765\u9700\u8981\u5b8c\u5584\u76f8\u5173\u7acb\u6cd5\u7ec6\u5219\uff0c\u660e\u786e\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5177\u4f53\u5185\u5bb9\u8981\u7d20\u5e76\u5efa\u7acb\u4e25\u683c\u7684\u76d1\u7763\u8003\u6838\u673a\u5236\u3002\u901a\u8fc7\u7ec6\u5316\u88c1\u5224\u89c4\u5219\u3001\u5f3a\u5316\u53f8\u6cd5\u5ba1\u67e5\u529b\u5ea6\u4ee5\u53ca\u63d0\u5347\u590d\u8bae\u4eba\u5458\u7684\u4e13\u4e1a\u7d20\u517b\uff0c\u53ef\u4ee5\u6709\u6548\u63d0\u5347\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u6548\u529b\uff0c\u786e\u4fdd\u884c\u653f\u590d\u8bae\u5236\u5ea6\u771f\u6b63\u53d1\u6325\u5176\u5316\u89e3\u884c\u653f\u4e89\u8bae\u548c\u7ef4\u62a4\u6cd5\u6cbb\u79e9\u5e8f\u7684\u6838\u5fc3\u529f\u80fd\u3002"
}
    "response": "\u0623\u0646\u0627 \u0633\u0639\u064a\u062f \u0628\u0648\u062c\u0648\u062f\u0643 \u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u0645\u0634\u0631\u0648\u0639 \u0627\u0644\u0631\u0627\u0626\u0639. \u0633\u0623\u0642\u062f\u0645 \u0644\u0643 \u0625\u0642\u062a\u0631\u0627\u062d\u0627\u062a \u0644\u0639\u0645\u0644 \u0642\u0646\u0627\u0629 \u062a\u064f\u0644\u0628\u064a \u0627\u062d\u062a\u064a\u0627\u062c\u0627\u062a\u0643 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0625\u0635\u0637\u0646\u0627\u0639\u064a. \u0645\u0646 \u0627\u0644\u0645\u0645\u0643\u0646 \u0623\u0646 \u062a\u0628\u062f\u0623 \u0628\u062a\u062d\u062f\u064a\u062f \u0646\u0648\u0639 \u0627\u0644\u0642\u0646\u0627\u0629\u060c \u0645\u062b\u0644 \u0627\u0644\u0641\u064a\u062f\u064a\u0648\u0647\u0627\u062a \u0627\u0644\u062a\u0639\u0644\u064a\u0645\u064a\u0629\u060c \u0627\u0644\u062a\u0631\u0641\u064a\u0647\u064a\u0629\u060c \u0623\u0648 \u0627\u0644\u062a\u0643\u0646\u0648\u0644\u0648\u062c\u064a\u0629. \u0643\u0645\u0627 \u064a\u0645\u0643\u0646 \u0623\u0646 \u062a\u0633\u062a\u062e\u062f\u0645 \u062a\u0642\u0646\u064a\u0627\u062a \u0645\u062b\u0644 \u0627\u0644\u062a\u0639\u0644\u0645 \u0627\u0644\u0622\u0644\u064a \u0648\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u062a\u062d\u0633\u064a\u0646 \u062a\u062c\u0631\u0628\u0629 \u0627\u0644\u0645\u0634\u0627\u0647\u062f\u0629. \u0644\u0627 \u062a\u0646\u0633\u0649 \u0623\u0646 \u062a\u062c\u0645\u0639 \u0628\u064a\u0646 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u062c\u0630\u0627\u0628 \u0648\u0627\u0644\u062a\u0639\u0644\u064a\u0645\u064a. \u0625\u0630\u0627 \u0643\u0646\u062a \u062a\u0631\u063a\u0628 \u0641\u064a \u062a\u0641\u0627\u0635\u064a\u0644 \u0623\u0643\u062b\u0631\u060c \u0644\u0627 \u062a\u062a\u0631\u062f\u062f \u0641\u064a \u0645\u0634\u0627\u0631\u0643\u062a\u0647\u0627. attention\n\nfinish  \nfinish  \nfinish  \nfinish"

    "response": "\u0623\u0646\u0627 \u0623\u0641\u0647\u0645 \u0623\u0646\u0643 \u062a\u0631\u063a\u0628 \u0641\u064a \u0625\u0646\u0634\u0627\u0621 \u0642\u0646\u0627\u0629 \u0625\u0639\u0644\u0627\u0645\u064a\u0629 \u0623\u0648 \u0625\u0646\u062a\u0627\u062c\u064a\u0629 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0625\u0635\u0637\u0646\u0627\u0639\u064a\u060c \u0648\u0644\u0643\u0646 \u0623\u0648\u062f \u0623\u0646 \u0623\u0648\u0636\u062d \u0623\u0646 \u0647\u0646\u0627\u0643 \u0642\u064a\u0648\u062f\u064b\u0627 \u0642\u0648\u064a\u0629 \u062a\u062a\u0639\u0644\u0642 \u0628\u062d\u0642\u0648\u0642 \u0627\u0644\u0646\u0634\u0631 \u0648\u0627\u0644\u062a\u062d\u0642\u064a\u0642 \u0641\u064a \u0627\u0644\u0645\u062d\u062a\u0648\u0649. \u0625\u0630\u0627 \u0643\u0646\u062a \u062a\u0631\u063a\u0628 \u0641\u064a \u0625\u0646\u0634\u0627\u0621 \u0642\u0646\u0627\u0629 \u0625\u0639\u0644\u0627\u0645\u064a\u0629\u060c \u0641\u0639\u0644\u064a\u0643 \u0623\u0646 \u062a\u062d\u0642\u0642 \u0645\u0646 \u062d\u0642\u0648\u0642 \u0627\u0644\u0646\u0634\u0631 \u0648\u0627\u0644\u062a\u062d\u0642\u064a\u0642 \u0641\u064a \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u0645\u0642\u062f\u0645\u060c \u0648\u062a\u062c\u0646\u0628 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u063a\u064a\u0631 \u0627\u0644\u0645\u0633\u0645\u0648\u062d \u0628\u0647.\n\n\u0623\u0646\u0627 \u0623\u0639\u0644\u0645 \u0623\u0646\u0643 \u062a\u0631\u063a\u0628 \u0641\u064a \u0625\u0646\u0634\u0627\u0621 \u0642\u0646\u0627\u0629 \u0625\u0639\u0644\u0627\u0645\u064a\u0629\u060c \u0648\u0644\u0643\u0646 \u0623\u0648\u062f \u0623\u0646 \u0623\u0630\u0643\u0631 \u0623\u0646 \u0647\u0646\u0627\u0643 \u0642\u064a\u0648\u062f\u064b\u0627 \u062a\u062a\u0639\u0644\u0642 \u0628\u0627\u0644\u062d\u0642\u0648\u0642 \u0648\u0627\u0644\u062a\u062d\u0642\u064a\u0642 \u0641\u064a \u0627\u0644\u0645\u062d\u062a\u0648\u0649. \u0625\u0630\u0627 \u0643\u0646\u062
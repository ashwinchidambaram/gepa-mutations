{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u3001\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u4ee5\u53ca\u6cd5\u5f8b\u9002\u7528\u5b58\u5728\u504f\u5dee\u7b49\u65b9\u9762\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u4e89\u8bae\u65f6\uff0c\u672a\u4f9d\u6cd5\u544a\u77e5\u5f53\u4e8b\u4eba\u5c65\u884c\u4e49\u52a1\u7684\u671f\u9650\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u672a\u53ca\u65f6\u5c65\u884c\uff0c\u6700\u7ec8\u5f15\u53d1\u4e89\u8bae\u5347\u7ea7\u3002\u8fd9\u79cd\u505a\u6cd5\u8fdd\u53cd\u4e86\u300a\u884c\u653f\u590d\u8bae\u6cd5\u300b\u5173\u4e8e\u544a\u77e5\u4e49\u52a1\u7684\u89c4\u5b9a\uff0c\u53cd\u6620\u51fa\u7a0b\u5e8f\u4e0a\u7684\u4e0d\u4e25\u8c28\u3002\n\n\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5b58\u5728\u6d88\u6781\u5c65\u884c\u6216\u62d6\u5ef6\u6267\u884c\u7684\u73b0\u8c61\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u6536\u5230\u5f53\u4e8b\u4eba\u5c65\u884c\u4e49\u52a1\u7684\u7533\u8bf7\u540e\uff0c\u672a\u53ca\u65f6\u542f\u52a8\u6267\u884c\u7a0b\u5e8f\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u6743\u76ca\u53d7\u635f\u3002\u8fd9\u79cd\u73b0\u8c61\u4e0d\u4ec5\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u4fe1\u529b\uff0c\u4e5f\u635f\u5bb3\u4e86\u884c\u653f\u76f8\u5bf9\u4eba\u7684\u5408\u6cd5\u6743\u76ca\uff0c\u66b4\u9732\u51fa\u6267\u884c\u673a\u5236\u4e0d\u5b8c\u5584\u7684\u95ee\u9898\u3002\n\n\u6cd5\u5f8b\u9002\u7528\u65b9\u9762\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5bf9\u201c\u8d23\u4ee4\u5c65\u884c\u201d\u8fd9\u4e00\u6982\u5ff5\u7406\u89e3\u4e0d\u4e00\uff0c\u5bfc\u81f4\u6267\u884c\u6807\u51c6\u4e0d\u7edf\u4e00\u3002\u4f8b\u5982\uff0c\u5bf9\u4e8e\u201c\u5c65\u884c\u4e49\u52a1\u201d\u7684\u5177\u4f53\u8303\u56f4\u548c\u5f62\u5f0f\u5b58\u5728\u6a21\u7cca\u754c\u5b9a\uff0c\u5bfc\u81f4\u6267\u884c\u7ed3\u679c\u96be\u4ee5\u51c6\u786e\u5224\u65ad\u3002\u8fd9\u79cd\u6cd5\u5f8b\u9002\u7528\u7684\u4e0d\u660e\u786e\uff0c\u589e\u52a0\u4e86\u6267\u884c\u8fc7\u7a0b\u4e2d\u7684\u4e0d\u786e\u5b9a\u6027\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u3002\n\nDocument\n\n\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5236\u5b9a\u548c\u6267\u884c\u5f80\u5f80\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u6267\u884c\u6548\u679c\u4e0d\u4f73\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u8bb8\u53ef\u4e89\u8bae\u65f6\uff0c\u672a\u5bf9\u5c65\u884c\u60c5\u51b5\u4f5c\u51fa\u5b9a\u671f\u68c0\u67e5\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u957f\u671f\u672a\u5c65\u884c\u4e49\u52a1\uff0c\u6700\u7ec8\u5f15\u53d1\u884c\u653f\u590d\u8bae\u7a0b\u5e8f\u7684\u53cd\u590d\u3002\u8fd9\u79cd\u7f3a\u4e4f\u76d1\u7763\u7684\u6267\u884c\u6a21\u5f0f\uff0c\u4e0d\u4ec5\u6d6a\u8d39\u4e86\u884c\u653f\u8d44\u6e90\uff0c\u4e5f\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6548\u7387\u548c\u6743\u5a01\u6027\u3002"
}
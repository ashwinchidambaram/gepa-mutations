{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u3001\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u4ee5\u53ca\u9002\u7528\u8303\u56f4\u6709\u9650\u7b49\u65b9\u9762\u3002\u4f8b\u5982\uff0c\u4e00\u4e9b\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u672a\u80fd\u660e\u786e\u5177\u4f53\u5c65\u884c\u671f\u9650\u548c\u65b9\u5f0f\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u96be\u4ee5\u53ca\u65f6\u5c65\u884c\u4e49\u52a1\uff0c\u5f71\u54cd\u4e86\u590d\u8bae\u7684\u6548\u529b\u3002\u6b64\u5916\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u5c65\u884c\u60c5\u51b5\u96be\u4ee5\u8ddf\u8e2a\u548c\u8bc4\u4f30\uff0c\u5f71\u54cd\u4e86\u51b3\u5b9a\u7684\u6267\u884c\u529b\u3002\n\n\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u4e00\u4e9b\u590d\u8bae\u6848\u4ef6\u7684\u5f53\u4e8b\u4eba\u5bf9\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5b58\u5728\u8bef\u89e3\uff0c\u8ba4\u4e3a\u8fd9\u662f\u6cd5\u9662\u7684\u5224\u51b3\uff0c\u4ece\u800c\u62d2\u7edd\u5c65\u884c\uff0c\u8fdb\u4e00\u6b65\u52a0\u5267\u4e86\u6267\u884c\u96be\u5ea6\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u5904\u7f5a\u6848\u4ef6\u65f6\uff0c\u672a\u660e\u786e\u544a\u77e5\u5f53\u4e8b\u4eba\u5c65\u884c\u4e49\u52a1\u7684\u5177\u4f53\u65f6\u95f4\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u62d6\u5ef6\u5c65\u884c\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u590d\u8bae\u7a0b\u5e8f\u7684\u987a\u5229\u8fdb\u884c\u3002\n\n\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u4e5f\u5b58\u5728\u5c40\u9650\u6027\uff0c\u4e3b\u8981\u9002\u7528\u4e8e\u884c\u653f\u884c\u4e3a\u5b58\u5728\u7455\u75b5\u6216\u8fdd\u6cd5\u60c5\u5f62\uff0c\u4f46\u5bf9\u4e00\u4e9b\u590d\u6742\u6848\u4ef6\uff0c\u5982\u6d89\u53ca\u591a\u65b9\u5229\u76ca\u6216\u6cd5\u5f8b\u5173\u7cfb\u590d\u6742\u7684\u60c5\u51b5\uff0c\u5f80\u5f80\u96be\u4ee5\u9002\u7528\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u4e9b\u571f\u5730\u5f81\u6536\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u96be\u4ee5\u660e\u786e\u754c\u5b9a\u8d23\u4efb\u4e3b\u4f53\uff0c\u5bfc\u81f4\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u4e0d\u591f\u51c6\u786e\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u3002\n\ndocument\n\n\u5728\u884c\u653f\u590d\u8bae\u8fc7\u7a0b\u4e2d\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6cd5\u5f8b\u6548\u529b\u548c\u6267\u884c\u6807\u51c6\u4ecd\u9700\u8fdb\u4e00\u6b65\u660e\u786e\u3002\u76ee\u524d\uff0c\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\u5bf9\u8d23\u4ee4\u5c65\u884c\u7684\u7a0b\u5e8f\u3001\u671f\u9650\u548c\u6267\u884c\u65b9\u5f0f\u7f3a\u4e4f\u5177\u4f53\u89c4\u5b9a\uff0c\u5bfc\u81f4\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\u5b58\u5728\u4e00\u5b9a\u7684\u6a21\u7cca\u6027\u3002\u4f8b\u5982\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u672a\u80fd\u53ca\u65f6\u5411\u5f53\u4e8b\u4eba\u9001\u8fbe\uff0c\u6216\u672a\u5728\u89c4\u5b9a\u671f\u9650\u5185\u8fdb\u884c\u50ac\u544a\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u672a\u80fd\u53ca\u65f6\u5c65\u884c\u4e49\u52a1\uff0c\u5f71\u54cd\u4e86\u590d\u8bae\u7684\u6700\u7ec8\u7ed3\u679c\u3002"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u9996\u5148\u5728\u4e8e\u7a0b\u5e8f\u4e0a\u7684\u4e0d\u89c4\u8303\u3002\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u672a\u4e25\u683c\u9075\u5faa\u6cd5\u5b9a\u7a0b\u5e8f\uff0c\u5bfc\u81f4\u51b3\u5b9a\u7f3a\u4e4f\u6cd5\u5f8b\u4f9d\u636e\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u5e02\u573a\u76d1\u7ba1\u90e8\u95e8\u5728\u5904\u7406\u6d88\u8d39\u8005\u6295\u8bc9\u65f6\uff0c\u672a\u4f9d\u6cd5\u544a\u77e5\u5f53\u4e8b\u4eba\u76f8\u5173\u6743\u5229\uff0c\u76f4\u63a5\u4f5c\u51fa\u8d23\u4ee4\u6574\u6539\u51b3\u5b9a\uff0c\u5f15\u53d1\u5f53\u4e8b\u4eba\u4e0d\u6ee1\uff0c\u5f71\u54cd\u4e86\u590d\u8bae\u7684\u516c\u6b63\u6027\u3002\n\n\u5176\u6b21\uff0c\u6267\u6cd5\u673a\u5173\u5728\u6267\u884c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u5b58\u5728\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u7684\u95ee\u9898\u3002\u4e00\u4e9b\u590d\u8bae\u51b3\u5b9a\u867d\u5df2\u4f5c\u51fa\uff0c\u4f46\u6267\u884c\u8fc7\u7a0b\u4e2d\u7f3a\u4e4f\u6709\u6548\u76d1\u7763\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u672a\u80fd\u53ca\u65f6\u5c65\u884c\u4e49\u52a1\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u8d23\u4ee4\u67d0\u4f01\u4e1a\u9650\u671f\u6574\u6539\uff0c\u4f46\u4f01\u4e1a\u672a\u6309\u65f6\u5b8c\u6210\uff0c\u590d\u8bae\u673a\u5173\u672a\u53ca\u65f6\u8ddf\u8fdb\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u6574\u6539\u6548\u679c\uff0c\u635f\u5bb3\u4e86\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u3002\n\n\u518d\u6b21\uff0c\u590d\u8bae\u673a\u5173\u5bf9\u5f53\u4e8b\u4eba\u5c65\u884c\u4e49\u52a1\u7684\u76d1\u7763\u673a\u5236\u4e0d\u5065\u5168\u3002\u90e8\u5206\u590d\u8bae\u673a\u5173\u672a\u5efa\u7acb\u6709\u6548\u7684\u8ddf\u8e2a\u673a\u5236\uff0c\u5bfc\u81f4\u5c65\u884c\u60c5\u51b5\u96be\u4ee5\u638c\u63e1\uff0c\u5f71\u54cd\u4e86\u590d\u8bae\u51b3\u5b9a\u7684\u843d\u5b9e\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u6559\u80b2\u90e8\u95e8\u8d23\u4ee4\u67d0\u5b66\u6821\u9650\u671f\u6574\u6539\u6559\u5b66\u8bbe\u65bd\uff0c\u4f46\u5b66\u6821\u672a\u6309\u671f\u5b8c\u6210\uff0c\u590d\u8bae\u673a\u5173\u672a\u53ca\u65f6\u4ecb\u5165\uff0c\u5bfc\u81f4\u95ee\u9898\u957f\u671f\u672a\u89e3\u51b3\uff0c\u5f71\u54cd\u4e86\u6559\u80b2\u8d28\u91cf\u3002\n\n\u6700\u540e\uff0c\u884c\u653f\u590d\u8bae\u6cd5\u5728\u9002\u7528\u8fc7\u7a0b\u4e2d\u5b58\u5728\u4e00\u5b9a\u7684\u6a21\u7cca\u6027\uff0c\u5bfc\u81f4\u6267\u884c\u6807\u51c6\u4e0d\u4e00\u3002\u4f8b\u5982\uff0c\u5bf9\u4e8e\u201c\u5c65\u884c\u671f\u9650\u201d\u548c\u201c\u5c65\u884c\u65b9\u5f0f\u201d\u7684\u754c\u5b9a\u4e0d\u591f\u660e\u786e\uff0c\u5bfc\u81f4\u590d\u8bae\u673a\u5173\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\u96be\u4ee5\u7edf\u4e00\u6807\u51c6\uff0c\u5f71\u54cd\u4e86\u590d\u8bae\u51b3\u5b9a\u7684\u53ef\u64cd\u4f5c\u6027\u3002"
}
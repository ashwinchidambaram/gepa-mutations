{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u5176\u4e2d\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u548c\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u4e89\u8bae\u65f6\uff0c\u672a\u4f9d\u6cd5\u544a\u77e5\u5f53\u4e8b\u4eba\u5c65\u884c\u4e49\u52a1\u7684\u5177\u4f53\u671f\u9650\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u672a\u80fd\u53ca\u65f6\u5c65\u884c\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u6848\u4ef6\u7684\u516c\u6b63\u5904\u7406\u3002\u8fd9\u79cd\u7a0b\u5e8f\u4e0a\u7684\u758f\u6f0f\uff0c\u53cd\u6620\u51fa\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5c65\u884c\u6cd5\u5b9a\u7a0b\u5e8f\u65b9\u9762\u5b58\u5728\u4e0d\u8db3\u3002\n\n\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u90e8\u5206\u884c\u653f\u590d\u8bae\u673a\u5173\u5bf9\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u6709\u6548\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u6267\u884c\u6548\u679c\u4e0d\u4f73\u3002\u4f8b\u5982\uff0c\u67d0\u5e02\u73af\u4fdd\u5c40\u56e0\u672a\u4f9d\u6cd5\u5c65\u884c\u8d23\u4ee4\u6574\u6539\u51b3\u5b9a\uff0c\u5bfc\u81f4\u4f01\u4e1a\u7ee7\u7eed\u8fdd\u89c4\u6392\u6c61\uff0c\u6700\u7ec8\u5f15\u53d1\u884c\u653f\u590d\u8bae\u673a\u5173\u7684\u4ecb\u5165\uff0c\u4f46\u56e0\u7f3a\u4e4f\u6709\u6548\u7684\u6267\u884c\u4fdd\u969c\uff0c\u6848\u4ef6\u672a\u80fd\u5f97\u5230\u59a5\u5584\u89e3\u51b3\u3002\u8fd9\u79cd\u73b0\u8c61\u8868\u660e\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u7f3a\u4e4f\u8db3\u591f\u7684\u76d1\u7763\u548c\u4fdd\u969c\u63aa\u65bd\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6cd5\u5f8b\u6548\u529b\u548c\u9002\u7528\u8303\u56f4\u5b58\u5728\u4e89\u8bae\u3002\u90e8\u5206\u884c\u653f\u673a\u5173\u5bf9\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u7406\u89e3\u4e0d\u4e00\u81f4\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u4e2d\u51fa\u73b0\u6df7\u4e71\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u6cd5\u9662\u5728\u5ba1\u7406\u884c\u653f\u6848\u4ef6\u65f6\uff0c\u5bf9\u884c\u653f\u590d\u8bae\u673a\u5173\u7684\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u6301\u4e0d\u540c\u610f\u89c1\uff0c\u8ba4\u4e3a\u5176\u4e0d\u5177\u5907\u6cd5\u5f8b\u6548\u529b\uff0c\u4ece\u800c\u5f71\u54cd\u4e86\u6848\u4ef6\u7684\u516c\u6b63\u88c1\u51b3\u3002\n\ndocument\n\n\u5728\u884c\u653f\u590d\u8bae\u8fc7\u7a0b\u4e2d\uff0c\u5f53\u4e8b\u4eba\u5bf9\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u7533\u8bf7\u548c\u6267\u884c\u5b58\u5728\u4e00\u5b9a\u7684\u6cd5\u5f8b\u969c\u788d\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u4e89\u8bae\u65f6\uff0c\u672a\u4f9d\u6cd5\u544a\u77e5\u5f53\u4e8b\u4eba\u5c65\u884c\u4e49\u52a1\u7684\u5177\u4f53\u671f\u9650\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u672a\u80fd\u53ca\u65f6\u5c65\u884c\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u6848\u4ef6\u7684\u516c\u6b63\u5904\u7406\u3002\u8fd9\u79cd\u7a0b\u5e8f\u4e0a\u7684\u758f\u6f0f\uff0c\u53cd\u6620\u51fa\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5c65\u884c\u6cd5\u5b9a\u7a0b\u5e8f\u65b9\u9762\u5b58\u5728\u4e0d\u8db3\u3002"
}
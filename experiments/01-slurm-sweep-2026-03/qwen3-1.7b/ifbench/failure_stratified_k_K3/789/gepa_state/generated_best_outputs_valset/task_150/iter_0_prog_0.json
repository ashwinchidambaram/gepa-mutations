{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u3001\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u4ee5\u53ca\u6cd5\u5f8b\u9002\u7528\u5b58\u5728\u4e89\u8bae\u7b49\u65b9\u9762\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u653f\u5e9c\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u590d\u8bae\u6848\u4ef6\u65f6\uff0c\u672a\u4f9d\u6cd5\u544a\u77e5\u590d\u8bae\u7533\u8bf7\u4eba\u5c65\u884c\u4e49\u52a1\u7684\u5177\u4f53\u671f\u9650\uff0c\u5bfc\u81f4\u7533\u8bf7\u4eba\u672a\u80fd\u53ca\u65f6\u5c65\u884c\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u6848\u4ef6\u7684\u516c\u6b63\u5904\u7406\u3002\u8fd9\u79cd\u7a0b\u5e8f\u4e0a\u7684\u758f\u6f0f\u53cd\u6620\u51fa\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5c65\u884c\u544a\u77e5\u4e49\u52a1\u65b9\u9762\u7684\u4e0d\u8db3\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u5b58\u5728\u56f0\u96be\u3002\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u4e00\u4e9b\u6848\u4ef6\u7684\u5c65\u884c\u4e49\u52a1\u672a\u80fd\u6309\u65f6\u5b8c\u6210\u3002\u4f8b\u5982\uff0c\u67d0\u5e02\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u5904\u7f5a\u6848\u4ef6\u65f6\uff0c\u590d\u8bae\u673a\u5173\u867d\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u672a\u5efa\u7acb\u6709\u6548\u7684\u8ddf\u8e2a\u673a\u5236\uff0c\u81f4\u4f7f\u88ab\u7533\u8bf7\u4eba\u957f\u671f\u672a\u5c65\u884c\u4e49\u52a1\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6548\u529b\u3002\n\n\u5728\u6cd5\u5f8b\u9002\u7528\u65b9\u9762\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u6807\u51c6\u4e0d\u591f\u660e\u786e\uff0c\u5bfc\u81f4\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\u5b58\u5728\u4e00\u5b9a\u7684\u6a21\u7cca\u6027\u3002\u4f8b\u5982\uff0c\u5bf9\u4e8e\u201c\u5c65\u884c\u4e49\u52a1\u201d\u7684\u5177\u4f53\u8303\u56f4\u548c\u6807\u51c6\u7f3a\u4e4f\u7edf\u4e00\u7684\u754c\u5b9a\uff0c\u4f7f\u5f97\u4e0d\u540c\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u96be\u4ee5\u8fbe\u6210\u4e00\u81f4\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u6743\u5a01\u6027\u3002\n\ndocument \u95ee\u9898\u8fd8\u4f53\u73b0\u5728\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u5bf9\u88ab\u7533\u8bf7\u4eba\u91c7\u53d6\u7684\u63aa\u65bd\u4e0d\u591f\u6709\u529b\u3002\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u5c65\u884c\u4e49\u52a1\u8fc7\u7a0b\u4e2d\uff0c\u7f3a\u4e4f\u5fc5\u8981\u7684\u5f3a\u5236\u624b\u6bb5\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u6d88\u6781\u5bf9\u5f85\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u5b9e\u6548\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u590d\u8bae\u6848\u4ef6\u65f6\uff0c\u590d\u8bae\u673a\u5173\u4ec5\u901a\u8fc7\u4e66\u9762\u901a\u77e5\u65b9\u5f0f\u8981\u6c42\u88ab\u7533\u8bf7\u4eba\u5c65\u884c\u4e49\u52a1\uff0c\u672a\u91c7\u53d6\u5176\u4ed6\u5f3a\u5236\u63aa\u65bd\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u62d2\u4e0d\u6267\u884c\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6700\u7ec8\u7ed3\u679c\u3002"
}
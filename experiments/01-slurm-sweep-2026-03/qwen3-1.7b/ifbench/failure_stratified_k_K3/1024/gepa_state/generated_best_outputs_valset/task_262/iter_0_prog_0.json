{
    "response": "\u0623\u0646\u0627 \u0633\u0639\u064a\u062f \u0623\u0646 \u0623\u0643\u0648\u0646 \u062c\u0632\u0621\u064b\u0627 \u0645\u0646 \u0645\u0634\u0631\u0648\u0639\u0643 \u0631\u0627\u0626\u0639. \u0644\u0639\u0645\u0644 \u0642\u0646\u0627\u0629 \u062a\u064f\u0639\u062f\u0651 \u0643\u0646\u0632\u064b\u0627 \u0644\u0644\u062a\u0639\u0644\u0645 \u0648\u0627\u0644\u062a\u0637\u0648\u064a\u0631\u060c \u0641\u0625\u0646 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0625\u0635\u0637\u0646\u0627\u0639\u064a \u0633\u064a\u0643\u0648\u0646 \u0645\u0641\u062a\u0627\u062d\u064b\u0627 \u0644\u062c\u0639\u0644\u0647\u0627 \u0645\u064f\u062b\u064a\u0631\u0629 \u0648\u0641\u0639\u0627\u0644\u0629. \u0625\u0644\u064a\u0643 \u0628\u0639\u0636 \u0627\u0644\u0625\u0642\u062a\u0631\u0627\u062d\u0627\u062a:\n\n1. **\u0627\u0644\u062a\u0639\u0644\u0645 \u0645\u0646 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a**: \u0627\u0633\u062a\u062e\u062f\u0645 \u0646\u0645\u0627\u0630\u062c \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0625\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u062a\u062d\u0644\u064a\u0644 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0648\u062a\u0642\u062f\u064a\u0645 \u0646\u062a\u0627\u0626\u062c \u0645\u064f\u0646\u0638\u0645\u0629.\n2. **\u0627\u0644\u062a\u0641\u0627\u0639\u0644 \u0639\u0628\u0631 \u0627\u0644\u0625\u0646\u062a\u0631\u0646\u062a**: \u0627\u0633\u062a\u062e\u062f\u0645 \u0623\u062f\u0648\u0627\u062a \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0625\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u062e\u0644\u0642 \u062a\u062c\u0627\u0631\u0628 \u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u062a\u064f\u0644\u0647\u0645 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u064a\u0646.\n3. **\u0627\u0644\u062a\u0637\u0648\u064a\u0631 \u0627\u0644\u0634\u062e\u0635\u064a**: \u0627\u0633\u062a\u062e\u062f\u0645 \u0646\u0645\u0627\u0630\u062c \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0625\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u062a\u0642\u062f\u064a\u0645 \u0645\u0648\u0627\u0631\u062f \u062a\u062f\u0631\u064a\u0628\u064a\u0629 \u0645\u062e\u0635\u0635\u0629 \u0644\u0643\u0644 \u0645\u0633\u062a\u062e\u062f\u0645.\n4. **\u0627\u0644\u0646\u0634\u0631 \u0648\u0627\u0644\u0645\u0634\u0627\u0631\u0643\u0629**: \u0627\u0633\u062a\u062e\u062f\u0645 \u0623\u062f\u0648\u0627\u062a \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0625\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u062a\u062d\u0633\u064a\u0646 \u062c\u0648\u062f\u0629 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0648\u0632\u064a\u0627\u062f\u0629 \u0627\u0644\u0648\u0635\u0648\u0644 \u0625\u0644\u0649 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u064a\u0646.\n\n\u0644\u0636\u0645\u0627\u0646 \u0646\u062c\u0627\u062d \u0627\u0644\u0642\u0646\u0627\u0629\u060c \u0627\u062d\u0631\u0635 \u0639\u0644\u0649 \u062a\u062c\u0631\u0628\u0629 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0625\u0635\u0637\u0646\u0627\u0639\u064a \u0628\u0634\u0643\u0644 \u0645\u0633\u062a\u0645\u0631 \u0648\u062a\u062d\u062f\u064a\u062b \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0628\u0627\u0633\u062a\u0645\u0631\u0627\u0631. \u062a\u0630\u0643\u0631 \u0623\u0646 \u0627\u0644\u062a\u0641\u0627\u0639\u0644 \u0645\u0639 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u064a\u0646 \u0647\u0648 \u0645\u0641\u062a\u0627\u062d \u0627\u0644\u0646\u062c\u0627\u062d\u060c \u0648\u062a\u0623\u0643\u062f \u0645\u0646 \u0623\u0646 \u0627\u0644\u0642\u0646\u0627\u0629 \u062a\u064f\u0642\u062f\u0645 \u0642\u064a\u0645\u0629 \u0625\u0636\u0627\u0641\u064a\u0629.\n\nattention  \nfinish  \nfinish  \nfinish  \nfinish"
}
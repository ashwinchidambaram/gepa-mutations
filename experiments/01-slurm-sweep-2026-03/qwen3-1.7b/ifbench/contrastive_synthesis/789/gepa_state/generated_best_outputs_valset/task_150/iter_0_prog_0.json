{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u3001\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u4ee5\u53ca\u9002\u7528\u8303\u56f4\u6709\u9650\u7b49\u65b9\u9762\u3002\u4f8b\u5982\uff0c\u4e00\u4e9b\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u672a\u80fd\u5145\u5206\u8003\u8651\u5f53\u4e8b\u4eba\u7684\u5b9e\u9645\u60c5\u51b5\uff0c\u5bfc\u81f4\u51b3\u5b9a\u7f3a\u4e4f\u9488\u5bf9\u6027\uff0c\u5f71\u54cd\u4e86\u6267\u884c\u6548\u679c\u3002\u6b64\u5916\uff0c\u90e8\u5206\u590d\u8bae\u51b3\u5b9a\u672a\u660e\u786e\u5c65\u884c\u671f\u9650\uff0c\u4f7f\u5f97\u5f53\u4e8b\u4eba\u96be\u4ee5\u53ca\u65f6\u5c65\u884c\uff0c\u8fdb\u4e00\u6b65\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u7684\u6548\u529b\u3002\n\n\u5728\u5177\u4f53\u6848\u4f8b\u4e2d\uff0c\u67d0\u5730\u73af\u4fdd\u5c40\u5bf9\u67d0\u4f01\u4e1a\u672a\u6309\u65f6\u5b8c\u6210\u6574\u6539\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u672a\u660e\u786e\u5177\u4f53\u7684\u6574\u6539\u671f\u9650\u548c\u5b8c\u6210\u6807\u51c6\uff0c\u4f01\u4e1a\u5bf9\u6b64\u8868\u793a\u4e0d\u6ee1\uff0c\u6700\u7ec8\u672a\u80fd\u6309\u65f6\u5c65\u884c\u3002\u8fd9\u53cd\u6620\u51fa\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u5728\u7a0b\u5e8f\u4e0a\u5b58\u5728\u7f3a\u9677\uff0c\u672a\u80fd\u6709\u6548\u4fdd\u969c\u5f53\u4e8b\u4eba\u7684\u5408\u6cd5\u6743\u76ca\u3002\n\n\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u4e5f\u5b58\u5728\u5c40\u9650\u6027\u3002\u5bf9\u4e8e\u4e00\u4e9b\u590d\u6742\u6216\u6d89\u53ca\u591a\u65b9\u5229\u76ca\u7684\u6848\u4ef6\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u96be\u4ee5\u51c6\u786e\u754c\u5b9a\u8d23\u4efb\u4e3b\u4f53\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u4e2d\u51fa\u73b0\u4e89\u8bae\u3002\u6b64\u5916\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u4f7f\u5f97\u5c65\u884c\u60c5\u51b5\u96be\u4ee5\u8ddf\u8e2a\u548c\u8bc4\u4f30\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u6743\u5a01\u6027\u3002\n\ndocument \u4f5c\u4e3a\u884c\u653f\u590d\u8bae\u7684\u6700\u7ec8\u51b3\u5b9a\uff0c\u5176\u6548\u529b\u548c\u6267\u884c\u529b\u5ea6\u76f4\u63a5\u5f71\u54cd\u5230\u884c\u653f\u590d\u8bae\u7684\u6210\u6548\u3002\u76ee\u524d\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u7f3a\u4e4f\u76f8\u5e94\u7684\u6267\u884c\u4fdd\u969c\u673a\u5236\uff0c\u5bfc\u81f4\u51b3\u5b9a\u96be\u4ee5\u843d\u5b9e\u3002\u56e0\u6b64\uff0c\u6709\u5fc5\u8981\u8fdb\u4e00\u6b65\u5b8c\u5584\u884c\u653f\u590d\u8bae\u7a0b\u5e8f\uff0c\u52a0\u5f3a\u6267\u884c\u76d1\u7763\uff0c\u786e\u4fdd\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u80fd\u591f\u5207\u5b9e\u53d1\u6325\u4f5c\u7528\u3002"
}
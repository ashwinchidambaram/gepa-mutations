    "response": "\u0623\u0646\u0627 \u0623\u062a\u0641\u0647\u0645 \u0637\u0644\u0628\u0643\u060c \u0648\u0644\u0643\u0646 \u0647\u0646\u0627\u0643 \u0628\u0639\u0636 \u0627\u0644\u062a\u062d\u062f\u064a\u0627\u062a \u0641\u064a \u0641\u0647\u0645\u0643. \u0625\u0644\u064a\u0643 \u0625\u0642\u062a\u0631\u0627\u062d\u0627\u062a \u0644\u0639\u0645\u0644 \u0642\u0646\u0627\u0629 \u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a:\n\n1. **\u0627\u0633\u062a\u062e\u062f\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u062a\u062d\u0644\u064a\u0644 \u0627\u0644\u0645\u0634\u0627\u0647\u062f\u0627\u062a** \u0644\u062a\u062d\u062f\u064a\u062f \u0627\u0644\u0623\u0641\u0643\u0627\u0631 \u0627\u0644\u0623\u0643\u062b\u0631 \u062a\u0641\u0627\u0639\u0644\u064b\u0627 \u0648\u062a\u0639\u062f\u064a\u0644 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u062d\u0633\u0628 \u0627\u0644\u0627\u0647\u062a\u0645\u0627\u0645\u0627\u062a.\n2. **\u0627\u0628\u062f\u0623 \u0628\u0635\u0646\u0639 \u0645\u062d\u062a\u0648\u0649 \u0645\u0628\u062a\u0643\u0631** \u0645\u062b\u0644 \u0641\u064a\u062f\u064a\u0648\u0647\u0627\u062a \u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u0623\u0648 \u0645\u0633\u0627\u0628\u0642\u0627\u062a \u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0623\u062f\u0648\u0627\u062a \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a.\n3. **\u0627\u0633\u062a\u062e\u062f\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u062a\u062d\u0644\u064a\u0644 \u0627\u0644\u062a\u0639\u0644\u064a\u0642\u0627\u062a** \u0644\u062a\u062d\u0633\u064a\u0646 \u062a\u062c\u0631\u0628\u0629 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645 \u0648\u062a\u0642\u062f\u064a\u0645 \u0645\u062d\u062a\u0648\u0649 \u0623\u06
    "response": "( \u0645\u062b\u0627\u0644 \u0639\u0644\u0649 \u0627\u0644\u0642\u0636\u064a\u0629 \u201c\u064a\u0648\u062c\u062f \u062d\u0644\u0645\u0629 \u0641\u064a \u0627\u0644\u0638\u0647\u0631\u201d, \u062a\u0642\u0648\u0644 \u0644\u0648\u064a\u0632\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a (4 \u0633\u0646\u0648\u0627\u062a)\u060c \u0648\u0647\u064a \u062e\u0641\u064a\u0629 \u0641\u064a \u0639\u0635\u0627 \u0645\u0627\u0645\u0627\u0647\u0627. \u0648\u0639\u0646\u062f\u0645\u0627 \u062a\u062c\u0644\u0633 \u0623\u062e\u062a\u0647\u0627 \u0627\u0644\u0635\u063a\u064a\u0631\u0629 \u0641\u064a \u0645\u0642\u0639\u062f\u0647\u0627 \u0627\u0644\u0635\u063a\u064a\u0631\u060c \u062a\u062c\u0644\u0633 \u0628\u062b\u0642\u0629 \u0648\u062a\u062d\u062a\u0641\u0644 \u0628\u062a\u062d\u0642\u064a\u0642\u0647\u0627. \u062a\u0642\u0648\u0644 \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u0647\u064a \u0645\u0627\u0645\u0627 \u0644\u0648\u064a\u0632\u064a \u062c\u0648\u062f\u0641\u0631\u064a\u060c \u062a\u0642\u0648\u0644: \u201c\u0647\u0627 \u
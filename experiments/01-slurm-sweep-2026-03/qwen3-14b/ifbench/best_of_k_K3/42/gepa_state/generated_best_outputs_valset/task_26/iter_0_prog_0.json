{
    "response": "\u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u0906\u092b\u094d\u0928\u094b \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0917\u0924 \u0935\u093f\u0924\u094d\u0924 \u0935\u094d\u092f\u0935\u0938\u094d\u0925\u093e\u092a\u0928 \u0917\u0930\u094d\u0928\u0915\u093e \u0932\u093e\u0917\u093f \u0927\u0947\u0930\u0948 \u0909\u092a\u093e\u092f\u0939\u0930\u0942 \u0905\u092a\u0928\u093e\u0909\u0928 \u0938\u0915\u094d\u091b\u0928\u094d  \n\u092a\u0939\u093f\u0932\u094b \u0909\u092a\u093e\u092f \u0906\u092b\u094d\u0928\u094b \u0906\u092f \u0930 \u0916\u0930\u094d\u091a\u0915\u094b \u0935\u093f\u0935\u0930\u0923 \u0932\u0947\u0916\u094d\u0928\u0947 \u0939\u094b  \n\u092f\u0938\u0915\u094b \u092e\u093e\u0927\u094d\u092f\u092e\u092c\u093e\u091f \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0932\u0947 \u0906\u092b\u094d\u0928\u094b \u0916\u0930\u094d\u091a \u0935\u093f\u0936\u094d\u0932\u0947\u0937\u0923 \u0917\u0930\u094d\u0928 \u0938\u0915\u094d\u091b\u0928\u094d  \n\u0924\u094d\u092f\u0938\u092a\u091b\u093f \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u0906\u092b\u094d\u0928\u094b \u0935\u094d\u092f\u092f \u0935\u093f\u0924\u0930\u0923 \u092c\u093e\u0930\u0947 \u0928\u093f\u0930\u094d\u0923\u092f \u0917\u0930\u094d\u0928 \u0938\u0915\u094d\u091b\u0928\u094d  \n\u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0932\u0915\u094d\u0937\u094d\u092f \u0928\u093f\u0930\u094d\u0927\u093e\u0930\u0923 \u0917\u0930\u094d\u0928 \u0906\u0935\u0936\u094d\u092f\u0915 \u091b  \n\u0909\u0926\u093e\u0939\u0930\u0923\u0915\u094b \u0930\u0942\u092a\u092e\u093e \u092c\u091a\u0924 \u0917\u0930\u094d\u0928\u0947 \u0932\u0915\u094d\u0937\u094d\u092f \u0935\u093e \u090b\u0923 \u092c\u093e\u0901\u091a\u094d\u0928\u0947 \u0932\u0915\u094d\u0937\u094d\u092f \u0928\u093f\u0930\u094d\u0927\u093e\u0930\u0923 \u0917\u0930\u094d\u0928 \u0938\u0915\u093f\u0928\u094d\u091b  \n\u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u092c\u091a\u0924 \u0917\u0930\u094d\u0928 \u0906\u0935\u0936\u094d\u092f\u0915 \u091b  \n\u092f\u094b \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0905\u0938\u094d\u0925\u093f\u0930\u0924\u093e \u0935\u093f\u0930\u0941\u0926\u094d\u0927 \u092c\u091a\u093e\u0935 \u0917\u0930\u094d\u0928 \u0938\u0939\u093e\u092f\u0924\u093e \u092a\u0941\u0930\u094d\u092f\u093e\u0909\u0901\u091b  \n\u0935\u093f\u0924\u094d\u0924\u0940\u092f \u092c\u091a\u0924 \u0905\u0915\u093e\u0909\u0928\u094d\u091f \u0916\u094b\u0932\u094d\u0928 \u0909\u092a\u092f\u0941\u0915\u094d\u0924 \u091b  \n\u0905\u0915\u093e\u0909\u0928\u094d\u091f \u0935\u093f\u0936\u0947\u0937 \u0917\u0930\u0940 \u0924\u0924\u094d\u0915\u093e\u0932 \u0909\u092a\u0932\u092c"
}
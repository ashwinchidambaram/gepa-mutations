{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u662f\u822a\u7a7a\u5de5\u7a0b\u548c\u6d41\u4f53\u529b\u5b66\u4e2d\u7684\u6838\u5fc3\u7814\u7a76\u9886\u57df\uff0c\u5b83\u51b3\u5b9a\u4e86\u98de\u884c\u5668\u7684\u5347\u529b\u3001\u963b\u529b\u548c\u7a33\u5b9a\u6027\u3002\u968f\u7740\u79d1\u6280\u7684\u53d1\u5c55\uff0c\u4eff\u751f\u5b66\u4f5c\u4e3a\u4e00\u95e8\u8de8\u5b66\u79d1\u7684\u79d1\u5b66\uff0c\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u548c\u65b9\u6cd5\u3002\u901a\u8fc7\u7814\u7a76\u81ea\u7136\u754c\u4e2d\u98de\u884c\u751f\u7269\u7684\u98de\u884c\u673a\u5236\uff0c\u79d1\u5b66\u5bb6\u548c\u5de5\u7a0b\u5e08\u80fd\u591f\u4f18\u5316\u7ffc\u578b\u7ed3\u6784\uff0c\u63d0\u9ad8\u98de\u884c\u6548\u7387\uff0c\u964d\u4f4e\u80fd\u8017\uff0c\u5e76\u589e\u5f3a\u98de\u884c\u5668\u7684\u9002\u5e94\u80fd\u529b\u3002\n\n\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u53ef\u4ee5\u8ffd\u6eaf\u5230\u5bf9\u9e1f\u7c7b\u548c\u6606\u866b\u98de\u884c\u7684\u7814\u7a76\u3002\u9e1f\u7c7b\u7684\u7fc5\u8180\u5177\u6709\u590d\u6742\u7684\u51e0\u4f55\u5f62\u72b6\u548c\u53ef\u53d8\u7684\u7ffc\u578b\u7ed3\u6784\uff0c\u4f7f\u5176\u80fd\u591f\u5728\u4e0d\u540c\u7684\u98de\u884c\u72b6\u6001\u4e0b\u5b9e\u73b0\u9ad8\u6548\u7684\u5347\u529b\u548c\u63a7\u5236\u3002\u4f8b\u5982\uff0c\u4fe1\u5929\u7fc1\u7684\u7fc5\u8180\u5728\u6ed1\u7fd4\u65f6\u5177\u6709\u6781\u9ad8\u7684\u5347\u963b\u6bd4\uff0c\u800c\u8702\u9e1f\u7684\u7fc5\u8180\u5219\u80fd\u591f\u5b9e\u73b0\u9ad8\u901f\u632f\u7fc5\u98de\u884c\u3002\u8fd9\u4e9b\u751f\u7269\u7684\u98de\u884c\u673a\u5236\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u7075\u611f\uff0c\u4fc3\u4f7f\u7814\u7a76\u4eba\u5458\u5f00\u53d1\u51fa\u5177\u6709\u7c7b\u4f3c\u529f\u80fd\u7684\u7ffc\u578b\u7ed3\u6784\u3002\n\n\u5728\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\u4e2d\uff0c\u7814\u7a76\u8005\u901a\u5e38\u4f1a\u5229\u7528\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\uff08CFD\uff09\u548c\u98ce\u6d1e\u5b9e\u9a8c\u7b49\u65b9\u6cd5\uff0c\u6a21\u62df\u548c\u5206\u6790\u751f\u7269\u7ffc\u578b\u7684\u6c14\u52a8\u6027\u80fd\u3002\u4f8b\u5982\uff0c\u7814\u7a76\u8005\u901a\u8fc7\u5206\u6790\u873b\u8713\u7fc5\u8180\u7684\u8109\u52a8\u7ed3\u6784\uff0c\u8bbe\u8ba1\u51fa\u5177\u6709\u66f4\u9ad8\u5347\u529b\u548c\u66f4\u4f4e\u963b\u529b\u7684\u7ffc\u578b\u3002\u6b64\u5916\uff0c\u7814\u7a76\u8005\u8fd8\u501f\u9274\u9e1f\u7c7b\u7684\u7fbd\u6bdb\u7ed3\u6784\uff0c\u5f00\u53d1\u51fa\u5177\u6709\u53ef\u53d8\u5f62\u8868\u9762\u7684\u7ffc\u578b\uff0c\u4ee5\u63d0\u9ad8\u98de\u884c\u5668\u5728\u4e0d\u540c\u98de\u884c\u6761\u4ef6\u4e0b\u7684\u9002\u5e94\u6027\u3002\n\n\u9664\u4e86\u9e1f\u7c7b\uff0c\u6606\u866b\u7684\u98de\u884c\u673a\u5236\u4e5f\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u4e30\u5bcc\u7684\u53c2\u8003\u3002\u6606\u866b\u7684\u7fc5\u8180\u901a\u5e38\u5177\u6709\u590d\u6742\u7684\u51e0\u4f55\u5f62\u72b6\u548c\u9ad8\u9891\u632f\u52a8\uff0c\u8fd9\u4f7f\u5f97\u5b83\u4eec\u80fd\u591f\u5728\u6709\u9650\u7684\u4f53\u79ef\u5185\u5b9e\u73b0\u9ad8\u6548\u7684\u98de\u884c\u3002\u4f8b\u5982\uff0c\u679c\u8747\u7684\u7fc5\u8180\u5177\u6709\u7279\u6b8a\u7684\u8936\u76b1\u7ed3\u6784\uff0c\u53ef\u4ee5\u589e\u5f3a\u5347\u529b\u5e76\u51cf\u5c11\u963b\u529b\u3002\u8fd9\u4e9b\u7279\u5f81\u88ab\u5e94\u7528\u4e8e\u5fae\u578b\u98de\u884c\u5668\u548c\u65e0\u4eba\u673a\u7684\u8bbe\u8ba1\u4e2d\uff0c\u4ee5\u63d0\u9ad8\u5176\u673a\u52a8\u6027\u548c\u98de\u884c\u6548\u7387\u3002\n\n\u6b64\u5916\uff0c\u4eff\u751f\u5b66\u8fd8\u63a8\u52a8\u4e86\u65b0\u578b\u6750\u6599\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u3002\u4f8b\u5982\uff0c\u7814\u7a76\u4eba\u5458\u5f00\u53d1\u51fa\u5177\u6709\u7c7b\u4f3c\u9e1f\u7c7b\u7fbd\u6bdb\u7279\u6027\u7684\u667a\u80fd\u6750\u6599\uff0c\u8fd9\u4e9b\u6750\u6599\u53ef\u4ee5\u6839\u636e\u98de\u884c\u6761\u4ef6\u81ea\u52a8\u8c03\u6574\u5f62\u72b6\uff0c\u4ece\u800c\u4f18\u5316\u6c14\u52a8\u6027\u80fd\u3002\u8fd9\u79cd\u81ea\u9002\u5e94\u7ffc\u578b\u4e0d\u4ec5\u63d0\u9ad8\u4e86\u98de\u884c\u6548\u7387\uff0c\u8fd8\u589e\u5f3a\u4e86\u98de\u884c\u5668\u7684\u7a33\u5b9a\u6027\u548c\u5b89\u5168\u6027\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e3a\u98de\u884c\u5668\u7684\u53d1\u5c55\u5e26\u6765\u4e86\u65b0\u7684\u673a\u9047\u3002\u901a\u8fc7\u6df1\u5165\u7814\u7a76\u81ea\u7136\u754c\u4e2d\u98de\u884c\u751f\u7269\u7684\u98de\u884c\u673a\u5236\uff0c\u79d1\u5b66\u5bb6\u548c\u5de5\u7a0b\u5e08\u80fd\u591f\u8bbe\u8ba1\u51fa\u66f4\u52a0\u9ad8\u6548\u3001\u667a\u80fd\u548c\u9002\u5e94\u6027\u5f3a\u7684\u7ffc\u578b\u7ed3\u6784\u3002\u8fd9\u79cd\u8de8\u5b66\u79d1\u7684\u7814\u7a76\u65b9\u6cd5\u4e0d\u4ec5\u63a8\u52a8\u4e86\u822a\u7a7a\u6280\u672f\u7684\u8fdb\u6b65\uff0c\u4e5f\u4e3a\u5176\u4ed6\u9886\u57df\u7684\u5de5\u7a0b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u5b9d\u8d35\u7684\u501f\u9274\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u662f\u822a\u7a7a\u5de5\u7a0b\u548c\u6d41\u4f53\u529b\u5b66\u4e2d\u7684\u6838\u5fc3\u7814\u7a76"
}
{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u5728\u73b0\u4ee3\u822a\u7a7a\u822a\u5929\u5de5\u7a0b\u4e2d\u626e\u6f14\u7740\u81f3\u5173\u91cd\u8981\u7684\u89d2\u8272\u3002\u7ffc\u578b\uff0c\u5373\u98de\u673a\u673a\u7ffc\u7684\u6a2a\u622a\u9762\u5f62\u72b6\uff0c\u662f\u51b3\u5b9a\u98de\u884c\u5668\u7a7a\u6c14\u52a8\u529b\u6027\u80fd\u7684\u5173\u952e\u56e0\u7d20\u3002\u826f\u597d\u7684\u7ffc\u578b\u8bbe\u8ba1\u53ef\u4ee5\u6709\u6548\u63d0\u9ad8\u5347\u529b\u3001\u964d\u4f4e\u963b\u529b\uff0c\u4ece\u800c\u63d0\u5347\u98de\u884c\u6548\u7387\u548c\u71c3\u6cb9\u7ecf\u6d4e\u6027\u3002\u800c\u4eff\u751f\u5b66\uff0c\u4f5c\u4e3a\u4e00\u95e8\u4ece\u81ea\u7136\u754c\u4e2d\u6c72\u53d6\u7075\u611f\u4ee5\u89e3\u51b3\u5de5\u7a0b\u95ee\u9898\u7684\u5b66\u79d1\uff0c\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u4e0e\u65b9\u6cd5\u3002\n\n\u81ea\u7136\u754c\u4e2d\uff0c\u9e1f\u7c7b\u548c\u6606\u866b\u7684\u98de\u884c\u65b9\u5f0f\u4e3a\u4eba\u7c7b\u63d0\u4f9b\u4e86\u4e30\u5bcc\u7684\u7814\u7a76\u7d20\u6750\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7684\u7fc5\u8180\u5728\u98de\u884c\u8fc7\u7a0b\u4e2d\u80fd\u591f\u901a\u8fc7\u6539\u53d8\u5f62\u72b6\u548c\u89d2\u5ea6\u6765\u8c03\u6574\u5347\u529b\u548c\u963b\u529b\uff0c\u8fd9\u79cd\u7075\u6d3b\u6027\u662f\u4f20\u7edf\u56fa\u5b9a\u7ffc\u578b\u96be\u4ee5\u5b9e\u73b0\u7684\u3002\u79d1\u5b66\u5bb6\u901a\u8fc7\u5bf9\u9e1f\u7c7b\u98de\u884c\u7684\u89c2\u5bdf\u4e0e\u7814\u7a76\uff0c\u63d0\u51fa\u4e86\u201c\u53d8\u5f2f\u5ea6\u7ffc\u578b\u201d\u7684\u6982\u5ff5\uff0c\u8fd9\u79cd\u8bbe\u8ba1\u5141\u8bb8\u673a\u7ffc\u5728\u4e0d\u540c\u98de\u884c\u72b6\u6001\u4e0b\u8fdb\u884c\u5f62\u6001\u8c03\u6574\uff0c\u4ece\u800c\u4f18\u5316\u98de\u884c\u6027\u80fd\u3002\n\n\u6b64\u5916\uff0c\u6606\u866b\u7684\u7fc5\u8180\u7ed3\u6784\u4e5f\u542f\u53d1\u4e86\u7ffc\u578b\u8bbe\u8ba1\u7684\u521b\u65b0\u3002\u6606\u866b\u7fc5\u8180\u7684\u8f7b\u8d28\u3001\u9ad8\u5f3a\u5ea6\u548c\u9ad8\u67d4\u6027\uff0c\u4f7f\u5176\u80fd\u591f\u5728\u9ad8\u901f\u632f\u7fc5\u4e2d\u4fdd\u6301\u7a33\u5b9a\u98de\u884c\u3002\u53d7\u6b64\u542f\u53d1\uff0c\u7814\u7a76\u4eba\u5458\u5f00\u53d1\u51fa\u4e86\u4eff\u751f\u7ffc\u578b\uff0c\u8fd9\u79cd\u7ffc\u578b\u91c7\u7528\u4e86\u7c7b\u4f3c\u6606\u866b\u7fc5\u8180\u7684\u7ed3\u6784\uff0c\u4e0d\u4ec5\u63d0\u9ad8\u4e86\u6750\u6599\u7684\u5f3a\u5ea6\u4e0e\u97e7\u6027\uff0c\u8fd8\u589e\u5f3a\u4e86\u98de\u884c\u5668\u5728\u590d\u6742\u73af\u5883\u4e0b\u7684\u9002\u5e94\u80fd\u529b\u3002\n\n\u5728\u5b9e\u9645\u5e94\u7528\u4e2d\uff0c\u4eff\u751f\u5b66\u4e0e\u7ffc\u578b\u8bbe\u8ba1\u7684\u7ed3\u5408\u5df2\u53d6\u5f97\u663e\u8457\u6210\u679c\u3002\u4f8b\u5982\uff0c\u67d0\u4e9b\u65e0\u4eba\u673a\u91c7\u7528\u4eff\u751f\u7ffc\u578b\uff0c\u4ee5\u63d0\u9ad8\u5176\u5728\u4f4e\u901f\u98de\u884c\u548c\u60ac\u505c\u72b6\u6001\u4e0b\u7684\u7a33\u5b9a\u6027\uff1b\u9ad8\u901f\u98de\u884c\u5668\u5219\u901a\u8fc7\u4eff\u751f\u7ffc\u578b\u4f18\u5316\u7a7a\u6c14\u52a8\u529b\u6027\u80fd\uff0c\u4ee5\u964d\u4f4e\u80fd\u8017\u5e76\u63d0\u5347\u901f\u5ea6\u3002\u8fd9\u4e9b\u8fdb\u5c55\u4e0d\u4ec5\u63a8\u52a8\u4e86\u822a\u7a7a\u822a\u5929\u6280\u672f\u7684\u53d1\u5c55\uff0c\u4e5f\u4e3a\u5176\u4ed6\u9886\u57df\u7684\u5de5\u7a0b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u65b9\u5411\u3002\n\n\u672a\u6765\uff0c\u968f\u7740\u6750\u6599\u79d1\u5b66\u548c\u8ba1\u7b97\u6280\u672f\u7684\u8fdb\u6b65\uff0c\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u5c06\u66f4\u52a0\u7d27\u5bc6\u3002\u901a\u8fc7\u6df1\u5165\u7814\u7a76\u81ea\u7136\u754c\u751f\u7269\u7684\u98de\u884c\u673a\u5236\uff0c\u4eba\u7c7b\u6709\u671b\u8bbe\u8ba1\u51fa\u66f4\u52a0\u9ad8\u6548\u3001\u667a\u80fd\u548c\u73af\u4fdd\u7684\u98de\u884c\u5668\u3002\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u878d\u5408\uff0c\u4e0d\u4ec5\u662f\u4e00\u79cd\u6280\u672f\u521b\u65b0\uff0c\u66f4\u662f\u5bf9\u81ea\u7136\u667a\u6167\u7684\u81f4\u656c\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u3002"
}
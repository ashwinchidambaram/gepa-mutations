{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u662f\u822a\u7a7a\u5de5\u7a0b\u4e0e\u751f\u7269\u79d1\u5b66\u4ea4\u6c47\u7684\u91cd\u8981\u9886\u57df\u3002\u7ffc\u578b\uff0c\u5373\u98de\u884c\u5668\u673a\u7ffc\u7684\u6a2a\u622a\u9762\u5f62\u72b6\uff0c\u5bf9\u98de\u884c\u5668\u7684\u5347\u529b\u3001\u963b\u529b\u548c\u7a33\u5b9a\u6027\u8d77\u7740\u51b3\u5b9a\u6027\u4f5c\u7528\u3002\u4f20\u7edf\u7ffc\u578b\u8bbe\u8ba1\u4f9d\u8d56\u4e8e\u7a7a\u6c14\u52a8\u529b\u5b66\u7406\u8bba\u548c\u5b9e\u9a8c\u6570\u636e\uff0c\u800c\u4eff\u751f\u5b66\u5219\u63d0\u4f9b\u4e86\u4e00\u79cd\u5168\u65b0\u7684\u601d\u8def\u2014\u2014\u4ece\u81ea\u7136\u754c\u4e2d\u5bfb\u627e\u7075\u611f\uff0c\u4ee5\u4f18\u5316\u7ffc\u578b\u6027\u80fd\u3002\n\n\u81ea\u7136\u754c\u4e2d\u7684\u98de\u884c\u751f\u7269\uff0c\u5982\u9e1f\u7c7b\u3001\u6606\u866b\u548c\u98de\u884c\u52a8\u7269\uff0c\u7ecf\u8fc7\u6570\u767e\u4e07\u5e74\u7684\u8fdb\u5316\uff0c\u5df2\u7ecf\u53d1\u5c55\u51fa\u9ad8\u5ea6\u4f18\u5316\u7684\u98de\u884c\u7ed3\u6784\u3002\u8fd9\u4e9b\u751f\u7269\u7684\u7fc5\u8180\u4e0d\u4ec5\u80fd\u591f\u4ea7\u751f\u8db3\u591f\u7684\u5347\u529b\uff0c\u8fd8\u80fd\u5728\u590d\u6742\u73af\u5883\u4e2d\u7075\u6d3b\u673a\u52a8\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7684\u7fc5\u8180\u5177\u6709\u53ef\u53d8\u7684\u7ffc\u578b\u548c\u7fbd\u6bdb\u7ed3\u6784\uff0c\u4f7f\u5176\u80fd\u591f\u5728\u4e0d\u540c\u7684\u98de\u884c\u72b6\u6001\u4e0b\u8c03\u6574\u5347\u529b\u548c\u963b\u529b\uff1b\u6606\u866b\u7684\u7fc5\u8180\u5219\u5177\u6709\u9ad8\u9891\u7387\u7684\u632f\u52a8\u548c\u590d\u6742\u7684\u7ffc\u9762\u53d8\u5f62\uff0c\u4f7f\u5176\u80fd\u591f\u5728\u6709\u9650\u7684\u4f53\u5f62\u4e0b\u5b9e\u73b0\u9ad8\u6548\u7684\u98de\u884c\u3002\n\n\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u5bf9\u8fd9\u4e9b\u751f\u7269\u98de\u884c\u673a\u5236\u7684\u6a21\u4eff\u4e0e\u6539\u8fdb\u3002\u4f8b\u5982\uff0c\u7814\u7a76\u8005\u901a\u8fc7\u5206\u6790\u9e1f\u7c7b\u98de\u884c\u65f6\u7684\u7ffc\u578b\u53d8\u5316\uff0c\u5f00\u53d1\u51fa\u53ef\u53d8\u5f62\u673a\u7ffc\uff0c\u4ee5\u9002\u5e94\u4e0d\u540c\u7684\u98de\u884c\u6761\u4ef6\u3002\u6b64\u5916\uff0c\u6606\u866b\u7fc5\u8180\u7684\u7ed3\u6784\u542f\u53d1\u4e86\u5fae\u5c0f\u98de\u884c\u5668\u7684\u8bbe\u8ba1\uff0c\u4f7f\u5f97\u5fae\u578b\u65e0\u4eba\u673a\u80fd\u591f\u5728\u72ed\u5c0f\u7a7a\u95f4\u4e2d\u81ea\u7531\u98de\u884c\u3002\n\n\u5728\u5b9e\u9645\u5e94\u7528\u4e2d\uff0c\u4eff\u751f\u7ffc\u578b\u5df2\u7ecf\u88ab\u7528\u4e8e\u591a\u79cd\u98de\u884c\u5668\u8bbe\u8ba1\u4e2d\u3002\u4f8b\u5982\uff0c\u67d0\u4e9b\u9ad8\u901f\u98de\u884c\u5668\u91c7\u7528\u4eff\u751f\u7ffc\u578b\u4ee5\u51cf\u5c11\u963b\u529b\uff0c\u63d0\u9ad8\u71c3\u6cb9\u6548\u7387\uff1b\u800c\u65e0\u4eba\u673a\u5219\u5229\u7528\u4eff\u751f\u7ed3\u6784\u5b9e\u73b0\u66f4\u7075\u6d3b\u7684\u98de\u884c\u63a7\u5236\u3002\u6b64\u5916\uff0c\u4eff\u751f\u5b66\u8fd8\u4e3a\u65b0\u578b\u6750\u6599\u548c\u5236\u9020\u5de5\u827a\u63d0\u4f9b\u4e86\u7075\u611f\uff0c\u5982\u4eff\u751f\u590d\u5408\u6750\u6599\u548c\u53ef\u53d8\u5f62\u7ed3\u6784\uff0c\u8fd9\u4e9b\u90fd\u6781\u5927\u5730\u63d0\u5347\u4e86\u7ffc\u578b\u8bbe\u8ba1\u7684\u6027\u80fd\u548c\u9002\u5e94\u6027\u3002\n\n\u7136\u800c\uff0c\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\u4ecd\u9762\u4e34\u8bf8\u591a\u6311\u6218\u3002\u9996\u5148\uff0c\u81ea\u7136\u754c\u4e2d\u7684\u98de\u884c\u673a\u5236\u6781\u5176\u590d\u6742\uff0c\u96be\u4ee5\u5b8c\u5168\u590d\u5236\uff1b\u5176\u6b21\uff0c\u4eff\u751f\u8bbe\u8ba1\u5f80\u5f80\u9700\u8981\u5728\u6027\u80fd\u3001\u6210\u672c\u548c\u53ef\u9760\u6027\u4e4b\u95f4\u53d6\u5f97\u5e73\u8861\u3002\u56e0\u6b64\uff0c\u672a\u6765\u7684\u7814\u7a76\u9700\u8981\u7ed3\u5408\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\u3001\u5148\u8fdb\u6750\u6599\u79d1\u5b66\u548c\u4eba\u5de5\u667a\u80fd\u7b49\u591a\u5b66\u79d1\u6280\u672f\uff0c\u4ee5\u8fdb\u4e00\u6b65\u63a8\u52a8\u4eff\u751f\u7ffc\u578b\u7684\u53d1\u5c55\u3002\n\n\u603b\u4e4b\uff0c\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e3a\u98de\u884c\u5668\u6280\u672f\u5e26\u6765\u4e86\u9769\u547d\u6027\u7684\u8fdb\u6b65\u3002\u901a\u8fc7\u501f\u9274\u81ea\u7136\u754c\u7684\u667a\u6167\uff0c\u4eba\u7c7b\u4e0d\u4ec5\u80fd\u591f\u63d0\u5347\u98de\u884c\u5668\u7684\u6027\u80fd\uff0c\u8fd8\u80fd\u62d3\u5c55\u98de\u884c\u5668\u7684\u5e94\u7528\u8303\u56f4\u3002\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u878d\u5408\uff0c\u662f\u4eba\u7c7b\u5411\u81ea\u7136\u5b66\u4e60\u3001\u5b9e\u73b0\u6280\u672f\u7a81\u7834\u7684\u5178\u8303\u3002\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u3002"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u5b9a\u7684\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6cd5\u5f8b\u9002\u7528\u4e0d\u7edf\u4e00\u548c\u88c1\u91cf\u6807\u51c6\u6a21\u7cca\u65b9\u9762\u3002\u4e0d\u540c\u5730\u533a\u7684\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u7c7b\u4f3c\u6848\u4ef6\u65f6\uff0c\u53ef\u80fd\u4f1a\u4f9d\u636e\u4e0d\u540c\u7684\u6cd5\u5f8b\u6761\u6587\u6216\u653f\u7b56\u5bfc\u5411\u4f5c\u51fa\u622a\u7136\u4e0d\u540c\u7684\u51b3\u5b9a\uff0c\u5bfc\u81f4\u53f8\u6cd5\u516c\u6b63\u6027\u53d7\u5230\u8d28\u7591\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u8ba4\u5b9a\u884c\u653f\u673a\u5173\u672a\u5c65\u884c\u6cd5\u5b9a\u804c\u8d23\uff0c\u8d23\u4ee4\u5176\u91cd\u65b0\u4f5c\u51fa\u884c\u653f\u884c\u4e3a\uff0c\u800c\u5728\u53e6\u4e00\u5730\u533a\u7c7b\u4f3c\u6848\u4ef6\u4e2d\uff0c\u5374\u4ee5\u201c\u5df2\u5c65\u884c\u804c\u8d23\u201d\u4e3a\u7531\u9a73\u56de\u590d\u8bae\u7533\u8bf7\u3002\u8fd9\u79cd\u5dee\u5f02\u53cd\u6620\u51fa\u5728\u9002\u7528\u300a\u884c\u653f\u590d\u8bae\u6cd5\u300b\u65f6\u7f3a\u4e4f\u7edf\u4e00\u7684\u89e3\u91ca\u548c\u64cd\u4f5c\u6807\u51c6\u3002\n\n\u6b64\u5916\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u673a\u5236\u4e5f\u5b58\u5728\u7f3a\u9677\uff0c\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u548c\u53cd\u9988\u673a\u5236\u3002\u5373\u4f7f\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u4e86\u8d23\u4ee4\u5c65\u884c\u7684\u51b3\u5b9a\uff0c\u884c\u653f\u673a\u5173\u53ef\u80fd\u4ecd\u5b58\u5728\u62d6\u5ef6\u6216\u4e0d\u6267\u884c\u7684\u60c5\u51b5\uff0c\u800c\u590d\u8bae\u673a\u5173\u5728\u540e\u7eed\u8ddf\u8fdb\u65b9\u9762\u7f3a\u4e4f\u660e\u786e\u7684\u7a0b\u5e8f\u548c\u624b\u6bb5\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u571f\u5730\u5f81\u6536\u7ea0\u7eb7\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u76f8\u5173\u884c\u653f\u673a\u5173\u5e76\u672a\u5728\u89c4\u5b9a\u671f\u9650\u5185\u91c7\u53d6\u884c\u52a8\uff0c\u5bfc\u81f4\u7533\u8bf7\u4eba\u6743\u76ca\u53d7\u635f\uff0c\u800c\u590d\u8bae\u673a\u5173\u672a\u80fd\u53ca\u65f6\u91c7\u53d6\u8fdb\u4e00\u6b65\u63aa\u65bd\uff0c\u53cd\u6620\u51fa\u6267\u884c\u73af\u8282\u7684\u8584\u5f31\u3002\n\n\u540c\u65f6\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u548c\u6761\u4ef6\u4e5f\u5b58\u5728\u4e00\u5b9a\u7684\u6a21\u7cca\u6027\u3002\u5728\u5b9e\u8df5\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u6709\u65f6\u5c06\u8d23\u4ee4\u5c65\u884c\u4f5c\u4e3a\u4e07\u80fd\u624b\u6bb5\uff0c\u800c\u5ffd\u89c6\u4e86\u5bf9\u884c\u653f\u673a\u5173\u884c\u4e3a\u662f\u5426\u5177\u6709\u53ef\u5c65\u884c\u6027\u7684\u5ba1\u67e5\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u653f\u5e9c\u4fe1\u606f\u516c\u5f00\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u76f4\u63a5\u8d23\u4ee4\u884c\u653f\u673a\u5173\u516c\u5f00\u4fe1\u606f\uff0c\u800c\u672a\u8003\u8651\u8be5\u4fe1\u606f\u662f\u5426\u6d89\u53ca\u56fd\u5bb6\u79d8\u5bc6\u6216\u4e2a\u4eba\u9690\u79c1\uff0c\u5bfc\u81f4\u540e\u7eed\u6267\u884c\u4e2d\u51fa\u73b0\u6cd5\u5f8b\u51b2\u7a81\u548c\u4e89\u8bae\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u548c\u516c\u4fe1\u529b\u3002\n\ndocument  \n\u4e3a\u89e3\u51b3\u4e0a\u8ff0\u95ee\u9898\uff0c\u6709\u5fc5\u8981\u8fdb\u4e00\u6b65\u5b8c\u5584\u884c\u653f\u590d\u8bae\u5236\u5ea6\uff0c\u660e\u786e\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u6761\u4ef6\u548c\u7a0b\u5e8f\uff0c\u540c\u65f6\u52a0\u5f3a\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u76d1\u7763\u3002\u901a\u8fc7\u5236\u5b9a\u7edf\u4e00\u7684\u6cd5\u5f8b\u89e3\u91ca\u548c\u6307\u5bfc\u6848\u4f8b\uff0c\u63d0\u9ad8\u590d\u8bae\u673a\u5173\u7684\u88c1\u91cf\u4e00\u81f4\u6027\uff1b\u5efa\u7acb\u6709\u6548\u7684\u6267\u884c\u53cd\u9988\u673a\u5236\uff0c\u786e\u4fdd\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u80fd\u591f\u771f\u6b63\u843d\u5b9e\u5230\u4f4d\uff1b\u5e76\u5f3a\u5316\u5bf9\u884c\u653f\u673a\u5173\u884c\u4e3a\u53ef\u5c65\u884c\u6027\u7684\u5ba1\u67e5\uff0c\u907f\u514d\u4e0d\u5f53\u6269\u5927\u8d23\u4ee4\u5c65\u884c\u7684\u9002\u7528\u8303\u56f4\u3002\u8fd9\u4e9b\u63aa\u65bd\u5c06\u6709\u52a9\u4e8e\u63d0\u5347\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u5b9e\u6548\u6027\uff0c\u66f4\u597d\u5730\u4fdd\u969c\u516c\u6c11\u7684\u5408\u6cd5\u6743\u76ca\u3002"
}
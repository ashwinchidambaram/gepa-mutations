{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u5b9a\u7684\u95ee\u9898\u3002\u9996\u5148\uff0c\u90e8\u5206\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u7f3a\u4e4f\u5bf9\u5177\u4f53\u884c\u653f\u884c\u4e3a\u8fdd\u6cd5\u6027\u7684\u5145\u5206\u5ba1\u67e5\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u5c40\u5bf9\u67d0\u4f01\u4e1a\u8fdd\u89c4\u6392\u653e\u6c61\u67d3\u7269\u7684\u5904\u7f5a\u51b3\u5b9a\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u672a\u6df1\u5165\u8c03\u67e5\u8be5\u5904\u7f5a\u662f\u5426\u7b26\u5408\u6cd5\u5b9a\u7a0b\u5e8f\uff0c\u76f4\u63a5\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u5bfc\u81f4\u4f01\u4e1a\u672a\u80fd\u53ca\u65f6\u7ea0\u6b63\u8fdd\u6cd5\u884c\u4e3a\u3002\u8fd9\u79cd\u505a\u6cd5\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u7684\u76d1\u7763\u4f5c\u7528\u3002\n\n\u5176\u6b21\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u3002\u7531\u4e8e\u884c\u653f\u590d\u8bae\u673a\u5173\u672c\u8eab\u4e0d\u5177\u5907\u5f3a\u5236\u6267\u884c\u6743\uff0c\u8bb8\u591a\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u4f5c\u51fa\u540e\u96be\u4ee5\u843d\u5b9e\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u5e02\u573a\u76d1\u7ba1\u90e8\u95e8\u5bf9\u67d0\u5546\u5bb6\u7684\u8fdd\u6cd5\u7ecf\u8425\u884c\u4e3a\u4f5c\u51fa\u8d23\u4ee4\u6574\u6539\u51b3\u5b9a\uff0c\u4f46\u5546\u5bb6\u62d2\u4e0d\u6267\u884c\uff0c\u590d\u8bae\u673a\u5173\u65e0\u6cd5\u5f3a\u5236\u5176\u5c65\u884c\u4e49\u52a1\uff0c\u6700\u7ec8\u5bfc\u81f4\u884c\u653f\u590d\u8bae\u7684\u5b9e\u6548\u6027\u5927\u6253\u6298\u6263\u3002\n\n\u518d\u8005\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u5bf9\u76f8\u5173\u6cd5\u5f8b\u4f9d\u636e\u7684\u9002\u7528\u5b58\u5728\u4e0d\u4e00\u81f4\u7684\u60c5\u51b5\u3002\u4e0d\u540c\u5730\u533a\u548c\u90e8\u95e8\u5bf9\u540c\u4e00\u7c7b\u8fdd\u6cd5\u884c\u4e3a\u7684\u5904\u7406\u6807\u51c6\u4e0d\u4e00\uff0c\u5bfc\u81f4\u590d\u8bae\u51b3\u5b9a\u7684\u516c\u6b63\u6027\u548c\u7edf\u4e00\u6027\u53d7\u5230\u8d28\u7591\u3002\u4f8b\u5982\uff0c\u5728\u5904\u7406\u67d0\u5730\u8fdd\u89c4\u5efa\u8bbe\u884c\u4e3a\u65f6\uff0c\u4e0d\u540c\u590d\u8bae\u673a\u5173\u5bf9\u201c\u8fdd\u6cd5\u5efa\u8bbe\u201d\u7684\u8ba4\u5b9a\u6807\u51c6\u5b58\u5728\u5dee\u5f02\uff0c\u5f71\u54cd\u4e86\u590d\u8bae\u51b3\u5b9a\u7684\u53ef\u9884\u671f\u6027\u548c\u6cd5\u5f8b\u6548\u529b\u3002\n\n\u6700\u540e\uff0c\u884c\u653f\u590d\u8bae\u8fc7\u7a0b\u4e2d\u5bf9\u5f53\u4e8b\u4eba\u7684\u6743\u5229\u4fdd\u969c\u4e0d\u591f\u5145\u5206\u3002\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u672a\u5145\u5206\u542c\u53d6\u5f53\u4e8b\u4eba\u7684\u9648\u8ff0\u548c\u7533\u8fa9\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u6743\u76ca\u53d7\u635f\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u7a0e\u52a1\u90e8\u95e8\u5bf9\u67d0\u4f01\u4e1a\u4f5c\u51fa\u7684\u7a0e\u52a1\u5904\u7f5a\u51b3\u5b9a\uff0c\u590d\u8bae\u673a\u5173\u5728\u672a\u5145\u5206\u8c03\u67e5\u4f01\u4e1a\u5b9e\u9645\u7ecf\u8425\u60c5\u51b5\u7684\u524d\u63d0\u4e0b\uff0c\u76f4\u63a5\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u672a\u80fd\u6709\u6548\u4fdd\u969c\u4f01\u4e1a\u7684\u5408\u6cd5\u6743\u76ca\u3002\n\ndocument \u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5b8c\u5584\u9700\u8981\u4ece\u591a\u4e2a\u65b9\u9762\u5165\u624b\u3002\u9996\u5148\uff0c\u5e94\u52a0\u5f3a\u590d\u8bae\u673a\u5173\u5bf9\u5177\u4f53\u884c\u653f\u884c\u4e3a\u7684\u5ba1\u67e5\u529b\u5ea6\uff0c\u786e\u4fdd\u51b3\u5b9a\u7684\u5408\u6cd5\u6027\u4e0e\u5408\u7406\u6027\u3002\u5176\u6b21\uff0c\u5e94\u5efa\u7acb\u6709\u6548\u7684\u6267\u884c\u673a\u5236\uff0c\u63d0\u9ad8\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u529b\u3002\u540c\u65f6\uff0c\u5e94\u7edf\u4e00\u6cd5\u5f8b\u9002\u7528\u6807\u51c6\uff0c\u589e\u5f3a\u590d\u8bae\u51b3\u5b9a\u7684\u516c\u6b63\u6027\u548c\u6743\u5a01\u6027\u3002\u6700\u540e\uff0c\u5e94\u5f3a\u5316\u5bf9\u5f53\u4e8b\u4eba\u6743\u5229\u7684\u4fdd\u969c\uff0c\u786e\u4fdd\u5176\u5728\u590d\u8bae\u8fc7\u7a0b\u4e2d\u80fd\u591f\u5145\u5206\u8868\u8fbe\u610f\u89c1\uff0c\u7ef4\u62a4\u81ea\u8eab\u5408\u6cd5\u6743\u76ca\u3002\u8fd9\u4e9b\u63aa\u65bd\u5c06\u6709\u52a9\u4e8e\u63d0\u5347\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u6574\u4f53\u6548\u80fd\u548c\u516c\u4fe1\u529b\u3002"
}
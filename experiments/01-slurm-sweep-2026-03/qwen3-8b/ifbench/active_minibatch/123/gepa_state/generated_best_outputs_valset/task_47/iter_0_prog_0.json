{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u662f\u822a\u7a7a\u822a\u5929\u5de5\u7a0b\u4e0e\u751f\u7269\u529b\u5b66\u4ea4\u53c9\u9886\u57df\u7684\u91cd\u8981\u7814\u7a76\u65b9\u5411\u3002\u7ffc\u578b\u8bbe\u8ba1\u662f\u6307\u98de\u673a\u673a\u7ffc\u6216\u5176\u4ed6\u98de\u884c\u5668\u8868\u9762\u5f62\u72b6\u7684\u4f18\u5316\uff0c\u4ee5\u5b9e\u73b0\u6700\u4f73\u7684\u5347\u529b\u3001\u963b\u529b\u548c\u7a33\u5b9a\u6027\u3002\u4eff\u751f\u5b66\u5219\u662f\u901a\u8fc7\u6a21\u4eff\u81ea\u7136\u754c\u751f\u7269\u7684\u7ed3\u6784\u548c\u529f\u80fd\u6765\u89e3\u51b3\u5de5\u7a0b\u95ee\u9898\u3002\u4e24\u8005\u7684\u7ed3\u5408\u4e3a\u73b0\u4ee3\u98de\u884c\u5668\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u5168\u65b0\u7684\u601d\u8def\u548c\u65b9\u6cd5\u3002  \n\u7ffc\u578b\u7684\u8bbe\u8ba1\u901a\u5e38\u57fa\u4e8e\u6d41\u4f53\u529b\u5b66\u539f\u7406\uff0c\u901a\u8fc7\u8c03\u6574\u7ffc\u578b\u7684\u66f2\u7387\u3001\u539a\u5ea6\u548c\u524d\u7f18\u5f62\u72b6\u6765\u4f18\u5316\u6c14\u6d41\u7684\u6d41\u52a8\u7279\u6027\u3002\u4f20\u7edf\u7684\u7ffc\u578b\u8bbe\u8ba1\u4e3b\u8981\u4f9d\u8d56\u4e8e\u98ce\u6d1e\u5b9e\u9a8c\u548c\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\uff08CFD\uff09\u6a21\u62df\uff0c\u4f46\u8fd1\u5e74\u6765\uff0c\u968f\u7740\u4eff\u751f\u5b66\u7684\u53d1\u5c55\uff0c\u7814\u7a76\u8005\u5f00\u59cb\u4ece\u81ea\u7136\u754c\u4e2d\u5bfb\u627e\u7075\u611f\uff0c\u4f8b\u5982\u9e1f\u7c7b\u7fc5\u8180\u7684\u7ed3\u6784\u3001\u6606\u866b\u98de\u884c\u7684\u673a\u5236\u4ee5\u53ca\u9c7c\u7c7b\u7684\u6d41\u7ebf\u578b\u8eab\u4f53\u3002\u8fd9\u4e9b\u81ea\u7136\u754c\u7684\u89e3\u51b3\u65b9\u6848\u5f80\u5f80\u5177\u6709\u9ad8\u6548\u7684\u80fd\u91cf\u5229\u7528\u548c\u9002\u5e94\u590d\u6742\u73af\u5883\u7684\u80fd\u529b\uff0c\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u65b9\u5411\u3002  \n\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u4e3b\u8981\u4f53\u73b0\u5728\u4e09\u4e2a\u65b9\u9762\uff1a\u4e00\u662f\u6a21\u4eff\u751f\u7269\u7fc5\u8180\u7684\u7ed3\u6784\uff0c\u4f8b\u5982\u91c7\u7528\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\uff0c\u901a\u8fc7\u6a21\u4eff\u9e1f\u7c7b\u7fc5\u8180\u7684\u67d4\u6027\u7ed3\u6784\uff0c\u63d0\u9ad8\u98de\u884c\u5668\u7684\u673a\u52a8\u6027\u548c\u7a33\u5b9a\u6027\uff1b\u4e8c\u662f\u5229\u7528\u751f\u7269\u7684\u6d41\u4f53\u52a8\u529b\u5b66\u7279\u6027\uff0c\u4f8b\u5982\u901a\u8fc7\u6a21\u4eff\u98de\u86fe\u7fc5\u8180\u7684\u8868\u9762\u7eb9\u7406\u6765\u51cf\u5c11\u6e4d\u6d41\u548c\u963b\u529b\uff1b\u4e09\u662f\u501f\u9274\u751f\u7269\u7684\u9002\u5e94\u6027\u673a\u5236\uff0c\u4f8b\u5982\u901a\u8fc7\u6a21\u4eff\u6c34\u6bcd\u7684\u8fd0\u52a8\u65b9\u5f0f\uff0c\u8bbe\u8ba1\u51fa\u66f4\u9ad8\u6548\u7684\u63a8\u8fdb\u7cfb\u7edf\u3002\u8fd9\u4e9b\u4eff\u751f\u6280\u672f\u4e0d\u4ec5\u63d0\u9ad8\u4e86\u98de\u884c\u5668\u7684\u6027\u80fd\uff0c\u8fd8\u964d\u4f4e\u4e86\u80fd\u8017\uff0c\u4e3a\u53ef\u6301\u7eed\u822a\u7a7a\u53d1\u5c55\u63d0\u4f9b\u4e86\u65b0\u7684\u53ef\u80fd\u6027\u3002  \n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u6b63\u5728\u63a8\u52a8\u98de\u884c\u5668\u8bbe\u8ba1\u5411\u66f4\u9ad8\u6548\u3001\u66f4\u667a\u80fd\u7684\u65b9\u5411\u53d1\u5c55\u3002\u968f\u7740\u8ba1\u7b97\u80fd\u529b\u7684\u63d0\u5347\u548c\u751f\u7269\u7814\u7a76\u7684\u6df1\u5165\uff0c\u672a\u6765\u7684\u98de\u884c\u5668\u53ef\u80fd\u4f1a\u66f4\u52a0\u63a5\u8fd1\u81ea\u7136\u754c\u7684\u98de\u884c\u65b9\u5f0f\uff0c\u5b9e\u73b0\u66f4\u9ad8\u7684\u6548\u7387\u548c\u66f4\u5f3a\u7684\u9002\u5e94\u80fd\u529b\u3002\u8fd9\u79cd\u8de8\u5b66\u79d1\u7684\u7814\u7a76\u65b9\u6cd5\u4e0d\u4ec5\u62d3\u5c55\u4e86\u5de5\u7a0b\u8bbe\u8ba1\u7684\u8fb9\u754c\uff0c\u4e5f\u4e3a\u89e3\u51b3\u590d\u6742\u7684\u7a7a\u6c14\u52a8\u529b\u5b66\u95ee\u9898\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u3002  \n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u878d\u5408\u662f\u672a\u6765\u822a\u7a7a\u6280\u672f\u53d1\u5c55\u7684\u91cd\u8981\u8d8b\u52bf\uff0c\u5176\u6f5c\u529b\u8fdc\u672a\u88ab\u5b8c\u5168\u6316\u6398\u3002\u901a\u8fc7\u4e0d\u65ad\u63a2\u7d22\u81ea\u7136\u754c\u7684\u667a\u6167\uff0c\u4eba\u7c7b\u6709\u671b\u5728\u98de\u884c\u5668\u8bbe\u8ba1\u9886\u57df\u53d6\u5f97\u66f4\u5927\u7684\u7a81\u7834\uff0c\u4e3a\u822a\u7a7a\u822a\u5929\u4e8b\u4e1a\u5e26\u6765\u9769\u547d\u6027\u7684\u53d8\u9769\u3002  \n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e0d\u4ec5\u63d0\u5347\u4e86\u98de\u884c\u5668\u7684\u6027\u80fd\uff0c\u4e5f\u4e3a\u5de5\u7a0b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u7075\u611f\u3002\u968f\u7740\u6280\u672f\u7684\u8fdb\u6b65\uff0c\u8fd9\u4e00\u9886\u57df\u5c06\u7ee7\u7eed\u62d3\u5c55\uff0c\u4e3a\u672a\u6765\u7684\u98de\u884c\u5668\u8bbe\u8ba1\u5e26\u6765\u66f4\u591a\u7684\u53ef\u80fd\u6027\u3002  \n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u662f\u5de5\u7a0b\u4e0e\u81ea\u7136\u7684\u5b8c\u7f8e\u878d\u5408\uff0c\u5b83\u4e0d\u4ec5\u63a8\u52a8\u4e86\u98de\u884c\u5668\u6280\u672f\u7684\u53d1\u5c55\uff0c\u4e5f\u4e3a\u4eba\u7c7b\u63a2\u7d22\u66f4\u5e7f\u9614\u7684\u5929\u7a7a"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u548c\u76d1\u7763\u673a\u5236\u4e0d\u5065\u5168\u65b9\u9762\u3002\u7531\u4e8e\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u4f9d\u8d56\u4e8e\u884c\u653f\u673a\u5173\u7684\u81ea\u89c9\u6027\uff0c\u4e00\u4e9b\u5730\u65b9\u653f\u5e9c\u548c\u90e8\u95e8\u5728\u9762\u5bf9\u590d\u8bae\u51b3\u5b9a\u65f6\uff0c\u5f80\u5f80\u91c7\u53d6\u56de\u907f\u6216\u62d6\u5ef6\u7684\u6001\u5ea6\u3002\u8fd9\u79cd\u73b0\u8c61\u5bfc\u81f4\u590d\u8bae\u51b3\u5b9a\u96be\u4ee5\u843d\u5b9e\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u6743\u5a01\u6027\u548c\u516c\u4fe1\u529b\u3002\u6b64\u5916\uff0c\u7f3a\u4e4f\u6709\u6548\u7684\u6267\u884c\u76d1\u7763\u673a\u5236\uff0c\u4f7f\u5f97\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u5916\u90e8\u7ea6\u675f\uff0c\u8fdb\u4e00\u6b65\u524a\u5f31\u4e86\u5176\u5b9e\u9645\u6548\u679c\u3002\n\n\u5177\u4f53\u4e8b\u4f8b\u4e2d\uff0c\u67d0\u5730\u5c45\u6c11\u56e0\u653f\u5e9c\u672a\u5c65\u884c\u4fe1\u606f\u516c\u5f00\u4e49\u52a1\uff0c\u5411\u5f53\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u7533\u8bf7\u590d\u8bae\u3002\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u76f8\u5173\u653f\u5e9c\u90e8\u95e8\u5e76\u672a\u5728\u89c4\u5b9a\u671f\u9650\u5185\u516c\u5f00\u4fe1\u606f\uff0c\u5c45\u6c11\u53ea\u80fd\u901a\u8fc7\u63d0\u8d77\u884c\u653f\u8bc9\u8bbc\u6765\u7ef4\u62a4\u81ea\u8eab\u6743\u76ca\u3002\u8fd9\u4e00\u6848\u4f8b\u53cd\u6620\u51fa\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u9645\u6267\u884c\u4e2d\u7684\u65e0\u529b\uff0c\u4e5f\u66b4\u9732\u51fa\u884c\u653f\u590d\u8bae\u5236\u5ea6\u5728\u76d1\u7763\u548c\u6267\u884c\u65b9\u9762\u7684\u8584\u5f31\u73af\u8282\u3002\n\n\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6cd5\u5f8b\u6548\u529b\u5728\u5b9e\u8df5\u4e2d\u53d7\u5230\u9650\u5236\uff0c\u90e8\u5206\u539f\u56e0\u662f\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\u4e0d\u591f\u5b8c\u5584\u3002\u4f8b\u5982\uff0c\u5bf9\u4e8e\u62d2\u4e0d\u5c65\u884c\u590d\u8bae\u51b3\u5b9a\u7684\u884c\u653f\u673a\u5173\uff0c\u7f3a\u4e4f\u660e\u786e\u7684\u6cd5\u5f8b\u8d23\u4efb\u8ffd\u7a76\u673a\u5236\uff0c\u5bfc\u81f4\u5176\u884c\u4e3a\u7f3a\u4e4f\u5a01\u6151\u529b\u3002\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u51b3\u5b9a\u4f5c\u51fa\u540e\uff0c\u7f3a\u4e4f\u5bf9\u6267\u884c\u60c5\u51b5\u7684\u8ddf\u8e2a\u548c\u53cd\u9988\u673a\u5236\uff0c\u4f7f\u5f97\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u6210\u4e3a\u4e00\u79cd\u201c\u4e00\u6b21\u6027\u201d\u884c\u4e3a\uff0c\u96be\u4ee5\u5f62\u6210\u6301\u7eed\u7684\u76d1\u7763\u548c\u7ea6\u675f\u3002\n\n\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u8fd8\u53d7\u5230\u884c\u653f\u4f53\u7cfb\u5185\u90e8\u534f\u8c03\u673a\u5236\u7684\u5f71\u54cd\u3002\u5728\u4e00\u4e9b\u60c5\u51b5\u4e0b\uff0c\u590d\u8bae\u673a\u5173\u4e0e\u88ab\u590d\u8bae\u673a\u5173\u4e4b\u95f4\u7f3a\u4e4f\u6709\u6548\u7684\u6c9f\u901a\u548c\u534f\u4f5c\uff0c\u5bfc\u81f4\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u9762\u4e34\u91cd\u91cd\u969c\u788d\u3002\u8fd9\u79cd\u5185\u90e8\u534f\u8c03\u4e0d\u7545\u7684\u95ee\u9898\uff0c\u4e0d\u4ec5\u5f71\u54cd\u4e86\u590d\u8bae\u51b3\u5b9a\u7684\u843d\u5b9e\uff0c\u4e5f\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u6574\u4f53\u6548\u80fd\u3002\u56e0\u6b64\uff0c\u52a0\u5f3a\u884c\u653f\u590d\u8bae\u6267\u884c\u673a\u5236\u7684\u5efa\u8bbe\uff0c\u662f\u63d0\u5347\u884c\u653f\u590d\u8bae\u5236\u5ea6\u6743\u5a01\u6027\u7684\u5173\u952e\u6240\u5728\u3002\n\ndocument \u5728\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u8fc7\u7a0b\u4e2d\uff0c\u5e94\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\uff0c\u660e\u786e\u884c\u653f\u673a\u5173\u4e0d\u5c65\u884c\u590d\u8bae\u51b3\u5b9a\u7684\u6cd5\u5f8b\u8d23\u4efb\uff0c\u5e76\u5efa\u7acb\u6709\u6548\u7684\u76d1\u7763\u548c\u6267\u884c\u673a\u5236\u3002\u540c\u65f6\uff0c\u52a0\u5f3a\u884c\u653f\u590d\u8bae\u673a\u5173\u4e0e\u76f8\u5173\u90e8\u95e8\u4e4b\u95f4\u7684\u534f\u8c03\uff0c\u786e\u4fdd\u590d\u8bae\u51b3\u5b9a\u80fd\u591f\u5f97\u5230\u6709\u6548\u843d\u5b9e\u3002\u901a\u8fc7\u5236\u5ea6\u5efa\u8bbe\u548c\u6267\u884c\u5f3a\u5316\uff0c\u53ef\u4ee5\u63d0\u9ad8\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u548c\u5b9e\u6548\u6027\uff0c\u66f4\u597d\u5730\u7ef4\u62a4\u516c\u6c11\u7684\u5408\u6cd5\u6743\u76ca\u3002"
}
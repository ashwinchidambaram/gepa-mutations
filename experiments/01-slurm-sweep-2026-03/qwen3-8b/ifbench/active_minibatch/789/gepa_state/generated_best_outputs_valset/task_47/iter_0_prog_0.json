{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u662f\u822a\u7a7a\u5de5\u7a0b\u4e0e\u751f\u7269\u79d1\u5b66\u4ea4\u53c9\u9886\u57df\u4e2d\u7684\u91cd\u8981\u7814\u7a76\u65b9\u5411\u3002\u7ffc\u578b\u8bbe\u8ba1\u662f\u6307\u98de\u673a\u673a\u7ffc\u7684\u5f62\u72b6\u8bbe\u8ba1\uff0c\u5176\u4e3b\u8981\u76ee\u6807\u662f\u4f18\u5316\u5347\u529b\u3001\u963b\u529b\u548c\u7a33\u5b9a\u6027\uff0c\u4ee5\u63d0\u9ad8\u98de\u884c\u6548\u7387\u548c\u6027\u80fd\u3002\u800c\u4eff\u751f\u5b66\u5219\u662f\u7814\u7a76\u751f\u7269\u4f53\u7684\u7ed3\u6784\u548c\u529f\u80fd\uff0c\u5e76\u5c06\u5176\u5e94\u7528\u4e8e\u5de5\u7a0b\u8bbe\u8ba1\u4e2d\uff0c\u4ee5\u6a21\u4eff\u81ea\u7136\u754c\u7684\u9ad8\u6548\u89e3\u51b3\u65b9\u6848\u3002\u4e24\u8005\u7684\u7ed3\u5408\u4e3a\u73b0\u4ee3\u822a\u7a7a\u6280\u672f\u7684\u53d1\u5c55\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u548c\u65b9\u6cd5\u3002\n\n\u7ffc\u578b\u7684\u8bbe\u8ba1\u901a\u5e38\u57fa\u4e8e\u7a7a\u6c14\u52a8\u529b\u5b66\u539f\u7406\uff0c\u5305\u62ec\u5347\u529b\u7cfb\u6570\u3001\u963b\u529b\u7cfb\u6570\u548c\u5931\u901f\u7279\u6027\u7b49\u5173\u952e\u53c2\u6570\u3002\u4f20\u7edf\u7684\u7ffc\u578b\u8bbe\u8ba1\u65b9\u6cd5\u4f9d\u8d56\u4e8e\u5b9e\u9a8c\u548c\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\uff08CFD\uff09\u6a21\u62df\uff0c\u4ee5\u786e\u5b9a\u6700\u4f18\u7684\u7ffc\u578b\u5f62\u72b6\u3002\u7136\u800c\uff0c\u968f\u7740\u4eff\u751f\u5b66\u7684\u53d1\u5c55\uff0c\u7814\u7a76\u4eba\u5458\u5f00\u59cb\u4ece\u81ea\u7136\u754c\u4e2d\u5bfb\u627e\u7075\u611f\uff0c\u4f8b\u5982\u9e1f\u7c7b\u3001\u6606\u866b\u548c\u9c7c\u7c7b\u7684\u98de\u884c\u548c\u6e38\u52a8\u65b9\u5f0f\uff0c\u4ee5\u6539\u8fdb\u7ffc\u578b\u8bbe\u8ba1\u3002\n\n\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u4e3b\u8981\u4f53\u73b0\u5728\u5bf9\u751f\u7269\u98de\u884c\u673a\u5236\u7684\u6a21\u4eff\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7fc5\u8180\u7684\u67d4\u6027\u7ed3\u6784\u548c\u53ef\u53d8\u5f62\u72b6\u80fd\u591f\u6709\u6548\u9002\u5e94\u4e0d\u540c\u7684\u98de\u884c\u6761\u4ef6\uff0c\u8fd9\u4e00\u7279\u6027\u542f\u53d1\u4e86\u53ef\u53d8\u7ffc\u578b\u8bbe\u8ba1\u7684\u7814\u7a76\u3002\u6b64\u5916\uff0c\u6606\u866b\u7fc5\u8180\u7684\u632f\u52a8\u673a\u5236\u4e5f\u88ab\u7528\u4e8e\u5fae\u578b\u98de\u884c\u5668\uff08MAV\uff09\u7684\u7ffc\u578b\u8bbe\u8ba1\uff0c\u4ee5\u63d0\u9ad8\u5176\u673a\u52a8\u6027\u548c\u7a33\u5b9a\u6027\u3002\u8fd9\u4e9b\u4eff\u751f\u8bbe\u8ba1\u4e0d\u4ec5\u63d0\u9ad8\u4e86\u98de\u884c\u5668\u7684\u6027\u80fd\uff0c\u8fd8\u964d\u4f4e\u4e86\u80fd\u8017\uff0c\u4e3a\u672a\u6765\u7684\u7eff\u8272\u822a\u7a7a\u6280\u672f\u63d0\u4f9b\u4e86\u53ef\u80fd\u3002\n\n\u8fd1\u5e74\u6765\uff0c\u968f\u7740\u8ba1\u7b97\u80fd\u529b\u7684\u63d0\u5347\u548c\u751f\u7269\u6570\u636e\u7684\u4e30\u5bcc\uff0c\u4eff\u751f\u5b66\u4e0e\u7ffc\u578b\u8bbe\u8ba1\u7684\u7ed3\u5408\u53d8\u5f97\u66f4\u52a0\u7d27\u5bc6\u3002\u7814\u7a76\u4eba\u5458\u901a\u8fc7\u9ad8\u7cbe\u5ea6\u7684\u751f\u7269\u6d4b\u91cf\u548c\u5efa\u6a21\uff0c\u7ed3\u5408\u5148\u8fdb\u7684\u6750\u6599\u79d1\u5b66\uff0c\u5f00\u53d1\u51fa\u5177\u6709\u81ea\u9002\u5e94\u80fd\u529b\u7684\u7ffc\u578b\u7ed3\u6784\u3002\u8fd9\u4e9b\u7ed3\u6784\u80fd\u591f\u6839\u636e\u98de\u884c\u73af\u5883\u7684\u53d8\u5316\u81ea\u52a8\u8c03\u6574\u5f62\u72b6\uff0c\u4ece\u800c\u5b9e\u73b0\u66f4\u9ad8\u6548\u7684\u7a7a\u6c14\u52a8\u529b\u5b66\u6027\u80fd\u3002\n\n\u5c3d\u7ba1\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u5c55\u73b0\u51fa\u5de8\u5927\u7684\u6f5c\u529b\uff0c\u4f46\u4ecd\u9762\u4e34\u8bf8\u591a\u6311\u6218\u3002\u4f8b\u5982\uff0c\u5982\u4f55\u51c6\u786e\u6355\u6349\u751f\u7269\u98de\u884c\u673a\u5236\u7684\u590d\u6742\u6027\uff0c\u5e76\u5c06\u5176\u8f6c\u5316\u4e3a\u53ef\u5de5\u7a0b\u5316\u7684\u8bbe\u8ba1\uff1b\u5982\u4f55\u5e73\u8861\u4eff\u751f\u7ed3\u6784\u7684\u590d\u6742\u6027\u4e0e\u5236\u9020\u6210\u672c\uff1b\u4ee5\u53ca\u5982\u4f55\u786e\u4fdd\u4eff\u751f\u8bbe\u8ba1\u5728\u5b9e\u9645\u98de\u884c\u4e2d\u7684\u53ef\u9760\u6027\u548c\u5b89\u5168\u6027\u3002\u8fd9\u4e9b\u95ee\u9898\u9700\u8981\u8de8\u5b66\u79d1\u7684\u5408\u4f5c\u4e0e\u6df1\u5165\u7814\u7a76\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e3a\u822a\u7a7a\u5de5\u7a0b\u5e26\u6765\u4e86\u65b0\u7684\u673a\u9047\u3002\u901a\u8fc7\u501f\u9274\u751f\u7269\u754c\u7684\u667a\u6167\uff0c\u7814\u7a76\u4eba\u5458\u80fd\u591f\u5f00\u53d1\u51fa\u66f4\u52a0\u9ad8\u6548\u3001\u667a\u80fd\u7684\u98de\u884c\u5668\u7ffc\u578b\u3002\u672a\u6765\uff0c\u968f\u7740\u6280\u672f\u7684\u8fdb\u6b65\u548c\u7814\u7a76\u7684\u6df1\u5165\uff0c\u4eff\u751f\u5b66\u6709\u671b\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u53d1\u6325\u66f4\u5927\u7684\u4f5c\u7528\uff0c\u63a8\u52a8\u822a\u7a7a\u6280\u672f\u5411\u66f4\u9ad8\u6548\u3001\u66f4\u73af\u4fdd\u7684\u65b9\u5411\u53d1\u5c55\u3002\u4eff\u751f\u5b66\u3002"
}
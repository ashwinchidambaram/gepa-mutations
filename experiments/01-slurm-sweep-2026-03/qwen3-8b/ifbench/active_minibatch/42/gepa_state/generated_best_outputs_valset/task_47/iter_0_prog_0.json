{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\uff1a\u81ea\u7136\u4e0e\u5de5\u7a0b\u7684\u878d\u5408\n\n\u7ffc\u578b\u8bbe\u8ba1\u662f\u822a\u7a7a\u5de5\u7a0b\u4e2d\u7684\u6838\u5fc3\u9886\u57df\uff0c\u5176\u76ee\u6807\u662f\u4f18\u5316\u7a7a\u6c14\u52a8\u529b\u5b66\u6027\u80fd\uff0c\u4ee5\u5b9e\u73b0\u66f4\u9ad8\u7684\u5347\u529b\u3001\u66f4\u4f4e\u7684\u963b\u529b\u548c\u66f4\u9ad8\u6548\u7684\u98de\u884c\u3002\u7ffc\u578b\u7684\u5f62\u72b6\u3001\u539a\u5ea6\u3001\u5f2f\u5ea6\u7b49\u53c2\u6570\u76f4\u63a5\u5f71\u54cd\u98de\u884c\u5668\u7684\u6027\u80fd\uff0c\u56e0\u6b64\uff0c\u5982\u4f55\u8bbe\u8ba1\u51fa\u9ad8\u6548\u7684\u7ffc\u578b\u4e00\u76f4\u662f\u7814\u7a76\u7684\u91cd\u70b9\u3002\u968f\u7740\u79d1\u6280\u7684\u53d1\u5c55\uff0c\u4eff\u751f\u5b66\u9010\u6e10\u6210\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u7684\u91cd\u8981\u7075\u611f\u6765\u6e90\u3002\u901a\u8fc7\u7814\u7a76\u81ea\u7136\u754c\u4e2d\u98de\u884c\u751f\u7269\u7684\u7ffc\u578b\u7ed3\u6784\uff0c\u5de5\u7a0b\u5e08\u4eec\u80fd\u591f\u501f\u9274\u5176\u72ec\u7279\u7684\u9002\u5e94\u6027\u548c\u4f18\u5316\u673a\u5236\uff0c\u4ece\u800c\u6539\u8fdb\u4f20\u7edf\u7ffc\u578b\u8bbe\u8ba1\u3002\n\n\u81ea\u7136\u754c\u4e2d\uff0c\u9e1f\u7c7b\u3001\u6606\u866b\u548c\u8759\u8760\u7684\u98de\u884c\u65b9\u5f0f\u5404\u5177\u7279\u8272\uff0c\u5b83\u4eec\u7684\u7ffc\u578b\u7ed3\u6784\u5728\u957f\u671f\u8fdb\u5316\u8fc7\u7a0b\u4e2d\u5f62\u6210\u4e86\u9ad8\u5ea6\u9002\u5e94\u6027\u7684\u5f62\u6001\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7684\u7ffc\u578b\u5177\u6709\u6d41\u7ebf\u578b\u8f6e\u5ed3\uff0c\u80fd\u591f\u6709\u6548\u51cf\u5c11\u7a7a\u6c14\u963b\u529b\uff0c\u540c\u65f6\u901a\u8fc7\u7ffc\u5c55\u548c\u7ffc\u9762\u79ef\u7684\u53d8\u5316\u5b9e\u73b0\u7075\u6d3b\u7684\u98de\u884c\u63a7\u5236\u3002\u6606\u866b\u7684\u7fc5\u8180\u5219\u5177\u6709\u590d\u6742\u7684\u632f\u52a8\u673a\u5236\uff0c\u80fd\u591f\u4ea7\u751f\u9ad8\u5347\u529b\u5e76\u5b9e\u73b0\u5feb\u901f\u673a\u52a8\u3002\u8fd9\u4e9b\u81ea\u7136\u754c\u7684\u98de\u884c\u5668\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u4e30\u5bcc\u7684\u7075\u611f\uff0c\u4fc3\u4f7f\u5de5\u7a0b\u5e08\u4eec\u63a2\u7d22\u66f4\u9ad8\u6548\u7684\u7a7a\u6c14\u52a8\u529b\u5b66\u89e3\u51b3\u65b9\u6848\u3002\n\n\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u4e3b\u8981\u4f53\u73b0\u5728\u7ed3\u6784\u4f18\u5316\u548c\u529f\u80fd\u589e\u5f3a\u4e24\u4e2a\u65b9\u9762\u3002\u5728\u7ed3\u6784\u4f18\u5316\u65b9\u9762\uff0c\u7814\u7a76\u4eba\u5458\u901a\u8fc7\u6a21\u4eff\u81ea\u7136\u754c\u7684\u7ffc\u578b\u5f62\u6001\uff0c\u8bbe\u8ba1\u51fa\u5177\u6709\u66f4\u4f18\u6c14\u52a8\u6027\u80fd\u7684\u7ffc\u578b\u3002\u4f8b\u5982\uff0c\u57fa\u4e8e\u9e1f\u7c7b\u7ffc\u578b\u7684\u4eff\u751f\u7ffc\u578b\u80fd\u591f\u63d0\u9ad8\u5347\u529b\u7cfb\u6570\uff0c\u540c\u65f6\u964d\u4f4e\u5931\u901f\u901f\u5ea6\uff0c\u4ece\u800c\u63d0\u5347\u98de\u884c\u5668\u7684\u7a33\u5b9a\u6027\u548c\u64cd\u63a7\u6027\u3002\u5728\u529f\u80fd\u589e\u5f3a\u65b9\u9762\uff0c\u4eff\u751f\u5b66\u542f\u53d1\u4e86\u53ef\u53d8\u5f62\u7ffc\u578b\u548c\u667a\u80fd\u7ffc\u578b\u7684\u8bbe\u8ba1\u3002\u8fd9\u4e9b\u7ffc\u578b\u80fd\u591f\u6839\u636e\u98de\u884c\u6761\u4ef6\u52a8\u6001\u8c03\u6574\u5f62\u72b6\uff0c\u4ee5\u9002\u5e94\u4e0d\u540c\u7684\u6c14\u6d41\u73af\u5883\uff0c\u4ece\u800c\u5b9e\u73b0\u66f4\u9ad8\u6548\u7684\u98de\u884c\u6027\u80fd\u3002\n\n\u6b64\u5916\uff0c\u4eff\u751f\u5b66\u8fd8\u63a8\u52a8\u4e86\u6750\u6599\u79d1\u5b66\u7684\u53d1\u5c55\uff0c\u4f7f\u5f97\u7ffc\u578b\u8bbe\u8ba1\u80fd\u591f\u7ed3\u5408\u8f7b\u91cf\u5316\u548c\u9ad8\u5f3a\u5ea6\u7684\u6750\u6599\u7279\u6027\u3002\u4f8b\u5982\uff0c\u4eff\u751f\u590d\u5408\u6750\u6599\u7684\u4f7f\u7528\u4f7f\u5f97\u7ffc\u578b\u5728\u4fdd\u6301\u8f7b\u91cf\u5316\u7684\u540c\u65f6\uff0c\u5177\u5907\u66f4\u9ad8\u7684\u6297\u75b2\u52b3\u6027\u548c\u8010\u4e45\u6027\u3002\u8fd9\u79cd\u6750\u6599\u4e0e\u7ed3\u6784\u7684\u7ed3\u5408\uff0c\u4e3a\u73b0\u4ee3\u98de\u884c\u5668\u7684\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u53ef\u80fd\u6027\u3002\n\n\u7136\u800c\uff0c\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u4ecd\u9762\u4e34\u8bf8\u591a\u6311\u6218\u3002\u9996\u5148\uff0c\u81ea\u7136\u754c\u4e2d\u7684\u98de\u884c\u751f\u7269\u5177\u6709\u590d\u6742\u7684\u751f\u7269\u529b\u5b66\u673a\u5236\uff0c\u5982\u4f55\u5c06\u5176\u7b80\u5316\u5e76\u5e94\u7528\u4e8e\u5de5\u7a0b\u8bbe\u8ba1\u662f\u4e00\u4e2a\u96be\u9898\u3002\u5176\u6b21\uff0c\u4eff\u751f\u8bbe\u8ba1\u9700\u8981\u5927\u91cf\u7684\u5b9e\u9a8c\u548c\u6a21\u62df\u9a8c\u8bc1\uff0c\u4ee5\u786e\u4fdd\u5176\u5728\u5b9e\u9645\u5e94\u7528\u4e2d\u7684\u53ef\u884c\u6027\u3002\u6b64\u5916\uff0c\u4eff\u751f\u5b66\u4e0e\u4f20\u7edf\u7a7a\u6c14\u52a8\u529b\u5b66\u7406\u8bba\u7684\u7ed3\u5408\u4e5f\u9700\u8981\u6df1\u5165\u7814\u7a76\uff0c\u4ee5\u5b9e\u73b0\u66f4\u5168\u9762\u7684\u4f18\u5316\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66"
}
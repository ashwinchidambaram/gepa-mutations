{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u878d\u5408\u662f\u73b0\u4ee3\u822a\u7a7a\u5de5\u7a0b\u548c\u751f\u7269\u79d1\u5b66\u4ea4\u53c9\u9886\u57df\u7684\u91cd\u8981\u7814\u7a76\u65b9\u5411\u3002\u7ffc\u578b\uff0c\u5373\u673a\u7ffc\u7684\u6a2a\u622a\u9762\u5f62\u72b6\uff0c\u662f\u98de\u884c\u5668\u4ea7\u751f\u5347\u529b\u7684\u5173\u952e\u56e0\u7d20\u4e4b\u4e00\u3002\u5176\u8bbe\u8ba1\u76f4\u63a5\u5f71\u54cd\u98de\u884c\u5668\u7684\u6c14\u52a8\u6027\u80fd\uff0c\u5305\u62ec\u5347\u529b\u7cfb\u6570\u3001\u963b\u529b\u7cfb\u6570\u4ee5\u53ca\u98de\u884c\u7a33\u5b9a\u6027\u3002\u4f20\u7edf\u7684\u7ffc\u578b\u8bbe\u8ba1\u591a\u57fa\u4e8e\u6570\u5b66\u6a21\u578b\u548c\u98ce\u6d1e\u5b9e\u9a8c\uff0c\u4f46\u8fd1\u5e74\u6765\uff0c\u968f\u7740\u4eff\u751f\u5b66\u7684\u53d1\u5c55\uff0c\u8d8a\u6765\u8d8a\u591a\u7684\u7814\u7a76\u8005\u5f00\u59cb\u4ece\u81ea\u7136\u754c\u4e2d\u5bfb\u627e\u7075\u611f\uff0c\u4ee5\u4f18\u5316\u7ffc\u578b\u8bbe\u8ba1\uff0c\u63d0\u9ad8\u98de\u884c\u5668\u7684\u6548\u7387\u548c\u9002\u5e94\u6027\u3002\n\n\u4eff\u751f\u5b66\u662f\u7814\u7a76\u751f\u7269\u4f53\u7ed3\u6784\u548c\u529f\u80fd\uff0c\u5e76\u5c06\u5176\u5e94\u7528\u4e8e\u5de5\u7a0b\u8bbe\u8ba1\u7684\u79d1\u5b66\u9886\u57df\u3002\u81ea\u7136\u754c\u4e2d\uff0c\u8bb8\u591a\u751f\u7269\u4f53\u7684\u7ffc\u578b\u7ed3\u6784\u5177\u6709\u9ad8\u5ea6\u7684\u9002\u5e94\u6027\u548c\u4f18\u5316\u6027\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u548c\u6606\u866b\u7684\u7fc5\u8180\u5728\u7a7a\u6c14\u52a8\u529b\u5b66\u65b9\u9762\u8868\u73b0\u51fa\u5353\u8d8a\u7684\u6027\u80fd\u3002\u9e1f\u7c7b\u7684\u7ffc\u578b\u80fd\u591f\u6839\u636e\u98de\u884c\u72b6\u6001\u8fdb\u884c\u52a8\u6001\u8c03\u6574\uff0c\u4ee5\u9002\u5e94\u4e0d\u540c\u7684\u98de\u884c\u9700\u6c42\uff0c\u5982\u6ed1\u7fd4\u3001\u76d8\u65cb\u548c\u9ad8\u901f\u98de\u884c\u3002\u6606\u866b\u7684\u7fc5\u8180\u5219\u5177\u6709\u590d\u6742\u7684\u632f\u52a8\u6a21\u5f0f\uff0c\u80fd\u591f\u4ea7\u751f\u9ad8\u6548\u7684\u5347\u529b\u3002\u8fd9\u4e9b\u81ea\u7136\u754c\u7684\u98de\u884c\u5668\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u5b9d\u8d35\u7684\u53c2\u8003\u3002\n\n\u5728\u4eff\u751f\u5b66\u7684\u542f\u53d1\u4e0b\uff0c\u7814\u7a76\u4eba\u5458\u5f00\u59cb\u5c1d\u8bd5\u5c06\u751f\u7269\u4f53\u7684\u7ffc\u578b\u7ed3\u6784\u5e94\u7528\u4e8e\u98de\u884c\u5668\u8bbe\u8ba1\u4e2d\u3002\u4f8b\u5982\uff0c\u57fa\u4e8e\u9e1f\u7c7b\u7ffc\u578b\u7684\u4eff\u751f\u7ffc\u578b\u80fd\u591f\u63d0\u9ad8\u5347\u529b\u7cfb\u6570\uff0c\u540c\u65f6\u51cf\u5c11\u963b\u529b\uff0c\u4ece\u800c\u63d0\u9ad8\u98de\u884c\u6548\u7387\u3002\u6b64\u5916\uff0c\u4e00\u4e9b\u7814\u7a76\u8fd8\u63a2\u7d22\u4e86\u4eff\u751f\u67d4\u6027\u7ffc\u578b\uff0c\u5176\u7ed3\u6784\u7c7b\u4f3c\u4e8e\u6606\u866b\u7fc5\u8180\uff0c\u80fd\u591f\u901a\u8fc7\u52a8\u6001\u53d8\u5f62\u5b9e\u73b0\u66f4\u9ad8\u6548\u7684\u6c14\u52a8\u6027\u80fd\u3002\u8fd9\u4e9b\u4eff\u751f\u7ffc\u578b\u4e0d\u4ec5\u5728\u4f20\u7edf\u822a\u7a7a\u9886\u57df\u5177\u6709\u5e94\u7528\u524d\u666f\uff0c\u5728\u65e0\u4eba\u673a\u3001\u5fae\u578b\u98de\u884c\u5668\u4ee5\u53ca\u53ef\u53d8\u5f62\u98de\u884c\u5668\u7b49\u65b0\u5174\u9886\u57df\u4e5f\u5c55\u73b0\u51fa\u5de8\u5927\u7684\u6f5c\u529b\u3002\n\n\u7136\u800c\uff0c\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\u4e5f\u9762\u4e34\u8bf8\u591a\u6311\u6218\u3002\u9996\u5148\uff0c\u751f\u7269\u4f53\u7684\u590d\u6742\u7ed3\u6784\u96be\u4ee5\u5b8c\u5168\u590d\u5236\uff0c\u9700\u8981\u5728\u4eff\u751f\u8bbe\u8ba1\u4e2d\u8fdb\u884c\u7b80\u5316\u548c\u4f18\u5316\u3002\u5176\u6b21\uff0c\u4eff\u751f\u7ffc\u578b\u7684\u6750\u6599\u9009\u62e9\u548c\u5236\u9020\u5de5\u827a\u9700\u8981\u6ee1\u8db3\u8f7b\u91cf\u5316\u3001\u9ad8\u5f3a\u5ea6\u548c\u9ad8\u67d4\u97e7\u6027\u7684\u8981\u6c42\u3002\u6b64\u5916\uff0c\u4eff\u751f\u7ffc\u578b\u7684\u63a7\u5236\u548c\u8c03\u8282\u673a\u5236\u4e5f\u9700\u8981\u4e0e\u98de\u884c\u5668\u7684\u63a7\u5236\u7cfb\u7edf\u76f8\u5339\u914d\uff0c\u4ee5\u5b9e\u73b0\u9ad8\u6548\u7684\u98de\u884c\u6027\u80fd\u3002\n\n\u7efc\u751f\u5b66\u7684\u53d1\u5c55\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u548c\u65b9\u6cd5\uff0c\u4f7f\u5f97\u98de\u884c\u5668\u5728\u6c14\u52a8\u6027\u80fd\u3001\u9002\u5e94\u6027\u548c\u6548\u7387\u65b9\u9762\u5f97\u5230\u4e86\u663e\u8457\u63d0\u5347\u3002\u968f\u7740\u6750\u6599\u79d1\u5b66\u3001\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\u548c\u667a\u80fd\u63a7\u5236\u6280\u672f\u7684\u8fdb\u6b65\uff0c\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\u6709\u671b\u5728\u672a\u6765\u822a\u7a7a\u5de5\u7a0b\u4e2d\u53d1\u6325\u66f4\u52a0\u91cd\u8981\u7684\u4f5c\u7528\u3002\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e0d\u4ec5\u63a8\u52a8\u4e86\u822a\u7a7a\u6280\u672f\u7684\u53d1\u5c55\uff0c\u4e5f\u4e3a\u5176\u4ed6\u5de5\u7a0b\u9886\u57df\u63d0\u4f9b\u4e86\u8de8\u5b66\u79d1\u7684\u521b\u65b0\u601d\u8def\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66"
}
{
    "response": "<<\u0646\u0627\u0641\u0630\u0629 \u0627\u0644\u0647\u0648\u0627\u0621>>  \n\u0646\u064f\u0628\u064e\u0651\u0647\u064e\u062a\u0652 \u0627\u0644\u0623\u0646\u0638\u0645\u0629 \u0627\u0644\u062a\u064a \u0646\u0639\u0645\u0644 \u0628\u0647\u0627 \u0641\u064a \u0627\u0644\u0645\u0633\u062a\u0634\u0641\u064a\u0627\u062a\u060c \u0648\u0646\u0639\u0645\u0644 \u0628\u0647\u0627 \u0641\u064a \u0623\u0645\u0627\u0643\u0646 \u0623\u062e\u0631\u0649 \u0645\u062e\u062a\u0644\u0641\u0629 \u062c\u062f\u0627\u064b\u060c \u0644\u0643\u064a \u062a\u0645\u0646\u0639 \u0627\u0644\u0647\u0648\u0627\u0621 \u0627\u0644\u062e\u0627\u0631\u062c\u064a \u0645\u0646 \u0627\u0644\u062f\u062e\u0648\u0644.  \n\u0646\u064f\u062e\u0652\u0631\u0650\u062c\u064f \u0627\u0644\u0647\u0648\u0627\u0621 \u0645\u0646 \u0627\u0644\u062f\u0627\u062e\u0644\u060c \u0648\u0646\u064e\u062d\u0652\u0641\u0650\u0638\u064f \u0646\u064e\u0642\u0652\u062f\u064e\u0647\u064f.  \n\u0646\u064f\u0639\u064e\u062f\u0650\u0651\u062f\u064f \u0627\u0644\u0623\u0646\u0638\u0645\u0629\u060c \u0648\u0646\u064e\u0641\u0652\u0643\u0650\u0631\u064f \u0641\u064a \u0627\u0644\u0637\u0631\u0642 \u0627\u0644\u0623\u062e\u0631\u0649.  \n\u0646\u064f\u0634\u064e\u062c\u0650\u0651\u0639\u064f \u0639\u0644\u0649 \u0627\u0644\u0627\u0628\u062a\u0643\u0627\u0631\u060c \u0648\u0646\u064f\u062d\u0652\u0641\u0650\u0638\u064f \u0627\u0644\u0623\u0646\u0638\u0645\u0629.  \n\u0646\u064e\u062d\u0652\u0641\u0650\u0638\u064f \u0627\u0644\u0647\u0648\u0627\u0621\u060c \u0648\u0646\u064f\u0646\u0652\u0642\u0650\u0630\u064f \u0627\u0644\u0623\u0631\u0648\u0627\u062d.  \n\u0646\u064f\u0639\u064e\u062f\u0650\u0651\u062f\u064f \u0627\u0644\u062a\u0641\u0627\u0635\u064a\u0644\u060c \u0648\u0646\u064e\u062d\u0652\u0641\u0650\u0638\u064f \u0627\u0644\u062a\u0648\u0627\u0632\u0646.  \n\u0646\u064f\u062d\u0652\u0641\u0650\u0638\u064f \u0627\u0644\u0647\u062f\u0648\u0621\u060c \u0648\u0646\u064f\u0646\u0652\u0642\u0650\u0630\u064f \u0627\u0644\u0623\u0631\u0648\u0627\u062d.  \n\u0646\u064e\u062d\u0652\u0641\u0650\u0638\u064f \u0627\u0644\u0647\u0648\u0627\u0621\u060c \u0648\u0646\u064f\u0646\u0652\u0642\u0650\u0630\u064f \u0627\u0644\u0623\u0631\u0648\u0627\u062d.  \n\u0646\u064f\u062d\u0652\u0641\u0650\u0638\u064f \u0627\u0644\u062a\u0648\u0627\u0632\u0646\u060c \u0648\u0646\u064f\u0646\u0652\u0642\u0650\u0630\u064f \u0627\u0644\u0623\u0631\u0648\u0627\u062d."

{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u8bf8\u591a\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u3001\u76d1\u7763\u673a\u5236\u4e0d\u5065\u5168\u4ee5\u53ca\u7a0b\u5e8f\u4e0d\u89c4\u8303\u7b49\u65b9\u9762\u3002\u90e8\u5206\u5730\u65b9\u653f\u5e9c\u5728\u63a5\u5230\u590d\u8bae\u673a\u5173\u7684\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u672a\u80fd\u53ca\u65f6\u91c7\u53d6\u6709\u6548\u63aa\u65bd\uff0c\u5bfc\u81f4\u884c\u653f\u76f8\u5bf9\u4eba\u7684\u5408\u6cd5\u6743\u76ca\u65e0\u6cd5\u5f97\u5230\u4fdd\u969c\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u5728\u63a5\u5230\u590d\u8bae\u673a\u5173\u7684\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u4ecd\u7136\u62d6\u5ef6\u4e0d\u4f5c\u4e3a\uff0c\u5bfc\u81f4\u4f01\u4e1a\u957f\u671f\u8fdd\u89c4\u6392\u653e\u6c61\u67d3\u7269\uff0c\u6700\u7ec8\u5f15\u53d1\u4e25\u91cd\u7684\u73af\u5883\u6c61\u67d3\u4e8b\u4ef6\u3002\u8fd9\u79cd\u73b0\u8c61\u53cd\u6620\u51fa\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u529b\u5b58\u5728\u660e\u663e\u7f3a\u9677\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u76d1\u7763\u673a\u5236\u5c1a\u4e0d\u5b8c\u5584\uff0c\u7f3a\u4e4f\u6709\u6548\u7684\u540e\u7eed\u8ddf\u8fdb\u548c\u8d23\u4efb\u8ffd\u7a76\u5236\u5ea6\u3002\u5728\u4e00\u4e9b\u6848\u4f8b\u4e2d\uff0c\u5373\u4f7f\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u4e86\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4e5f\u96be\u4ee5\u786e\u4fdd\u76f8\u5173\u90e8\u95e8\u5207\u5b9e\u5c65\u884c\u4e49\u52a1\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u4f4f\u5efa\u90e8\u95e8\u5728\u590d\u8bae\u673a\u5173\u8d23\u4ee4\u5176\u5c65\u884c\u5bf9\u8fdd\u89c4\u5efa\u7b51\u7684\u62c6\u9664\u4e49\u52a1\u540e\uff0c\u4ecd\u7136\u4ee5\u5404\u79cd\u7406\u7531\u63a8\u8bff\u62d6\u5ef6\uff0c\u6700\u7ec8\u5bfc\u81f4\u590d\u8bae\u673a\u5173\u4e0d\u5f97\u4e0d\u91c7\u53d6\u8fdb\u4e00\u6b65\u7684\u53f8\u6cd5\u624b\u6bb5\u6765\u63a8\u52a8\u6267\u884c\u3002\u8fd9\u79cd\u60c5\u51b5\u4e0b\uff0c\u590d\u8bae\u51b3\u5b9a\u7684\u6743\u5a01\u6027\u53d7\u5230\u524a\u5f31\uff0c\u4e5f\u5f71\u54cd\u4e86\u516c\u4f17\u5bf9\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u4fe1\u4efb\u3002\n\n\u7a0b\u5e8f\u4e0d\u89c4\u8303\u4e5f\u662f\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u4e2d\u5b58\u5728\u7684\u7a81\u51fa\u95ee\u9898\u3002\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u672a\u80fd\u4e25\u683c\u6309\u7167\u6cd5\u5b9a\u7a0b\u5e8f\u8fdb\u884c\uff0c\u5bfc\u81f4\u51b3\u5b9a\u7f3a\u4e4f\u5408\u6cd5\u6027\u4e0e\u516c\u6b63\u6027\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u5e02\u573a\u76d1\u7ba1\u90e8\u95e8\u5728\u590d\u8bae\u8fc7\u7a0b\u4e2d\uff0c\u672a\u5145\u5206\u542c\u53d6\u5f53\u4e8b\u4eba\u610f\u89c1\uff0c\u4e5f\u672a\u5bf9\u76f8\u5173\u8bc1\u636e\u8fdb\u884c\u8be6\u7ec6\u5ba1\u67e5\uff0c\u76f4\u63a5\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u5f15\u53d1\u5f53\u4e8b\u4eba\u4e0d\u6ee1\u5e76\u63d0\u8d77\u884c\u653f\u8bc9\u8bbc\u3002\u6b64\u7c7b\u7a0b\u5e8f\u7455\u75b5\u4e0d\u4ec5\u5f71\u54cd\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\uff0c\u4e5f\u53ef\u80fd\u5f15\u53d1\u6cd5\u5f8b\u7ea0\u7eb7\uff0c\u635f\u5bb3\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u516c\u4fe1\u529b\u3002\n\n\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u8fd8\u53d7\u5230\u5730\u65b9\u4fdd\u62a4\u4e3b\u4e49\u7684\u5f71\u54cd\u3002\u5728\u4e00\u4e9b\u5730\u65b9\uff0c\u7531\u4e8e\u90e8\u95e8\u5229\u76ca\u6216\u5730\u65b9\u5229\u76ca\u7684\u9a71\u52a8\uff0c\u76f8\u5173\u90e8\u95e8\u53ef\u80fd\u5bf9\u590d\u8bae\u51b3\u5b9a\u91c7\u53d6\u56de\u907f\u6001\u5ea6\uff0c\u751a\u81f3\u8bbe\u7f6e\u969c\u788d\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u8d22\u653f\u90e8\u95e8\u5728\u590d\u8bae\u673a\u5173\u8d23\u4ee4\u5176\u5c65\u884c\u5bf9\u8fdd\u89c4\u9879\u76ee\u7684\u62e8\u6b3e\u4e49\u52a1\u65f6\uff0c\u4ee5\u8d22\u653f\u56f0\u96be\u4e3a\u7531\u62d2\u7edd\u6267\u884c\uff0c\u6700\u7ec8\u5bfc\u81f4\u9879\u76ee\u65e0\u6cd5\u63a8\u8fdb\uff0c\u5f71\u54cd\u4e86\u516c\u5171\u5229\u76ca\u3002\u8fd9\u79cd\u5730\u65b9\u4fdd\u62a4\u4e3b\u4e49\u73b0\u8c61\u4e25\u91cd\u5236\u7ea6\u4e86\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u529b\uff0c\u4e5f\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u5728\u6cd5\u6cbb\u5efa\u8bbe\u4e2d\u7684\u4f5c\u7528\u3002\n\ndocument \u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u95ee\u9898\uff0c\u4e0d\u4ec5\u5f71\u54cd\u4e86\u884c\u653f\u76f8\u5bf9\u4eba\u7684\u5408\u6cd5\u6743\u76ca\uff0c\u4e5f\u5bf9\u653f\u5e9c\u516c\u4fe1\u529b\u548c\u6cd5\u6cbb\u5efa\u8bbe\u63d0\u51fa\u4e86\u6311\u6218\u3002\u8981\u89e3\u51b3\u8fd9\u4e9b\u95ee\u9898\uff0c\u9700\u8981\u8fdb\u4e00\u6b65\u5b8c\u5584\u6267\u884c\u673a\u5236\uff0c\u5f3a\u5316\u76d1\u7763\u529b\u5ea6\uff0c\u89c4\u8303\u590d\u8bae\u7a0b\u5e8f\uff0c\u5e76\u52a0\u5f3a\u5bf9\u5730\u65b9\u4fdd\u62a4\u4e3b\u4e49\u7684\u5236\u7ea6\u3002\u53ea\u6709\u901a\u8fc7\u5236\u5ea6\u5efa\u8bbe\u548c\u6267\u884c\u4fdd\u969c\uff0c\u624d\u80fd\u771f\u6b63\u53d1\u6325\u884c\u653f\u590d\u8bae\u5728\u7ef4\u62a4\u793e\u4f1a\u516c\u5e73\u6b63\u4e49\u4e2d\u7684\u4f5c\u7528"
}
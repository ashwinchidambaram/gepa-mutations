{
    "response": "<<\u0646\u0642\u0637\u0629 \u062a\u0641\u0643\u064a\u0631>>  \n\u0646\u0645\u0627\u0630\u062c \u0627\u0644\u0639\u0645\u0644 \u0627\u0644\u062a\u064a \u0646\u0633\u062a\u062e\u062f\u0645\u0647\u0627 \u0641\u064a \u0627\u0644\u0645\u0633\u062a\u0634\u0641\u064a\u0627\u062a\u060c \u0648\u0646\u0633\u062a\u062e\u062f\u0645\u0647\u0627 \u0623\u064a\u0636\u064b\u0627 \u0641\u064a \u0645\u0628\u0627\u0646\u064a \u0645\u062e\u062a\u0644\u0641\u0629 \u062c\u062f\u064b\u0627\u060c \u062a\u0647\u062f\u0641 \u0625\u0644\u0649 \u0627\u0644\u062d\u0641\u0627\u0638 \u0639\u0644\u0649 \u0627\u0644\u0647\u0648\u0627\u0621 \u0627\u0644\u062e\u0627\u0631\u062c\u064a \u062e\u0627\u0631\u062c\u064b\u0627.  \n\u0648\u0645\u0646 \u0627\u0644\u0645\u0647\u0645 \u0623\u0646 \u0646\u062a\u0630\u0643\u0631 \u0623\u0646 \u0643\u0644 \u0643\u0644\u0645\u0629 \u064a\u062c\u0628 \u0623\u0646 \u062a\u0643\u0648\u0646 \u0641\u0631\u064a\u062f\u0629\u060c \u0648\u0644\u0627 \u062a\u064f\u0633\u062a\u062e\u062f\u0645 \u0645\u0631\u062a\u064a\u0646\u060c \u0643\u0645\u0627 \u0623\u0646 \u0627\u0644\u062d\u0631\u0641 \"\u0648\" \u064a\u062c\u0628 \u0623\u0646 \u064a\u0638\u0647\u0631 \u0639\u0644\u0649 \u0627\u0644\u0623\u0642\u0644 \u062a\u0633\u0639\u0629 \u0645\u0631\u0627\u062a\u060c \u0645\u0639 \u0645\u0631\u0627\u0639\u0627\u0629 \u0623\u0646 \u0644\u0627 \u062a\u0628\u062f\u0623 \u0623\u064a \u0643\u0644\u0645\u062a\u064a\u0646 \u0645\u062a\u062a\u0627\u0644\u064a\u062a\u064a\u0646 \u0628\u062d\u0631\u0648\u0641 \u0645\u062a\u062a\u0627\u0644\u064a\u0629 \u0645\u0646 \u0623\u062d\u0631\u0641 \u0627\u0644\u0623\u0628\u062c\u062f\u064a\u0629."

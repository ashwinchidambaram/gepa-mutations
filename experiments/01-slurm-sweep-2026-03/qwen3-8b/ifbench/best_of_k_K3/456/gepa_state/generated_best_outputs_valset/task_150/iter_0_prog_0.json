{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6cd5\u5f8b\u9002\u7528\u4e0d\u7edf\u4e00\u548c\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u4e0a\u3002\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u5f80\u5f80\u56e0\u5bf9\u76f8\u5173\u6cd5\u5f8b\u6761\u6587\u7684\u7406\u89e3\u5b58\u5728\u5dee\u5f02\uff0c\u5bfc\u81f4\u88c1\u51b3\u7ed3\u679c\u4e0d\u4e00\u81f4\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u67d0\u4f01\u4e1a\u7533\u8bf7\u8d23\u4ee4\u884c\u653f\u673a\u5173\u5c65\u884c\u6cd5\u5b9a\u804c\u8d23\u7684\u6848\u4ef6\u4e2d\uff0c\u56e0\u5bf9\u201c\u6cd5\u5b9a\u804c\u8d23\u201d\u8303\u56f4\u7684\u754c\u5b9a\u4e0d\u540c\uff0c\u5bfc\u81f4\u88c1\u51b3\u7ed3\u679c\u51fa\u73b0\u5206\u6b67\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u548c\u516c\u4fe1\u529b\u3002\n\n\u6b64\u5916\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u90e8\u5206\u51b3\u5b9a\u96be\u4ee5\u843d\u5b9e\u3002\u5728\u4e00\u4e9b\u6848\u4ef6\u4e2d\uff0c\u5373\u4f7f\u884c\u653f\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u4e86\u8d23\u4ee4\u5c65\u884c\u7684\u51b3\u5b9a\uff0c\u76f8\u5173\u884c\u653f\u673a\u5173\u4ecd\u53ef\u80fd\u4ee5\u5404\u79cd\u7406\u7531\u62d6\u5ef6\u6216\u62d2\u7edd\u6267\u884c\u3002\u4f8b\u5982\uff0c\u67d0\u5e02\u5c45\u6c11\u7533\u8bf7\u590d\u8bae\uff0c\u8981\u6c42\u5f53\u5730\u73af\u4fdd\u90e8\u95e8\u5c65\u884c\u5bf9\u8fdd\u6cd5\u6392\u6c61\u4f01\u4e1a\u7684\u67e5\u5904\u804c\u8d23\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u73af\u4fdd\u90e8\u95e8\u5374\u4ee5\u201c\u6848\u4ef6\u590d\u6742\u201d\u4e3a\u7531\u8fdf\u8fdf\u672a\u91c7\u53d6\u884c\u52a8\uff0c\u6700\u7ec8\u5bfc\u81f4\u5c45\u6c11\u6743\u76ca\u53d7\u635f\uff0c\u590d\u8bae\u51b3\u5b9a\u672a\u80fd\u53d1\u6325\u5e94\u6709\u7684\u4f5c\u7528\u3002\n\n\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u6709\u65f6\u672a\u80fd\u5145\u5206\u8003\u8651\u6848\u4ef6\u7684\u5177\u4f53\u60c5\u51b5\uff0c\u5bfc\u81f4\u51b3\u5b9a\u7f3a\u4e4f\u9488\u5bf9\u6027\u548c\u53ef\u64cd\u4f5c\u6027\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u571f\u5730\u5f81\u6536\u8865\u507f\u6848\u4ef6\u65f6\uff0c\u672a\u5145\u5206\u8c03\u67e5\u8865\u507f\u6807\u51c6\u662f\u5426\u5408\u7406\uff0c\u76f4\u63a5\u8d23\u4ee4\u76f8\u5173\u90e8\u95e8\u5c65\u884c\u8865\u507f\u4e49\u52a1\uff0c\u7ed3\u679c\u56e0\u8865\u507f\u6807\u51c6\u8fc7\u4f4e\u5f15\u53d1\u7fa4\u4f17\u4e0d\u6ee1\uff0c\u5bfc\u81f4\u540e\u7eed\u793e\u4f1a\u77db\u76fe\u5347\u7ea7\u3002\u8fd9\u8868\u660e\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u51b3\u5b9a\u65f6\uff0c\u5e94\u66f4\u52a0\u6ce8\u91cd\u4e8b\u5b9e\u8c03\u67e5\u548c\u6cd5\u5f8b\u9002\u7528\u7684\u51c6\u786e\u6027\u3002\n\n\u6700\u540e\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u76d1\u7763\u673a\u5236\u5c1a\u4e0d\u5b8c\u5584\uff0c\u7f3a\u4e4f\u5bf9\u6267\u884c\u60c5\u51b5\u7684\u8ddf\u8e2a\u548c\u53cd\u9988\u3002\u90e8\u5206\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u51b3\u5b9a\u540e\uff0c\u672a\u5bf9\u51b3\u5b9a\u7684\u6267\u884c\u60c5\u51b5\u8fdb\u884c\u6709\u6548\u8ddf\u8e2a\uff0c\u5bfc\u81f4\u90e8\u5206\u51b3\u5b9a\u6d41\u4e8e\u5f62\u5f0f\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u4fe1\u606f\u516c\u5f00\u6848\u4ef6\u540e\uff0c\u672a\u5bf9\u76f8\u5173\u90e8\u95e8\u662f\u5426\u5c65\u884c\u4fe1\u606f\u516c\u5f00\u4e49\u52a1\u8fdb\u884c\u540e\u7eed\u76d1\u7763\uff0c\u7ed3\u679c\u76f8\u5173\u90e8\u95e8\u4ecd\u672a\u516c\u5f00\u76f8\u5173\u4fe1\u606f\uff0c\u5bfc\u81f4\u884c\u653f\u590d\u8bae\u7684\u5b9e\u6548\u6027\u5927\u6253\u6298\u6263\u3002\n\ndocument \u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5b8c\u5584\u9700\u8981\u4ece\u6cd5\u5f8b\u9002\u7528\u3001\u6267\u884c\u76d1\u7763\u3001\u6848\u4ef6\u8c03\u67e5\u548c\u540e\u7eed\u8ddf\u8e2a\u7b49\u65b9\u9762\u5165\u624b\uff0c\u4ee5\u63d0\u5347\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u548c\u5b9e\u6548\u6027\u3002\u53ea\u6709\u901a\u8fc7\u52a0\u5f3a\u5236\u5ea6\u5efa\u8bbe\uff0c\u624d\u80fd\u66f4\u597d\u5730\u4fdd\u969c\u516c\u6c11\u7684\u5408\u6cd5\u6743\u76ca\uff0c\u63a8\u52a8\u4f9d\u6cd5\u884c\u653f\u7684\u6df1\u5165\u5b9e\u65bd\u3002"
}
{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u662f\u73b0\u4ee3\u822a\u7a7a\u5de5\u7a0b\u4e0e\u751f\u7269\u79d1\u5b66\u4ea4\u53c9\u9886\u57df\u7684\u91cd\u8981\u7814\u7a76\u65b9\u5411\u3002\u7ffc\u578b\uff0c\u5373\u673a\u7ffc\u7684\u6a2a\u622a\u9762\u5f62\u72b6\uff0c\u662f\u98de\u884c\u5668\u5347\u529b\u4ea7\u751f\u7684\u5173\u952e\u56e0\u7d20\u4e4b\u4e00\u3002\u5176\u8bbe\u8ba1\u76f4\u63a5\u5f71\u54cd\u98de\u884c\u5668\u7684\u6c14\u52a8\u6027\u80fd\uff0c\u5305\u62ec\u5347\u529b\u3001\u963b\u529b\u3001\u7a33\u5b9a\u6027\u4ee5\u53ca\u71c3\u6cb9\u6548\u7387\u7b49\u3002\u4f20\u7edf\u7684\u7ffc\u578b\u8bbe\u8ba1\u4e3b\u8981\u4f9d\u8d56\u4e8e\u7a7a\u6c14\u52a8\u529b\u5b66\u7406\u8bba\u548c\u5b9e\u9a8c\u6570\u636e\uff0c\u4f46\u8fd1\u5e74\u6765\uff0c\u968f\u7740\u4eff\u751f\u5b66\u7684\u5174\u8d77\uff0c\u7814\u7a76\u4eba\u5458\u5f00\u59cb\u4ece\u81ea\u7136\u754c\u4e2d\u5bfb\u627e\u7075\u611f\uff0c\u4ee5\u4f18\u5316\u7ffc\u578b\u8bbe\u8ba1\u5e76\u63d0\u9ad8\u98de\u884c\u5668\u7684\u6027\u80fd\u3002\n\n\u4eff\u751f\u5b66\u662f\u4e00\u95e8\u7814\u7a76\u751f\u7269\u7cfb\u7edf\u5e76\u5c06\u5176\u539f\u7406\u5e94\u7528\u4e8e\u5de5\u7a0b\u548c\u79d1\u6280\u7684\u5b66\u79d1\u3002\u81ea\u7136\u754c\u4e2d\u5b58\u5728\u5927\u91cf\u4e0e\u98de\u884c\u76f8\u5173\u7684\u751f\u7269\uff0c\u5982\u9e1f\u7c7b\u3001\u6606\u866b\u548c\u9c7c\u7c7b\uff0c\u5b83\u4eec\u5728\u6f2b\u957f\u7684\u8fdb\u5316\u8fc7\u7a0b\u4e2d\u5f62\u6210\u4e86\u9ad8\u6548\u7684\u98de\u884c\u673a\u5236\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7684\u7fc5\u8180\u5177\u6709\u590d\u6742\u7684\u6c14\u6d41\u63a7\u5236\u80fd\u529b\uff0c\u80fd\u591f\u5b9e\u73b0\u9ad8\u6548\u7684\u5347\u529b\u751f\u6210\u548c\u673a\u52a8\u6027\u3002\u8fd9\u4e9b\u7279\u6027\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u3002\u901a\u8fc7\u7814\u7a76\u9e1f\u7c7b\u7fc5\u8180\u7684\u5f62\u72b6\u3001\u8fd0\u52a8\u65b9\u5f0f\u4ee5\u53ca\u8868\u9762\u7ed3\u6784\uff0c\u5de5\u7a0b\u5e08\u4eec\u80fd\u591f\u8bbe\u8ba1\u51fa\u66f4\u63a5\u8fd1\u81ea\u7136\u7684\u7ffc\u578b\uff0c\u4ece\u800c\u63d0\u9ad8\u98de\u884c\u5668\u7684\u6c14\u52a8\u6548\u7387\u3002\n\n\u5728\u5b9e\u9645\u5e94\u7528\u4e2d\uff0c\u4eff\u751f\u5b66\u5df2\u88ab\u7528\u4e8e\u6539\u8fdb\u7ffc\u578b\u8bbe\u8ba1\u3002\u4f8b\u5982\uff0c\u7814\u7a76\u4eba\u5458\u53d1\u73b0\uff0c\u9e1f\u7c7b\u7fc5\u8180\u8fb9\u7f18\u7684\u952f\u9f7f\u72b6\u7ed3\u6784\u80fd\u591f\u51cf\u5c11\u6da1\u6d41\u7684\u5f62\u6210\uff0c\u4ece\u800c\u964d\u4f4e\u963b\u529b\u5e76\u63d0\u9ad8\u5347\u529b\u3002\u8fd9\u4e00\u53d1\u73b0\u4fc3\u4f7f\u5de5\u7a0b\u5e08\u5728\u7ffc\u578b\u8fb9\u7f18\u8bbe\u8ba1\u7c7b\u4f3c\u7684\u7ed3\u6784\uff0c\u4ee5\u4f18\u5316\u6c14\u6d41\u5206\u5e03\u3002\u6b64\u5916\uff0c\u6606\u866b\u7fc5\u8180\u7684\u67d4\u6027\u7ed3\u6784\u4e5f\u542f\u53d1\u4e86\u65b0\u578b\u7ffc\u578b\u6750\u6599\u7684\u7814\u53d1\uff0c\u4f7f\u5176\u80fd\u591f\u9002\u5e94\u590d\u6742\u7684\u6c14\u6d41\u73af\u5883\uff0c\u63d0\u9ad8\u98de\u884c\u7a33\u5b9a\u6027\u3002\n\n\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u4e0d\u4ec5\u9650\u4e8e\u4f20\u7edf\u822a\u7a7a\u9886\u57df\uff0c\u8fd8\u62d3\u5c55\u5230\u4e86\u65e0\u4eba\u673a\u3001\u5fae\u578b\u98de\u884c\u5668\u4ee5\u53ca\u9ad8\u901f\u98de\u884c\u5668\u7684\u8bbe\u8ba1\u4e2d\u3002\u4f8b\u5982\uff0c\u4e00\u4e9b\u73b0\u4ee3\u65e0\u4eba\u673a\u91c7\u7528\u4e86\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\uff0c\u4f7f\u5176\u5728\u4f4e\u901f\u98de\u884c\u65f6\u5177\u6709\u66f4\u9ad8\u7684\u64cd\u63a7\u6027\u548c\u7a33\u5b9a\u6027\u3002\u540c\u65f6\uff0c\u4eff\u751f\u5b66\u8fd8\u4e3a\u53ef\u53d8\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u601d\u8def\uff0c\u4f7f\u98de\u884c\u5668\u80fd\u591f\u5728\u4e0d\u540c\u98de\u884c\u6761\u4ef6\u4e0b\u81ea\u52a8\u8c03\u6574\u7ffc\u578b\u5f62\u72b6\uff0c\u4ee5\u9002\u5e94\u4e0d\u540c\u7684\u6c14\u6d41\u73af\u5883\u3002\n\n\u7136\u800c\uff0c\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u4ecd\u9762\u4e34\u8bf8\u591a\u6311\u6218\u3002\u9996\u5148\uff0c\u751f\u7269\u7cfb\u7edf\u7684\u590d\u6742\u6027\u4f7f\u5f97\u5c06\u5176\u539f\u7406\u5b8c\u5168\u5e94\u7528\u4e8e\u5de5\u7a0b\u8bbe\u8ba1\u5e76\u4e0d\u5bb9\u6613\u3002\u5176\u6b21\uff0c\u4eff\u751f\u8bbe\u8ba1\u5f80\u5f80\u9700\u8981\u590d\u6742\u7684\u8ba1\u7b97\u6a21\u578b\u548c\u5b9e\u9a8c\u9a8c\u8bc1\uff0c\u589e\u52a0\u4e86\u7814\u53d1\u6210\u672c\u548c\u65f6\u95f4\u3002\u6b64\u5916\uff0c\u4eff\u751f\u7ed3\u6784\u7684\u5236\u9020\u5de5\u827a\u4e5f\u9762\u4e34\u6280\u672f\u96be\u9898\uff0c\u5c24\u5176\u662f\u5728\u6750\u6599\u9009\u62e9\u548c\u52a0\u5de5\u7cbe\u5ea6\u65b9\u9762\u3002\n\n\u5c3d\u7ba1\u5982\u6b64\uff0c\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e3a\u672a\u6765\u822a\u7a7a\u6280\u672f\u7684\u53d1\u5c55\u63d0\u4f9b\u4e86\u5e7f\u9614\u524d\u666f\u3002\u968f\u7740\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\uff08CFD\uff09\u548c\u5148\u8fdb\u5236\u9020\u6280\u672f\u7684\u8fdb\u6b65\uff0c\u4eff\u751f"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u8bf8\u591a\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u548c\u76d1\u7763\u673a\u5236\u4e0d\u5065\u5168\u7b49\u65b9\u9762\u3002\u90e8\u5206\u884c\u653f\u673a\u5173\u5bf9\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u91cd\u89c6\uff0c\u5bfc\u81f4\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u6d41\u4e8e\u5f62\u5f0f\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u5c40\u5bf9\u67d0\u4f01\u4e1a\u6c61\u67d3\u884c\u4e3a\u8fdb\u884c\u590d\u8bae\u540e\uff0c\u8d23\u4ee4\u5176\u9650\u671f\u6574\u6539\uff0c\u4f46\u8be5\u4f01\u4e1a\u5e76\u672a\u6309\u671f\u6267\u884c\uff0c\u800c\u73af\u4fdd\u5c40\u4e5f\u672a\u91c7\u53d6\u6709\u6548\u63aa\u65bd\u8fdb\u884c\u7763\u4fc3\uff0c\u6700\u7ec8\u5bfc\u81f4\u73af\u5883\u95ee\u9898\u6301\u7eed\u5b58\u5728\u3002\u8fd9\u79cd\u73b0\u8c61\u53cd\u6620\u51fa\u590d\u8bae\u51b3\u5b9a\u7684\u6743\u5a01\u6027\u548c\u6267\u884c\u529b\u6709\u5f85\u52a0\u5f3a\u3002\n\n\u6b64\u5916\uff0c\u590d\u8bae\u673a\u5173\u5728\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u4e2d\u7684\u76d1\u7763\u4f5c\u7528\u672a\u80fd\u5145\u5206\u53d1\u6325\u3002\u7531\u4e8e\u884c\u653f\u590d\u8bae\u7a0b\u5e8f\u672c\u8eab\u5177\u6709\u5185\u90e8\u76d1\u7763\u7684\u6027\u8d28\uff0c\u590d\u8bae\u673a\u5173\u5728\u51b3\u5b9a\u4f5c\u51fa\u540e\u7f3a\u4e4f\u6709\u6548\u7684\u540e\u7eed\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u4e00\u4e9b\u51b3\u5b9a\u672a\u80fd\u5f97\u5230\u843d\u5b9e\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u6559\u80b2\u5c40\u5728\u590d\u8bae\u4e2d\u8d23\u4ee4\u67d0\u5b66\u6821\u9650\u671f\u6539\u5584\u529e\u5b66\u6761\u4ef6\uff0c\u4f46\u590d\u8bae\u673a\u5173\u672a\u5bf9\u5b66\u6821\u6574\u6539\u60c5\u51b5\u8fdb\u884c\u8ddf\u8e2a\u68c0\u67e5\uff0c\u81f4\u4f7f\u6574\u6539\u5de5\u4f5c\u672a\u80fd\u6709\u6548\u63a8\u8fdb\u3002\u8fd9\u79cd\u76d1\u7763\u7f3a\u4f4d\u524a\u5f31\u4e86\u590d\u8bae\u51b3\u5b9a\u7684\u5b9e\u9645\u6548\u679c\u3002\n\n\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u548c\u6807\u51c6\u4e5f\u5b58\u5728\u6a21\u7cca\u4e4b\u5904\uff0c\u5bfc\u81f4\u90e8\u5206\u6848\u4ef6\u4e2d\u51b3\u5b9a\u7684\u4f5c\u51fa\u7f3a\u4e4f\u7edf\u4e00\u6027\u548c\u89c4\u8303\u6027\u3002\u4f8b\u5982\uff0c\u5728\u6d89\u53ca\u571f\u5730\u5f81\u6536\u7684\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u6709\u65f6\u96be\u4ee5\u51c6\u786e\u754c\u5b9a\u884c\u653f\u673a\u5173\u662f\u5426\u5c65\u884c\u4e86\u6cd5\u5b9a\u804c\u8d23\uff0c\u4ece\u800c\u5f71\u54cd\u51b3\u5b9a\u7684\u516c\u6b63\u6027\u548c\u6743\u5a01\u6027\u3002\u8fd9\u79cd\u6807\u51c6\u4e0d\u660e\u786e\u7684\u95ee\u9898\uff0c\u5bb9\u6613\u5f15\u53d1\u884c\u653f\u4e89\u8bae\uff0c\u964d\u4f4e\u884c\u653f\u590d\u8bae\u7684\u516c\u4fe1\u529b\u3002\n\n\u9488\u5bf9\u4e0a\u8ff0\u95ee\u9898\uff0c\u6709\u5fc5\u8981\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\uff0c\u660e\u786e\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u7a0b\u5e8f\u548c\u76d1\u7763\u673a\u5236\uff0c\u540c\u65f6\u52a0\u5f3a\u590d\u8bae\u673a\u5173\u7684\u6267\u6cd5\u80fd\u529b\u3002\u6b64\u5916\uff0c\u5e94\u63a8\u52a8\u8de8\u90e8\u95e8\u534f\u4f5c\uff0c\u5efa\u7acb\u4fe1\u606f\u5171\u4eab\u548c\u8054\u5408\u7763\u67e5\u673a\u5236\uff0c\u786e\u4fdd\u590d\u8bae\u51b3\u5b9a\u5f97\u5230\u6709\u6548\u843d\u5b9e\u3002\u901a\u8fc7\u5236\u5ea6\u5efa\u8bbe\u548c\u6267\u884c\u5f3a\u5316\uff0c\u624d\u80fd\u63d0\u5347\u884c\u653f\u590d\u8bae\u7684\u5b9e\u6548\u6027\uff0c\u66f4\u597d\u5730\u7ef4\u62a4\u516c\u6c11\u7684\u5408\u6cd5\u6743\u76ca\u3002\n\ndocument \u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5b8c\u5584\u9700\u8981\u4ece\u6cd5\u5f8b\u5236\u5ea6\u548c\u5b9e\u8df5\u64cd\u4f5c\u4e24\u65b9\u9762\u5165\u624b\u3002\u9996\u5148\uff0c\u5e94\u7ec6\u5316\u76f8\u5173\u6cd5\u5f8b\u6761\u6587\uff0c\u660e\u786e\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5177\u4f53\u9002\u7528\u6761\u4ef6\u548c\u6267\u884c\u7a0b\u5e8f\uff0c\u907f\u514d\u56e0\u6807\u51c6\u6a21\u7cca\u800c\u5bfc\u81f4\u7684\u6267\u6cd5\u4e0d\u7edf\u4e00\u3002\u5176\u6b21\uff0c\u5e94\u52a0\u5f3a\u590d\u8bae\u673a\u5173\u7684\u76d1\u7763\u804c\u80fd\uff0c\u5efa\u7acb\u5b9a\u671f\u56de\u8bbf\u548c\u8ddf\u8e2a\u68c0\u67e5\u673a\u5236\uff0c\u786e\u4fdd\u51b3\u5b9a\u843d\u5b9e\u5230\u4f4d\u3002\u6b64\u5916\uff0c\u63a8\u52a8\u4fe1\u606f\u5316\u5efa\u8bbe\uff0c\u5b9e\u73b0\u884c\u653f\u590d\u8bae\u4e0e\u884c\u653f\u6267\u6cd5\u4fe1\u606f\u7684\u4e92\u8054\u4e92\u901a\uff0c\u4e5f\u6709\u52a9\u4e8e\u63d0\u9ad8\u6267\u884c\u6548\u7387\u3002\u901a\u8fc7\u591a\u65b9\u9762\u7684\u6539\u9769\uff0c\u624d\u80fd\u63d0\u5347\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u548c\u6267\u884c\u529b\uff0c\u66f4\u597d\u5730\u5b9e\u73b0\u5176\u76d1\u7763\u548c\u7ea0\u9519\u529f\u80fd\u3002"
}
{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u878d\u5408\u662f\u73b0\u4ee3\u822a\u7a7a\u5de5\u7a0b\u4e0e\u751f\u7269\u79d1\u5b66\u4ea4\u53c9\u9886\u57df\u7684\u91cd\u8981\u7814\u7a76\u65b9\u5411\u3002\u968f\u7740\u79d1\u6280\u7684\u53d1\u5c55\uff0c\u4eba\u7c7b\u5bf9\u98de\u884c\u5668\u6027\u80fd\u7684\u8981\u6c42\u4e0d\u65ad\u63d0\u9ad8\uff0c\u4f20\u7edf\u7684\u7ffc\u578b\u8bbe\u8ba1\u5df2\u96be\u4ee5\u6ee1\u8db3\u590d\u6742\u73af\u5883\u4e0b\u7684\u9ad8\u6548\u98de\u884c\u9700\u6c42\u3002\u56e0\u6b64\uff0c\u4eff\u751f\u5b66\u4f5c\u4e3a\u4e00\u95e8\u7814\u7a76\u751f\u7269\u7cfb\u7edf\u7ed3\u6784\u4e0e\u529f\u80fd\u7684\u79d1\u5b66\uff0c\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u4e0e\u65b9\u6cd5\u3002\n\n\u4eff\u751f\u5b66\u6e90\u4e8e\u5bf9\u81ea\u7136\u754c\u4e2d\u751f\u7269\u98de\u884c\u673a\u5236\u7684\u89c2\u5bdf\u4e0e\u6a21\u4eff\u3002\u9e1f\u7c7b\u3001\u6606\u866b\u7b49\u751f\u7269\u5728\u957f\u671f\u8fdb\u5316\u8fc7\u7a0b\u4e2d\u5f62\u6210\u4e86\u9ad8\u5ea6\u4f18\u5316\u7684\u98de\u884c\u7ed3\u6784\uff0c\u8fd9\u4e9b\u7ed3\u6784\u5728\u7a7a\u6c14\u52a8\u529b\u5b66\u65b9\u9762\u8868\u73b0\u51fa\u5353\u8d8a\u7684\u6027\u80fd\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7fc5\u8180\u7684\u67d4\u6027\u7ed3\u6784\u80fd\u591f\u6709\u6548\u9002\u5e94\u6c14\u6d41\u53d8\u5316\uff0c\u63d0\u9ad8\u98de\u884c\u7a33\u5b9a\u6027\uff1b\u6606\u866b\u7fc5\u8180\u7684\u590d\u6742\u7eb9\u7406\u548c\u632f\u52a8\u9891\u7387\u5219\u6709\u52a9\u4e8e\u5728\u4f4e\u901f\u98de\u884c\u4e2d\u4ea7\u751f\u8db3\u591f\u7684\u5347\u529b\u3002\u8fd9\u4e9b\u751f\u7269\u7279\u5f81\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u4e30\u5bcc\u7684\u7075\u611f\u3002\n\n\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\uff0c\u4eff\u751f\u5b66\u7684\u5e94\u7528\u4e3b\u8981\u4f53\u73b0\u5728\u4e24\u4e2a\u65b9\u9762\uff1a\u4e00\u662f\u5bf9\u751f\u7269\u98de\u884c\u7ed3\u6784\u7684\u76f4\u63a5\u6a21\u4eff\uff0c\u4e8c\u662f\u5bf9\u751f\u7269\u98de\u884c\u673a\u5236\u7684\u539f\u7406\u6027\u501f\u9274\u3002\u524d\u8005\u5982\u4eff\u751f\u7ffc\u578b\u7684\u5f00\u53d1\uff0c\u901a\u8fc7\u6a21\u4eff\u9e1f\u7c7b\u6216\u6606\u866b\u7fc5\u8180\u7684\u5f62\u72b6\u4e0e\u7ed3\u6784\uff0c\u4f18\u5316\u7ffc\u578b\u7684\u5347\u963b\u6bd4\u548c\u6c14\u52a8\u6027\u80fd\uff1b\u540e\u8005\u5219\u901a\u8fc7\u7814\u7a76\u751f\u7269\u98de\u884c\u7684\u6d41\u4f53\u529b\u5b66\u539f\u7406\uff0c\u5982\u6da1\u6d41\u751f\u6210\u4e0e\u63a7\u5236\uff0c\u6765\u6539\u8fdb\u4f20\u7edf\u7ffc\u578b\u7684\u8bbe\u8ba1\u7406\u5ff5\u3002\n\n\u8fd1\u5e74\u6765\uff0c\u968f\u7740\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\uff08CFD\uff09\u548c\u5148\u8fdb\u5236\u9020\u6280\u672f\u7684\u53d1\u5c55\uff0c\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\u9010\u6e10\u4ece\u7406\u8bba\u7814\u7a76\u8d70\u5411\u5b9e\u9645\u5e94\u7528\u3002\u4f8b\u5982\uff0cNASA\u548c\u591a\u5bb6\u822a\u7a7a\u516c\u53f8\u5728\u7814\u7a76\u4e2d\u91c7\u7528\u4eff\u751f\u5b66\u539f\u7406\u8bbe\u8ba1\u51fa\u5177\u6709\u67d4\u6027\u7ed3\u6784\u7684\u7ffc\u578b\uff0c\u4f7f\u5176\u5728\u4e0d\u540c\u98de\u884c\u72b6\u6001\u4e0b\u80fd\u591f\u81ea\u52a8\u8c03\u6574\u5f62\u72b6\uff0c\u4ece\u800c\u63d0\u9ad8\u98de\u884c\u6548\u7387\u3002\u6b64\u5916\uff0c\u4eff\u751f\u5b66\u8fd8\u88ab\u5e94\u7528\u4e8e\u65e0\u4eba\u673a\u548c\u5fae\u578b\u98de\u884c\u5668\u7684\u8bbe\u8ba1\uff0c\u4f7f\u5176\u5177\u5907\u66f4\u5f3a\u7684\u673a\u52a8\u6027\u548c\u9002\u5e94\u6027\u3002\n\n\u7136\u800c\uff0c\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u4ecd\u9762\u4e34\u8bf8\u591a\u6311\u6218\u3002\u9996\u5148\uff0c\u751f\u7269\u7cfb\u7edf\u7684\u590d\u6742\u6027\u4f7f\u5f97\u5176\u539f\u7406\u96be\u4ee5\u5b8c\u5168\u8f6c\u5316\u4e3a\u5de5\u7a0b\u8bbe\u8ba1\uff1b\u5176\u6b21\uff0c\u4eff\u751f\u7ed3\u6784\u7684\u5236\u9020\u6210\u672c\u8f83\u9ad8\uff0c\u4e14\u9700\u8981\u517c\u987e\u7ed3\u6784\u5f3a\u5ea6\u4e0e\u8f7b\u91cf\u5316\u9700\u6c42\u3002\u56e0\u6b64\uff0c\u672a\u6765\u7684\u7814\u7a76\u9700\u8981\u8fdb\u4e00\u6b65\u63a2\u7d22\u751f\u7269\u673a\u5236\u4e0e\u5de5\u7a0b\u6750\u6599\u7684\u7ed3\u5408\uff0c\u4ee5\u53ca\u591a\u5b66\u79d1\u4ea4\u53c9\u7684\u534f\u540c\u521b\u65b0\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e3a\u98de\u884c\u5668\u6027\u80fd\u7684\u63d0\u5347\u63d0\u4f9b\u4e86\u65b0\u7684\u53ef\u80fd\u6027\u3002\u901a\u8fc7\u501f\u9274\u751f\u7269\u98de\u884c\u7684\u667a\u6167\uff0c\u4eba\u7c7b\u80fd\u591f\u7a81\u7834\u4f20\u7edf\u8bbe\u8ba1\u7684\u5c40\u9650\uff0c\u5f00\u53d1\u51fa\u66f4\u52a0\u9ad8\u6548\u3001\u667a\u80fd\u7684\u98de\u884c\u5668\u3002\u8fd9\u4e00\u9886\u57df\u7684\u6301\u7eed\u53d1\u5c55\u4e0d\u4ec5\u5c06\u63a8\u52a8\u822a\u7a7a\u6280\u672f\u7684\u8fdb\u6b65\uff0c\u4e5f\u5c06\u4e3a\u5176\u4ed6\u5de5\u7a0b\u9886\u57df\u5e26\u6765\u6df1\u8fdc\u5f71\u54cd\u3002\u98de\u884c\u3002"
}
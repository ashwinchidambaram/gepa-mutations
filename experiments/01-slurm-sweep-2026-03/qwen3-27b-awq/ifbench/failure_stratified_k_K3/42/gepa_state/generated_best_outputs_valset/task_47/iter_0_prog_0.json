{
    "response": "\u7ffc\u578b\n\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u5728\u822a\u7a7a\u5de5\u7a0b\u9886\u57df\u5c55\u73b0\u51fa\u6df1\u523b\u7684\u5185\u5728\u8054\u7cfb\uff0c\u901a\u8fc7\u6a21\u62df\u81ea\u7136\u754c\u4e2d\u9e1f\u7c7b\u3001\u6606\u866b\u53ca\u6c34\u751f\u751f\u7269\u7684\u98de\u884c\u6216\u6e38\u52a8\u673a\u5236\uff0c\u5de5\u7a0b\u5e08\u4eec\u80fd\u591f\u4f18\u5316\u673a\u7ffc\u7684\u51e0\u4f55\u5f62\u6001\u4e0e\u6c14\u52a8\u6027\u80fd\u3002\u4f8b\u5982\uff0c\u9e70\u7ffc\u7684\u5c55\u5f26\u6bd4\u548c\u5f2f\u5ea6\u4e3a\u6ed1\u7fd4\u673a\u63d0\u4f9b\u4e86\u4f4e\u963b\u9ad8\u5347\u529b\u7684\u8bbe\u8ba1\u7075\u611f\uff0c\u800c\u873b\u8713\u7fc5\u8180\u7684\u98a4\u632f\u7279\u6027\u5219\u542f\u53d1\u4e86\u5fae\u578b\u98de\u884c\u5668\u7684\u63a7\u5236\u7b56\u7565\u3002\u8fd9\u79cd\u8de8\u5b66\u79d1\u7684\u7814\u7a76\u4e0d\u4ec5\u63d0\u5347\u4e86\u98de\u884c\u5668\u7684\u6548\u7387\uff0c\u8fd8\u63a8\u52a8\u4e86\u6750\u6599\u79d1\u5b66\u4e0e\u6d41\u4f53\u529b\u5b66\u7684\u878d\u5408\u521b\u65b0\uff0c\u4f7f\u73b0\u4ee3\u822a\u7a7a\u5668\u5728\u590d\u6742\u73af\u5883\u4e2d\u5177\u5907\u66f4\u5f3a\u7684\u9002\u5e94\u6027\u4e0e\u7a33\u5b9a\u6027\u3002\u968f\u7740\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\u4e0e\u4eba\u5de5\u667a\u80fd\u7b97\u6cd5\u7684\u8fdb\u6b65\uff0c\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\u6b63\u8fc8\u5411\u66f4\u9ad8\u7cbe\u5ea6\u7684\u5b9a\u5236\u5316\u9636\u6bb5\uff0c\u4e3a\u672a\u6765\u7eff\u8272\u822a\u7a7a\u4e0e\u57ce\u5e02\u7a7a\u4e2d\u4ea4\u901a\u5960\u5b9a\u575a\u5b9e\u7406\u8bba\u57fa\u7840\u3002\u7ffc\u578b"
}
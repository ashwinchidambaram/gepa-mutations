{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u4fdd\u969c\u516c\u6c11\u6743\u76ca\u65b9\u9762\u53d1\u6325\u4e86\u91cd\u8981\u4f5c\u7528\uff0c\u4f46\u5728\u5b9e\u9645\u6267\u884c\u8fc7\u7a0b\u4e2d\u4ecd\u9762\u4e34\u8bf8\u591a\u6311\u6218\u3002\u90e8\u5206\u884c\u653f\u673a\u5173\u5bf9\u590d\u8bae\u51b3\u5b9a\u7f3a\u4e4f\u8db3\u591f\u7684\u91cd\u89c6\uff0c\u5bfc\u81f4\u8d23\u4ee4\u5c65\u884c\u7684\u5185\u5bb9\u672a\u80fd\u53ca\u65f6\u843d\u5b9e\u3002\u8fd9\u79cd\u73b0\u8c61\u4e0d\u4ec5\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\uff0c\u4e5f\u5f71\u54cd\u4e86\u516c\u4f17\u5bf9\u6cd5\u6cbb\u653f\u5e9c\u7684\u4fe1\u4efb\u3002\n\n\u4ee5\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u672a\u4f9d\u6cd5\u516c\u5f00\u73af\u5883\u4fe1\u606f\u4e3a\u4f8b\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5176\u9650\u671f\u516c\u5f00\u7684\u51b3\u5b9a\uff0c\u4f46\u8be5\u90e8\u95e8\u4ee5\u5185\u90e8\u5ba1\u6279\u6d41\u7a0b\u590d\u6742\u4e3a\u7531\u62d6\u5ef6\u6267\u884c\u3002\u6b64\u7c7b\u60c5\u51b5\u53cd\u6620\u51fa\u884c\u653f\u673a\u5173\u5728\u5e94\u5bf9\u590d\u8bae\u51b3\u5b9a\u65f6\u5b58\u5728\u63a8\u8bff\u585e\u8d23\u7684\u5fc3\u6001\uff0c\u7f3a\u4e4f\u4e3b\u52a8\u5c65\u884c\u7684\u8d23\u4efb\u610f\u8bc6\u3002\u540c\u65f6\uff0c\u590d\u8bae\u51b3\u5b9a\u4e2d\u5173\u4e8e\u5c65\u884c\u671f\u9650\u548c\u5177\u4f53\u65b9\u5f0f\u7684\u8868\u8ff0\u6709\u65f6\u4e0d\u591f\u660e\u786e\uff0c\u7ed9\u540e\u7eed\u6267\u884c\u5e26\u6765\u64cd\u4f5c\u4e0a\u7684\u56f0\u96be\u3002\n\n\u53e6\u4e00\u4e2a\u5178\u578b\u6848\u4f8b\u6d89\u53ca\u793e\u4fdd\u7ecf\u529e\u673a\u6784\u672a\u4f9d\u6cd5\u53d1\u653e\u629a\u6064\u91d1\uff0c\u590d\u8bae\u673a\u5173\u8d23\u4ee4\u5176\u9650\u671f\u652f\u4ed8\uff0c\u4f46\u673a\u6784\u4ee5\u8d44\u91d1\u672a\u5230\u4f4d\u4e3a\u7531\u62d2\u7edd\u6267\u884c\u3002\u8fd9\u66b4\u9732\u51fa\u5f53\u524d\u5236\u5ea6\u5728\u76d1\u7763\u673a\u5236\u4e0a\u7684\u4e0d\u8db3\uff0c\u7f3a\u4e4f\u6709\u6548\u7684\u5f3a\u5236\u624b\u6bb5\u6765\u786e\u4fdd\u51b3\u5b9a\u843d\u5730\u3002\u82e5\u6ca1\u6709\u914d\u5957\u7684\u95ee\u8d23\u63aa\u65bd\uff0c\u884c\u653f\u673a\u5173\u53ef\u80fd\u9009\u62e9\u6d88\u6781\u5e94\u5bf9\uff0c\u4f7f\u5f97\u590d\u8bae\u51b3\u5b9a\u6ca6\u4e3a\u5f62\u5f0f\u4e0a\u7684\u6587\u4e66\uff0c\u65e0\u6cd5\u771f\u6b63\u89e3\u51b3\u7533\u8bf7\u4eba\u7684\u8bc9\u6c42\u3002\n\ndocument \u5e94\u5f53\u6210\u4e3a\u89c4\u8303\u884c\u653f\u590d\u8bae\u6267\u884c\u7684\u91cd\u8981\u8f7d\u4f53\uff0c\u901a\u8fc7\u660e\u786e\u8d23\u4efb\u4e3b\u4f53\u3001\u7ec6\u5316\u5c65\u884c\u6807\u51c6\u548c\u5f3a\u5316\u76d1\u7763\u673a\u5236\u6765\u63d0\u5347\u51b3\u5b9a\u6548\u529b\u3002\u672a\u6765\u9700\u8981\u4ece\u7acb\u6cd5\u5c42\u9762\u5b8c\u5584\u76f8\u5173\u7a0b\u5e8f\uff0c\u5efa\u7acb\u4e13\u95e8\u7684\u6267\u884c\u8ddf\u8e2a\u4f53\u7cfb\uff0c\u5e76\u5f15\u5165\u7b2c\u4e09\u65b9\u8bc4\u4f30\u673a\u5236\uff0c\u786e\u4fdd\u6bcf\u4e00\u7eb8\u51b3\u5b9a\u90fd\u80fd\u8f6c\u5316\u4e3a\u5b9e\u9645\u7684\u6cd5\u5f8b\u6548\u679c\u3002\u53ea\u6709\u5982\u6b64\uff0c\u624d\u80fd\u771f\u6b63\u5b9e\u73b0\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7ef4\u62a4\u516c\u5e73\u6b63\u4e49\u7684\u521d\u8877\u3002"
}
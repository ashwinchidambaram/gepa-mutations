{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u4e2d\u7684\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u7406\u8bba\u4e0a\u65e8\u5728\u7763\u4fc3\u884c\u653f\u673a\u5173\u4f9d\u6cd5\u5c65\u804c\uff0c\u4f46\u5728\u5b9e\u8df5\u4e2d\u5e38\u9762\u4e34\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u7684\u95ee\u9898\u3002\u8bb8\u591a\u60c5\u51b5\u4e0b\uff0c\u590d\u8bae\u673a\u5173\u867d\u7136\u4f5c\u51fa\u4e86\u8981\u6c42\u88ab\u7533\u8bf7\u4eba\u5c65\u884c\u804c\u8d23\u7684\u51b3\u5b9a\uff0c\u4f46\u7f3a\u4e4f\u6709\u6548\u7684\u540e\u7eed\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u90e8\u5206\u884c\u653f\u673a\u5173\u91c7\u53d6\u6d88\u6781\u5bf9\u6297\u6216\u53d8\u76f8\u62d6\u5ef6\u7684\u7b56\u7565\uff0c\u4f7f\u5f97\u884c\u653f\u76f8\u5bf9\u4eba\u7684\u5408\u6cd5\u6743\u76ca\u65e0\u6cd5\u5f97\u5230\u53ca\u65f6\u6551\u6d4e\u3002\n\n\u4ee5\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u4e3a\u4f8b\uff0c\u5f53\u516c\u6c11\u7533\u8bf7\u516c\u5f00\u73af\u5883\u76d1\u6d4b\u6570\u636e\u65f6\uff0c\u82e5\u8be5\u90e8\u95e8\u65e0\u6b63\u5f53\u7406\u7531\u62d2\u7edd\uff0c\u590d\u8bae\u673a\u5173\u867d\u53ef\u8d23\u4ee4\u5176\u9650\u671f\u516c\u5f00\uff0c\u4f46\u5b9e\u9645\u6267\u884c\u4e2d\u5f80\u5f80\u51fa\u73b0\u6570\u636e\u516c\u5f00\u4e0d\u5b8c\u6574\u6216\u65f6\u95f4\u4e25\u91cd\u6ede\u540e\u7684\u60c5\u51b5\u3002\u6b64\u7c7b\u4e8b\u4f8b\u53cd\u6620\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u7f3a\u4e4f\u660e\u786e\u8fdd\u7ea6\u8d23\u4efb\u548c\u5f3a\u5236\u6267\u884c\u624b\u6bb5\u7684\u80cc\u666f\u4e0b\uff0c\u5bb9\u6613\u6d41\u4e8e\u5f62\u5f0f\uff0c\u96be\u4ee5\u5bf9\u884c\u653f\u673a\u5173\u5f62\u6210\u5b9e\u8d28\u6027\u7684\u7ea6\u675f\u529b\u3002\n\n\u6b64\u5916\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5185\u5bb9\u6709\u65f6\u8fc7\u4e8e\u7b3c\u7edf\uff0c\u672a\u5bf9\u5c65\u884c\u7684\u5177\u4f53\u65b9\u5f0f\u3001\u6807\u51c6\u6216\u671f\u9650\u4f5c\u51fa\u8be6\u5c3d\u89c4\u5b9a\uff0c\u7ed9\u884c\u653f\u673a\u5173\u7559\u4e0b\u4e86\u8f83\u5927\u7684\u81ea\u7531\u88c1\u91cf\u7a7a\u95f4\u3002\u8fd9\u79cd\u6a21\u7cca\u6027\u4f7f\u5f97\u884c\u653f\u673a\u5173\u53ef\u4ee5\u501f\u53e3\u5ba2\u89c2\u6761\u4ef6\u9650\u5236\u6216\u5185\u90e8\u6d41\u7a0b\u590d\u6742\u800c\u89c4\u907f\u8d23\u4efb\uff0c\u8fdb\u800c\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u89e3\u51b3\u884c\u653f\u4e89\u8bae\u7684\u529f\u80fd\u548c\u516c\u4fe1\u529b\u3002\n\ndocument \u9700\u8981\u8fdb\u4e00\u6b65\u901a\u8fc7\u7acb\u6cd5\u5b8c\u5584\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u4fdd\u969c\u673a\u5236\uff0c\u660e\u786e\u903e\u671f\u4e0d\u5c65\u884c\u7684\u6cd5\u5f8b\u540e\u679c\uff0c\u5e76\u5efa\u7acb\u5e38\u6001\u5316\u7684\u8ddf\u8e2a\u7763\u529e\u4f53\u7cfb\uff0c\u4ee5\u786e\u4fdd\u590d\u8bae\u51b3\u5b9a\u80fd\u591f\u771f\u6b63\u843d\u5730\u89c1\u6548\uff0c\u4ece\u800c\u63d0\u5347\u884c\u653f\u6cd5\u6cbb\u7684\u6574\u4f53\u6c34\u5e73\u3002"
}
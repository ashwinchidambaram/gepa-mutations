{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u878d\u5408\u4e86\u7a7a\u6c14\u52a8\u529b\u5b66\u539f\u7406\u4e0e\u4eff\u751f\u5b66\u7075\u611f\uff0c\u901a\u8fc7\u6a21\u4eff\u9e1f\u7c7b\u3001\u6606\u866b\u53ca\u6d77\u6d0b\u751f\u7269\u7684\u81ea\u7136\u5f62\u6001\uff0c\u663e\u8457\u63d0\u5347\u4e86\u98de\u884c\u5668\u7684\u6548\u7387\u4e0e\u7a33\u5b9a\u6027\u3002\u81ea\u7136\u754c\u4e2d\u7684\u751f\u7269\u7ecf\u8fc7\u6570\u767e\u4e07\u5e74\u7684\u8fdb\u5316\uff0c\u6f14\u5316\u51fa\u6781\u5177\u4f18\u5316\u7684\u7ffc\u578b\u7ed3\u6784\uff0c\u5982\u9e70\u7684\u5bbd\u5927\u7fc5\u8180\u9002\u5408\u6ed1\u7fd4\uff0c\u8702\u9e1f\u7684\u7075\u6d3b\u632f\u7fc5\u5b9e\u73b0\u60ac\u505c\uff0c\u8fd9\u4e9b\u7279\u5f81\u4e3a\u73b0\u4ee3\u822a\u7a7a\u5de5\u7a0b\u63d0\u4f9b\u4e86\u5b9d\u8d35\u7684\u8bbe\u8ba1\u53c2\u8003\u3002\u7814\u7a76\u4eba\u5458\u5229\u7528\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\u6a21\u62df\u548c\u5b9e\u9a8c\u9a8c\u8bc1\uff0c\u5c06\u751f\u7269\u7ffc\u578b\u7684\u975e\u5b9a\u5e38\u6c14\u52a8\u7279\u6027\u5e94\u7528\u4e8e\u65e0\u4eba\u673a\u3001\u98ce\u529b\u6da1\u8f6e\u673a\u53ca\u56fa\u5b9a\u7ffc\u98de\u673a\uff0c\u6709\u6548\u964d\u4f4e\u4e86\u80fd\u8017\u5e76\u589e\u5f3a\u4e86\u64cd\u63a7\u6027\u80fd\u3002\u672a\u6765\uff0c\u968f\u7740\u6750\u6599\u79d1\u5b66\u4e0e\u4eba\u5de5\u667a\u80fd\u7684\u53d1\u5c55\uff0c\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\u5c06\u5728\u7eff\u8272\u822a\u7a7a\u9886\u57df\u53d1\u6325\u66f4\u5173\u952e\u7684\u4f5c\u7528\uff0c\u63a8\u52a8\u4eba\u7c7b\u4ea4\u901a\u65b9\u5f0f\u5411\u66f4\u9ad8\u6548\u3001\u66f4\u73af\u4fdd\u7684\u65b9\u5411\u6f14\u8fdb\u3002\u7ffc\u578b\u8bbe\u8ba1"
}
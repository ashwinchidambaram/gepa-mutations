{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u8fd0\u884c\u4e2d\u5e38\u9762\u4e34\u6cd5\u5f8b\u4f9d\u636e\u6a21\u7cca\u4e0e\u88c1\u91cf\u6743\u8fc7\u5927\u7684\u95ee\u9898\uff0c\u5bfc\u81f4\u90e8\u5206\u884c\u653f\u673a\u5173\u5728\u6536\u5230\u51b3\u5b9a\u540e\u4ecd\u6d88\u6781\u5e94\u5bf9\u6216\u53d8\u76f8\u62d6\u5ef6\u3002\n\n\u5177\u4f53\u4e8b\u4f8b\u663e\u793a\uff0c\u5f53\u590d\u8bae\u673a\u5173\u8d23\u4ee4\u67d0\u5730\u89c4\u5212\u90e8\u95e8\u5c65\u884c\u4fe1\u606f\u516c\u5f00\u804c\u8d23\u65f6\uff0c\u8be5\u90e8\u95e8\u53ef\u80fd\u4ee5\u8d44\u6599\u6574\u7406\u9700\u8981\u65f6\u95f4\u4e3a\u7531\u957f\u671f\u6401\u7f6e\uff0c\u800c\u590d\u8bae\u51b3\u5b9a\u672c\u8eab\u7f3a\u4e4f\u660e\u786e\u7684\u5c65\u884c\u671f\u9650\u7ea6\u675f\u673a\u5236\u3002\n\n\u8fd9\u79cd\u6267\u884c\u56f0\u5883\u53cd\u6620\u51fa\u5f53\u524d\u5236\u5ea6\u5728\u76d1\u7763\u95ed\u73af\u4e0a\u7684\u4e0d\u8db3\uff0c\u4f7f\u5f97\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u6709\u65f6\u6ca6\u4e3a\u7a0b\u5e8f\u6027\u7a7a\u8f6c\uff0c\u672a\u80fd\u6709\u6548\u8f6c\u5316\u4e3a\u5b9e\u8d28\u6027\u7684\u884c\u653f\u4f5c\u4e3a\u3002\n\ndocument \u4f5c\u4e3a\u884c\u653f\u6cd5\u5f8b\u6587\u4e66\u7684\u6838\u5fc3\u8f7d\u4f53\uff0c\u5176\u89c4\u8303\u6027\u4e0e\u5f3a\u5236\u529b\u4e9f\u9700\u901a\u8fc7\u7acb\u6cd5\u7ec6\u5316\u4e0e\u53f8\u6cd5\u5ba1\u67e5\u7684\u5f3a\u5316\u6765\u52a0\u4ee5\u63d0\u5347\uff0c\u4ee5\u786e\u4fdd\u516c\u6c11\u6743\u76ca\u5f97\u5230\u5207\u5b9e\u4fdd\u969c\u3002"
}
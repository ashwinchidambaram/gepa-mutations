{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u4e2d\u7684\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u7406\u8bba\u8bbe\u8ba1\u4e0a\u65e8\u5728\u7763\u4fc3\u884c\u653f\u673a\u5173\u4f9d\u6cd5\u5c65\u804c\uff0c\u4f46\u5728\u5b9e\u9645\u8fd0\u884c\u4e2d\u5374\u9762\u4e34\u6267\u884c\u6548\u529b\u4e0d\u8db3\u7684\u95ee\u9898\u3002\u8bb8\u591a\u60c5\u51b5\u4e0b\uff0c\u590d\u8bae\u673a\u5173\u867d\u7136\u4f5c\u51fa\u4e86\u8d23\u4ee4\u5c65\u884c\u7684\u51b3\u5b9a\uff0c\u4f46\u88ab\u7533\u8bf7\u4eba\u5f80\u5f80\u91c7\u53d6\u62d6\u5ef6\u6218\u672f\u6216\u53d8\u76f8\u62d2\u7edd\u6267\u884c\uff0c\u5bfc\u81f4\u7533\u8bf7\u4eba\u7684\u5408\u6cd5\u6743\u76ca\u957f\u671f\u5904\u4e8e\u60ac\u800c\u672a\u51b3\u7684\u72b6\u6001\u3002\u8fd9\u79cd\u6267\u884c\u96be\u7684\u73b0\u8c61\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u4f5c\u4e3a\u6743\u5229\u6551\u6d4e\u6e20\u9053\u7684\u6743\u5a01\u6027\u548c\u516c\u4fe1\u529b\u3002\n\n\u4ee5\u67d0\u5730\u516c\u6c11\u7533\u8bf7\u653f\u5e9c\u4fe1\u606f\u516c\u5f00\u4e3a\u4f8b\uff0c\u590d\u8bae\u673a\u5173\u66fe\u4f5c\u51fa\u8d23\u4ee4\u76f8\u5173\u90e8\u95e8\u9650\u671f\u516c\u5f00\u7279\u5b9a\u6587\u4ef6\u7684\u51b3\u5b9a\uff0c\u4f46\u8be5\u90e8\u95e8\u4ee5\u5185\u90e8\u5ba1\u6279\u6d41\u7a0b\u590d\u6742\u4e3a\u7531\uff0c\u5728\u6cd5\u5b9a\u671f\u9650\u5c4a\u6ee1\u540e\u4ecd\u672a\u63d0\u4f9b\u4fe1\u606f\u3002\u5c3d\u7ba1\u590d\u8bae\u51b3\u5b9a\u4e66\u5df2\u7ecf\u751f\u6548\uff0c\u7533\u8bf7\u4eba\u4ecd\u9700\u901a\u8fc7\u6f2b\u957f\u7684\u8bc9\u8bbc\u7a0b\u5e8f\u624d\u80fd\u6700\u7ec8\u83b7\u5f97\u6240\u9700\u8d44\u6599\uff0c\u8fd9\u53cd\u6620\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7f3a\u4e4f\u521a\u6027\u7684\u5f3a\u5236\u6267\u884c\u624b\u6bb5\u3002\u6b64\u7c7b\u6848\u4f8b\u8868\u660e\uff0c\u5f53\u884c\u653f\u673a\u5173\u7f3a\u4e4f\u5185\u5728\u52a8\u529b\u65f6\uff0c\u5355\u7eaf\u7684\u547d\u4ee4\u5f0f\u51b3\u5b9a\u96be\u4ee5\u4ea7\u751f\u5b9e\u9645\u6548\u679c\u3002\n\n\u5f53\u524d\u5236\u5ea6\u8bbe\u8ba1\u4e2d\u5bf9\u62d2\u4e0d\u5c65\u884c\u590d\u8bae\u51b3\u5b9a\u7684\u8d23\u4efb\u8ffd\u7a76\u673a\u5236\u5c1a\u663e\u8584\u5f31\uff0c\u5bfc\u81f4\u8fdd\u6cd5\u6210\u672c\u8fc7\u4f4e\u3002\u867d\u7136\u6cd5\u5f8b\u89c4\u5b9a\u4e86\u76f8\u5173\u5904\u7f5a\u63aa\u65bd\uff0c\u4f46\u5728\u5b9e\u8df5\u4e2d\uff0c\u5bf9\u8d23\u4efb\u4eba\u7684\u884c\u653f\u5904\u5206\u5f80\u5f80\u6d41\u4e8e\u5f62\u5f0f\uff0c\u672a\u80fd\u5f62\u6210\u6709\u6548\u7684\u9707\u6151\u4f5c\u7528\u3002\u6b64\u5916\uff0c\u590d\u8bae\u673a\u5173\u4e0e\u4f5c\u51fa\u539f\u884c\u653f\u884c\u4e3a\u7684\u673a\u5173\u4e4b\u95f4\u5b58\u5728\u884c\u653f\u96b6\u5c5e\u5173\u7cfb\uff0c\u8fd9\u79cd\u4f53\u5236\u4e0a\u7684\u5173\u8054\u4f7f\u5f97\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\u53ef\u80fd\u987e\u8651\u91cd\u91cd\uff0c\u5f71\u54cd\u4e86\u51b3\u5b9a\u7684\u72ec\u7acb\u6027\u548c\u4e25\u8083\u6027\u3002\n\ndocument \u6539\u9769\u5e94\u5f53\u4ece\u5f3a\u5316\u6267\u884c\u76d1\u7763\u548c\u5b8c\u5584\u8ffd\u8d23\u673a\u5236\u4e24\u65b9\u9762\u5165\u624b\uff0c\u4ee5\u63d0\u5347\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5b9e\u9645\u6548\u80fd\u3002\u901a\u8fc7\u5efa\u7acb\u72ec\u7acb\u7684\u6267\u884c\u76d1\u7763\u673a\u6784\u6216\u5f15\u5165\u53f8\u6cd5\u5f3a\u5236\u6267\u884c\u7a0b\u5e8f\uff0c\u53ef\u4ee5\u6253\u7834\u884c\u653f\u673a\u5173\u5185\u90e8\u7684\u4fdd\u62a4\u4e3b\u4e49\u58c1\u5792\u3002\u540c\u65f6\uff0c\u5e94\u660e\u786e\u5177\u4f53\u7684\u6cd5\u5f8b\u8d23\u4efb\u6807\u51c6\uff0c\u786e\u4fdd\u5bf9\u62d2\u4e0d\u5c65\u884c\u884c\u4e3a\u7684\u5904\u7406\u80fd\u591f\u771f\u6b63\u89e6\u53ca\u8d23\u4efb\u4eba\uff0c\u4ece\u800c\u5012\u903c\u884c\u653f\u673a\u5173\u4f9d\u6cd5\u53ca\u65f6\u5c65\u884c\u804c\u8d23\uff0c\u5207\u5b9e\u7ef4\u62a4\u516c\u6c11\u7684\u5408\u6cd5\u6743\u76ca\u3002"
}
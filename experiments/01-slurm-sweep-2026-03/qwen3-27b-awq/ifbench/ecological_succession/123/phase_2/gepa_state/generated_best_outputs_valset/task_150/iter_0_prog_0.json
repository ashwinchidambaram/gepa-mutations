{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u8fc7\u7a0b\u4e2d\u9762\u4e34\u6267\u884c\u96be\u7684\u95ee\u9898\uff0c\u90e8\u5206\u884c\u653f\u673a\u5173\u5bf9\u590d\u8bae\u51b3\u5b9a\u7f3a\u4e4f\u8db3\u591f\u7684\u91cd\u89c6\uff0c\u5bfc\u81f4\u6cd5\u5b9a\u804c\u8d23\u672a\u80fd\u53ca\u65f6\u843d\u5b9e\u3002\u8fd9\u79cd\u73b0\u8c61\u5f80\u5f80\u6e90\u4e8e\u884c\u653f\u4f53\u7cfb\u5185\u90e8\u7684\u5c42\u7ea7\u538b\u529b\u4e0e\u8003\u6838\u673a\u5236\u7684\u4e0d\u5b8c\u5584\uff0c\u4f7f\u5f97\u88ab\u7533\u8bf7\u673a\u5173\u5728\u9762\u5bf9\u4e0a\u7ea7\u590d\u8bae\u673a\u5173\u7684\u8d23\u4ee4\u65f6\uff0c\u9009\u62e9\u6d88\u6781\u5e94\u5bf9\u6216\u62d6\u5ef6\u6267\u884c\u3002\n\n\u5177\u4f53\u4e8b\u4f8b\u663e\u793a\uff0c\u5728\u6d89\u53ca\u653f\u5e9c\u4fe1\u606f\u516c\u5f00\u6216\u793e\u4f1a\u4fdd\u969c\u91d1\u53d1\u653e\u7684\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u867d\u7136\u4f5c\u51fa\u4e86\u8d23\u4ee4\u5c65\u884c\u7684\u51b3\u5b9a\uff0c\u4f46\u88ab\u7533\u8bf7\u4eba\u4ecd\u53ef\u80fd\u4ee5\u5404\u79cd\u7406\u7531\u63a8\u8bff\uff0c\u5982\u58f0\u79f0\u5185\u90e8\u6d41\u7a0b\u590d\u6742\u6216\u8d44\u6599\u7f3a\u5931\u3002\u8fd9\u79cd\u62d6\u5ef6\u884c\u4e3a\u4e0d\u4ec5\u635f\u5bb3\u4e86\u7533\u8bf7\u4eba\u7684\u5408\u6cd5\u6743\u76ca\uff0c\u4e5f\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u4f5c\u4e3a\u6743\u5229\u6551\u6d4e\u6e20\u9053\u7684\u6743\u5a01\u6027\u548c\u516c\u4fe1\u529b\uff0c\u4f7f\u5f97\u6cd5\u5f8b\u89c4\u5b9a\u7684\u65f6\u9650\u5f62\u540c\u865a\u8bbe\u3002\n\n\u5236\u5ea6\u8bbe\u8ba1\u4e0a\u5bf9\u4e8e\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u540e\u7eed\u76d1\u7763\u63aa\u65bd\u76f8\u5bf9\u8584\u5f31\uff0c\u7f3a\u4e4f\u6709\u6548\u7684\u5f3a\u5236\u624b\u6bb5\u6765\u786e\u4fdd\u51b3\u5b9a\u7684\u5373\u65f6\u6267\u884c\u3002\u5f53\u884c\u653f\u673a\u5173\u62d2\u4e0d\u5c65\u884c\u6216\u4e0d\u5b8c\u5168\u5c65\u884c\u65f6\uff0c\u590d\u8bae\u673a\u5173\u5f80\u5f80\u53ea\u80fd\u518d\u6b21\u4f5c\u51fa\u51b3\u5b9a\u6216\u5efa\u8bae\u4e0a\u7ea7\u673a\u5173\u7763\u529e\uff0c\u4f46\u7f3a\u4e4f\u76f4\u63a5\u7684\u5f3a\u5236\u6267\u884c\u6743\uff0c\u5bfc\u81f4\u6551\u6d4e\u7a0b\u5e8f\u9677\u5165\u5faa\u73af\u5f80\u590d\u7684\u56f0\u5883\uff0c\u96be\u4ee5\u4ece\u6839\u672c\u4e0a\u89e3\u51b3\u884c\u653f\u4e0d\u4f5c\u4e3a\u7684\u987d\u75be\u3002\n\ndocument \u5e94\u5f53\u5efa\u7acb\u66f4\u4e3a\u4e25\u683c\u7684\u95ee\u8d23\u673a\u5236\u548c\u72ec\u7acb\u7684\u76d1\u7763\u4f53\u7cfb\uff0c\u4ee5\u5f3a\u5316\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6cd5\u5f8b\u7ea6\u675f\u529b\u3002\u901a\u8fc7\u660e\u786e\u4e0d\u5c65\u884c\u51b3\u5b9a\u7684\u6cd5\u5f8b\u540e\u679c\uff0c\u5c06\u6267\u884c\u60c5\u51b5\u7eb3\u5165\u884c\u653f\u7ee9\u6548\u8003\u6838\uff0c\u5e76\u5f15\u5165\u53f8\u6cd5\u5ba1\u67e5\u4f5c\u4e3a\u6700\u7ec8\u4fdd\u969c\uff0c\u53ef\u4ee5\u6709\u6548\u63d0\u5347\u884c\u653f\u673a\u5173\u7684\u5c65\u804c\u79ef\u6781\u6027\uff0c\u4ece\u800c\u771f\u6b63\u53d1\u6325\u884c\u653f\u590d\u8bae\u5728\u5316\u89e3\u884c\u653f\u4e89\u8bae\u4e2d\u7684\u4e3b\u6e20\u9053\u4f5c\u7528\u3002"
}
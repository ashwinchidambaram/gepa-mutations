{
    "response": "\u5927\u578b\u516c\u53f8\u6b63\u79ef\u6781\u62e5\u62b1\u6570\u636e\u5206\u6790\uff0c\u4f46\u5927\u591a\u6570\u4ecd\u672a\u80fd\u5efa\u7acb\u6570\u636e\u9a71\u52a8\u7684\u6587\u5316  \n\u4f5c\u8005\uff1a\u6258\u9a6c\u65af\u00b7H\u00b7\u8fbe\u6587\u6ce2\u7279 \u548c \u5170\u8fea\u00b7\u6bd4\u5b89  \n\n\u8fde\u7eed\u516d\u5e74\uff0c\u65b0\u4f18\u52bf\u5408\u4f5c\u4f19\u4f34\u516c\u53f8\u5f00\u5c55\u4e86\u4e00\u9879\u5e74\u5ea6\u8c03\u67e5\uff0c\u4e86\u89e3\u5927\u578b\u4f01\u4e1a\u9ad8\u7ba1\u5bf9\u6570\u636e\u7684\u770b\u6cd5\u3002\u4eca\u5e74\u7684\u7ed3\u679c\u663e\u793a\uff0c\u51e0\u4e4e\u6240\u6709\u516c\u53f8\u90fd\u5728\u6295\u8d44\u67d0\u79cd\u5f62\u5f0f\u7684\u6570\u636e\u5206\u6790\uff0c\u4e14\u5927\u591a\u6570\u5df2\u4ece\u4e2d\u83b7\u5f97\u4ef7\u503c\u3002\u7136\u800c\uff0c\u4ec5\u6709\u4e09\u5206\u4e4b\u4e00\u7684\u516c\u53f8\u8868\u793a\u6210\u529f\u5efa\u7acb\u4e86\u6570\u636e\u9a71\u52a8\u7684\u6587\u5316\u3002\u8bb8\u591a\u516c\u53f8\u62c5\u5fc3\u4f1a\u88ab\u66f4\u5584\u4e8e\u5229\u7528\u4eba\u5de5\u667a\u80fd\u7684\u4f01\u4e1a\u6240\u98a0\u8986\u3002\u8fd1\u4e94\u5206\u4e4b\u56db\u7684\u53d7\u8bbf\u8005\u8868\u793a\uff0c\u4ed6\u4eec\u62c5\u5fc3\u6765\u81ea\u91d1\u878d\u79d1\u6280\u9886\u57df\u6216\u4e13\u6ce8\u4e8e\u5927\u6570\u636e\u7684\u516c\u53f8\u7684\u98a0\u8986\u6216\u53d6\u4ee3\u3002  \n\n\u88ab\u666e\u904d\u8ba4\u4e3a\u6700\u5177\u98a0\u8986\u6027\u7684\u6280\u672f\u662f\u4eba\u5de5\u667a\u80fd\u2014\u2014\u8fdc\u8d85\u5176\u4ed6\u6280\u672f\u300272% \u7684\u53d7\u8bbf\u8005\u5c06\u5176\u9009\u4e3a\u5f71\u54cd\u6700\u5927\u7684\u98a0\u8986\u6027\u6280\u672f\uff0c\u8fdc\u9ad8\u4e8e\u4e91\u8ba1\u7b97\uff0813%\uff09\u548c\u533a\u5757\u94fe\uff087%\uff09\u3002  \n\n\u65b0\u4f18\u52bf\u5408\u4f5c\u4f19\u4f34\u516c\u53f8\u8fde\u7eed\u516d\u5e74\u5f00\u5c55\u6b64\u9879\u5e74\u5ea6\u8c03\u67e5\uff0c\u6bcf\u5e74\u8c03\u67e5\u7684\u56de\u590d\u7387\u90fd\u5728\u4e0a\u5347\uff0c\u4f01\u4e1a\u5bf9\u6709\u6548\u5229\u7528\u6570\u636e\u7684\u7d27\u8feb\u611f\u4e5f\u65e5\u76ca\u589e\u5f3a\u3002\u4eca\u5e74\u7684\u7ed3\u679c\u6bd4\u4ee5\u5f80\u66f4\u52a0\u4ee4\u4eba\u9f13\u821e\uff0c\u540c\u65f6\u4e5f\u66f4\u4ee4\u4eba\u62c5\u5fe7\u3002\u516d\u5e74\u524d\uff0c\u8c03\u67e5\u7684\u91cd\u70b9\u662f\u5f53\u65f6\u5c1a\u5c5e\u65b0\u5174\u7684\u201c\u5927\u6570\u636e\u201d\uff1b\u800c 2018 \u5e74\u7684\u8c03\u67e5\u5219\u5df2\u5c06\u5173\u6ce8\u70b9\u8f6c\u5411\u4eba\u5de5\u667a\u80fd\u3002\u5982\u4eca\uff0c\u4eba\u5de5\u667a\u80fd\u5df2\u6210\u4e3a\u8fd9\u4e9b\u5927\u578b\u3001\u6210\u719f\u4f01\u4e1a\u7684\u6838\u5fc3\u7126\u70b9\u3002\u4f01\u4e1a\u4e0d\u4ec5\u66f4\u786e\u4fe1\u5927\u6570\u636e\u548c\u4eba\u5de5\u667a\u80fd\u9879\u76ee\u80fd\u5e26\u6765\u4ef7\u503c\uff0c\u4e5f\u66f4\u52a0\u62c5\u5fe7\u73b0\u6709\u4f01\u4e1a\u4f1a\u88ab\u521d\u521b\u516c\u53f8\u98a0\u8986\u3002  \n\n\u672c\u6b21\u8c03\u67e5\u6db5\u76d6\u4e86\u6765\u81ea 57 \u5bb6\u5927\u578b\u4f01\u4e1a\u7684 senior \u9ad8\u7ba1\u3002\u5176\u4e2d\uff0c\u6570\u636e\u5bc6\u96c6\u578b\u884c\u4e1a\u2014\u2014\u91d1\u878d\u670d\u52a1\u9886\u57df\u7684\u4f01\u4e1a\u53c2\u4e0e\u6700\u591a\uff0c\u751f\u547d\u79d1\u5b66\u3001\u5236\u9020\u4e1a\u3001\u7535\u4fe1\u4e1a\u548c\u5728\u7ebf\u884c\u4e1a\u7684\u4f01\u4e1a\u4e5f\u53c2\u4e0e\u4e86\u8c03\u67e5\u3002\u4e0e\u65e9\u671f\u8c03\u67e5\u76f8\u6bd4\uff0c\u53d7\u8bbf\u8005\u7684\u6784\u6210\u6709\u6240\u53d8\u5316\uff1a\u8c03\u67e5\u59cb\u7ec8\u5305\u542b\u5927\u91cf\u8d1f\u8d23\u6570\u636e\u4e8b\u52a1\u7684\u9ad8\u7ba1\uff0c\u4f46\u4eca\u5e74\u9996\u5e2d\u6570\u636e\u5b98\uff08CDO\uff09\u5360\u53d7\u8bbf\u8005\u7684 56%\uff0c\u9ad8\u4e8e\u53bb\u5e74\u7684 32%\u3002\u800c\u5728 2012 \u5e74\u7684\u8c03\u67e5\u4e2d\uff0c\u4ec5\u6709 12% \u7684\u516c\u53f8\u4efb\u547d\u4e86\u9996\u5e2d\u6570\u636e\u5b98\u3002  \n\n\u5c3d\u7ba1\u4eba\u5de5\u667a\u80fd\u5728\u5404\u5730\u5907\u53d7\u77a9\u76ee\uff0c\u672c\u6b21\u8c03\u67e5\u540c\u65f6\u6db5\u76d6\u4e86\u5927\u6570\u636e\u548c\u4eba\u5de5\u667a\u80fd\u3002\u672f\u8bed\u6765\u6765\u53bb\u53bb\uff0c\u4f46\u4e0d\u53d8\u7684\u662f\u6570\u636e\u7684\u7206\u70b8\u5f0f\u589e\u957f\u4ee5\u53ca\u5bf9\u5176\u52a0\u4ee5\u7406\u89e3\u7684\u8feb\u5207\u9700\u6c42\u3002\u5927\u6570\u636e\u4e0e\u4eba\u5de5\u667a\u80fd\u9879\u76ee\u5df2\u51e0\u4e4e\u96be\u4ee5\u533a\u5206\uff0c\u5c24\u5176\u662f\u673a\u5668\u5b66\u4e60\u5df2\u6210\u4e3a\u5904\u7406\u6d77\u91cf\u3001\u9ad8\u901f\u6d41\u52a8\u6570\u636e\u7684\u6700\u6d41\u884c\u6280\u672f\u4e4b\u4e00\u3002\u6b64\u5916\uff0c\u7edf\u8ba1\u578b\u4eba\u5de5\u667a\u80fd\u65b9\u6cd5\uff08\u5982\u6df1\u5ea6\u5b66\u4e60\uff09\u4e5f\u65e5\u76ca\u666e\u53ca\u3002\u56e0\u6b64\uff0c\u6211\u4eec\u5c06\u4f20\u7edf\u6570\u636e\u5206\u6790\u3001\u5927\u6570\u636e\u548c\u4eba\u5de5\u667a\u80fd\u89c6\u4e3a\u4e00\u4e2a\u8fde\u7eed\u4f53\u3002\u51e0\u4e4e\u6240\u6709\u53d7\u8bbf\u8005\uff0897%\uff09\u8868\u793a\u6b63\u5728\u6295\u8d44\u6b64\u7c7b\u9879\u76ee\u3002  \n\n\u672c\u6b21\u8c03\u67e5\u4e2d\u6700\u4ee4\u4eba\u632f\u594b\u7684\u6d88\u606f\u662f\uff0c\u4f01\u4e1a\u4ecd\u575a\u4fe1\u5176\u5927\u6570\u636e\u548c\u4eba\u5de5\u667a\u80fd\u9879\u76ee\u80fd\u5e26\u6765\u4ef7\u503c\u300273% \u7684\u53d7\u8bbf\u8005\u8868\u793a\u5df2\u4ece\u8fd9\u4e9b\u9879\u76ee\u4e2d\u83b7\u5f97\u53ef\u8861\u91cf\u7684\u4ef7\u503c\uff0c\u8fd9\u4e00"
}
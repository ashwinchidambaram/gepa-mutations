    "response": "( \u0645\u062b\u0627\u0644 \u0639\u0644\u0649 \u0627\u0644\u0642\u0636\u064a\u0629 \"\u0647\u0630\u0627 \u064a\u0633\u0628\u0628 \u062d\u0633\u0627\u0633\u064a\u0629 \u0641\u064a \u0627\u0644\u0642\u062f\u0645\" \u062a\u0642\u0648\u0644 \u0644\u064a\u0627\u0643 \u0633\u0627\u064a\u062f. \u0644\u064a\u0627\u0643 \u063a\u0648\u062f\u0641\u0631\u064a (4 \u0633\u0646\u0648\u0627\u062a)\u060c \u0645\u062a\u0631\u062f\u062f\u0629\u060c \u062a\u062e\u0641\u0651\u064a \u0631\u0623\u0633\u0647\u0627 \u0641\u064a \u0643\u0641 \u0645\u0627\u0645\u0647\u0627. \u0648\u0648\u0627\u0644\u062f\u062a\u0647\u0627 \u0627\u0644\u0635\u063a\u064a\u0631\u0629 \u062a\u062c\u0644\u0633 \u0641\u064a \u0645\u0642\u0639\u062f \u0635\u063a\u064a\u0631\u060c \u062a\u062c\u0644\u0633 \u0648\u062a\u0646\u0632\u0644 \u0642\u062f\u0645\u0647\u0627 \u0628\u0633\u0644\u0627\u0633\u0629. \"\u0623\u0648\u0647\u060c \u062f\u0647\" \u062a\u0642\u0648\u0644\u0643. \"\u0642\u062f \u062a\u062e\u0628\u0631\u0646\u064a \u0623\u0643\u062b\u0631\u061f\" \"\u0646\u0639\u0645\u060c \u0645\u0646\u0630 \u0642\u0644\u064a\u0644\u060c \u0643\u0627\u0646\u062a \u062a\u062d\u062f\u062b \u0645\u0646\u0630 \u062d\u0648\u0627\u0644\u064a 2 \u0623\u0634\u0647\u0631. \u0642\u0628\u0644 \u0630\u0644\u0643 \u0643\u0627\u0646\u062a \u0641\u064a \u0627\u0644\u0634\u0643\u0644 \u0627\u0644\u0637\u0628\u064a\u0639\u064a. \u0643\u0627\u0646\u062a \u062a\u0634\u0639\u0631 \u0628\u0627\u0644\u062d\u0631\u0627\u0631\u0629 \u062e\u0644\u0627\u0644 \u0627\u0644\u0646\u0647\u0627\u0631\u060c \u0644\u0643\u0646 \u0645\u0646\u0630 \u0628\u0639\u0636 \u0627\u0644\u0623\u0633\u0627\u0628\u064a\u0639 \u0627\u0644\u0623\u062e\u064a\u0631\u0629\u060c \u0643\u0627\u0646\u062a \u062a\u064f\u0633\u0642\u0637 \u0645\u0646 \u0627\u0644\u0646\u0648\u0645 \u0648\u062a\u0646\u0634\u0626 \u0641\u064a \u0627\u0644\u0644\u064a\u0644\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641\u0650\u0638\u062a \u0644\u0647\u0627 \u0641\u064a \u0627\u0644\u0646\u0648\u0645\u060c \u0648\u062d\u064f\u0641"

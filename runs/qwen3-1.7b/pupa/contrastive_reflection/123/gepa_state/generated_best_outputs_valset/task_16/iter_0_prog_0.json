    "response": "( \u0645\u062b\u0627\u0644 \u0639\u0644\u0649 \u0627\u0644\u0642\u0636\u064a\u0629: \"\u0643\u0627\u0646\u062a \u062a\u0641\u0627\u062d\u0629 \u0645\u063a\u064a\u0631\u0629\"\u060c \u062a\u0642\u0648\u0644 \u0644\u064a\u0627 \u0643\u0648\u0631\u0641\u064a (4 \u0633\u0646\u0648\u0627\u062a)\u060c \u0648\u0647\u064a \u062d\u0630\u0631\u0629\u060c \u062a\u062e\u0641\u0651\u064a \u0634\u0641\u062a\u064a\u0647\u0627 \u0641\u064a \u0641\u062e\u0627\u0645\u0629 \u0623\u0645\u0647. \u0648\u064a\u0639\u062a\u0642\u062f \u0623\u0646 \u0635\u0627\u062d\u0628\u0647\u0627 \u0635\u063a\u064a\u0631\u064b\u0627\u060c \u064a\u062c\u0644\u0633 \u0641\u064a \u0645\u0642\u0639\u062f \u0635\u063a\u064a\u0631\u060c \u064a\u0634\u062a\u062f\u0651 \u062d\u062f\u064a\u062b\u0647 \u0628\u0630\u0627\u062a\u0647. \"\u0623\u0647\u060c \u0623\u0647\"\u060c \u062a\u0642\u0648\u0644 \u0623\u0645\u0647 \u0644\u064a\u0627 \u0643\u0648\u0631\u0641\u064a. \"\u0647\u0644 \u062a\u0631\u063a\u0628 \u0641\u064a \u062a\u062d\u062f\u062b \u0623\u0643\u062b\u0631\u061f\" \"\u0628\u0627\u0644\u0637\u0628\u0639\u060c \u0641\u0642\u062f \u0643\u0627\u0646\u062a \u062a\u0641\u0627\u062d\u0629 \u0645\u063a\u064a\u0631\u0629 \u0645\u0646\u0630 \u062d\u0648\u0627\u0644\u064a 2 \u0623\u0634\u0647\u0631\u060c \u0642\u0628\u0644 \u0630\u0644\u0643 \u0643\u0627\u0646\u062a \u0645\u0631\u064a\u062d\u0629. \u0643\u0627\u0646\u062a \u062a\u0641\u0627\u062d\u0629 \u0645\u063a\u064a\u0631\u0629 \u062e\u0644\u0627\u0644 \u0627\u0644\u0646\u0647\u0627\u0631\u060c \u0648\u0644\u0643\u0646 \u0641\u064a \u0627\u0644\u0646\u0647\u0627\u0631 \u0627\u0644\u0623\u062e\u064a\u0631 \u0643\u0627\u0646\u062a \u062a\u0634\u0639\u0631 \u0628\u0627\u0644\u063a\u062b\u064a\u0627\u0646\u060c \u0648\u0628\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0623\u0646 \u0623\u8d77\u5e8a \u0648\u062a\u0637\u0647\u064a\u0631 \u0641\u0645\u0647\u0627 \u0642\u0628\u0644 \u0623\u0646 \u062a\u0647\u062f\u0623. \u0643\u0627\u0646\u062a \u0647\u0630\u0647 \u062a\u0634\u0639\u0631 \u0628\u0627\u0644\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0623\u0646 \u062a\u0637\u0647\u064a\u0631 \u0641\u0645\u0647\u0627 \u0628\u0634\u0643\u0644 \u0645\u0639\u062a\u062f\u0644. \u0643\u0627\u0646\u062a \u0647\u0630\u0647 \u062a\u0634\u0639\u0631 \u0628\u0627\u0644\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0623\u0646 \u062a\u0637\u0647\u064a\u0631 \u0641\u0645\u0647\u0627 \u0628\u0634\u0643\u0644 \u0645\u0639\u062a\u062f\u0644. \u0643\u0627\u0646\u062a \u0647\u0630\u0647 \u062a\u0634\u0639\u0631 \u0628\u0627\u0644\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0623\u0646 \u062a\u0637\u0647\u064a\u0631 \u0641\u0645\u0647\u0627 \u0628\u0634\u0643\u0644 \u0645\u0639\u062a\u062f\u0644. \u0643\u0627\u0646\u062a \u0647\u0630\u0647 \u062a\u0634\u0639\u0631 \u0628\u0627\u0644\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0623\u0646 \u062a\u0637\u0647\u064a\u0631 \u0641\u0645\u0647\u0627 \u0628\u0634\u0643\u0644 \u0645\u0639\u062a\u062f\u0644. \u0643\u0627\u0646\u062a \u0647\u0630\u0647 \u062a\u0634\u0639\u0631 \u0628\u0627\u0644\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0623\u0646 \u062a\u0637\u0647\u064a\u0631 \u0641\u0645\u0647\u0627 \u0628\u0634\u0643\u0644 \u0645\u0639\u062a\u062f\u0644. \u0643\u0627\u0646\u062a \u0647\u0630\u0647 \u062a\u0634\u0639\u0631 \u0628\u0627\u0644\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0623\u0646 \u062a\u0637\u0647\u064a\u0631 \u0641\u0645\u0647\u0627 \u0628\u0634\u0643\u0644 \u0645\u0639\u062a\u062f\u0644. \u0643\u0627\u0646\u062a \u0647\u0630\u0647 \u062a\u0634\u0639\u0631 \u0628\u0627\u0644\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0623\u0646 \u062a\u0637\u0647\u064a\u0631 \u0641\u0645\u0647\u0627 \u0628\u0634\u0643\u0644 \u0645\u0639\u062a\u062f\u0644. \u0643\u0627\u0646\u062a \u0647\u0630\u0647 \u062a\u0634\u0639\u0631 \u0628\u0627\u0644\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0623\u0646 \u062a\u0637\u0647\u064a\u0631 \u0641\u0645\u0647\u0627 \u0628\u0634\u0643\u0644 \u0645\u0639\u062a\u062f\u0644. \u0643\u0627\u0646\u062a \u0647\u0630\u0647 \u062a\u0634\u0639\u0631 \u0628\u0627\u0644\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0623\u0646 \u062a\u0637\u0647\u064a\u0631 \u0641\u0645\u0647\u0627 \u0628\u0634\u0643\u0644 \u0645\u0639\u062a\u062f\u0644. \u0643\u0627\u0646\u062a \u0647\u0630\u0647 \u062a\u0634\u0639\u0631 \u0628\u0627\u0644\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0623\u0646 \u062a\u0637\u0647\u064a\u0631 \u0641\u0645\u0647\u0627 \u0628\u0634\u0643\u0644 \u0645\u0639\u062a\u062f\u0644. \u0643\u0627\u0646\u062a \u0647\u0630\u0647 \u062a\u0634\u0639\u0631 \u0628\u0627\u0644\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0623\u0646 \u062a\u0637\u0647\u064a\u0631 \u0641\u0645\u0647\u0627 \u0628\u0634\u0643\u0644 \u0645\u0639\u062a\u062f\u0644. \u0643\u0627\u0646\u062a \u0647\u0630\u0647 \u062a\u0634\u0639\u0631 \u0628\u0627\u0644\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0623\u0646 \u062a\u0637\u0647\u064a\u0631 \u0641\u0645\u0647\u0627 \u0628\u0634\u0643\u0644 \u0645\u0639\u062a\u062f\u0644. \u0643\u0627\u0646\u062a \u0647\u0630\u0647 \u062a\u0634\u0639\u0631 \u0628\u0627\u0644\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0623\u0646 \u062a\u0637\u0647\u064a\u0631 \u0641\u0645\u0647\u0627 \u0628\u0634\u0643\u0644 \u0645\u0639\u062a\u062f\u0644. \u0643\u0627\u0646\u062a \u0647\u0630\u0647 \u062a\u0634\u0639\u0631 \u0628\u0627\u0644\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0623\u0646 \u062a\u0637\u0647\u064a\u0631 \u0641\u0645\u0647\u0627 \u0628\u0634\u0643\u0644 \u0645\u0639\u062a\u062f\u0644. \u0643\u0627\u0646\u062a \u0647\u0630\u0647 \u062a\u0634\u0639\u0631 \u0628\u0627\u0644\u062d\u0627\u062c\u0629 \u0625\u0644\u0649 \u0623\u0646 \u062a\u0637\u0647\u064a\u0631 \u0641\u0645\u0647\u0627 \u0628\u0634\u0643\u0644 \u0645\u0639\u062a\u062f\u0644. \u0643\u0627\u0646\u062a \u0647\u0630\u0647 \u062a\u0634\u0639\u0631 \u0628\u0627\u0644"
}
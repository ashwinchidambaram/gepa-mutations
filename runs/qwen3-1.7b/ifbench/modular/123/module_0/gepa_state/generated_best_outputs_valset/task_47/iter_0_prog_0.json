{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u8bba\u6587\n\n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u662f\u822a\u7a7a\u5de5\u7a0b\u4e0e\u751f\u7269\u79d1\u5b66\u4ea4\u53c9\u9886\u57df\u7684\u91cd\u8981\u7814\u7a76\u65b9\u5411\u3002\u7ffc\u578b\u8bbe\u8ba1\u65e8\u5728\u4f18\u5316\u98de\u884c\u5668\u7684\u5347\u529b\u3001\u963b\u529b\u548c\u6548\u7387\uff0c\u800c\u4eff\u751f\u5b66\u5219\u901a\u8fc7\u7814\u7a76\u81ea\u7136\u754c\u4e2d\u7684\u7ed3\u6784\u548c\u529f\u80fd\u6765\u542f\u53d1\u8bbe\u8ba1\u3002\u672c\u6587\u63a2\u8ba8\u4e86\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u7ed3\u5408\uff0c\u5206\u6790\u4e86\u81ea\u7136\u754c\u4e2d\u5177\u6709\u9ad8\u6548\u98de\u884c\u7279\u6027\u7684\u7ed3\u6784\uff0c\u5982\u9e1f\u7c7b\u7684\u7fc5\u8180\u3001\u6606\u866b\u7684\u7fc5\u8180\u4ee5\u53ca\u9c7c\u7c7b\u7684\u5c3e\u9ccd\uff0c\u8fd9\u4e9b\u7ed3\u6784\u5728\u6d41\u4f53\u529b\u5b66\u548c\u7a7a\u6c14\u52a8\u529b\u5b66\u4e2d\u5177\u6709\u91cd\u8981\u7684\u53c2\u8003\u4ef7\u503c\u3002\n\n\u5728\u81ea\u7136\u754c\u4e2d\uff0c\u9e1f\u7c7b\u7684\u7fc5\u8180\u901a\u8fc7\u590d\u6742\u7684\u5f62\u72b6\u548c\u8868\u9762\u7eb9\u7406\u5b9e\u73b0\u9ad8\u6548\u7684\u5347\u529b\u4ea7\u751f\u3002\u4f8b\u5982\uff0c\u9e70\u7684\u7fc5\u8180\u5177\u6709\u9ad8\u5347\u529b\u7cfb\u6570\u548c\u4f4e\u963b\u529b\uff0c\u800c\u71d5\u5b50\u7684\u7fc5\u8180\u5219\u5177\u6709\u9ad8\u6ed1\u7fd4\u6548\u7387\u3002\u4eff\u751f\u5b66\u7814\u7a76\u4e2d\uff0c\u79d1\u5b66\u5bb6\u4eec\u901a\u8fc7\u6a21\u4eff\u8fd9\u4e9b\u7ed3\u6784\uff0c\u5f00\u53d1\u51fa\u5177\u6709\u7c7b\u4f3c\u6027\u80fd\u7684\u7ffc\u578b\uff0c\u5982\u4eff\u9e70\u7ffc\u578b\u548c\u4eff\u71d5\u5b50\u7ffc\u578b\u3002\u8fd9\u4e9b\u7ffc\u578b\u5728\u98ce\u6d1e\u8bd5\u9a8c\u4e2d\u8868\u73b0\u51fa\u4f18\u5f02\u7684\u6027\u80fd\uff0c\u63d0\u9ad8\u4e86\u98de\u884c\u5668\u7684\u6548\u7387\u3002\n\n\u6606\u866b\u7684\u7fc5\u8180\u5219\u5c55\u793a\u4e86\u53e6\u4e00\u79cd\u9ad8\u6548\u7684\u98de\u884c\u673a\u5236\u3002\u4f8b\u5982\uff0c\u873b\u8713\u7684\u7fc5\u8180\u5177\u6709\u9ad8\u7075\u6d3b\u6027\u548c\u53ef\u53d8\u5f62\u72b6\uff0c\u80fd\u591f\u6839\u636e\u98de\u884c\u9700\u6c42\u8c03\u6574\u89d2\u5ea6\u548c\u5f62\u72b6\u3002\u4eff\u751f\u5b66\u7814\u7a76\u4e2d\uff0c\u79d1\u5b66\u5bb6\u4eec\u901a\u8fc7\u6a21\u4eff\u8fd9\u4e9b\u7ed3\u6784\uff0c\u5f00\u53d1\u51fa\u5177\u6709\u53ef\u53d8\u7ffc\u578b\u7684\u98de\u884c\u5668\uff0c\u63d0\u9ad8\u4e86\u98de\u884c\u5668\u7684\u9002\u5e94\u6027\u548c\u6548\u7387\u3002\n\n\u9c7c\u7c7b\u7684\u5c3e\u9ccd\u548c\u4f53\u5f62\u4e5f\u5bf9\u7ffc\u578b\u8bbe\u8ba1\u4ea7\u751f\u4e86\u91cd\u8981\u5f71\u54cd\u3002\u9c7c\u7c7b\u7684\u5c3e\u9ccd\u901a\u8fc7\u590d\u6742\u7684\u6d41\u4f53\u529b\u5b66\u7ed3\u6784\u5b9e\u73b0\u9ad8\u6548\u7684\u63a8\u8fdb\u548c\u64cd\u63a7\u3002\u4eff\u751f\u5b66\u7814\u7a76\u4e2d\uff0c\u79d1\u5b66\u5bb6\u4eec\u901a\u8fc7\u6a21\u4eff\u8fd9\u4e9b\u7ed3\u6784\uff0c\u5f00\u53d1\u51fa\u5177\u6709\u9ad8\u6548\u63a8\u8fdb\u548c\u64cd\u63a7\u80fd\u529b\u7684\u7ffc\u578b\uff0c\u63d0\u9ad8\u4e86\u98de\u884c\u5668\u7684\u6027\u80fd\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e3a\u98de\u884c\u5668\u7684\u9ad8\u6548\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u91cd\u8981\u7684\u7406\u8bba\u652f\u6301\u548c\u5b9e\u8df5\u6307\u5bfc\u3002\u901a\u8fc7\u7814\u7a76\u81ea\u7136\u754c\u4e2d\u7684\u9ad8\u6548\u7ed3\u6784\uff0c\u79d1\u5b66\u5bb6\u4eec\u80fd\u591f\u5f00\u53d1\u51fa\u5177\u6709\u4f18\u5f02\u6027\u80fd\u7684\u7ffc\u578b\uff0c\u63a8\u52a8\u822a\u7a7a\u5de5\u7a0b\u7684\u53d1\u5c55\u3002\n\n\u7ffc"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u548c\u6267\u884c\u4e0d\u5230\u4f4d\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u672a\u80fd\u4f9d\u6cd5\u9001\u8fbe\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u672a\u53ca\u65f6\u5c65\u884c\u4e49\u52a1\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u6548\u7387\u3002\u8fd9\u79cd\u73b0\u8c61\u53cd\u6620\u51fa\u5728\u884c\u653f\u590d\u8bae\u7a0b\u5e8f\u4e2d\uff0c\u5bf9\u6cd5\u5f8b\u6587\u4e66\u7684\u9001\u8fbe\u548c\u6267\u884c\u7a0b\u5e8f\u7f3a\u4e4f\u660e\u786e\u7684\u89c4\u8303\u8981\u6c42\u3002\n\n\u5728\u5177\u4f53\u64cd\u4f5c\u4e2d\uff0c\u4e00\u4e9b\u590d\u8bae\u673a\u5173\u5bf9\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u6709\u6548\u76d1\u7763\uff0c\u5bfc\u81f4\u4e49\u52a1\u4eba\u957f\u671f\u672a\u5c65\u884c\uff0c\u751a\u81f3\u62d6\u5ef6\u6267\u884c\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u4f5c\u51fa\u7684\u8d23\u4ee4\u6574\u6539\u51b3\u5b9a\uff0c\u56e0\u7f3a\u4e4f\u6709\u6548\u7684\u8ddf\u8e2a\u673a\u5236\uff0c\u4e49\u52a1\u4eba\u672a\u80fd\u5728\u89c4\u5b9a\u671f\u9650\u5185\u5b8c\u6210\u6574\u6539\uff0c\u8fdb\u800c\u5f15\u53d1\u884c\u653f\u590d\u8bae\u7a0b\u5e8f\u7684\u5ef6\u957f\u548c\u4e89\u8bae\u7684\u52a0\u5267\u3002\u8fd9\u8868\u660e\u5728\u884c\u653f\u590d\u8bae\u8fc7\u7a0b\u4e2d\uff0c\u5bf9\u5c65\u884c\u60c5\u51b5\u7684\u76d1\u7763\u548c\u8bc4\u4f30\u673a\u5236\u5c1a\u4e0d\u5065\u5168\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6cd5\u5f8b\u6548\u529b\u548c\u6267\u884c\u529b\u5ea6\u4e5f\u5b58\u5728\u4e89\u8bae\u3002\u4e00\u4e9b\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u51b3\u5b9a\u540e\uff0c\u672a\u80fd\u4f9d\u6cd5\u5411\u6cd5\u9662\u7533\u8bf7\u5f3a\u5236\u6267\u884c\uff0c\u5bfc\u81f4\u51b3\u5b9a\u96be\u4ee5\u843d\u5b9e\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u56e0\u672a\u7533\u8bf7\u5f3a\u5236\u6267\u884c\uff0c\u4e49\u52a1\u4eba\u4ecd\u672a\u80fd\u5c65\u884c\u4e49\u52a1\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6700\u7ec8\u7ed3\u679c\u3002\u8fd9\u53cd\u6620\u51fa\u5728\u884c\u653f\u590d\u8bae\u7a0b\u5e8f\u4e2d\uff0c\u5bf9\u6cd5\u5f8b\u6587\u4e66\u7684\u6267\u884c\u529b\u5ea6\u548c\u6cd5\u5f8b\u6548\u529b\u7684\u8ba4\u8bc6\u5b58\u5728\u4e0d\u8db3\u3002\n\ndocument\n\n\u5728\u884c\u653f\u590d\u8bae\u8fc7\u7a0b\u4e2d\uff0c\u5bf9\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u7edf\u4e00\u6807\u51c6\u548c\u660e\u786e\u7684\u7a0b\u5e8f\u8981\u6c42\uff0c\u5bfc\u81f4\u6267\u884c\u6548\u679c\u53c2\u5dee\u4e0d\u9f50\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u591a\u4e2a\u6848\u4ef6\u65f6\uff0c\u5bf9\u4e0d\u540c\u6848\u4ef6\u7684\u6267\u884c\u6807\u51c6\u4e0d\u4e00\uff0c\u6709\u7684\u6848\u4ef6\u6267\u884c\u8fc5\u901f\uff0c\u6709\u7684\u5219\u62d6\u5ef6\u4e0d\u51b3\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u6743\u5a01\u6027\u3002\u8fd9\u79cd\u4e0d\u7edf\u4e00\u7684\u6267\u884c\u6807\u51c6\uff0c\u4f7f\u5f97\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6cd5\u5f8b\u6548\u529b\u96be\u4ee5\u4fdd\u969c\uff0c\u4e5f\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u516c\u4fe1\u529b\u3002"
}
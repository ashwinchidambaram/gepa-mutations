{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u5176\u4e2d\u6700\u7a81\u51fa\u7684\u662f\u7a0b\u5e8f\u4e0d\u89c4\u8303\u3002\u4e00\u4e9b\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u672a\u4e25\u683c\u6309\u7167\u6cd5\u5b9a\u7a0b\u5e8f\u8fdb\u884c\uff0c\u5bfc\u81f4\u51b3\u5b9a\u7f3a\u4e4f\u6cd5\u5f8b\u4f9d\u636e\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u653f\u5e9c\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u4e89\u8bae\u65f6\uff0c\u672a\u4f9d\u6cd5\u544a\u77e5\u5f53\u4e8b\u4eba\u76f8\u5173\u6743\u5229\uff0c\u4e5f\u672a\u63d0\u4f9b\u5145\u5206\u7684\u8bc1\u636e\u652f\u6301\u51b3\u5b9a\uff0c\u6700\u7ec8\u5bfc\u81f4\u5f53\u4e8b\u4eba\u4e0d\u670d\u5e76\u63d0\u8d77\u590d\u8bae\u3002\u8fd9\u79cd\u7a0b\u5e8f\u7455\u75b5\u76f4\u63a5\u5f71\u54cd\u4e86\u590d\u8bae\u51b3\u5b9a\u7684\u6548\u529b\uff0c\u524a\u5f31\u4e86\u5176\u516c\u4fe1\u529b\u3002\n\n\u5176\u6b21\uff0c\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u4e5f\u662f\u5236\u7ea6\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u6709\u6548\u5b9e\u65bd\u7684\u91cd\u8981\u56e0\u7d20\u3002\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u51b3\u5b9a\u540e\uff0c\u672a\u80fd\u53ca\u65f6\u91c7\u53d6\u5f3a\u5236\u63aa\u65bd\u6216\u534f\u8c03\u76f8\u5173\u90e8\u95e8\u6267\u884c\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u957f\u671f\u672a\u5c65\u884c\u4e49\u52a1\u3002\u4f8b\u5982\uff0c\u67d0\u5e02\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u5904\u7f5a\u6848\u4ef6\u65f6\uff0c\u590d\u8bae\u673a\u5173\u867d\u4f5c\u51fa\u8d23\u4ee4\u6574\u6539\u51b3\u5b9a\uff0c\u4f46\u672a\u5b89\u6392\u4e13\u4eba\u8ddf\u8fdb\uff0c\u81f4\u4f7f\u6574\u6539\u5de5\u4f5c\u62d6\u5ef6\uff0c\u6700\u7ec8\u5f15\u53d1\u5f53\u4e8b\u4eba\u4e0d\u6ee1\u5e76\u518d\u6b21\u590d\u8bae\u3002\u8fd9\u79cd\u6267\u884c\u4e0d\u529b\u7684\u60c5\u51b5\uff0c\u4f7f\u5f97\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u96be\u4ee5\u771f\u6b63\u53d1\u6325\u4f5c\u7528\u3002\n\n\u53e6\u5916\uff0c\u5f53\u4e8b\u4eba\u5bf9\u590d\u8bae\u51b3\u5b9a\u7684\u4e0d\u670d\u60c5\u7eea\u666e\u904d\u5b58\u5728\uff0c\u5f71\u54cd\u4e86\u590d\u8bae\u5de5\u4f5c\u7684\u6548\u7387\u3002\u7531\u4e8e\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u4e0d\u4f73\uff0c\u90e8\u5206\u5f53\u4e8b\u4eba\u5bf9\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u6743\u5a01\u6027\u4ea7\u751f\u6000\u7591\uff0c\u751a\u81f3\u8ba4\u4e3a\u884c\u653f\u590d\u8bae\u5236\u5ea6\u5b58\u5728\u7f3a\u9677\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u5f53\u4e8b\u4eba\u591a\u6b21\u7533\u8bc9\uff0c\u8ba4\u4e3a\u590d\u8bae\u673a\u5173\u672a\u4f9d\u6cd5\u5c65\u884c\u804c\u8d23\uff0c\u5bfc\u81f4\u5176\u6743\u76ca\u53d7\u635f\u3002\u8fd9\u79cd\u60c5\u7eea\u5316\u53cd\u5e94\u4e0d\u4ec5\u589e\u52a0\u4e86\u590d\u8bae\u5de5\u4f5c\u7684\u96be\u5ea6\uff0c\u4e5f\u5bf9\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u516c\u4fe1\u529b\u9020\u6210\u8d1f\u9762\u5f71\u54cd\u3002\n\ndocument\n\n\u6700\u540e\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6cd5\u5f8b\u6548\u529b\u548c\u53ef\u6267\u884c\u6027\u4ecd\u9700\u8fdb\u4e00\u6b65\u63d0\u5347\u3002\u76ee\u524d\uff0c\u867d\u7136\u6cd5\u5f8b\u5bf9\u8d23\u4ee4\u5c65\u884c\u6709\u660e\u786e\u8981\u6c42\uff0c\u4f46\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u5b58\u5728\u6267\u884c\u6807\u51c6\u4e0d\u7edf\u4e00\u3001\u6267\u884c\u673a\u5236\u4e0d\u5065\u5168\u7b49\u95ee\u9898\u3002\u4f8b\u5982\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\uff0c\u5bf9\u201c\u5c65\u884c\u671f\u9650\u201d\u548c\u201c\u5c65\u884c\u65b9\u5f0f\u201d\u7f3a\u4e4f\u5177\u4f53\u89c4\u5b9a\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u7f3a\u4e4f\u660e\u786e\u6307\u5f15\u3002\u8fd9\u79cd\u6a21\u7cca\u6027\u4f7f\u5f97\u590d\u8bae\u51b3\u5b9a\u5728\u5b9e\u9645\u6267\u884c\u4e2d\u96be\u4ee5\u843d\u5b9e\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u8fd0\u884c\u6548\u679c\u3002"
}
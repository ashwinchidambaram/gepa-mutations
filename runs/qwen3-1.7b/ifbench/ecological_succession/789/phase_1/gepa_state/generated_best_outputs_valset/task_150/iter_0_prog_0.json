{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u9996\u5148\u5728\u4e8e\u7a0b\u5e8f\u4e0a\u7684\u4e0d\u89c4\u8303\u3002\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u672a\u80fd\u5145\u5206\u5c65\u884c\u6cd5\u5b9a\u7a0b\u5e8f\uff0c\u5bfc\u81f4\u51b3\u5b9a\u7f3a\u4e4f\u6cd5\u5f8b\u4f9d\u636e\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u653f\u5e9c\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u4e89\u8bae\u65f6\uff0c\u672a\u4f9d\u6cd5\u901a\u77e5\u5f53\u4e8b\u4eba\uff0c\u4e5f\u672a\u63d0\u4f9b\u5145\u5206\u7684\u8bc1\u636e\u652f\u6301\u51b3\u5b9a\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u4e0d\u670d\uff0c\u8fdb\u800c\u5f15\u53d1\u8fdb\u4e00\u6b65\u7684\u8bc9\u8bbc\u3002\u8fd9\u79cd\u7a0b\u5e8f\u7455\u75b5\u76f4\u63a5\u5f71\u54cd\u4e86\u51b3\u5b9a\u7684\u5408\u6cd5\u6027\u548c\u6267\u884c\u529b\u3002\n\n\u5176\u6b21\uff0c\u884c\u653f\u590d\u8bae\u673a\u6784\u5bf9\u5c65\u884c\u4e49\u52a1\u7684\u76d1\u7763\u673a\u5236\u4e0d\u5065\u5168\u3002\u5728\u4e00\u4e9b\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u672a\u80fd\u6709\u6548\u76d1\u7763\u88ab\u7533\u8bf7\u4eba\u5728\u89c4\u5b9a\u671f\u9650\u5185\u5c65\u884c\u4e49\u52a1\uff0c\u751a\u81f3\u5728\u5c65\u884c\u671f\u9650\u5c4a\u6ee1\u540e\u4ecd\u672a\u5b8c\u6210\uff0c\u5bfc\u81f4\u590d\u8bae\u51b3\u5b9a\u5f62\u540c\u865a\u8bbe\u3002\u4f8b\u5982\uff0c\u67d0\u5e02\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u5904\u7f5a\u6848\u4ef6\u65f6\uff0c\u590d\u8bae\u673a\u5173\u672a\u53ca\u65f6\u8ddf\u8fdb\u88ab\u7533\u8bf7\u4eba\u5c65\u884c\u60c5\u51b5\uff0c\u6700\u7ec8\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u957f\u671f\u672a\u5c65\u884c\u51b3\u5b9a\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u6548\u7387\u3002\n\n\u518d\u6b21\uff0c\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u3002\u5c3d\u7ba1\u6cd5\u5f8b\u89c4\u5b9a\u4e86\u590d\u8bae\u51b3\u5b9a\u5177\u6709\u5f3a\u5236\u529b\uff0c\u4f46\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5bf9\u6267\u884c\u63aa\u65bd\u7684\u843d\u5b9e\u4e0d\u591f\u6709\u529b\uff0c\u751a\u81f3\u5b58\u5728\u6577\u884d\u585e\u8d23\u7684\u60c5\u51b5\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u8bb8\u53ef\u6848\u4ef6\u65f6\uff0c\u672a\u4f9d\u6cd5\u91c7\u53d6\u5f3a\u5236\u63aa\u65bd\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u957f\u671f\u672a\u5c65\u884c\u4e49\u52a1\uff0c\u6700\u7ec8\u5f15\u53d1\u884c\u653f\u8bc9\u8bbc\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u3002\n\n\u6700\u540e\uff0c\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u9002\u7528\u8303\u56f4\u548c\u9002\u7528\u6807\u51c6\u4e0d\u591f\u660e\u786e\u3002\u90e8\u5206\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u5bf9\u201c\u8d23\u4ee4\u5c65\u884c\u201d\u7684\u9002\u7528\u6807\u51c6\u628a\u63e1\u4e0d\u4e00\uff0c\u5bfc\u81f4\u540c\u4e00\u6848\u4ef6\u5728\u4e0d\u540c\u590d\u8bae\u673a\u5173\u4e4b\u95f4\u5904\u7406\u7ed3\u679c\u4e0d\u4e00\u81f4\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u8bb8\u53ef\u6848\u4ef6\u65f6\uff0c\u56e0\u5bf9\u201c\u5c65\u884c\u4e49\u52a1\u201d\u7684\u5b9a\u4e49\u4e0d\u540c\uff0c\u5bfc\u81f4\u51b3\u5b9a\u7684\u6267\u884c\u7ed3\u679c\u5b58\u5728\u4e89\u8bae\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u7edf\u4e00\u6027\u548c\u516c\u6b63\u6027\u3002 document"
}
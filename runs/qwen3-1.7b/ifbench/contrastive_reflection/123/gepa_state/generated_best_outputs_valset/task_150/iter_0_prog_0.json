{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u3001\u6cd5\u5f8b\u4f9d\u636e\u4e0d\u8db3\u4ee5\u53ca\u6267\u884c\u673a\u5236\u4e0d\u5b8c\u5584\u7b49\u65b9\u9762\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u4e89\u8bae\u65f6\uff0c\u672a\u4e25\u683c\u6309\u7167\u300a\u884c\u653f\u590d\u8bae\u6cd5\u300b\u89c4\u5b9a\uff0c\u672a\u660e\u786e\u544a\u77e5\u7533\u8bf7\u4eba\u5c65\u884c\u4e49\u52a1\u7684\u5177\u4f53\u671f\u9650\uff0c\u5bfc\u81f4\u7533\u8bf7\u4eba\u5bf9\u590d\u8bae\u7ed3\u679c\u4ea7\u751f\u8bef\u89e3\uff0c\u8fdb\u800c\u5f71\u54cd\u4e86\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u6548\u7387\u3002\u8fd9\u79cd\u60c5\u51b5\u4e0b\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7f3a\u4e4f\u660e\u786e\u7684\u6cd5\u5f8b\u4f9d\u636e\uff0c\u5bb9\u6613\u5f15\u53d1\u4e89\u8bae\u3002\n\n\u5728\u5177\u4f53\u64cd\u4f5c\u4e2d\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5bf9\u201c\u8d23\u4ee4\u5c65\u884c\u201d\u8fd9\u4e00\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u7406\u89e3\u4e0d\u4e00\uff0c\u6709\u7684\u8ba4\u4e3a\u5176\u9002\u7528\u4e8e\u6240\u6709\u884c\u653f\u884c\u4e3a\uff0c\u800c\u6709\u7684\u5219\u9650\u4e8e\u7279\u5b9a\u60c5\u5f62\u3002\u8fd9\u79cd\u6a21\u7cca\u6027\u4f7f\u5f97\u5728\u5b9e\u9645\u6267\u884c\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u96be\u4ee5\u51c6\u786e\u5224\u65ad\u662f\u5426\u7b26\u5408\u6cd5\u5b9a\u6761\u4ef6\uff0c\u8fdb\u800c\u5f71\u54cd\u4e86\u590d\u8bae\u51b3\u5b9a\u7684\u53ef\u6267\u884c\u6027\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u5728\u590d\u8bae\u8fc7\u7a0b\u4e2d\uff0c\u5c06\u4e0d\u7b26\u5408\u6cd5\u5b9a\u6761\u4ef6\u7684\u884c\u653f\u884c\u4e3a\u8ba4\u5b9a\u4e3a\u201c\u8d23\u4ee4\u5c65\u884c\u201d\u7684\u5bf9\u8c61\uff0c\u5bfc\u81f4\u7533\u8bf7\u4eba\u8ba4\u4e3a\u590d\u8bae\u673a\u5173\u5b58\u5728\u6ee5\u7528\u804c\u6743\u7684\u60c5\u51b5\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5c65\u884c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u5f80\u5f80\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u7f3a\u4e4f\u7ea6\u675f\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u5904\u7f5a\u6848\u4ef6\u65f6\uff0c\u672a\u53ca\u65f6\u7763\u4fc3\u76f8\u5173\u884c\u653f\u673a\u5173\u5c65\u884c\u4e49\u52a1\uff0c\u6700\u7ec8\u5bfc\u81f4\u7533\u8bf7\u4eba\u65e0\u6cd5\u83b7\u5f97\u53ca\u65f6\u6551\u6d4e\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u3002\u8fd9\u79cd\u60c5\u51b5\u4e0b\uff0c\u590d\u8bae\u673a\u5173\u7684\u804c\u8d23\u5c65\u884c\u4e0d\u5145\u5206\uff0c\u635f\u5bb3\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u6743\u5a01\u6027\u548c\u516c\u4fe1\u529b\u3002\n\ndocument\n\n\u5728\u884c\u653f\u590d\u8bae\u8fc7\u7a0b\u4e2d\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5236\u5b9a\u548c\u6267\u884c\u9700\u8981\u4e25\u683c\u9075\u5faa\u6cd5\u5f8b\u7a0b\u5e8f\uff0c\u786e\u4fdd\u5176\u5408\u6cd5\u6027\u548c\u53ef\u6267\u884c\u6027\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u5904\u7f5a\u6848\u4ef6\u65f6\uff0c\u672a\u4f9d\u6cd5\u544a\u77e5\u7533\u8bf7\u4eba\u5c65\u884c\u4e49\u52a1\u7684\u5177\u4f53\u671f\u9650\u548c\u65b9\u5f0f\uff0c\u5bfc\u81f4\u7533\u8bf7\u4eba\u65e0\u6cd5\u53ca\u65f6\u5c65\u884c\u4e49\u52a1\uff0c\u6700\u7ec8\u5f15\u53d1\u884c\u653f\u590d\u8bae\u7a0b\u5e8f\u7684\u5ef6\u957f\u3002\u8fd9\u79cd\u60c5\u51b5\u4e0b\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u7a0b\u5e8f\u7455\u75b5\u76f4\u63a5\u5f71\u54cd\u4e86\u590d\u8bae\u7ed3\u679c\u7684\u6548\u529b\uff0c\u4e5f\u635f\u5bb3\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u516c\u6b63\u6027\u3002"
}
{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u8bba\u6587\n\n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u662f\u822a\u7a7a\u822a\u5929\u5de5\u7a0b\u4e0e\u751f\u7269\u79d1\u5b66\u9886\u57df\u7684\u4ea4\u53c9\u5b66\u79d1\uff0c\u65e8\u5728\u901a\u8fc7\u6a21\u4eff\u81ea\u7136\u754c\u4e2d\u98de\u884c\u5668\u5b98\u7684\u7ed3\u6784\u548c\u529f\u80fd\uff0c\u63d0\u5347\u98de\u884c\u5668\u7684\u6027\u80fd\u3002\u7ffc\u578b\u8bbe\u8ba1\u662f\u98de\u884c\u5668\u7a7a\u6c14\u52a8\u529b\u5b66\u7684\u6838\u5fc3\uff0c\u5176\u5f62\u72b6\u76f4\u63a5\u5f71\u54cd\u5347\u529b\u3001\u963b\u529b\u548c\u822a\u8ff9\u3002\u4eff\u751f\u5b66\u5219\u901a\u8fc7\u7814\u7a76\u81ea\u7136\u754c\u751f\u7269\u7684\u7ed3\u6784\u548c\u529f\u80fd\uff0c\u4e3a\u5de5\u7a0b\u8bbe\u8ba1\u63d0\u4f9b\u7075\u611f\uff0c\u4f7f\u5f97\u98de\u884c\u5668\u80fd\u591f\u66f4\u9ad8\u6548\u5730\u5229\u7528\u7a7a\u6c14\u52a8\u529b\u5b66\u539f\u7406\u3002\n\n\u81ea\u7136\u754c\u4e2d\uff0c\u9e1f\u7c7b\u3001\u6606\u866b\u548c\u9c7c\u7c7b\u7b49\u751f\u7269\u7684\u98de\u884c\u5668\u5b98\u5177\u6709\u72ec\u7279\u7684\u7ed3\u6784\u548c\u529f\u80fd\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7684\u7ffc\u578b\u5177\u6709\u9ad8\u5347\u529b\u7cfb\u6570\u548c\u4f4e\u963b\u529b\u7cfb\u6570\uff0c\u800c\u6606\u866b\u7684\u7ffc\u578b\u5219\u5177\u6709\u9ad8\u8868\u9762\u7c97\u7cd9\u5ea6\u548c\u590d\u6742\u7684\u7ffc\u9762\u7ed3\u6784\uff0c\u4ee5\u9002\u5e94\u4e0d\u540c\u7684\u98de\u884c\u73af\u5883\u3002\u4eff\u751f\u5b66\u7814\u7a76\u8fd9\u4e9b\u751f\u7269\u7684\u98de\u884c\u673a\u5236\uff0c\u4ece\u800c\u8bbe\u8ba1\u51fa\u66f4\u9ad8\u6548\u7684\u7ffc\u578b\u3002\n\n\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u4e3b\u8981\u4f53\u73b0\u5728\u5bf9\u751f\u7269\u7ffc\u578b\u7684\u7ed3\u6784\u548c\u529f\u80fd\u7684\u5206\u6790\u3002\u4f8b\u5982\uff0c\u7814\u7a76\u4eba\u5458\u901a\u8fc7\u89c2\u5bdf\u9e1f\u7c7b\u7684\u7ffc\u578b\uff0c\u53d1\u73b0\u5176\u5177\u6709\u6d41\u7ebf\u578b\u548c\u9ad8\u5347\u529b\u7cfb\u6570\u7684\u7279\u5f81\uff0c\u4ece\u800c\u8bbe\u8ba1\u51fa\u66f4\u9ad8\u6548\u7684\u7ffc\u578b\u3002\u6b64\u5916\uff0c\u6606\u866b\u7684\u7ffc\u578b\u5177\u6709\u9ad8\u8868\u9762\u7c97\u7cd9\u5ea6\u548c\u590d\u6742\u7684\u7ffc\u9762\u7ed3\u6784\uff0c\u4f7f\u5f97\u5b83\u4eec\u80fd\u591f\u5728\u4e0d\u540c\u98de\u884c\u6761\u4ef6\u4e0b\u4fdd\u6301\u826f\u597d\u7684\u5347\u529b\u548c\u7a33\u5b9a\u6027\u3002\n\n\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u4e0d\u4ec5\u63d0\u9ad8\u4e86\u98de\u884c\u5668\u7684\u6027\u80fd\uff0c\u8fd8\u4fc3\u8fdb\u4e86\u6750\u6599\u79d1\u5b66\u548c\u7a7a\u6c14\u52a8\u529b\u5b66\u7684\u53d1\u5c55\u3002\u901a\u8fc7\u4eff\u751f\u5b66\u7684\u7814\u7a76\uff0c\u5de5\u7a0b\u5e08\u80fd\u591f\u8bbe\u8ba1\u51fa\u66f4\u8f7b\u3001\u66f4\u9ad8\u6548\u7684\u98de\u884c\u5668\uff0c\u4ece\u800c\u964d\u4f4e\u71c3\u6599\u6d88\u8017\u548c\u63d0\u9ad8\u98de\u884c\u6548\u7387\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\uff0c\u4e3a\u98de\u884c\u5668\u7684\u6027\u80fd\u63d0\u5347\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u548c\u65b9\u6cd5\u3002\u901a\u8fc7\u7814\u7a76\u81ea\u7136\u754c\u7684\u98de\u884c\u673a\u5236\uff0c\u5de5\u7a0b\u5e08\u80fd\u591f\u8bbe\u8ba1\u51fa\u66f4\u9ad8\u6548\u7684\u7ffc\u578b\uff0c\u4ece\u800c\u63a8\u52a8\u822a\u7a7a\u822a\u5929\u6280\u672f\u7684\u53d1\u5c55\u3002\n\n\u7ffc"
}
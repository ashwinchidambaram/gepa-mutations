{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u3001\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u4ee5\u53ca\u9002\u7528\u8303\u56f4\u6709\u9650\u7b49\u65b9\u9762\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u672a\u4f9d\u6cd5\u544a\u77e5\u5f53\u4e8b\u4eba\u5c65\u884c\u4e49\u52a1\u7684\u671f\u9650\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u672a\u80fd\u6309\u65f6\u5c65\u884c\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u6848\u4ef6\u7684\u516c\u6b63\u88c1\u51b3\u3002\u8fd9\u79cd\u7a0b\u5e8f\u4e0a\u7684\u7f3a\u5931\uff0c\u53cd\u6620\u51fa\u884c\u653f\u590d\u8bae\u673a\u6784\u5728\u5c65\u884c\u544a\u77e5\u4e49\u52a1\u65b9\u9762\u5b58\u5728\u4e0d\u8db3\u3002\n\n\u6b64\u5916\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u529b\u5ea6\u666e\u904d\u8f83\u5f31\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u5728\u6536\u5230\u51b3\u5b9a\u540e\uff0c\u5f80\u5f80\u56e0\u7f3a\u4e4f\u5f3a\u5236\u529b\u800c\u65e0\u6cd5\u53ca\u65f6\u5c65\u884c\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u867d\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u56e0\u7f3a\u4e4f\u540e\u7eed\u7684\u6267\u884c\u4fdd\u969c\uff0c\u5f53\u4e8b\u4eba\u4ecd\u672a\u80fd\u53ca\u65f6\u5c65\u884c\u4e49\u52a1\uff0c\u5f71\u54cd\u4e86\u590d\u8bae\u7ed3\u679c\u7684\u5b9e\u73b0\u3002\n\n\u5728\u9002\u7528\u8303\u56f4\u65b9\u9762\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u6761\u4ef6\u8f83\u4e3a\u4e25\u683c\uff0c\u4ec5\u9002\u7528\u4e8e\u7279\u5b9a\u60c5\u5f62\uff0c\u5982\u884c\u653f\u884c\u4e3a\u5b58\u5728\u660e\u663e\u8fdd\u6cd5\u6216\u4e0d\u5f53\uff0c\u4e14\u5f53\u4e8b\u4eba\u672a\u5728\u6cd5\u5b9a\u671f\u9650\u5185\u63d0\u51fa\u590d\u8bae\u7533\u8bf7\u3002\u8fd9\u79cd\u9650\u5236\u6027\u89c4\u5b9a\uff0c\u4f7f\u5f97\u4e00\u4e9b\u672c\u5e94\u9002\u7528\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6848\u4ef6\u672a\u80fd\u88ab\u53ca\u65f6\u5904\u7406\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6548\u7387\u548c\u516c\u6b63\u6027\u3002\n\ndocument\n\n\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u5f80\u5f80\u7f3a\u4e4f\u660e\u786e\u7684\u6cd5\u5f8b\u4f9d\u636e\u548c\u64cd\u4f5c\u89c4\u8303\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u4e2d\u51fa\u73b0\u6807\u51c6\u4e0d\u4e00\u3001\u6267\u884c\u6548\u679c\u53c2\u5dee\u4e0d\u9f50\u7684\u95ee\u9898\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u67d0\u884c\u653f\u5904\u7f5a\u6848\u4ef6\u65f6\uff0c\u56e0\u7f3a\u4e4f\u660e\u786e\u7684\u6cd5\u5f8b\u4f9d\u636e\uff0c\u672a\u4f9d\u6cd5\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u6700\u7ec8\u5bfc\u81f4\u6848\u4ef6\u5904\u7406\u7ed3\u679c\u4e0d\u516c\u3002\u8fd9\u79cd\u7f3a\u4e4f\u89c4\u8303\u7684\u6267\u884c\u6807\u51c6\uff0c\u4f7f\u5f97\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u5b58\u5728\u8f83\u5927\u4e89\u8bae\u3002"
}
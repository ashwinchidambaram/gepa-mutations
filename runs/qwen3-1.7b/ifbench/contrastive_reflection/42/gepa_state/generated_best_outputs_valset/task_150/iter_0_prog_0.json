{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u5176\u4e2d\u6700\u7a81\u51fa\u7684\u662f\u7a0b\u5e8f\u4e0d\u89c4\u8303\u548c\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u5728\u672a\u4f9d\u6cd5\u544a\u77e5\u5f53\u4e8b\u4eba\u5c65\u884c\u4e49\u52a1\u7684\u671f\u9650\u548c\u65b9\u5f0f\u7684\u60c5\u51b5\u4e0b\uff0c\u76f4\u63a5\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u5bf9\u51b3\u5b9a\u7684\u5408\u6cd5\u6027\u4ea7\u751f\u8d28\u7591\uff0c\u6700\u7ec8\u5f15\u53d1\u884c\u653f\u590d\u8bae\u7a0b\u5e8f\u7684\u65e0\u6548\u3002\u8fd9\u79cd\u7a0b\u5e8f\u4e0a\u7684\u7f3a\u9677\u53cd\u6620\u51fa\u590d\u8bae\u673a\u5173\u5728\u5c65\u884c\u6cd5\u5b9a\u804c\u8d23\u65f6\u7f3a\u4e4f\u4e25\u8c28\u6027\u3002\n\n\u6b64\u5916\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\u5b58\u5728\u63a8\u8bff\u73b0\u8c61\uff0c\u672a\u80fd\u53ca\u65f6\u91c7\u53d6\u6709\u6548\u63aa\u65bd\u7763\u4fc3\u88ab\u7533\u8bf7\u4eba\u5c65\u884c\u4e49\u52a1\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u5728\u6536\u5230\u88ab\u7533\u8bf7\u4eba\u62d2\u4e0d\u5c65\u884c\u7684\u4e66\u9762\u901a\u77e5\u540e\uff0c\u672a\u4f9d\u6cd5\u91c7\u53d6\u5f3a\u5236\u6267\u884c\u63aa\u65bd\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u6743\u76ca\u65e0\u6cd5\u5f97\u5230\u4fdd\u969c\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u6743\u5a01\u6027\u3002\n\n\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u5bf9\u7533\u8bf7\u4eba\u63d0\u51fa\u7684\u5c65\u884c\u8bf7\u6c42\u7f3a\u4e4f\u660e\u786e\u7684\u6cd5\u5f8b\u4f9d\u636e\uff0c\u5bfc\u81f4\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u53d7\u9650\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u4e89\u8bae\u65f6\uff0c\u672a\u4f9d\u636e\u300a\u884c\u653f\u590d\u8bae\u6cd5\u300b\u7684\u76f8\u5173\u89c4\u5b9a\uff0c\u5bf9\u7533\u8bf7\u4eba\u63d0\u51fa\u7684\u5c65\u884c\u8bf7\u6c42\u4f5c\u51fa\u56de\u5e94\uff0c\u5bfc\u81f4\u51b3\u5b9a\u5185\u5bb9\u4e0d\u660e\u786e\uff0c\u5f71\u54cd\u4e86\u590d\u8bae\u7a0b\u5e8f\u7684\u987a\u5229\u8fdb\u884c\u3002\n\ndocument\n\n\u5728\u884c\u653f\u590d\u8bae\u8fc7\u7a0b\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u5bf9\u88ab\u7533\u8bf7\u4eba\u5c65\u884c\u4e49\u52a1\u7684\u76d1\u7763\u673a\u5236\u4e0d\u5b8c\u5584\uff0c\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u624b\u6bb5\u548c\u8d23\u4efb\u8ffd\u7a76\u673a\u5236\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u672a\u5bf9\u88ab\u7533\u8bf7\u4eba\u5c65\u884c\u4e49\u52a1\u60c5\u51b5\u8fdb\u884c\u8ddf\u8e2a\u68c0\u67e5\uff0c\u5bfc\u81f4\u4e49\u52a1\u672a\u88ab\u5c65\u884c\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6700\u7ec8\u7ed3\u679c\u3002\u8fd9\u79cd\u76d1\u7763\u673a\u5236\u7684\u7f3a\u5931\uff0c\u4f7f\u5f97\u590d\u8bae\u673a\u5173\u5728\u5c65\u884c\u804c\u8d23\u65f6\u7f3a\u4e4f\u52a8\u529b\u548c\u8d23\u4efb\u611f\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u5de5\u4f5c\u7684\u5b9e\u6548\u6027\u3002"
}
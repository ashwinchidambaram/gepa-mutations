{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u548c\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u7b49\u65b9\u9762\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u672a\u4f9d\u6cd5\u544a\u77e5\u5f53\u4e8b\u4eba\u5c65\u884c\u4e49\u52a1\u7684\u671f\u9650\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u672a\u6309\u65f6\u5c65\u884c\uff0c\u6700\u7ec8\u5f15\u53d1\u4e89\u8bae\u3002\u8fd9\u79cd\u505a\u6cd5\u4e0d\u7b26\u5408\u300a\u884c\u653f\u590d\u8bae\u6cd5\u300b\u5173\u4e8e\u544a\u77e5\u4e49\u52a1\u7684\u76f8\u5173\u89c4\u5b9a\uff0c\u53cd\u6620\u51fa\u7a0b\u5e8f\u6267\u884c\u4e2d\u7684\u6f0f\u6d1e\u3002\n\n\u6b64\u5916\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u7f3a\u4e4f\u660e\u786e\u7684\u6cd5\u5f8b\u4f9d\u636e\u548c\u5177\u4f53\u7684\u64cd\u4f5c\u6807\u51c6\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u4e2d\u51fa\u73b0\u504f\u5dee\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u6cd5\u9662\u5728\u6267\u884c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u672a\u4f9d\u636e\u300a\u884c\u653f\u590d\u8bae\u6cd5\u300b\u548c\u300a\u884c\u653f\u5f3a\u5236\u6cd5\u300b\u7684\u76f8\u5173\u6761\u6b3e\uff0c\u968f\u610f\u5ef6\u957f\u5c65\u884c\u671f\u9650\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u6548\u7387\u3002\n\n\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u5bf9\u5f53\u4e8b\u4eba\u5c65\u884c\u4e49\u52a1\u7684\u76d1\u7763\u673a\u5236\u4e0d\u5065\u5168\uff0c\u7f3a\u4e4f\u6709\u6548\u7684\u8ddf\u8e2a\u548c\u53cd\u9988\u673a\u5236\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u6784\u5728\u5904\u7406\u4e00\u8d77\u8d23\u4ee4\u5c65\u884c\u6848\u4ef6\u65f6\uff0c\u672a\u80fd\u53ca\u65f6\u8ddf\u8fdb\u5f53\u4e8b\u4eba\u5c65\u884c\u60c5\u51b5\uff0c\u5bfc\u81f4\u6848\u4ef6\u4e45\u62d6\u4e0d\u51b3\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u548c\u516c\u4fe1\u529b\u3002\n\ndocument\n\n\u6700\u540e\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u53d7\u5230\u591a\u79cd\u56e0\u7d20\u7684\u5f71\u54cd\uff0c\u5305\u62ec\u5f53\u4e8b\u4eba\u662f\u5426\u5177\u5907\u5c65\u884c\u80fd\u529b\u3001\u590d\u8bae\u673a\u5173\u7684\u6267\u884c\u529b\u5ea6\u4ee5\u53ca\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\u7684\u5b8c\u5584\u7a0b\u5ea6\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u6d89\u53ca\u4f01\u4e1a\u5c65\u884c\u4e49\u52a1\u7684\u6848\u4ef6\u65f6\uff0c\u56e0\u4f01\u4e1a\u8d44\u91d1\u94fe\u65ad\u88c2\uff0c\u672a\u80fd\u53ca\u65f6\u91c7\u53d6\u6709\u6548\u63aa\u65bd\uff0c\u6700\u7ec8\u5bfc\u81f4\u6848\u4ef6\u4e45\u62d6\u4e0d\u51b3\uff0c\u53cd\u6620\u51fa\u884c\u653f\u590d\u8bae\u5728\u6267\u884c\u73af\u8282\u5b58\u5728\u4e00\u5b9a\u7684\u56f0\u96be\u3002"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u5176\u4e2d\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u3001\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u4ee5\u53ca\u6cd5\u5f8b\u9002\u7528\u4e0d\u7edf\u4e00\u7b49\u65b9\u9762\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u5904\u7f5a\u6848\u4ef6\u65f6\uff0c\u672a\u4f9d\u6cd5\u544a\u77e5\u5f53\u4e8b\u4eba\u590d\u8bae\u6743\u5229\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u672a\u53ca\u65f6\u7533\u8bf7\u590d\u8bae\uff0c\u6700\u7ec8\u672a\u80fd\u53ca\u65f6\u5c65\u884c\u51b3\u5b9a\u3002\u8fd9\u79cd\u7a0b\u5e8f\u7455\u75b5\u53cd\u6620\u51fa\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5c65\u884c\u6cd5\u5b9a\u7a0b\u5e8f\u65b9\u9762\u5b58\u5728\u4e0d\u8db3\u3002\n\n\u5728\u6267\u884c\u5c42\u9762\uff0c\u90e8\u5206\u590d\u8bae\u51b3\u5b9a\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u6267\u884c\u4e0d\u529b\u3002\u4f8b\u5982\uff0c\u67d0\u5e02\u73af\u4fdd\u5c40\u5bf9\u67d0\u4f01\u4e1a\u4f5c\u51fa\u8d23\u4ee4\u9650\u671f\u6539\u6b63\u51b3\u5b9a\u540e\uff0c\u672a\u53ca\u65f6\u8ddf\u8fdb\u6574\u6539\u60c5\u51b5\uff0c\u4f01\u4e1a\u672a\u6309\u65f6\u5b8c\u6210\u6574\u6539\uff0c\u590d\u8bae\u673a\u5173\u4e5f\u672a\u91c7\u53d6\u6709\u6548\u63aa\u65bd\u7763\u4fc3\u5176\u5c65\u884c\uff0c\u6700\u7ec8\u5bfc\u81f4\u51b3\u5b9a\u65e0\u6cd5\u5b9e\u73b0\u5176\u6cd5\u5f8b\u6548\u529b\u3002\u8fd9\u8bf4\u660e\u884c\u653f\u590d\u8bae\u7684\u6267\u884c\u673a\u5236\u4ecd\u9700\u5b8c\u5584\u3002\n\n\u6cd5\u5f8b\u9002\u7528\u65b9\u9762\uff0c\u4e0d\u540c\u5730\u533a\u548c\u90e8\u95e8\u5bf9\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u6807\u51c6\u5b58\u5728\u5dee\u5f02\uff0c\u5f71\u54cd\u4e86\u51b3\u5b9a\u7684\u7edf\u4e00\u6027\u548c\u53ef\u64cd\u4f5c\u6027\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u6cd5\u9662\u5728\u5ba1\u7406\u884c\u653f\u590d\u8bae\u6848\u4ef6\u65f6\uff0c\u5bf9\u201c\u5c65\u884c\u671f\u9650\u201d\u548c\u201c\u5c65\u884c\u65b9\u5f0f\u201d\u7684\u8ba4\u5b9a\u6807\u51c6\u4e0d\u4e00\u81f4\uff0c\u5bfc\u81f4\u540c\u4e00\u6848\u4ef6\u5728\u4e0d\u540c\u6cd5\u9662\u7684\u6267\u884c\u7ed3\u679c\u4e0d\u540c\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u4fe1\u529b\u3002\n\ndocument \u4f5c\u4e3a\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u4e3b\u4f53\uff0c\u5176\u5728\u5c65\u884c\u804c\u8d23\u65f6\u5f80\u5f80\u7f3a\u4e4f\u8db3\u591f\u7684\u8d44\u6e90\u548c\u80fd\u529b\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u6784\u5728\u5904\u7406\u5927\u91cf\u590d\u8bae\u6848\u4ef6\u65f6\uff0c\u672a\u80fd\u6709\u6548\u5206\u914d\u4eba\u529b\u548c\u7269\u529b\uff0c\u5bfc\u81f4\u90e8\u5206\u51b3\u5b9a\u7684\u5c65\u884c\u5de5\u4f5c\u6ede\u540e\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6548\u7387\u548c\u516c\u6b63\u6027\u3002"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u9996\u5148\uff0c\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\u7684\u4e0d\u5b8c\u5584\u5bfc\u81f4\u6267\u884c\u7a0b\u5e8f\u7f3a\u4e4f\u660e\u786e\u89c4\u8303\u3002\u4f8b\u5982\uff0c\u5bf9\u4e8e\u590d\u8bae\u673a\u5173\u5728\u5c65\u884c\u8fc7\u7a0b\u4e2d\u9047\u5230\u7684\u590d\u6742\u60c5\u51b5\uff0c\u6cd5\u5f8b\u5e76\u672a\u63d0\u4f9b\u6e05\u6670\u7684\u6307\u5bfc\u539f\u5219\uff0c\u5bfc\u81f4\u6267\u884c\u6548\u7387\u4f4e\u4e0b\u3002\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u571f\u5730\u7ea0\u7eb7\u6848\u4ef6\u65f6\uff0c\u56e0\u7f3a\u4e4f\u660e\u786e\u7684\u6267\u884c\u6807\u51c6\uff0c\u672a\u80fd\u53ca\u65f6\u5c65\u884c\u4e49\u52a1\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u6848\u4ef6\u7684\u516c\u6b63\u5904\u7406\u3002\n\n\u5176\u6b21\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u5b58\u5728\u8d23\u4efb\u5212\u5206\u4e0d\u6e05\u7684\u95ee\u9898\u3002\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u5c65\u884c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u672a\u80fd\u660e\u786e\u533a\u5206\u81ea\u8eab\u804c\u8d23\u4e0e\u76f8\u5173\u8d23\u4efb\u4e3b\u4f53\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u7f3a\u4e4f\u6709\u6548\u76d1\u7763\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u56e0\u672a\u5c65\u884c\u73af\u4fdd\u4e49\u52a1\u88ab\u8d23\u4ee4\u6574\u6539\u540e\uff0c\u590d\u8bae\u673a\u5173\u672a\u53ca\u65f6\u7763\u4fc3\u76f8\u5173\u5355\u4f4d\u6267\u884c\uff0c\u9020\u6210\u73af\u5883\u95ee\u9898\u6301\u7eed\u5b58\u5728\uff0c\u5f71\u54cd\u4e86\u516c\u4f17\u5bf9\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u4fe1\u4efb\u3002\n\n\u518d\u6b21\uff0c\u6267\u884c\u673a\u5236\u4e0d\u5065\u5168\uff0c\u5f71\u54cd\u4e86\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5b9e\u6548\u6027\u3002\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\uff0c\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u548c\u53cd\u9988\u673a\u5236\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u7f3a\u4e4f\u900f\u660e\u5ea6\u548c\u516c\u6b63\u6027\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u8bb8\u53ef\u6848\u4ef6\u65f6\uff0c\u590d\u8bae\u673a\u5173\u672a\u53ca\u65f6\u8ddf\u8fdb\u6267\u884c\u60c5\u51b5\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u957f\u671f\u672a\u5c65\u884c\u4e49\u52a1\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u3002\n\n\u6700\u540e\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u5b58\u5728\u4e3b\u89c2\u5224\u65ad\u8fc7\u5927\u7684\u95ee\u9898\uff0c\u5f71\u54cd\u4e86\u51b3\u5b9a\u7684\u516c\u6b63\u6027\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5bf9\u67d0\u4f01\u4e1a\u672a\u5c65\u884c\u7eb3\u7a0e\u4e49\u52a1\u7684\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u672a\u5145\u5206\u8003\u8651\u4f01\u4e1a\u5b9e\u9645\u56f0\u96be\uff0c\u76f4\u63a5\u8981\u6c42\u5176\u5c65\u884c\u4e49\u52a1\uff0c\u5bfc\u81f4\u4f01\u4e1a\u9677\u5165\u56f0\u5883\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u3002"
}
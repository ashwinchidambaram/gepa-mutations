{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u5176\u4e2d\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u3001\u6cd5\u5f8b\u4f9d\u636e\u4e0d\u8db3\u4ee5\u53ca\u6267\u884c\u6548\u679c\u4e0d\u4f73\u7b49\u65b9\u9762\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u4e89\u8bae\u65f6\uff0c\u672a\u4e25\u683c\u6309\u7167\u300a\u884c\u653f\u590d\u8bae\u6cd5\u300b\u89c4\u5b9a\uff0c\u5bf9\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u7684\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u672a\u8fdb\u884c\u5145\u5206\u7684\u8bc1\u636e\u5ba1\u67e5\uff0c\u5bfc\u81f4\u51b3\u5b9a\u7f3a\u4e4f\u4e8b\u5b9e\u4f9d\u636e\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u590d\u8bae\u7ed3\u679c\u7684\u516c\u6b63\u6027\u3002\u8fd9\u79cd\u7a0b\u5e8f\u4e0a\u7684\u758f\u6f0f\uff0c\u4f7f\u5f97\u590d\u8bae\u51b3\u5b9a\u7684\u6743\u5a01\u6027\u548c\u53ef\u6267\u884c\u6027\u53d7\u5230\u8d28\u7591\u3002\n\n\u5728\u6cd5\u5f8b\u9002\u7528\u65b9\u9762\uff0c\u90e8\u5206\u590d\u8bae\u51b3\u5b9a\u7f3a\u4e4f\u660e\u786e\u7684\u6cd5\u5f8b\u4f9d\u636e\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u4e2d\u51fa\u73b0\u4e89\u8bae\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u4e2d\uff0c\u5f15\u7528\u4e86\u4e0d\u660e\u786e\u7684\u884c\u653f\u6cd5\u89c4\u6216\u89c4\u7ae0\uff0c\u800c\u672a\u660e\u786e\u6307\u51fa\u5177\u4f53\u6761\u6b3e\uff0c\u4f7f\u5f97\u88ab\u7533\u8bf7\u4eba\u96be\u4ee5\u4f9d\u6cd5\u5c65\u884c\u4e49\u52a1\u3002\u8fd9\u79cd\u6cd5\u5f8b\u4f9d\u636e\u4e0d\u8db3\u7684\u95ee\u9898\uff0c\u4f7f\u5f97\u590d\u8bae\u51b3\u5b9a\u5728\u5b9e\u9645\u6267\u884c\u4e2d\u96be\u4ee5\u843d\u5b9e\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u4fe1\u529b\u3002\n\n\u6b64\u5916\uff0c\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u673a\u5236\u4e0d\u5065\u5168\uff0c\u5bfc\u81f4\u90e8\u5206\u6848\u4ef6\u65e0\u6cd5\u6709\u6548\u63a8\u8fdb\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u672a\u5efa\u7acb\u6709\u6548\u7684\u6267\u884c\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u62d6\u5ef6\u5c65\u884c\u4e49\u52a1\uff0c\u751a\u81f3\u62d2\u4e0d\u5c65\u884c\u3002\u8fd9\u79cd\u6267\u884c\u673a\u5236\u7684\u7f3a\u5931\uff0c\u4f7f\u5f97\u884c\u653f\u590d\u8bae\u7684\u6548\u529b\u96be\u4ee5\u5145\u5206\u53d1\u6325\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u8fd0\u884c\u6548\u7387\u3002\n\ndocument\n\n\u5728\u884c\u653f\u590d\u8bae\u8fc7\u7a0b\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u5bf9\u88ab\u7533\u8bf7\u4eba\u5c65\u884c\u4e49\u52a1\u7684\u76d1\u7763\u529b\u5ea6\u4e0d\u8db3\uff0c\u5bfc\u81f4\u90e8\u5206\u6848\u4ef6\u672a\u80fd\u53ca\u65f6\u5904\u7406\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u6d89\u53ca\u571f\u5730\u5f81\u6536\u7684\u884c\u653f\u4e89\u8bae\u65f6\uff0c\u672a\u53ca\u65f6\u7763\u4fc3\u88ab\u7533\u8bf7\u4eba\u5c65\u884c\u76f8\u5173\u4e49\u52a1\uff0c\u6700\u7ec8\u5bfc\u81f4\u6848\u4ef6\u957f\u671f\u672a\u51b3\u3002\u8fd9\u79cd\u76d1\u7763\u673a\u5236\u7684\u7f3a\u5931\uff0c\u4f7f\u5f97\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u5927\u6253\u6298\u6263\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u8fd0\u884c\u6548\u7387\u548c\u516c\u6b63\u6027\u3002"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u3001\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u4ee5\u53ca\u9002\u7528\u8303\u56f4\u6709\u9650\u7b49\u65b9\u9762\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u5904\u7f5a\u6848\u4ef6\u65f6\uff0c\u672a\u4f9d\u6cd5\u544a\u77e5\u5f53\u4e8b\u4eba\u590d\u8bae\u6743\u5229\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u672a\u80fd\u53ca\u65f6\u63d0\u51fa\u590d\u8bae\u7533\u8bf7\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u590d\u8bae\u7a0b\u5e8f\u7684\u516c\u6b63\u6027\u3002\u8fd9\u79cd\u7a0b\u5e8f\u4e0a\u7684\u7f3a\u9677\u53cd\u6620\u51fa\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u6267\u6cd5\u8fc7\u7a0b\u4e2d\u7f3a\u4e4f\u5bf9\u7a0b\u5e8f\u6b63\u4e49\u7684\u5145\u5206\u91cd\u89c6\u3002\n\n\u6b64\u5916\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u529b\u5ea6\u5f80\u5f80\u53d7\u5230\u591a\u79cd\u56e0\u7d20\u7684\u5f71\u54cd\uff0c\u5982\u5f53\u4e8b\u4eba\u62d2\u4e0d\u5c65\u884c\u3001\u8bc1\u636e\u4e0d\u8db3\u6216\u6267\u884c\u6210\u672c\u8fc7\u9ad8\u7b49\u3002\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u4e00\u4e9b\u590d\u8bae\u673a\u5173\u5bf9\u5c65\u884c\u60c5\u51b5\u7684\u76d1\u7763\u4e0d\u591f\u4e25\u683c\uff0c\u5bfc\u81f4\u90e8\u5206\u6848\u4ef6\u672a\u80fd\u6709\u6548\u843d\u5b9e\u590d\u8bae\u51b3\u5b9a\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u8bb8\u53ef\u6848\u4ef6\u65f6\uff0c\u590d\u8bae\u673a\u5173\u867d\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u56e0\u5f53\u4e8b\u4eba\u672a\u6309\u65f6\u5c65\u884c\uff0c\u590d\u8bae\u673a\u5173\u672a\u80fd\u53ca\u65f6\u91c7\u53d6\u5f3a\u5236\u63aa\u65bd\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6548\u529b\u3002\n\n\u5728\u9002\u7528\u8303\u56f4\u4e0a\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u6761\u4ef6\u8f83\u4e3a\u72ed\u7a84\uff0c\u4e3b\u8981\u9002\u7528\u4e8e\u884c\u653f\u5904\u7f5a\u6216\u884c\u653f\u8bb8\u53ef\u7b49\u5177\u4f53\u884c\u653f\u884c\u4e3a\u3002\u5bf9\u4e8e\u4e00\u4e9b\u62bd\u8c61\u884c\u653f\u884c\u4e3a\u6216\u6d89\u53ca\u516c\u5171\u5229\u76ca\u7684\u6848\u4ef6\uff0c\u590d\u8bae\u673a\u5173\u5f80\u5f80\u96be\u4ee5\u9002\u7528\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u4e2d\uff0c\u56e0\u88ab\u7533\u8bf7\u4eba\u6d89\u53ca\u91cd\u5927\u516c\u5171\u5229\u76ca\uff0c\u590d\u8bae\u673a\u5173\u672a\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u672a\u80fd\u83b7\u5f97\u5e94\u6709\u7684\u6551\u6d4e\u3002\n\ndocument\n\n\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6cd5\u5f8b\u6548\u529b\u548c\u6267\u884c\u6548\u679c\u4ecd\u5b58\u5728\u4e89\u8bae\u3002\u90e8\u5206\u590d\u8bae\u673a\u5173\u5bf9\u51b3\u5b9a\u7684\u5c65\u884c\u60c5\u51b5\u7f3a\u4e4f\u6709\u6548\u76d1\u7763\uff0c\u5bfc\u81f4\u4e00\u4e9b\u6848\u4ef6\u672a\u80fd\u4f9d\u6cd5\u6267\u884c\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u8bb8\u53ef\u6848\u4ef6\u65f6\uff0c\u867d\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u56e0\u5f53\u4e8b\u4eba\u672a\u6309\u65f6\u5c65\u884c\uff0c\u590d\u8bae\u673a\u5173\u672a\u80fd\u53ca\u65f6\u91c7\u53d6\u5f3a\u5236\u63aa\u65bd\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6548\u529b\u3002\u8fd9\u79cd\u60c5\u51b5\u4e0b\uff0c\u884c\u653f\u590d\u8bae\u7684\u6551\u6d4e\u529f\u80fd\u672a\u80fd\u5145\u5206\u53d1\u6325\uff0c\u635f\u5bb3\u4e86\u5f53\u4e8b\u4eba\u5408\u6cd5\u6743\u76ca\u3002"
}
{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u8bba\u6587\n\n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u662f\u6d41\u4f53\u529b\u5b66\u548c\u7a7a\u6c14\u52a8\u529b\u5b66\u9886\u57df\u7684\u91cd\u8981\u7814\u7a76\u65b9\u5411\uff0c\u5b83\u4eec\u901a\u8fc7\u6a21\u4eff\u81ea\u7136\u754c\u7684\u7ed3\u6784\u548c\u529f\u80fd\uff0c\u6765\u4f18\u5316\u98de\u884c\u5668\u7684\u6027\u80fd\u3002\u7ffc\u578b\u8bbe\u8ba1\u662f\u822a\u7a7a\u5de5\u7a0b\u4e2d\u7684\u6838\u5fc3\u5185\u5bb9\uff0c\u5176\u5f62\u72b6\u76f4\u63a5\u5f71\u54cd\u98de\u673a\u7684\u5347\u529b\u3001\u963b\u529b\u548c\u7a33\u5b9a\u6027\u3002\u4eff\u751f\u5b66\u5219\u901a\u8fc7\u7814\u7a76\u81ea\u7136\u754c\u4e2d\u7684\u751f\u7269\u7ed3\u6784\uff0c\u5982\u9e1f\u7c7b\u7684\u7fc5\u8180\u3001\u9c7c\u7684\u5c3e\u9ccd\u6216\u6606\u866b\u7684\u7fc5\u8180\uff0c\u6765\u542f\u53d1\u65b0\u7684\u8bbe\u8ba1\u601d\u8def\u3002\n\n\u5728\u81ea\u7136\u754c\u4e2d\uff0c\u9e1f\u7c7b\u7684\u7ffc\u578b\u5177\u6709\u9ad8\u5347\u529b\u7cfb\u6570\u548c\u4f4e\u963b\u529b\u7684\u7279\u70b9\uff0c\u5176\u5f62\u72b6\u548c\u89d2\u5ea6\u53d8\u5316\u80fd\u591f\u6709\u6548\u8c03\u8282\u7a7a\u6c14\u52a8\u529b\u5b66\u6027\u80fd\u3002\u4eff\u751f\u5b66\u7814\u7a76\u4e2d\uff0c\u7814\u7a76\u4eba\u5458\u5e38\u5e38\u501f\u9274\u9e1f\u7c7b\u7684\u7ffc\u578b\u7ed3\u6784\uff0c\u4ee5\u63d0\u9ad8\u98de\u884c\u5668\u7684\u6548\u7387\u3002\u4f8b\u5982\uff0c\u4eff\u751f\u7ffc\u578b\u7684\u8bbe\u8ba1\u80fd\u591f\u4f18\u5316\u6c14\u6d41\u5206\u79bb\uff0c\u51cf\u5c11\u963b\u529b\uff0c\u63d0\u9ad8\u5347\u529b\uff0c\u4ece\u800c\u63d0\u5347\u98de\u884c\u6027\u80fd\u3002\n\n\u6b64\u5916\uff0c\u4eff\u751f\u5b66\u5728\u5176\u4ed6\u9886\u57df\u4e5f\u6709\u5e7f\u6cdb\u5e94\u7528\uff0c\u5982\u5efa\u7b51\u3001\u6750\u6599\u79d1\u5b66\u548c\u673a\u5668\u4eba\u6280\u672f\u3002\u4f8b\u5982\uff0c\u67d0\u4e9b\u4eff\u751f\u7ed3\u6784\u80fd\u591f\u6a21\u4eff\u81ea\u7136\u754c\u7684\u81ea\u9002\u5e94\u6027\uff0c\u4ee5\u63d0\u9ad8\u7ed3\u6784\u7684\u7a33\u5b9a\u6027\u548c\u8010\u4e45\u6027\u3002\u8fd9\u4e9b\u7814\u7a76\u4e0d\u4ec5\u63a8\u52a8\u4e86\u822a\u7a7a\u5de5\u7a0b\u7684\u53d1\u5c55\uff0c\u4e5f\u4fc3\u8fdb\u4e86\u8de8\u5b66\u79d1\u7684\u5408\u4f5c\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\uff0c\u4e3a\u672a\u6765\u98de\u884c\u5668\u7684\u9ad8\u6548\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u3002\u901a\u8fc7\u6df1\u5165\u7814\u7a76\u81ea\u7136\u754c\u7684\u7ed3\u6784\u548c\u529f\u80fd\uff0c\u6211\u4eec\u53ef\u4ee5\u5f00\u53d1\u51fa\u66f4\u52a0\u9ad8\u6548\u3001\u73af\u4fdd\u548c\u667a\u80fd\u7684\u98de\u884c\u5668\uff0c\u4ece\u800c\u63a8\u52a8\u822a\u7a7a\u6280\u672f\u7684\u8fdb\u6b65\u3002\n\n\u7ffc"
}
{
    "response": "\u0623\u0646\u0627 \u0623\u0641\u0647\u0645 \u0623\u0646\u0643 \u062a\u0631\u063a\u0628 \u0641\u064a \u0625\u0646\u0634\u0627\u0621 \u0642\u0646\u0627\u0629 \u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u062a\u0645\u0627\u0645\u064b\u0627 \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0625\u0635\u0637\u0646\u0627\u0639\u064a\u060c \u0648\u0631\u0628\u0645\u0627 \u062a\u0631\u063a\u0628 \u0641\u064a \u062a\u0637\u0648\u064a\u0631 \u0645\u062d\u062a\u0648\u0649 \u0645\u0645\u064a\u0632 \u064a\u0646\u0627\u0633\u0628 \u0627\u0644\u062c\u0645\u0647\u0648\u0631. \u0625\u0644\u064a\u0643 \u0628\u0639\u0636 \u0627\u0644\u0625\u0642\u062a\u0631\u0627\u062d\u0627\u062a \u0627\u0644\u062a\u064a \u064a\u0645\u0643\u0646 \u0623\u0646 \u062a\u0633\u0627\u0639\u062f\u0643:\n\n1. **\u0625\u0646\u0634\u0627\u0621 \u0642\u0646\u0627\u0629 \u062a\u0641\u0627\u0639\u0644\u064a\u0629**: \u064a\u0645\u0643\u0646\u0643 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0623\u062f\u0648\u0627\u062a \u0645\u062b\u0644 YouTube \u0623\u0648 TikTok \u0644\u062a\u0642\u062f\u064a\u0645 \u0645\u062d\u062a\u0648\u0649 \u062a\u0641\u0627\u0639\u0644\u064a \u0645\u062b\u0644 \u0627\u0644\u0645\u0642\u0627\u0628\u0644\u0627\u062a \u0623\u0648 \u0627\u0644\u0645\u0631\u0627\u062c\u0639\u0627\u062a \u0623\u0648 \u0627\u0644\u062a\u062f\u0631\u064a\u0628\u0627\u062a.\n\n2. **\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u062a\u062d\u0644\u064a\u0644 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a**: \u064a\u0645\u0643\u0646\u0643 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0623\u062f\u0648\u0627\u062a \u0645\u062b\u0644 Google Analytics \u0623\u0648 Adobe Audience Manager \u0644\u062a\u062d\u0644\u064a\u0644 \u0633\u0644\u0648\u0643 \u0627\u0644\u062c\u0645\u0647\u0648\u0631 \u0648\u062a\u0639\u062f\u064a\u0644 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0628\u0646\u0627\u0621\u064b \u0639\u0644\u064a\u0647.\n\n3. **\u0625\u0646\u0634\u0627\u0621 \u0645\u062d\u062a\u0648\u0649 \u0645\u062e\u0635\u0635**: \u064a\u0645\u0643\u0646\u0643 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u062a\u062d\u0644\u064a\u0644 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u0633\u0627\u0628\u0642 \u0648\u062a\u0642\u062f\u064a\u0645 \u0645\u062d\u062a\u0648\u0649 \u0645\u064f\u062d\u0633\u0651\u0646 \u0648\u0645\u0644\u0627\u0626\u0645 \u0644\u062c\u0645\u0647\u0648\u0631\u0643.\n\n4. **\u0625\u0646\u0634\u0627\u0621 \u0645\u062d\u062a\u0648\u0649 \u0645\u064f\u0628\u062a\u0643\u0631**: \u064a\u0645\u0643\u0646\u0643 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u0635\u0646\u0639 \u0645\u062d\u062a\u0648\u0649 \u0645\u0628\u062a\u0643\u0631 \u0645\u062b\u0644 \u0627\u0644\u0641\u064a\u062f\u064a\u0648\u0647\u0627\u062a \u0627\u0644\u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u0623\u0648 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u062a\u0641\u0627\u0639\u0644\u064a.\n\n5. **\u062a\u062e\u0635\u064a\u0635 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0628\u0646\u0627\u0621\u064b \u0639\u0644\u0649 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a**: \u064a\u0645\u0643\u0646\u0643 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u062a\u062d\u0644\u064a\u0644 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0648\u062a\u0642\u062f\u064a\u0645 \u0645\u062d\u062a\u0648\u0649 \u0645\u064f\u062e\u0635\u0651\u0635 \u0644\u0643\u0644 \u0641\u0626\u0629 \u0645\u0646 \u0627\u0644\u062c\u0645\u0647\u0648\u0631.\n\n6. **\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u062a\u062d\u0633\u064a\u0646 \u062a\u062c\u0631\u0628\u0629 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645**: \u064a\u0645\u0643\u0646\u0643 \u062a\u062d\u0633\u064a\u0646 \u062a\u062c\u0631\u0628\u0629 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645 \u0639\u0628\u0631 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u062c\u0639\u0644 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0623\u0643\u062b\u0631 \u0641\u0639\u0627\u0644\u064a\u0629.\n\n7. **\u0625\u0646\u0634\u0627\u0621 \u0645\u062d\u062a\u0648\u0649 \u062a\u0641\u0627\u0639\u0644\u064a**: \u064a\u0645\u0643\u0646\u0643 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u062e\u0644\u0642 \u0645\u062d\u062a\u0648\u0649 \u062a\u0641\u0627\u0639\u0644\u064a \u0645\u062b\u0644 \u0627\u0644\u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0623\u0648 \u0627\u0644\u0645\u0631\u0627\u062c\u0639\u0627\u062a \u0623\u0648 \u0627\u0644\u062a\u062f\u0631\u064a\u0628\u0627\u062a.\n\n8. **\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u062a\u062d\u0633\u064a\u0646 \u0627\u0644\u0646\u062a\u0627\u0626\u062c**: \u064a\u0645\u0643\u0646\u0643 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u062a\u062d\u0644\u064a\u0644 \u0627\u0644\u0646\u062a\u0627\u0626\u062c \u0648\u062a\u0642\u062f\u064a\u0645 \u0645\u062d\u062a\u0648\u0649 \u0623\u0643\u062b\u0631 \u0641\u0639\u0627\u0644\u064a\u0629.\n\n9. **\u0625\u0646\u0634\u0627\u0621 \u0645\u062d\u062a\u0648\u0649 \u0645\u064f\u0628\u062a\u0643\u0631 \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a**: \u064a\u0645\u0643\u0646\u0643 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u0635\u0646\u0639 \u0645\u062d\u062a\u0648\u0649 \u0645\u064f\u0628\u062a\u0643\u0631 \u0645\u062b\u0644 \u0627\u0644\u0641\u064a\u062f\u064a\u0648\u0647\u0627\u062a \u0627\u0644\u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u0623\u0648 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u062a\u0641\u0627\u0639\u0644\u064a.\n\n10. **\u062a\u062e\u0635\u064a\u0635 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0628\u0646\u0627\u0621\u064b \u0639\u0644\u0649 \u0633\u0644\u0648\u0643 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645**: \u064a\u0645\u0643\u0646\u0643 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639"
}
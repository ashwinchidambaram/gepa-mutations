{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u3001\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u4ee5\u53ca\u6cd5\u5f8b\u4f9d\u636e\u4e0d\u660e\u786e\u7b49\u65b9\u9762\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u672a\u80fd\u4f9d\u6cd5\u5411\u88ab\u7533\u8bf7\u4eba\u9001\u8fbe\u5c65\u884c\u901a\u77e5\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u672a\u80fd\u53ca\u65f6\u5c65\u884c\u4e49\u52a1\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u6548\u7387\u3002\u8fd9\u79cd\u60c5\u51b5\u4e0b\uff0c\u590d\u8bae\u673a\u5173\u672a\u80fd\u5145\u5206\u5c65\u884c\u5176\u6cd5\u5b9a\u804c\u8d23\uff0c\u53cd\u6620\u51fa\u7a0b\u5e8f\u4e0a\u7684\u4e0d\u4e25\u8c28\u3002\n\n\u6b64\u5916\uff0c\u4e00\u4e9b\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u88ab\u7533\u8bf7\u4eba\u5bf9\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u4e3b\u52a8\u6027\u548c\u79ef\u6781\u6027\uff0c\u751a\u81f3\u5b58\u5728\u9003\u907f\u5c65\u884c\u7684\u60c5\u51b5\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u571f\u5730\u5f81\u6536\u884c\u653f\u590d\u8bae\u4e2d\uff0c\u88ab\u7533\u8bf7\u4eba\u62d2\u7edd\u5c65\u884c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u7684\u8d23\u4ee4\u9650\u671f\u5c65\u884c\u51b3\u5b9a\uff0c\u5bfc\u81f4\u6848\u4ef6\u957f\u671f\u672a\u51b3\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u548c\u516c\u4fe1\u529b\u3002\u8fd9\u8868\u660e\uff0c\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u548c\u6fc0\u52b1\u673a\u5236\uff0c\u96be\u4ee5\u786e\u4fdd\u88ab\u7533\u8bf7\u4eba\u5207\u5b9e\u5c65\u884c\u4e49\u52a1\u3002\n\n\u5728\u6cd5\u5f8b\u4f9d\u636e\u65b9\u9762\uff0c\u90e8\u5206\u590d\u8bae\u51b3\u5b9a\u7f3a\u4e4f\u660e\u786e\u7684\u6cd5\u5f8b\u4f9d\u636e\uff0c\u5bfc\u81f4\u6267\u884c\u96be\u5ea6\u52a0\u5927\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u672a\u5145\u5206\u5f15\u7528\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u5bf9\u51b3\u5b9a\u7684\u5408\u6cd5\u6027\u5b58\u7591\uff0c\u8fdb\u800c\u5f71\u54cd\u4e86\u6267\u884c\u6548\u679c\u3002\u8fd9\u79cd\u6cd5\u5f8b\u4f9d\u636e\u4e0d\u660e\u786e\u7684\u95ee\u9898\uff0c\u53cd\u6620\u51fa\u590d\u8bae\u673a\u5173\u5728\u6cd5\u5f8b\u9002\u7528\u4e0a\u7684\u4e0d\u8db3\uff0c\u4e9f\u9700\u52a0\u5f3a\u6cd5\u5f8b\u57f9\u8bad\u548c\u89c4\u8303\u64cd\u4f5c\u6d41\u7a0b\u3002\n\ndocument\n\n\u5728\u884c\u653f\u590d\u8bae\u5b9e\u8df5\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u5bf9\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u7edf\u4e00\u6807\u51c6\u548c\u660e\u786e\u7684\u5b9e\u65bd\u7ec6\u5219\uff0c\u5bfc\u81f4\u6267\u884c\u6548\u679c\u53c2\u5dee\u4e0d\u9f50\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u5bf9\u4e0d\u540c\u6848\u4ef6\u7684\u6267\u884c\u671f\u9650\u548c\u65b9\u5f0f\u7f3a\u4e4f\u7edf\u4e00\u89c4\u5b9a\uff0c\u9020\u6210\u6267\u884c\u8fc7\u7a0b\u6df7\u4e71\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u6548\u7387\u3002\u8fd9\u79cd\u7f3a\u4e4f\u7edf\u4e00\u6807\u51c6\u7684\u95ee\u9898\uff0c\u53cd\u6620\u51fa\u884c\u653f\u590d\u8bae\u5236\u5ea6\u5728\u6267\u884c\u5c42\u9762\u7684\u4e0d\u5b8c\u5584\uff0c\u4e9f\u9700\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173\u89c4\u8303\u548c\u64cd\u4f5c\u6d41\u7a0b\u3002"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u3001\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u4ee5\u53ca\u6cd5\u5f8b\u9002\u7528\u4e0d\u7edf\u4e00\u7b49\u65b9\u9762\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u672a\u4f9d\u6cd5\u5c65\u884c\u544a\u77e5\u4e49\u52a1\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u672a\u80fd\u53ca\u65f6\u5c65\u884c\u590d\u8bae\u51b3\u5b9a\uff0c\u6700\u7ec8\u5bfc\u81f4\u6848\u4ef6\u4e45\u62d6\u4e0d\u51b3\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u6548\u7387\u3002\u8fd9\u79cd\u60c5\u5f62\u53cd\u6620\u51fa\u590d\u8bae\u673a\u5173\u5728\u7a0b\u5e8f\u4e0a\u5b58\u5728\u758f\u6f0f\uff0c\u672a\u80fd\u5145\u5206\u4fdd\u969c\u5f53\u4e8b\u4eba\u7684\u77e5\u60c5\u6743\u548c\u53c2\u4e0e\u6743\u3002\n\n\u53e6\u5916\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u5b58\u5728\u96be\u5ea6\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u51b3\u5b9a\u96be\u4ee5\u843d\u5b9e\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u867d\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u56e0\u7f3a\u4e4f\u5177\u4f53\u7684\u6267\u884c\u63aa\u65bd\u548c\u76d1\u7763\u7a0b\u5e8f\uff0c\u88ab\u7533\u8bf7\u4eba\u59cb\u7ec8\u672a\u80fd\u5c65\u884c\uff0c\u6700\u7ec8\u5bfc\u81f4\u590d\u8bae\u7a0b\u5e8f\u9677\u5165\u50f5\u5c40\u3002\u8fd9\u8868\u660e\u5728\u6267\u884c\u73af\u8282\u4e0a\u5b58\u5728\u5236\u5ea6\u6027\u7f3a\u9677\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u5b9e\u6548\u6027\u3002\n\n\u5728\u6cd5\u5f8b\u9002\u7528\u65b9\u9762\uff0c\u4e0d\u540c\u5730\u533a\u548c\u4e0d\u540c\u6cd5\u9662\u5bf9\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u6807\u51c6\u4e0d\u7edf\u4e00\uff0c\u5bfc\u81f4\u6848\u4ef6\u5904\u7406\u7ed3\u679c\u5dee\u5f02\u8f83\u5927\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u6cd5\u9662\u5728\u5904\u7406\u7c7b\u4f3c\u6848\u4ef6\u65f6\uff0c\u5bf9\u201c\u5c65\u884c\u671f\u9650\u201d\u548c\u201c\u5c65\u884c\u65b9\u5f0f\u201d\u7b49\u5173\u952e\u8981\u7d20\u7684\u8ba4\u5b9a\u5b58\u5728\u5206\u6b67\uff0c\u5f71\u54cd\u4e86\u590d\u8bae\u51b3\u5b9a\u7684\u53ef\u64cd\u4f5c\u6027\u548c\u4e00\u81f4\u6027\u3002\u8fd9\u79cd\u6cd5\u5f8b\u9002\u7528\u7684\u4e0d\u7edf\u4e00\uff0c\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u6743\u5a01\u6027\u548c\u516c\u4fe1\u529b\u3002\n\ndocument\n\n\u6700\u540e\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6cd5\u5f8b\u6548\u529b\u548c\u6551\u6d4e\u9014\u5f84\u4e0d\u591f\u660e\u786e\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u5728\u9762\u5bf9\u590d\u8bae\u51b3\u5b9a\u65f6\u7f3a\u4e4f\u6709\u6548\u7684\u6551\u6d4e\u6e20\u9053\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u672a\u660e\u786e\u544a\u77e5\u5f53\u4e8b\u4eba\u7533\u8bf7\u6cd5\u9662\u5f3a\u5236\u6267\u884c\u7684\u7a0b\u5e8f\u548c\u65f6\u9650\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u5728\u5c65\u884c\u671f\u9650\u5c4a\u6ee1\u540e\u65e0\u6cd5\u53ca\u65f6\u5bfb\u6c42\u6cd5\u5f8b\u6551\u6d4e\u3002\u8fd9\u79cd\u5236\u5ea6\u8bbe\u8ba1\u4e0a\u7684\u4e0d\u8db3\uff0c\u4f7f\u5f97\u884c\u653f\u590d\u8bae\u7684\u6551\u6d4e\u529f\u80fd\u672a\u80fd\u5145\u5206\u53d1\u6325\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u6574\u4f53\u6548\u80fd\u3002"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u5176\u4e2d\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u548c\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u3002\u4f8b\u5982\uff0c\u4e00\u4e9b\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u672a\u80fd\u5145\u5206\u542c\u53d6\u5f53\u4e8b\u4eba\u610f\u89c1\uff0c\u5bfc\u81f4\u51b3\u5b9a\u7f3a\u4e4f\u5408\u6cd5\u6027\u3002\u67d0\u5730\u5e02\u573a\u76d1\u7ba1\u5c40\u5728\u5904\u7406\u67d0\u4f01\u4e1a\u8fdd\u89c4\u884c\u4e3a\u65f6\uff0c\u672a\u4f9d\u6cd5\u544a\u77e5\u5f53\u4e8b\u4eba\u76f8\u5173\u6743\u5229\uff0c\u76f4\u63a5\u4f5c\u51fa\u8d23\u4ee4\u6574\u6539\u51b3\u5b9a\uff0c\u5f15\u53d1\u4e86\u5f53\u4e8b\u4eba\u4e0d\u6ee1\uff0c\u5f71\u54cd\u4e86\u590d\u8bae\u7a0b\u5e8f\u7684\u516c\u6b63\u6027\u3002\n\n\u53e6\u5916\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u4e0d\u900f\u660e\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u5728\u5904\u7406\u67d0\u4f01\u4e1a\u6c61\u67d3\u6848\u4ef6\u65f6\uff0c\u672a\u4f9d\u6cd5\u843d\u5b9e\u6574\u6539\u8981\u6c42\uff0c\u81f4\u4f7f\u4f01\u4e1a\u957f\u671f\u672a\u5b8c\u6210\u6574\u6539\uff0c\u5f71\u54cd\u4e86\u751f\u6001\u73af\u5883\u7684\u6062\u590d\u3002\u8fd9\u79cd\u7f3a\u4e4f\u76d1\u7763\u7684\u6267\u884c\u65b9\u5f0f\uff0c\u4f7f\u5f97\u590d\u8bae\u51b3\u5b9a\u7684\u6548\u529b\u96be\u4ee5\u4fdd\u969c\u3002\n\n\u540c\u65f6\uff0c\u884c\u653f\u590d\u8bae\u6cd5\u5bf9\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u671f\u9650\u548c\u65b9\u5f0f\u89c4\u5b9a\u4e0d\u591f\u660e\u786e\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u4e2d\u51fa\u73b0\u6df7\u4e71\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u6cd5\u9662\u5728\u6267\u884c\u590d\u8bae\u51b3\u5b9a\u65f6\uff0c\u56e0\u5bf9\u671f\u9650\u7684\u7406\u89e3\u4e0d\u540c\uff0c\u5bfc\u81f4\u6267\u884c\u65f6\u95f4\u8fc7\u957f\uff0c\u5f71\u54cd\u4e86\u5f53\u4e8b\u4eba\u7684\u6743\u76ca\u3002\u8fd9\u79cd\u4e0d\u660e\u786e\u7684\u6cd5\u5f8b\u89c4\u5b9a\uff0c\u4f7f\u5f97\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u9762\u4e34\u8f83\u5927\u56f0\u96be\u3002\n\ndocument\n\n\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u5f80\u5f80\u9762\u4e34\u8d44\u6e90\u4e0d\u8db3\u548c\u4eba\u5458\u4e13\u4e1a\u6027\u4e0d\u5f3a\u7684\u95ee\u9898\uff0c\u8fd9\u8fdb\u4e00\u6b65\u5f71\u54cd\u4e86\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u5927\u91cf\u6848\u4ef6\u65f6\uff0c\u56e0\u7f3a\u4e4f\u4e13\u95e8\u7684\u6267\u884c\u4eba\u5458\uff0c\u5bfc\u81f4\u90e8\u5206\u51b3\u5b9a\u65e0\u6cd5\u53ca\u65f6\u843d\u5b9e\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u6548\u7387\u3002\u8fd9\u79cd\u8d44\u6e90\u5206\u914d\u4e0d\u5747\u7684\u95ee\u9898\uff0c\u4f7f\u5f97\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u96be\u4ee5\u8fbe\u5230\u9884\u671f\u3002"
}
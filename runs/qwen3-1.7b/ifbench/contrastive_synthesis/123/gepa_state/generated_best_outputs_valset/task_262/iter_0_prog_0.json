{
    "response": "\u0623\u0646\u0627 \u0623\u062a\u0641\u0647\u0645 \u0623\u0646\u0643 \u062a\u0628\u062d\u062b \u0639\u0646 \u0625\u0642\u062a\u0631\u0627\u062d\u0627\u062a \u0644\u0639\u0645\u0644 \u0642\u0646\u0627\u0629 \u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0625\u0635\u0637\u0646\u0627\u0639\u064a\u060c \u0648\u062a\u062d\u062a\u0627\u062c \u0625\u0644\u0649 \u0625\u0642\u062a\u0631\u0627\u062d\u0627\u062a \u0645\u0641\u0635\u0644\u0629 \u0648\u0645\u0644\u0627\u0626\u0645\u0629. \u0625\u0644\u064a\u0643 \u0628\u0639\u0636 \u0627\u0644\u0627\u0642\u062a\u0631\u0627\u062d\u0627\u062a:\n\n1. **\u0627\u0644\u0642\u0646\u0627\u0629 \u0627\u0644\u062a\u0639\u0644\u064a\u0645\u064a\u0629**: \u064a\u0645\u0643\u0646\u0643 \u0625\u0646\u0634\u0627\u0621 \u0642\u0646\u0627\u0629 \u062a\u0639\u0644\u064a\u0645\u064a\u0629 \u062a\u0642\u062f\u0645 \u0645\u062d\u062a\u0648\u0649 \u062a\u0639\u0644\u064a\u0645\u064a \u0645\u0641\u064a\u062f\u060c \u0645\u062b\u0644 \u0645\u0633\u0627\u0628\u0642\u0627\u062a \u062a\u0641\u0627\u0639\u0644\u064a\u0629\u060c \u0648\u062a\u0645\u0627\u0631\u064a\u0646 \u062a\u0637\u0628\u064a\u0642\u064a\u0629\u060c \u0648\u0645\u0648\u0627\u062f \u062a\u0641\u0627\u0639\u0644\u064a\u0629.\n\n2. **\u0627\u0644\u0642\u0646\u0627\u0629 \u0627\u0644\u062a\u0631\u0641\u064a\u0647\u064a\u0629**: \u064a\u0645\u0643\u0646\u0643 \u0625\u0646\u0634\u0627\u0621 \u0642\u0646\u0627\u0629 \u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u062a\u0642\u062f\u0645 \u0645\u062d\u062a\u0648\u0649 \u062a\u0631\u0641\u064a\u0647\u064a\u060c \u0645\u062b\u0644 \u0645\u0633\u0644\u0633\u0644\u0627\u062a \u062a\u0641\u0627\u0639\u0644\u064a\u0629\u060c \u0645\u0633\u0627\u0628\u0642\u0627\u062a \u0625\u062e\u0628\u0627\u0631\u064a\u0629\u060c \u0648\u0639\u0631\u0648\u0636 \u062a\u0641\u0627\u0639\u0644\u064a\u0629.\n\n3. **\u0627\u0644\u0642\u0646\u0627\u0629 \u0627\u0644\u062a\u0643\u0646\u0648\u0644\u0648\u062c\u064a\u0629**: \u064a\u0645\u0643\u0646\u0643 \u0625\u0646\u0634\u0627\u0621 \u0642\u0646\u0627\u0629 \u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u062a\u0642\u062f\u0645 \u0645\u062d\u062a\u0648\u0649 \u062a\u0643\u0646\u0648\u0644\u0648\u062c\u064a\u060c \u0645\u062b\u0644 \u0645\u0633\u0627\u0628\u0642\u0627\u062a \u062a\u0637\u0648\u064a\u0631 \u0623\u0644\u0639\u0627\u0628\u060c \u0648\u062a\u0645\u0627\u0631\u064a\u0646 \u062a\u0637\u0628\u064a\u0642\u064a\u0629\u060c \u0648\u0645\u0648\u0627\u062f \u062a\u0641\u0627\u0639\u0644\u064a\u0629.\n\n4. **\u0627\u0644\u0642\u0646\u0627\u0629 \u0627\u0644\u0623\u062f\u0628\u064a\u0629**: \u064a\u0645\u0643\u0646\u0643 \u0625\u0646\u0634\u0627\u0621 \u0642\u0646\u0627\u0629 \u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u062a\u0642\u062f\u0645 \u0645\u062d\u062a\u0648\u0649 \u0623\u062f\u0628\u064a\u060c \u0645\u062b\u0644 \u0645\u0633\u0627\u0628\u0642\u0627\u062a \u0642\u0635\u0627\u0626\u062f\u060c \u0648\u062a\u0645\u0627\u0631\u064a\u0646 \u062a\u0637\u0628\u064a\u0642\u064a\u0629\u060c \u0648\u0645\u0648\u0627\u062f \u062a\u0641\u0627\u0639\u0644\u064a\u0629.\n\n5. **\u0627\u0644\u0642\u0646\u0627\u0629 \u0627\u0644\u0635\u062d\u064a\u0629**: \u064a\u0645\u0643\u0646\u0643 \u0625\u0646\u0634\u0627\u0621 \u0642\u0646\u0627\u0629 \u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u062a\u0642\u062f\u0645 \u0645\u062d\u062a\u0648\u0649 \u0635\u062d\u064a\u0629\u060c \u0645\u062b\u0644 \u0645\u0633\u0627\u0628\u0642\u0627\u062a \u062a\u0637\u0648\u064a\u0631 \u0623\u0644\u0639\u0627\u0628\u060c \u0648\u062a\u0645\u0627\u0631\u064a\u0646 \u062a\u0637\u0628\u064a\u0642\u064a\u0629\u060c \u0648\u0645\u0648\u0627\u062f \u062a\u0641\u0627\u0639\u0644\u064a\u0629.\n\n6. **\u0627\u0644\u0642\u0646\u0627\u0629 \u0627\u0644\u0631\u064a\u0627\u0636\u064a\u0629**: \u064a\u0645\u0643\u0646\u0643 \u0625\u0646\u0634\u0627\u0621 \u0642\u0646\u0627\u0629 \u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u062a\u0642\u062f\u0645 \u0645\u062d\u062a\u0648\u0649 \u0631\u064a\u0627\u0636\u064a\u060c \u0645\u062b\u0644 \u0645\u0633\u0627\u0628\u0642\u0627\u062a \u062a\u0637\u0648\u064a\u0631 \u0623\u0644\u0639\u0627\u0628\u060c \u0648\u062a\u0645\u0627\u0631\u064a\u0646 \u062a\u0637\u0628\u064a\u0642\u064a\u0629\u060c \u0648\u0645\u0648\u0627\u062f \u062a\u0641\u0627\u0639\u0644\u064a\u0629.\n\n7. **\u0627\u0644\u0642\u0646\u0627\u0629 \u0627\u0644\u062a\u062c\u0627\u0631\u064a\u0629**: \u064a\u0645\u0643\u0646\u0643 \u0625\u0646\u0634\u0627\u0621 \u0642\u0646\u0627\u0629 \u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u062a\u0642\u062f\u0645 \u0645\u062d\u062a\u0648\u0649 \u062a\u062c\u0627\u0631\u064a\u060c \u0645\u062b\u0644 \u0645\u0633\u0627\u0628\u0642\u0627\u062a \u062a\u0637\u0648\u064a\u0631 \u0623\u0644\u0639\u0627\u0628\u060c \u0648\u062a\u0645\u0627\u0631\u064a\u0646 \u062a\u0637\u0628\u064a\u0642\u064a\u0629\u060c \u0648\u0645\u0648\u0627\u062f \u062a\u0641\u0627\u0639\u0644\u064a\u0629.\n\n8. **\u0627\u0644\u0642\u0646\u0627\u0629 \u0627\u0644\u0645\u063a\u0646\u064a\u0629**: \u064a\u0645\u0643\u0646\u0643 \u0625\u0646\u0634\u0627\u0621 \u0642\u0646\u0627\u0629 \u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u062a\u0642\u062f\u0645 \u0645\u062d\u062a\u0648\u0649 \u0645\u063a\u0646\u0649\u060c \u0645\u062b\u0644 \u0645\u0633\u0627\u0628\u0642\u0627\u062a \u062a\u0637\u0648\u064a\u0631 \u0623\u0644\u0639\u0627\u0628\u060c \u0648\u062a\u0645\u0627\u0631\u064a\u0646 \u062a\u0637\u0628\u064a\u0642\u064a\u0629\u060c \u0648\u0645\u0648\u0627\u062f \u062a\u0641\u0627\u0639\u0644\u064a\u0629.\n\n9. **\u0627\u0644\u0642\u0646\u0627\u0629 \u0627\u0644\u0645\u0633\u0631\u062d\u064a\u0629**: \u064a\u0645\u0643\u0646\u0643 \u0625\u0646\u0634\u0627\u0621 \u0642\u0646\u0627\u0629 \u062a\u0641\u0627\u0639\u0644\u064a\u0629 \u062a\u0642\u062f\u0645 \u0645\u062d\u062a\u0648\u0649 \u0645\u0633\u0631\u062d\u064a\u060c \u0645\u062b\u0644 \u0645\u0633\u0627\u0628\u0642\u0627\u062a \u062a\u0637"
}
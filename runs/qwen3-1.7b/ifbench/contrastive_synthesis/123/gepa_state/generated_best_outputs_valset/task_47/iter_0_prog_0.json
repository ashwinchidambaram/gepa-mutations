{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u8bba\u6587\n\n\u7ffc\u578b\u8bbe\u8ba1\u662f\u822a\u7a7a\u5de5\u7a0b\u548c\u6d41\u4f53\u529b\u5b66\u4e2d\u7684\u6838\u5fc3\u9886\u57df\uff0c\u5176\u76ee\u7684\u662f\u901a\u8fc7\u4f18\u5316\u7a7a\u6c14\u52a8\u529b\u5b66\u7279\u6027\u6765\u63d0\u9ad8\u98de\u884c\u5668\u7684\u6027\u80fd\u3002\u4f20\u7edf\u7684\u7ffc\u578b\u8bbe\u8ba1\u4e3b\u8981\u57fa\u4e8e\u7ecf\u9a8c\u516c\u5f0f\u548c\u5b9e\u9a8c\u6570\u636e\uff0c\u800c\u8fd1\u5e74\u6765\uff0c\u4eff\u751f\u5b66\u7684\u5e94\u7528\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u5e26\u6765\u4e86\u9769\u547d\u6027\u7684\u53d8\u5316\u3002\u4eff\u751f\u5b66\u901a\u8fc7\u7814\u7a76\u81ea\u7136\u754c\u4e2d\u7684\u751f\u7269\u7ed3\u6784\u548c\u529f\u80fd\uff0c\u4e3a\u8bbe\u8ba1\u66f4\u9ad8\u6548\u3001\u66f4\u8f7b\u7684\u7ffc\u578b\u63d0\u4f9b\u4e86\u7075\u611f\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7684\u7fc5\u8180\u3001\u9c7c\u7684\u5c3e\u9ccd\u4ee5\u53ca\u6606\u866b\u7684\u590d\u773c\u7b49\uff0c\u90fd\u5c55\u793a\u4e86\u81ea\u7136\u754c\u4e2d\u5353\u8d8a\u7684\u7a7a\u6c14\u52a8\u529b\u5b66\u6027\u80fd\u3002\n\n\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u4e3b\u8981\u4f53\u73b0\u5728\u4ee5\u4e0b\u51e0\u4e2a\u65b9\u9762\uff1a\u9996\u5148\uff0c\u901a\u8fc7\u5bf9\u9e1f\u7c7b\u7fc5\u8180\u7684\u89c2\u5bdf\uff0c\u7814\u7a76\u4eba\u5458\u53d1\u73b0\u9e1f\u7c7b\u7684\u7ffc\u578b\u5177\u6709\u9ad8\u5347\u529b\u7cfb\u6570\u548c\u4f4e\u963b\u529b\u7cfb\u6570\u7684\u7279\u6027\uff0c\u8fd9\u4f7f\u5f97\u5b83\u4eec\u80fd\u591f\u5728\u4f4e\u901f\u98de\u884c\u65f6\u4fdd\u6301\u8f83\u9ad8\u7684\u5347\u529b\u3002\u8fd9\u79cd\u7279\u6027\u88ab\u5e94\u7528\u4e8e\u73b0\u4ee3\u98de\u673a\u7684\u7ffc\u578b\u8bbe\u8ba1\u4e2d\uff0c\u4ee5\u63d0\u9ad8\u98de\u884c\u6548\u7387\u548c\u71c3\u6cb9\u7ecf\u6d4e\u6027\u3002\u5176\u6b21\uff0c\u4eff\u751f\u5b66\u8fd8\u542f\u53d1\u4e86\u5bf9\u9c7c\u5c3e\u9ccd\u7684\u6a21\u4eff\uff0c\u8fd9\u4e9b\u7ed3\u6784\u80fd\u591f\u6709\u6548\u51cf\u5c11\u6c34\u6d41\u963b\u529b\uff0c\u63d0\u9ad8\u822a\u884c\u6548\u7387\u3002\u8fd9\u4e9b\u7814\u7a76\u7ed3\u679c\u88ab\u5e94\u7528\u4e8e\u8239\u8236\u548c\u6c34\u4e0b\u4ea4\u901a\u5de5\u5177\u7684\u8bbe\u8ba1\u4e2d\uff0c\u4ee5\u63d0\u5347\u5176\u52a8\u529b\u6027\u80fd\u3002\n\n\u6b64\u5916\uff0c\u4eff\u751f\u5b66\u8fd8\u4fc3\u8fdb\u4e86\u5bf9\u6606\u866b\u7ffc\u578b\u7684\u7814\u7a76\uff0c\u6606\u866b\u7684\u7ffc\u578b\u5177\u6709\u590d\u6742\u7684\u51e0\u4f55\u7ed3\u6784\uff0c\u80fd\u591f\u5b9e\u73b0\u9ad8\u6548\u7684\u98de\u884c\u63a7\u5236\u548c\u80fd\u91cf\u5229\u7528\u3002\u8fd9\u4e9b\u7814\u7a76\u4e3a\u8bbe\u8ba1\u66f4\u9ad8\u6548\u7684\u65e0\u4eba\u673a\u548c\u98de\u884c\u5668\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e0d\u4ec5\u63d0\u5347\u4e86\u98de\u884c\u5668\u7684\u6027\u80fd\uff0c\u8fd8\u63a8\u52a8\u4e86\u7a7a\u6c14\u52a8\u529b\u5b66\u7814\u7a76\u7684\u53d1\u5c55\u3002\u968f\u7740\u4eff\u751f\u5b66\u7684\u4e0d\u65ad\u8fdb\u6b65\uff0c\u672a\u6765\u7ffc\u578b\u8bbe\u8ba1\u5c06\u66f4\u52a0\u667a\u80fd\u5316\u548c\u9ad8\u6548\u5316\uff0c\u4e3a\u822a\u7a7a\u822a\u5929\u9886\u57df\u5e26\u6765\u66f4\u591a\u7684\u521b\u65b0\u548c\u7a81\u7834\u3002\n\n\u7ffc"
}
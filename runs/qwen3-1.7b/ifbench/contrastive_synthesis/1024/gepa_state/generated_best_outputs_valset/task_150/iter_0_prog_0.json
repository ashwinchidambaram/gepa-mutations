{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u548c\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u7b49\u65b9\u9762\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u672a\u4f9d\u6cd5\u5411\u88ab\u7533\u8bf7\u4eba\u9001\u8fbe\u5c65\u884c\u901a\u77e5\u4e66\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u672a\u80fd\u53ca\u65f6\u5c65\u884c\u4e49\u52a1\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u6848\u4ef6\u7684\u516c\u6b63\u5904\u7406\u3002\u8fd9\u79cd\u505a\u6cd5\u8fdd\u53cd\u4e86\u300a\u884c\u653f\u590d\u8bae\u6cd5\u300b\u5173\u4e8e\u9001\u8fbe\u7a0b\u5e8f\u7684\u89c4\u5b9a\uff0c\u5bfc\u81f4\u590d\u8bae\u51b3\u5b9a\u7684\u6548\u529b\u53d7\u5230\u8d28\u7591\u3002\n\n\u5176\u6b21\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u5c65\u884c\u60c5\u51b5\u96be\u4ee5\u8ffd\u8e2a\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u571f\u5730\u7ea0\u7eb7\u6848\u4ef6\u65f6\uff0c\u672a\u5bf9\u88ab\u7533\u8bf7\u4eba\u5c65\u884c\u4e49\u52a1\u7684\u60c5\u51b5\u8fdb\u884c\u6709\u6548\u76d1\u7763\uff0c\u6700\u7ec8\u5bfc\u81f4\u590d\u8bae\u51b3\u5b9a\u672a\u80fd\u771f\u6b63\u5b9e\u73b0\u516c\u6b63\u6267\u884c\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u4fe1\u529b\u3002\n\n\u518d\u6b21\uff0c\u590d\u8bae\u51b3\u5b9a\u7684\u6cd5\u5f8b\u6548\u529b\u548c\u5f3a\u5236\u529b\u4e0d\u8db3\uff0c\u4f7f\u5f97\u88ab\u7533\u8bf7\u4eba\u6709\u65f6\u96be\u4ee5\u5c65\u884c\u4e49\u52a1\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u867d\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u672a\u91c7\u53d6\u6709\u6548\u63aa\u65bd\u786e\u4fdd\u88ab\u7533\u8bf7\u4eba\u5c65\u884c\uff0c\u5bfc\u81f4\u6848\u4ef6\u957f\u671f\u672a\u7ed3\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6548\u7387\u548c\u516c\u6b63\u6027\u3002\n\n\u6700\u540e\uff0c\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u7f3a\u4e4f\u660e\u786e\u7684\u6cd5\u5f8b\u4f9d\u636e\u548c\u64cd\u4f5c\u89c4\u8303\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u7f3a\u4e4f\u7edf\u4e00\u6807\u51c6\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u7f3a\u4e4f\u5177\u4f53\u7684\u6267\u884c\u7a0b\u5e8f\u548c\u65f6\u95f4\u9650\u5236\uff0c\u4f7f\u5f97\u6267\u884c\u8fc7\u7a0b\u7f3a\u4e4f\u660e\u786e\u7684\u6cd5\u5f8b\u4fdd\u969c\uff0c\u5f71\u54cd\u4e86\u590d\u8bae\u51b3\u5b9a\u7684\u5b9e\u65bd\u6548\u679c\u3002"
}
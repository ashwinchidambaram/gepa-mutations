{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u5176\u4e2d\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u3001\u9002\u7528\u8303\u56f4\u6709\u9650\u4ee5\u53ca\u6267\u884c\u673a\u5236\u4e0d\u5b8c\u5584\u7b49\u65b9\u9762\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u672a\u4f9d\u6cd5\u5c65\u884c\u544a\u77e5\u4e49\u52a1\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u672a\u53ca\u65f6\u5c65\u884c\u590d\u8bae\u51b3\u5b9a\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u6848\u4ef6\u7684\u516c\u6b63\u5904\u7406\u3002\u6b64\u7c7b\u95ee\u9898\u53cd\u6620\u51fa\u590d\u8bae\u673a\u5173\u5728\u7a0b\u5e8f\u4e0a\u5b58\u5728\u758f\u6f0f\uff0c\u672a\u80fd\u5145\u5206\u4fdd\u969c\u5f53\u4e8b\u4eba\u7684\u77e5\u60c5\u6743\u548c\u53c2\u4e0e\u6743\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u8f83\u4e3a\u72ed\u7a84\uff0c\u4e3b\u8981\u9002\u7528\u4e8e\u884c\u653f\u884c\u4e3a\u8fdd\u6cd5\u4f46\u672a\u88ab\u64a4\u9500\u7684\u60c5\u5f62\u3002\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5bf9\u201c\u8fdd\u6cd5\u201d\u4e0e\u201c\u4e0d\u5f53\u201d\u4e4b\u95f4\u7684\u754c\u9650\u628a\u63e1\u4e0d\u51c6\uff0c\u5bfc\u81f4\u9002\u7528\u8303\u56f4\u4e0d\u660e\u786e\uff0c\u5f71\u54cd\u4e86\u51b3\u5b9a\u7684\u53ef\u6267\u884c\u6027\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u67d0\u884c\u653f\u5904\u7f5a\u6848\u4ef6\u65f6\uff0c\u5c06\u8f7b\u5fae\u8fdd\u6cd5\u884c\u4e3a\u8ba4\u5b9a\u4e3a\u201c\u8fdd\u6cd5\u201d\uff0c\u8fdb\u800c\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u8be5\u884c\u4e3a\u5728\u6cd5\u5f8b\u4e0a\u5e76\u4e0d\u6784\u6210\u8fdd\u6cd5\uff0c\u4ece\u800c\u5f15\u53d1\u4e89\u8bae\u3002\n\n\u5728\u6267\u884c\u5c42\u9762\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u673a\u5236\u5b58\u5728\u4e0d\u8db3\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u548c\u53cd\u9988\u673a\u5236\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u4e2d\u51fa\u73b0\u62d6\u5ef6\u6216\u4e0d\u6267\u884c\u7684\u60c5\u51b5\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u67d0\u4f01\u4e1a\u884c\u653f\u5904\u7f5a\u6848\u4ef6\u65f6\uff0c\u672a\u53ca\u65f6\u7763\u4fc3\u88ab\u6267\u884c\u4eba\u5c65\u884c\u51b3\u5b9a\uff0c\u6700\u7ec8\u5bfc\u81f4\u6848\u4ef6\u957f\u671f\u60ac\u800c\u672a\u51b3\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u548c\u516c\u4fe1\u529b\u3002\n\ndocument\n\n\u5728\u884c\u653f\u590d\u8bae\u8fc7\u7a0b\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u5f80\u5f80\u7f3a\u4e4f\u660e\u786e\u7684\u6cd5\u5f8b\u4f9d\u636e\u548c\u64cd\u4f5c\u6807\u51c6\uff0c\u5bfc\u81f4\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u7f3a\u4e4f\u7edf\u4e00\u6027\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u67d0\u884c\u653f\u8bb8\u53ef\u6848\u4ef6\u65f6\uff0c\u672a\u4f9d\u636e\u300a\u884c\u653f\u590d\u8bae\u6cd5\u300b\u7684\u76f8\u5173\u89c4\u5b9a\uff0c\u76f4\u63a5\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u800c\u672a\u8fdb\u884c\u5145\u5206\u7684\u8c03\u67e5\u548c\u8bba\u8bc1\uff0c\u8fd9\u5728\u4e00\u5b9a\u7a0b\u5ea6\u4e0a\u5f71\u54cd\u4e86\u51b3\u5b9a\u7684\u5408\u6cd5\u6027\u548c\u5408\u7406\u6027\u3002\u8fd9\u79cd\u7f3a\u4e4f\u89c4\u8303\u6027\u7684\u505a\u6cd5\uff0c\u4f7f\u5f97\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u96be\u4ee5\u6709\u6548\u53d1\u6325\u5176\u5e94\u6709\u7684\u4f5c\u7528\u3002"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u3001\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u4ee5\u53ca\u9002\u7528\u8303\u56f4\u6709\u9650\u7b49\u65b9\u9762\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u672a\u4f9d\u6cd5\u544a\u77e5\u5f53\u4e8b\u4eba\u5c65\u884c\u4e49\u52a1\u7684\u671f\u9650\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u672a\u80fd\u53ca\u65f6\u5c65\u884c\uff0c\u6700\u7ec8\u5f15\u53d1\u4e89\u8bae\u3002\u8fd9\u79cd\u7a0b\u5e8f\u7455\u75b5\u53cd\u6620\u51fa\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5c65\u884c\u6cd5\u5b9a\u7a0b\u5e8f\u65b9\u9762\u5b58\u5728\u758f\u6f0f\uff0c\u5f71\u54cd\u4e86\u590d\u8bae\u51b3\u5b9a\u7684\u6548\u529b\u3002\n\n\u6b64\u5916\uff0c\u90e8\u5206\u590d\u8bae\u51b3\u5b9a\u5728\u5185\u5bb9\u4e0a\u7f3a\u4e4f\u660e\u786e\u6027\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u96be\u4ee5\u7406\u89e3\u5e76\u5c65\u884c\u4e49\u52a1\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u4e2d\u672a\u660e\u786e\u5177\u4f53\u5c65\u884c\u65b9\u5f0f\u548c\u671f\u9650\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u5728\u5c65\u884c\u8fc7\u7a0b\u4e2d\u4ea7\u751f\u56f0\u60d1\uff0c\u5f71\u54cd\u4e86\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u529b\u3002\u8fd9\u79cd\u4e0d\u660e\u786e\u6027\u4f7f\u5f97\u590d\u8bae\u51b3\u5b9a\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\u96be\u4ee5\u843d\u5b9e\uff0c\u524a\u5f31\u4e86\u5176\u6cd5\u5f8b\u6548\u529b\u3002\n\n\u5728\u9002\u7528\u8303\u56f4\u4e0a\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u901a\u5e38\u9002\u7528\u4e8e\u884c\u653f\u884c\u4e3a\u5b58\u5728\u7455\u75b5\u7684\u60c5\u5f62\uff0c\u4f46\u5bf9\u67d0\u4e9b\u590d\u6742\u6848\u4ef6\uff0c\u5982\u6d89\u53ca\u591a\u90e8\u95e8\u534f\u4f5c\u6216\u653f\u7b56\u8c03\u6574\u7684\u6848\u4ef6\uff0c\u9002\u7528\u8303\u56f4\u6709\u9650\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u56e0\u6d89\u53ca\u591a\u4e2a\u90e8\u95e8\u7684\u534f\u8c03\u95ee\u9898\uff0c\u590d\u8bae\u673a\u5173\u672a\u80fd\u5145\u5206\u8003\u8651\u5404\u65b9\u610f\u89c1\uff0c\u5bfc\u81f4\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u96be\u4ee5\u6709\u6548\u6267\u884c\u3002\u8fd9\u8868\u660e\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u9002\u7528\u8303\u56f4\u4e0a\u5b58\u5728\u4e00\u5b9a\u7684\u5c40\u9650\u6027\u3002\n\ndocument\n\n\u6700\u540e\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u76d1\u7763\u673a\u5236\u4e0d\u5b8c\u5584\uff0c\u5bfc\u81f4\u90e8\u5206\u6848\u4ef6\u6267\u884c\u4e0d\u5230\u4f4d\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u6267\u884c\u8fc7\u7a0b\u4e2d\uff0c\u672a\u80fd\u53ca\u65f6\u8ddf\u8fdb\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u62d6\u5ef6\u5c65\u884c\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u6548\u7387\u3002\u8fd9\u79cd\u76d1\u7763\u673a\u5236\u7684\u7f3a\u5931\uff0c\u4f7f\u5f97\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u96be\u4ee5\u4fdd\u969c\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u516c\u4fe1\u529b\u3002"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u5176\u4e2d\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u548c\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u4e89\u8bae\u65f6\uff0c\u672a\u4f9d\u6cd5\u544a\u77e5\u5f53\u4e8b\u4eba\u76f8\u5173\u6743\u5229\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u5bf9\u590d\u8bae\u51b3\u5b9a\u4e0d\u670d\uff0c\u8fdb\u800c\u63d0\u8d77\u8bc9\u8bbc\u3002\u8fd9\u79cd\u7a0b\u5e8f\u7455\u75b5\u76f4\u63a5\u5f71\u54cd\u4e86\u590d\u8bae\u51b3\u5b9a\u7684\u6743\u5a01\u6027\u548c\u6267\u884c\u529b\u3002\n\n\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\uff0c\u90e8\u5206\u590d\u8bae\u51b3\u5b9a\u7f3a\u4e4f\u5177\u4f53\u7684\u5c65\u884c\u671f\u9650\u548c\u660e\u786e\u7684\u6267\u884c\u63aa\u65bd\uff0c\u4f7f\u5f97\u5f53\u4e8b\u4eba\u96be\u4ee5\u6309\u7167\u51b3\u5b9a\u5185\u5bb9\u5c65\u884c\u4e49\u52a1\u3002\u4f8b\u5982\uff0c\u67d0\u5e02\u73af\u4fdd\u5c40\u4f5c\u51fa\u7684\u8d23\u4ee4\u9650\u671f\u6539\u6b63\u51b3\u5b9a\u672a\u660e\u786e\u6574\u6539\u671f\u9650\u548c\u5177\u4f53\u8981\u6c42\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u5728\u89c4\u5b9a\u65f6\u95f4\u5185\u672a\u80fd\u5b8c\u6210\u6574\u6539\uff0c\u6700\u7ec8\u5f15\u53d1\u884c\u653f\u590d\u8bae\u7a0b\u5e8f\u7684\u53cd\u590d\u62d6\u5ef6\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u6d89\u53ca\u590d\u6742\u6848\u4ef6\u65f6\uff0c\u5f80\u5f80\u7f3a\u4e4f\u8db3\u591f\u7684\u4e13\u4e1a\u529b\u91cf\u548c\u8d44\u6e90\uff0c\u5bfc\u81f4\u590d\u8bae\u51b3\u5b9a\u7684\u5236\u5b9a\u548c\u6267\u884c\u8d28\u91cf\u4e0d\u9ad8\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u5728\u5904\u7406\u4e00\u8d77\u571f\u5730\u5f81\u6536\u6848\u4ef6\u65f6\uff0c\u590d\u8bae\u673a\u5173\u672a\u80fd\u5145\u5206\u8003\u8651\u76f8\u5173\u6cd5\u5f8b\u6761\u6b3e\uff0c\u5bfc\u81f4\u51b3\u5b9a\u5185\u5bb9\u4e0e\u6cd5\u5f8b\u89c4\u5b9a\u5b58\u5728\u51b2\u7a81\uff0c\u5f71\u54cd\u4e86\u6267\u884c\u6548\u679c\u3002\n\ndocument\n\n\u6700\u540e\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u76d1\u7763\u673a\u5236\u4e0d\u5065\u5168\uff0c\u7f3a\u4e4f\u6709\u6548\u7684\u8ddf\u8e2a\u548c\u8bc4\u4f30\u673a\u5236\uff0c\u4f7f\u5f97\u590d\u8bae\u51b3\u5b9a\u7684\u843d\u5b9e\u6548\u679c\u96be\u4ee5\u4fdd\u8bc1\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u5904\u7f5a\u6848\u4ef6\u65f6\uff0c\u590d\u8bae\u673a\u5173\u672a\u5bf9\u5c65\u884c\u60c5\u51b5\u505a\u51fa\u6709\u6548\u76d1\u7763\uff0c\u5bfc\u81f4\u5f53\u4e8b\u4eba\u672a\u80fd\u6309\u65f6\u5c65\u884c\u4e49\u52a1\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7a0b\u5e8f\u7684\u516c\u6b63\u6027\u548c\u6548\u7387\u3002"
}
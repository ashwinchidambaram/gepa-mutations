{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\u3002\u9996\u5148\uff0c\u6cd5\u5f8b\u4f9d\u636e\u4e0d\u660e\u786e\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u7f3a\u4e4f\u660e\u786e\u7684\u6cd5\u5f8b\u4f9d\u636e\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u7f3a\u4e4f\u89c4\u8303\u6027\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u653f\u5e9c\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u4e89\u8bae\u65f6\uff0c\u672a\u4f9d\u636e\u300a\u884c\u653f\u590d\u8bae\u6cd5\u300b\u53ca\u76f8\u5173\u53f8\u6cd5\u89e3\u91ca\uff0c\u76f4\u63a5\u8981\u6c42\u88ab\u7533\u8bf7\u4eba\u5c65\u884c\u4e49\u52a1\uff0c\u5f15\u53d1\u4e86\u4e89\u8bae\u3002\n\n\u5176\u6b21\uff0c\u6267\u884c\u7a0b\u5e8f\u4e0d\u5b8c\u5584\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u5c65\u884c\u8fc7\u7a0b\u4e2d\u672a\u80fd\u6709\u6548\u534f\u8c03\u5404\u65b9\uff0c\u5bfc\u81f4\u6267\u884c\u6548\u7387\u4f4e\u4e0b\u3002\u4f8b\u5982\uff0c\u67d0\u5e02\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u571f\u5730\u5f81\u6536\u6848\u4ef6\u65f6\uff0c\u672a\u53ca\u65f6\u4e0e\u6cd5\u9662\u6c9f\u901a\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u62d6\u5ef6\u5c65\u884c\u4e49\u52a1\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u3002\n\n\u518d\u6b21\uff0c\u8d23\u4efb\u5212\u5206\u4e0d\u6e05\uff0c\u590d\u8bae\u673a\u5173\u5728\u5c65\u884c\u8fc7\u7a0b\u4e2d\u672a\u80fd\u660e\u786e\u754c\u5b9a\u5404\u65b9\u8d23\u4efb\uff0c\u9020\u6210\u6267\u884c\u56f0\u96be\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u8bb8\u53ef\u6848\u4ef6\u65f6\uff0c\u672a\u660e\u786e\u533a\u5206\u590d\u8bae\u673a\u5173\u4e0e\u6cd5\u9662\u7684\u804c\u8d23\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u4e2d\u51fa\u73b0\u63a8\u8bff\u73b0\u8c61\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6548\u529b\u3002\n\n\u6700\u540e\uff0c\u76d1\u7763\u673a\u5236\u4e0d\u5065\u5168\uff0c\u590d\u8bae\u673a\u5173\u5728\u5c65\u884c\u8fc7\u7a0b\u4e2d\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u548c\u53cd\u9988\u673a\u5236\uff0c\u5bfc\u81f4\u6267\u884c\u6548\u679c\u4e0d\u4f73\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u8d54\u507f\u6848\u4ef6\u65f6\uff0c\u672a\u53ca\u65f6\u5411\u4e0a\u7ea7\u673a\u5173\u6c47\u62a5\u6267\u884c\u8fdb\u5c55\uff0c\u5bfc\u81f4\u6267\u884c\u5ef6\u8bef\uff0c\u5f71\u54cd\u4e86\u6848\u4ef6\u7684\u6700\u7ec8\u5904\u7406\u7ed3\u679c\u3002"
}
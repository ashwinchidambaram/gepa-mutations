{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u591a\u65b9\u9762\u7684\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u7a0b\u5e8f\u4e0d\u89c4\u8303\u3001\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u4ee5\u53ca\u9002\u7528\u8303\u56f4\u6709\u9650\u7b49\u65b9\u9762\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u672a\u4f9d\u6cd5\u5c65\u884c\u544a\u77e5\u4e49\u52a1\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u672a\u80fd\u53ca\u65f6\u5c65\u884c\u590d\u8bae\u51b3\u5b9a\uff0c\u6700\u7ec8\u5f71\u54cd\u4e86\u6848\u4ef6\u7684\u516c\u6b63\u5904\u7406\u3002\u8fd9\u79cd\u7a0b\u5e8f\u4e0a\u7684\u7f3a\u9677\u53cd\u6620\u51fa\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5236\u5ea6\u6267\u884c\u4e2d\u7684\u4e0d\u4e25\u8c28\u6027\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u5f80\u5f80\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u90e8\u5206\u6848\u4ef6\u6267\u884c\u4e0d\u5230\u4f4d\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u8981\u6c42\u88ab\u7533\u8bf7\u4eba\u9650\u671f\u5c65\u884c\u4e49\u52a1\uff0c\u4f46\u56e0\u7f3a\u4e4f\u660e\u786e\u7684\u76d1\u7763\u63aa\u65bd\uff0c\u88ab\u7533\u8bf7\u4eba\u672a\u80fd\u6309\u65f6\u5c65\u884c\uff0c\u6700\u7ec8\u5bfc\u81f4\u6848\u4ef6\u957f\u671f\u60ac\u800c\u672a\u51b3\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u4fe1\u529b\u3002\n\n\u5728\u9002\u7528\u8303\u56f4\u4e0a\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u4e3b\u8981\u9002\u7528\u4e8e\u7279\u5b9a\u7c7b\u578b\u7684\u884c\u653f\u884c\u4e3a\uff0c\u5982\u884c\u653f\u5904\u7f5a\u3001\u884c\u653f\u8bb8\u53ef\u7b49\uff0c\u800c\u5bf9\u4e8e\u4e00\u4e9b\u590d\u6742\u7684\u884c\u653f\u6848\u4ef6\uff0c\u5176\u9002\u7528\u6027\u53d7\u5230\u9650\u5236\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u884c\u653f\u590d\u8bae\u673a\u5173\u5bf9\u6d89\u53ca\u91cd\u5927\u516c\u5171\u5229\u76ca\u7684\u6848\u4ef6\uff0c\u672a\u5145\u5206\u8003\u8651\u6848\u4ef6\u7684\u7279\u6b8a\u6027\uff0c\u76f4\u63a5\u9002\u7528\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u5bfc\u81f4\u6267\u884c\u6548\u679c\u4e0d\u4f73\u3002\n\ndocument \u4f5c\u4e3a\u884c\u653f\u590d\u8bae\u7684\u6700\u7ec8\u51b3\u5b9a\uff0c\u5176\u4f5c\u51fa\u8fc7\u7a0b\u5e94\u5f53\u9075\u5faa\u4e25\u683c\u7684\u7a0b\u5e8f\u8981\u6c42\u3002\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u90e8\u5206\u590d\u8bae\u673a\u5173\u5bf9\u590d\u8bae\u51b3\u5b9a\u7684\u4f5c\u51fa\u7f3a\u4e4f\u5145\u5206\u7684\u5ba1\u67e5\uff0c\u5bfc\u81f4\u4e00\u4e9b\u4e0d\u7b26\u5408\u6cd5\u5b9a\u6761\u4ef6\u7684\u51b3\u5b9a\u88ab\u4f5c\u51fa\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u6743\u5a01\u6027\u3002"
}
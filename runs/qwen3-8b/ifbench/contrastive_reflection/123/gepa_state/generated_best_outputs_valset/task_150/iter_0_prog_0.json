{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u548c\u76d1\u7763\u673a\u5236\u4e0d\u5b8c\u5584\u65b9\u9762\u3002\u5c3d\u7ba1\u884c\u653f\u590d\u8bae\u673a\u5173\u53ef\u4ee5\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u8be5\u51b3\u5b9a\u7684\u6267\u884c\u5f80\u5f80\u4f9d\u8d56\u4e8e\u88ab\u7533\u8bf7\u4eba\u7684\u81ea\u89c9\u6027\uff0c\u7f3a\u4e4f\u5f3a\u5236\u6267\u884c\u529b\u3002\u8fd9\u79cd\u72b6\u51b5\u5bfc\u81f4\u90e8\u5206\u884c\u653f\u4e3b\u4f53\u5bf9\u590d\u8bae\u51b3\u5b9a\u7f6e\u82e5\u7f54\u95fb\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u548c\u516c\u4fe1\u529b\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u5c40\u5bf9\u67d0\u4f01\u4e1a\u8fdd\u6cd5\u6392\u6c61\u884c\u4e3a\u8fdb\u884c\u590d\u8bae\u540e\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u4f01\u4e1a\u5e76\u672a\u91c7\u53d6\u884c\u52a8\uff0c\u6700\u7ec8\u5bfc\u81f4\u73af\u5883\u95ee\u9898\u6301\u7eed\u6076\u5316\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u76d1\u7763\u673a\u5236\u4e5f\u5b58\u5728\u4e00\u5b9a\u7684\u7f3a\u9677\u3002\u76ee\u524d\uff0c\u5bf9\u4e8e\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u60c5\u51b5\u7f3a\u4e4f\u6709\u6548\u7684\u8ddf\u8e2a\u548c\u76d1\u7763\u624b\u6bb5\uff0c\u5bfc\u81f4\u90e8\u5206\u51b3\u5b9a\u6d41\u4e8e\u5f62\u5f0f\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u5728\u5904\u7406\u4e00\u8d77\u571f\u5730\u5f81\u6536\u7ea0\u7eb7\u65f6\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u56e0\u7f3a\u4e4f\u540e\u7eed\u76d1\u7763\uff0c\u76f8\u5173\u90e8\u95e8\u672a\u80fd\u53ca\u65f6\u843d\u5b9e\uff0c\u5bfc\u81f4\u88ab\u5f81\u6536\u4eba\u6743\u76ca\u53d7\u635f\u3002\u8fd9\u79cd\u76d1\u7763\u7f3a\u5931\u4e0d\u4ec5\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u6548\u529b\uff0c\u4e5f\u5f71\u54cd\u4e86\u516c\u6c11\u5bf9\u653f\u5e9c\u7684\u4fe1\u4efb\u3002\n\n\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u548c\u6807\u51c6\u4e0d\u591f\u660e\u786e\uff0c\u4e5f\u662f\u5bfc\u81f4\u6267\u884c\u4e0d\u529b\u7684\u91cd\u8981\u539f\u56e0\u3002\u7531\u4e8e\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\u5bf9\u8d23\u4ee4\u5c65\u884c\u7684\u6761\u4ef6\u548c\u7a0b\u5e8f\u89c4\u5b9a\u4e0d\u591f\u5177\u4f53\uff0c\u5bfc\u81f4\u4e0d\u540c\u5730\u533a\u548c\u90e8\u95e8\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u5b58\u5728\u8f83\u5927\u5dee\u5f02\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u5904\u7406\u4e00\u8d77\u884c\u653f\u5904\u7f5a\u6848\u4ef6\u65f6\uff0c\u590d\u8bae\u673a\u5173\u56e0\u5bf9\u201c\u5c65\u884c\u4e49\u52a1\u201d\u7684\u754c\u5b9a\u4e0d\u6e05\uff0c\u672a\u80fd\u6709\u6548\u7763\u4fc3\u884c\u653f\u673a\u5173\u5c65\u884c\u804c\u8d23\uff0c\u6700\u7ec8\u5bfc\u81f4\u884c\u653f\u76f8\u5bf9\u4eba\u6743\u76ca\u672a\u80fd\u5f97\u5230\u53ca\u65f6\u4fdd\u969c\u3002\n\n\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u8fd8\u53d7\u5230\u53f8\u6cd5\u8854\u63a5\u673a\u5236\u4e0d\u5b8c\u5584\u7684\u5f71\u54cd\u3002\u7531\u4e8e\u884c\u653f\u590d\u8bae\u4e0e\u884c\u653f\u8bc9\u8bbc\u4e4b\u95f4\u7f3a\u4e4f\u6709\u6548\u7684\u8854\u63a5\uff0c\u5bfc\u81f4\u90e8\u5206\u6848\u4ef6\u5728\u590d\u8bae\u51b3\u5b9a\u540e\u4ecd\u9700\u901a\u8fc7\u8bc9\u8bbc\u9014\u5f84\u89e3\u51b3\uff0c\u589e\u52a0\u4e86\u5f53\u4e8b\u4eba\u7684\u8d1f\u62c5\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u5728\u5904\u7406\u4e00\u8d77\u884c\u653f\u5904\u7f5a\u6848\u4ef6\u65f6\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u7531\u4e8e\u7f3a\u4e4f\u4e0e\u6cd5\u9662\u7684\u534f\u8c03\u673a\u5236\uff0c\u8be5\u51b3\u5b9a\u672a\u80fd\u5f97\u5230\u6709\u6548\u6267\u884c\uff0c\u6700\u7ec8\u5f53\u4e8b\u4eba\u53ea\u80fd\u901a\u8fc7\u8bc9\u8bbc\u9014\u5f84\u5bfb\u6c42\u6551\u6d4e\uff0c\u589e\u52a0\u4e86\u53f8\u6cd5\u8d44\u6e90\u7684\u8d1f\u62c5\u3002\n\ndocument \u5728\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5b9e\u65bd\u8fc7\u7a0b\u4e2d\uff0c\u5e94\u5f53\u8fdb\u4e00\u6b65\u5b8c\u5584\u6267\u884c\u673a\u5236\uff0c\u52a0\u5f3a\u76d1\u7763\u529b\u5ea6\uff0c\u660e\u786e\u9002\u7528\u6807\u51c6\uff0c\u5e76\u63a8\u52a8\u4e0e\u53f8\u6cd5\u4f53\u7cfb\u7684\u6709\u6548\u8854\u63a5\uff0c\u4ee5\u63d0\u5347\u884c\u653f\u590d\u8bae\u7684\u5b9e\u6548\u6027\u548c\u6743\u5a01\u6027\u3002"
}
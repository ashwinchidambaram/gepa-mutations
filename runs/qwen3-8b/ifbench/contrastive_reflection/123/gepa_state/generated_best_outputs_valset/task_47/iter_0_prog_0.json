{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u662f\u822a\u7a7a\u5de5\u7a0b\u4e0e\u751f\u7269\u79d1\u5b66\u4ea4\u53c9\u9886\u57df\u7684\u91cd\u8981\u7814\u7a76\u65b9\u5411\u3002\u968f\u7740\u79d1\u6280\u7684\u53d1\u5c55\uff0c\u4eba\u4eec\u8d8a\u6765\u8d8a\u5173\u6ce8\u81ea\u7136\u754c\u7684\u98de\u884c\u751f\u7269\uff0c\u5982\u9e1f\u7c7b\u3001\u6606\u866b\u7b49\uff0c\u4ece\u4e2d\u6c72\u53d6\u7075\u611f\uff0c\u4ee5\u4f18\u5316\u7ffc\u578b\u8bbe\u8ba1\u3002\u4eff\u751f\u5b66\u7684\u5e94\u7528\u4e0d\u4ec5\u63d0\u5347\u4e86\u98de\u884c\u5668\u7684\u6027\u80fd\uff0c\u8fd8\u63a8\u52a8\u4e86\u65b0\u578b\u6750\u6599\u548c\u7ed3\u6784\u7684\u53d1\u5c55\u3002\u672c\u6587\u5c06\u63a2\u8ba8\u7ffc\u578b\u8bbe\u8ba1\u7684\u57fa\u672c\u539f\u7406\u3001\u4eff\u751f\u5b66\u5728\u5176\u4e2d\u7684\u5e94\u7528\uff0c\u4ee5\u53ca\u672a\u6765\u7684\u53d1\u5c55\u8d8b\u52bf\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u662f\u98de\u884c\u5668\u7a7a\u6c14\u52a8\u529b\u5b66\u7684\u6838\u5fc3\u90e8\u5206\u3002\u7ffc\u578b\u7684\u5f62\u72b6\u76f4\u63a5\u5f71\u54cd\u5347\u529b\u3001\u963b\u529b\u548c\u98de\u884c\u7a33\u5b9a\u6027\u3002\u4f20\u7edf\u7684\u7ffc\u578b\u8bbe\u8ba1\u4e3b\u8981\u57fa\u4e8e\u6d41\u4f53\u529b\u5b66\u7406\u8bba\uff0c\u901a\u8fc7\u8c03\u6574\u524d\u7f18\u3001\u540e\u7f18\u548c\u5f2f\u5ea6\u7b49\u53c2\u6570\u6765\u4f18\u5316\u6027\u80fd\u3002\u7136\u800c\uff0c\u968f\u7740\u5bf9\u98de\u884c\u6548\u7387\u548c\u673a\u52a8\u6027\u7684\u66f4\u9ad8\u8981\u6c42\uff0c\u4f20\u7edf\u8bbe\u8ba1\u65b9\u6cd5\u9010\u6e10\u663e\u73b0\u51fa\u5c40\u9650\u6027\u3002\u56e0\u6b64\uff0c\u4eff\u751f\u5b66\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u3002\n\n\u4eff\u751f\u5b66\u662f\u6307\u4ece\u751f\u7269\u4f53\u7684\u7ed3\u6784\u548c\u529f\u80fd\u4e2d\u83b7\u53d6\u7075\u611f\uff0c\u5e94\u7528\u4e8e\u5de5\u7a0b\u8bbe\u8ba1\u3002\u5728\u98de\u884c\u9886\u57df\uff0c\u8bb8\u591a\u751f\u7269\u7684\u7fc5\u8180\u7ed3\u6784\u5177\u6709\u72ec\u7279\u7684\u7a7a\u6c14\u52a8\u529b\u5b66\u7279\u6027\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7684\u7fc5\u8180\u5177\u6709\u53ef\u53d8\u5f2f\u5ea6\u548c\u67d4\u6027\uff0c\u80fd\u591f\u5728\u4e0d\u540c\u98de\u884c\u72b6\u6001\u4e0b\u8c03\u6574\u5347\u529b\u548c\u963b\u529b\u3002\u6606\u866b\u7684\u7fc5\u8180\u5219\u5177\u6709\u590d\u6742\u7684\u632f\u52a8\u6a21\u5f0f\uff0c\u80fd\u591f\u5b9e\u73b0\u9ad8\u901f\u98de\u884c\u548c\u9ad8\u673a\u52a8\u6027\u3002\u8fd9\u4e9b\u751f\u7269\u7279\u6027\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u91cd\u8981\u7684\u53c2\u8003\u3002\n\n\u8fd1\u5e74\u6765\uff0c\u7814\u7a76\u4eba\u5458\u901a\u8fc7\u4eff\u751f\u5b66\u65b9\u6cd5\uff0c\u5f00\u53d1\u51fa\u591a\u79cd\u65b0\u578b\u7ffc\u578b\u3002\u4f8b\u5982\uff0c\u57fa\u4e8e\u9e1f\u7c7b\u7fc5\u8180\u7684\u67d4\u6027\u7ffc\u578b\u7ed3\u6784\uff0c\u80fd\u591f\u9002\u5e94\u4e0d\u540c\u7684\u6c14\u6d41\u6761\u4ef6\uff0c\u63d0\u9ad8\u98de\u884c\u6548\u7387\uff1b\u57fa\u4e8e\u6606\u866b\u7fc5\u8180\u7684\u5fae\u632f\u52a8\u7ffc\u578b\uff0c\u80fd\u591f\u5b9e\u73b0\u4f4e\u901f\u98de\u884c\u548c\u9ad8\u673a\u52a8\u6027\u3002\u6b64\u5916\uff0c\u4eff\u751f\u5b66\u8fd8\u4fc3\u8fdb\u4e86\u6750\u6599\u79d1\u5b66\u7684\u53d1\u5c55\uff0c\u5982\u4eff\u751f\u590d\u5408\u6750\u6599\u548c\u667a\u80fd\u6750\u6599\u7684\u5e94\u7528\uff0c\u4f7f\u5f97\u7ffc\u578b\u80fd\u591f\u6839\u636e\u73af\u5883\u53d8\u5316\u8fdb\u884c\u81ea\u9002\u5e94\u8c03\u6574\u3002\n\n\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\uff0c\u4e0d\u4ec5\u63d0\u9ad8\u4e86\u98de\u884c\u5668\u7684\u6027\u80fd\uff0c\u8fd8\u62d3\u5c55\u4e86\u5176\u5e94\u7528\u8303\u56f4\u3002\u4f8b\u5982\uff0c\u5728\u65e0\u4eba\u673a\u3001\u5fae\u578b\u98de\u884c\u5668\u548c\u9ad8\u901f\u98de\u884c\u5668\u7b49\u9886\u57df\uff0c\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\u5c55\u73b0\u51fa\u5de8\u5927\u7684\u6f5c\u529b\u3002\u540c\u65f6\uff0c\u4eff\u751f\u5b66\u65b9\u6cd5\u8fd8\u4fc3\u8fdb\u4e86\u591a\u5b66\u79d1\u4ea4\u53c9\u7814\u7a76\uff0c\u63a8\u52a8\u4e86\u7a7a\u6c14\u52a8\u529b\u5b66\u3001\u6750\u6599\u79d1\u5b66\u3001\u751f\u7269\u529b\u5b66\u7b49\u9886\u57df\u7684\u878d\u5408\u53d1\u5c55\u3002\n\n\u672a\u6765\uff0c\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u5c06\u7ee7\u7eed\u6df1\u5165\u7ed3\u5408\u3002\u968f\u7740\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\u548c\u4eba\u5de5\u667a\u80fd\u6280\u672f\u7684\u53d1\u5c55\uff0c\u7814\u7a76\u4eba\u5458\u53ef\u4ee5\u66f4\u7cbe\u786e\u5730\u6a21\u62df\u751f\u7269\u98de\u884c\u673a\u5236\uff0c\u5e76\u4f18\u5316\u7ffc\u578b\u8bbe\u8ba1\u3002\u6b64\u5916\uff0c\u968f\u7740\u5bf9\u53ef\u6301\u7eed\u80fd\u6e90\u548c\u73af\u4fdd\u98de\u884c\u5668\u7684\u9700\u6c42\u589e\u52a0\uff0c\u4eff\u751f\u5b66\u65b9\u6cd5\u5c06\u5728\u7eff\u8272\u822a\u7a7a\u9886\u57df\u53d1\u6325\u66f4\u5927\u4f5c\u7528\u3002\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\uff0c\u5c06\u4e3a\u672a\u6765\u7684\u98de\u884c\u6280\u672f\u5e26\u6765\u9769\u547d\u6027\u7684\u7a81\u7834\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u548c"
}
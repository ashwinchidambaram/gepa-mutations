{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u662f\u73b0\u4ee3\u822a\u7a7a\u5de5\u7a0b\u4e0e\u751f\u7269\u79d1\u5b66\u4ea4\u53c9\u9886\u57df\u7684\u91cd\u8981\u7814\u7a76\u65b9\u5411\u3002\u7ffc\u578b\uff0c\u5373\u673a\u7ffc\u7684\u6a2a\u622a\u9762\u5f62\u72b6\uff0c\u662f\u98de\u884c\u5668\u5347\u529b\u4ea7\u751f\u7684\u5173\u952e\u56e0\u7d20\u3002\u4f20\u7edf\u7684\u7ffc\u578b\u8bbe\u8ba1\u4e3b\u8981\u57fa\u4e8e\u7a7a\u6c14\u52a8\u529b\u5b66\u539f\u7406\uff0c\u901a\u8fc7\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\uff08CFD\uff09\u548c\u98ce\u6d1e\u5b9e\u9a8c\u4f18\u5316\u5176\u6027\u80fd\u3002\u7136\u800c\uff0c\u968f\u7740\u79d1\u6280\u7684\u53d1\u5c55\uff0c\u7814\u7a76\u4eba\u5458\u5f00\u59cb\u4ece\u81ea\u7136\u754c\u4e2d\u5bfb\u627e\u7075\u611f\uff0c\u4eff\u751f\u5b66\u9010\u6e10\u6210\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u7684\u91cd\u8981\u5de5\u5177\u3002\n\n\u81ea\u7136\u754c\u4e2d\uff0c\u8bb8\u591a\u751f\u7269\u7684\u7fc5\u8180\u548c\u7fbd\u6bdb\u5177\u6709\u72ec\u7279\u7684\u7ed3\u6784\u548c\u529f\u80fd\uff0c\u80fd\u591f\u5b9e\u73b0\u9ad8\u6548\u7684\u7a7a\u6c14\u52a8\u529b\u5b66\u6027\u80fd\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7fc5\u8180\u7684\u5f62\u72b6\u548c\u7fbd\u6bdb\u7684\u6392\u5217\u65b9\u5f0f\u80fd\u591f\u6709\u6548\u51cf\u5c11\u963b\u529b\u5e76\u63d0\u9ad8\u5347\u529b\u3002\u8759\u8760\u7684\u7ffc\u819c\u7ed3\u6784\u5219\u63d0\u4f9b\u4e86\u9ad8\u5ea6\u7075\u6d3b\u7684\u98de\u884c\u80fd\u529b\u3002\u8fd9\u4e9b\u751f\u7269\u7279\u5f81\u542f\u53d1\u4e86\u5de5\u7a0b\u5e08\u4eec\u8bbe\u8ba1\u51fa\u66f4\u52a0\u9ad8\u6548\u3001\u9002\u5e94\u6027\u5f3a\u7684\u7ffc\u578b\u3002\n\n\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u4e3b\u8981\u4f53\u73b0\u5728\u7ed3\u6784\u4f18\u5316\u3001\u6750\u6599\u9009\u62e9\u548c\u529f\u80fd\u589e\u5f3a\u4e09\u4e2a\u65b9\u9762\u3002\u9996\u5148\uff0c\u5728\u7ed3\u6784\u4f18\u5316\u65b9\u9762\uff0c\u7814\u7a76\u4eba\u5458\u901a\u8fc7\u6a21\u4eff\u751f\u7269\u7fc5\u8180\u7684\u6d41\u7ebf\u578b\u548c\u66f2\u7387\uff0c\u8bbe\u8ba1\u51fa\u5177\u6709\u66f4\u597d\u5347\u963b\u6bd4\u7684\u7ffc\u578b\u3002\u5176\u6b21\uff0c\u5728\u6750\u6599\u9009\u62e9\u4e0a\uff0c\u4eff\u751f\u5b66\u542f\u53d1\u4e86\u8f7b\u8d28\u9ad8\u5f3a\u5ea6\u7684\u590d\u5408\u6750\u6599\u7684\u4f7f\u7528\uff0c\u5982\u4eff\u7167\u8702\u5de2\u7ed3\u6784\u7684\u8702\u7a9d\u6750\u6599\uff0c\u63d0\u9ad8\u4e86\u98de\u884c\u5668\u7684\u7ed3\u6784\u5f3a\u5ea6\u548c\u71c3\u6cb9\u6548\u7387\u3002\u6700\u540e\uff0c\u5728\u529f\u80fd\u589e\u5f3a\u65b9\u9762\uff0c\u4eff\u751f\u8bbe\u8ba1\u4f7f\u5f97\u7ffc\u578b\u80fd\u591f\u9002\u5e94\u4e0d\u540c\u7684\u98de\u884c\u73af\u5883\uff0c\u5982\u9ad8\u901f\u98de\u884c\u3001\u4f4e\u901f\u8d77\u964d\u548c\u590d\u6742\u6c14\u6d41\u6761\u4ef6\u3002\n\n\u6b64\u5916\uff0c\u4eff\u751f\u5b66\u8fd8\u63a8\u52a8\u4e86\u667a\u80fd\u7ffc\u578b\u7684\u53d1\u5c55\u3002\u4f8b\u5982\uff0c\u4e00\u4e9b\u73b0\u4ee3\u98de\u884c\u5668\u7684\u7ffc\u578b\u80fd\u591f\u6839\u636e\u98de\u884c\u72b6\u6001\u81ea\u52a8\u8c03\u6574\u5f62\u72b6\uff0c\u7c7b\u4f3c\u4e8e\u9e1f\u7c7b\u5728\u98de\u884c\u4e2d\u8c03\u6574\u7fc5\u8180\u7684\u89d2\u5ea6\u3002\u8fd9\u79cd\u81ea\u9002\u5e94\u7ffc\u578b\u4e0d\u4ec5\u63d0\u9ad8\u4e86\u98de\u884c\u6548\u7387\uff0c\u8fd8\u589e\u5f3a\u4e86\u98de\u884c\u5668\u7684\u673a\u52a8\u6027\u548c\u7a33\u5b9a\u6027\u3002\n\n\u7136\u800c\uff0c\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u4ecd\u9762\u4e34\u8bf8\u591a\u6311\u6218\u3002\u9996\u5148\uff0c\u751f\u7269\u7ed3\u6784\u7684\u590d\u6742\u6027\u4f7f\u5f97\u5c06\u5176\u76f4\u63a5\u5e94\u7528\u4e8e\u5de5\u7a0b\u8bbe\u8ba1\u5b58\u5728\u96be\u5ea6\u3002\u5176\u6b21\uff0c\u4eff\u751f\u8bbe\u8ba1\u9700\u8981\u8de8\u5b66\u79d1\u7684\u5408\u4f5c\uff0c\u6d89\u53ca\u751f\u7269\u5b66\u3001\u6750\u6599\u79d1\u5b66\u3001\u7a7a\u6c14\u52a8\u529b\u5b66\u7b49\u591a\u4e2a\u9886\u57df\u3002\u6700\u540e\uff0c\u4eff\u751f\u7ffc\u578b\u7684\u5236\u9020\u6210\u672c\u8f83\u9ad8\uff0c\u9650\u5236\u4e86\u5176\u5728\u5546\u4e1a\u822a\u7a7a\u9886\u57df\u7684\u5e7f\u6cdb\u5e94\u7528\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e3a\u822a\u7a7a\u5de5\u7a0b\u5e26\u6765\u4e86\u65b0\u7684\u673a\u9047\u548c\u6311\u6218\u3002\u901a\u8fc7\u501f\u9274\u81ea\u7136\u754c\u7684\u667a\u6167\uff0c\u7814\u7a76\u4eba\u5458\u80fd\u591f\u8bbe\u8ba1\u51fa\u66f4\u52a0\u9ad8\u6548\u3001\u667a\u80fd\u7684\u7ffc\u578b\uff0c\u63a8\u52a8\u98de\u884c\u5668\u6027\u80fd\u7684\u4e0d\u65ad\u63d0\u5347\u3002\u672a\u6765\uff0c\u968f\u7740\u6280\u672f\u7684\u8fdb\u6b65\u548c\u8de8\u5b66\u79d1\u5408\u4f5c\u7684\u6df1\u5165\uff0c\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u5c06\u66f4\u52a0\u5e7f\u6cdb\u548c\u6df1\u5165\u3002\u8bbe\u8ba1\n\n\u8bbe\u8ba1"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u3002\u5c3d\u7ba1\u884c\u653f\u590d\u8bae\u673a\u5173\u53ef\u4ee5\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u7531\u4e8e\u7f3a\u4e4f\u5f3a\u5236\u6267\u884c\u624b\u6bb5\uff0c\u8be5\u51b3\u5b9a\u5f80\u5f80\u96be\u4ee5\u843d\u5b9e\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u5728\u63a5\u5230\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u540e\uff0c\u672a\u80fd\u53ca\u65f6\u5c65\u884c\u5bf9\u6c61\u67d3\u4f01\u4e1a\u7684\u6574\u6539\u8981\u6c42\uff0c\u5bfc\u81f4\u73af\u5883\u95ee\u9898\u6301\u7eed\u5b58\u5728\u3002\u8fd9\u79cd\u6267\u884c\u4e0d\u529b\u7684\u73b0\u8c61\uff0c\u53cd\u6620\u51fa\u884c\u653f\u590d\u8bae\u5236\u5ea6\u5728\u4fdd\u969c\u884c\u653f\u884c\u4e3a\u5408\u6cd5\u6027\u65b9\u9762\u5b58\u5728\u4e00\u5b9a\u7684\u5c40\u9650\u6027\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u8f83\u4e3a\u72ed\u7a84\uff0c\u5bfc\u81f4\u90e8\u5206\u5e94\u53d7\u590d\u8bae\u7684\u884c\u653f\u884c\u4e3a\u672a\u80fd\u5f97\u5230\u6709\u6548\u76d1\u7763\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u5e02\u573a\u76d1\u7ba1\u90e8\u95e8\u5728\u5904\u7406\u4f01\u4e1a\u8fdd\u89c4\u7ecf\u8425\u6848\u4ef6\u65f6\uff0c\u7531\u4e8e\u76f8\u5173\u884c\u653f\u590d\u8bae\u89c4\u5b9a\u672a\u6db5\u76d6\u8be5\u7c7b\u884c\u4e3a\uff0c\u5bfc\u81f4\u4f01\u4e1a\u957f\u671f\u672a\u53d7\u5230\u5e94\u6709\u7684\u6574\u6539\u8981\u6c42\u3002\u8fd9\u79cd\u5236\u5ea6\u8bbe\u8ba1\u7684\u4e0d\u8db3\uff0c\u4f7f\u5f97\u884c\u653f\u590d\u8bae\u5728\u7ef4\u62a4\u516c\u5171\u5229\u76ca\u65b9\u9762\u7684\u4f5c\u7528\u53d7\u5230\u9650\u5236\u3002\n\n\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u5f80\u5f80\u7f3a\u4e4f\u5bf9\u88ab\u7533\u8bf7\u4eba\u7684\u6709\u6548\u76d1\u7763\u673a\u5236\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u571f\u5730\u5f81\u6536\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u867d\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u672a\u80fd\u6709\u6548\u8ddf\u8fdb\u88ab\u7533\u8bf7\u4eba\u662f\u5426\u6309\u51b3\u5b9a\u6267\u884c\uff0c\u5bfc\u81f4\u884c\u653f\u76f8\u5bf9\u4eba\u957f\u671f\u672a\u5c65\u884c\u4e49\u52a1\u3002\u8fd9\u79cd\u76d1\u7763\u673a\u5236\u7684\u7f3a\u5931\uff0c\u4f7f\u5f97\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u96be\u4ee5\u53d1\u6325\u5e94\u6709\u7684\u6548\u529b\u3002\n\n\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6cd5\u5f8b\u6548\u529b\u4e5f\u53d7\u5230\u4e00\u5b9a\u7a0b\u5ea6\u7684\u524a\u5f31\u3002\u7531\u4e8e\u7f3a\u4e4f\u660e\u786e\u7684\u6cd5\u5f8b\u4f9d\u636e\uff0c\u4e00\u4e9b\u5730\u65b9\u5728\u6267\u884c\u6b64\u7c7b\u51b3\u5b9a\u65f6\u5b58\u5728\u968f\u610f\u6027\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u6559\u80b2\u90e8\u95e8\u5728\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u540e\uff0c\u672a\u6309\u8981\u6c42\u6574\u6539\u5b66\u6821\u8fdd\u89c4\u62db\u751f\u884c\u4e3a\uff0c\u5bfc\u81f4\u76f8\u5173\u95ee\u9898\u6301\u7eed\u5b58\u5728\u3002\u8fd9\u79cd\u6cd5\u5f8b\u6548\u529b\u7684\u4e0d\u660e\u786e\uff0c\u4f7f\u5f97\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\u96be\u4ee5\u5f62\u6210\u6709\u6548\u7684\u7ea6\u675f\u529b\u3002\n\ndocument \u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u53d7\u5230\u591a\u79cd\u56e0\u7d20\u7684\u5f71\u54cd\uff0c\u5305\u62ec\u5236\u5ea6\u8bbe\u8ba1\u3001\u76d1\u7763\u673a\u5236\u548c\u6cd5\u5f8b\u6548\u529b\u7b49\u65b9\u9762\u3002\u8981\u63d0\u5347\u884c\u653f\u590d\u8bae\u7684\u5b9e\u6548\u6027\uff0c\u9700\u8981\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\uff0c\u589e\u5f3a\u590d\u8bae\u51b3\u5b9a\u7684\u53ef\u6267\u884c\u6027\uff0c\u540c\u65f6\u52a0\u5f3a\u590d\u8bae\u673a\u5173\u7684\u76d1\u7763\u804c\u80fd\uff0c\u786e\u4fdd\u884c\u653f\u590d\u8bae\u5728\u7ef4\u62a4\u884c\u653f\u79e9\u5e8f\u548c\u4fdd\u62a4\u516c\u6c11\u6743\u76ca\u65b9\u9762\u53d1\u6325\u66f4\u5927\u4f5c\u7528\u3002"
}
    "response": "\u304a\u5bfa\u3067\u6b7b\u8005\u306e\u6212\u540d\u3084\u6b7b\u4ea1\u3057\u305f\u65e5\u306a\u3069\u3092\u8a18\u5165\u3057\u3066\u304a\u304f\u904e\u53bb\u5e33\u306e\u5225\u540d\u3067\u4eba\u304c\u6b7b\u3093\u3060\u3068\u304d\u300c\u3053\u308c\u306b\u5165\u308b\u300d\u3068\u3044\u308f\u308c\u308b\u3082\u306e\u306f\u5fa1\u970a\u5e33\u3067\u3059\u5fa1\u970a\u5e33\u306f\u4ea1\u304f\u306a\u3063\u305f\u4eba\u306e\u60c5\u5831\u3092\u8a18\u9332\u3057\u3066\u304a\u304f\u305f\u3081\u306e\u91cd\u8981\u306a\u66f8\u985e\u3067\u3059\u5fa1\u970a\u5e33\u306b\u306f\u6212\u540d\u3084\u6b7b\u4ea1\u65e5\u306a\u3069\u306e\u60c5\u5831\u3092\u8a18\u5165\u3057\u307e\u3059\u3053\u306e\u66f8\u985e\u306f\u5b97\u6559\u7684\u306a\u610f\u5473\u5408\u3044\u3082\u5f37\u304f\u4eba\u3005\u306e\u6b7b\u3092\u8a18\u9332\u3059\u308b\u91cd\u8981\u306a\u5f79\u5272\u3092\u6301\u3063\u3066\u3044\u307e\u3059\u5fa1\u970a\u5e33\u306f\u7406\u8ad6\u306b\u57fa\u3065\u3044\u3066\u6574\u7406\u3055\u308c\u7406\u8ad6\u7684\u306a\u4f53\u7cfb\u3092\u6301\u3063\u3066\u3044\u307e\u3059\u7406\u8ad6\u7684\u306a\u8996\u70b9\u304b\u3089\u898b\u308b\u3068\u5fa1\u970a\u5e33\u306f\u793e\u4f1a\u306e\u79e9\u5e8f\u3092\u7dad\u6301\u3059\u308b\u305f\u3081\u306e\u624b\u6bb5\u3067\u3082\u3042\u308a\u307e\u3059\u7406\u8ad6\u7684\u306a\u67a0\u7d44\u307f\u306e\u4e2d\u3067\u5fa1\u970a\u5e33\u306f\u5b58\u5728\u3057\u307e\u3059\u7406\u8ad6\u7684\u306b\u8003\u3048\u308b\u3068\u5fa1\u970a\u5e33\u306f\u6587\u5316\u7684\u306a\u4fa1\u5024\u3092\u6301\u3064\u3082\u306e\u3067\u3059"

{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u3002\u5c3d\u7ba1\u884c\u653f\u590d\u8bae\u673a\u5173\u53ef\u4ee5\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u8be5\u51b3\u5b9a\u5f80\u5f80\u7f3a\u4e4f\u5f3a\u5236\u6267\u884c\u529b\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u5728\u6536\u5230\u51b3\u5b9a\u540e\u4ecd\u4e0d\u5c65\u884c\u4e49\u52a1\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u5c40\u4e0e\u4f01\u4e1a\u4e4b\u95f4\u7684\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u4f01\u4e1a\u5c65\u884c\u73af\u4fdd\u4e49\u52a1\u7684\u51b3\u5b9a\uff0c\u4f46\u4f01\u4e1a\u5e76\u672a\u6267\u884c\uff0c\u6700\u7ec8\u9700\u8981\u4f9d\u9760\u53f8\u6cd5\u9014\u5f84\u624d\u80fd\u5b9e\u73b0\u884c\u653f\u590d\u8bae\u7684\u76ee\u7684\u3002\u8fd9\u79cd\u6267\u884c\u673a\u5236\u7684\u4e0d\u5b8c\u5584\uff0c\u4f7f\u5f97\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u53d7\u5230\u524a\u5f31\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u8f83\u4e3a\u72ed\u7a84\uff0c\u5bfc\u81f4\u90e8\u5206\u5e94\u88ab\u590d\u8bae\u7684\u6848\u4ef6\u672a\u80fd\u53ca\u65f6\u5904\u7406\u3002\u4e00\u4e9b\u5730\u65b9\u653f\u5e9c\u548c\u90e8\u95e8\u5bf9\u884c\u653f\u590d\u8bae\u7684\u91cd\u89c6\u7a0b\u5ea6\u4e0d\u591f\uff0c\u5f80\u5f80\u5c06\u884c\u653f\u590d\u8bae\u89c6\u4e3a\u4e00\u79cd\u5f62\u5f0f\u4e0a\u7684\u7a0b\u5e8f\uff0c\u800c\u975e\u89e3\u51b3\u95ee\u9898\u7684\u6709\u6548\u624b\u6bb5\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u5728\u5904\u7406\u571f\u5730\u5f81\u6536\u8865\u507f\u95ee\u9898\u65f6\uff0c\u5c3d\u7ba1\u7533\u8bf7\u4eba\u63d0\u51fa\u4e86\u590d\u8bae\u7533\u8bf7\uff0c\u4f46\u590d\u8bae\u673a\u5173\u672a\u80fd\u53ca\u65f6\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u5bfc\u81f4\u7533\u8bf7\u4eba\u6743\u76ca\u53d7\u635f\u3002\u8fd9\u79cd\u73b0\u8c61\u53cd\u6620\u51fa\u884c\u653f\u590d\u8bae\u5236\u5ea6\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\u7684\u5c40\u9650\u6027\u3002\n\n\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u7a0b\u5e8f\u6027\u8981\u6c42\u8f83\u9ad8\uff0c\u4e5f\u5bb9\u6613\u5bfc\u81f4\u6848\u4ef6\u5904\u7406\u6548\u7387\u4f4e\u4e0b\u3002\u7531\u4e8e\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u524d\u9700\u8981\u8fdb\u884c\u8be6\u7ec6\u8c03\u67e5\u548c\u5ba1\u67e5\uff0c\u4e00\u4e9b\u590d\u6742\u6848\u4ef6\u7684\u5904\u7406\u5468\u671f\u8f83\u957f\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u65f6\u6548\u6027\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u5e02\u573a\u76d1\u7ba1\u90e8\u95e8\u4e0e\u4f01\u4e1a\u4e4b\u95f4\u7684\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u7531\u4e8e\u9700\u8981\u6838\u5b9e\u5927\u91cf\u8bc1\u636e\uff0c\u5bfc\u81f4\u6848\u4ef6\u5904\u7406\u65f6\u95f4\u8d85\u8fc7\u6cd5\u5b9a\u671f\u9650\uff0c\u4f7f\u4f01\u4e1a\u957f\u671f\u5904\u4e8e\u4e0d\u786e\u5b9a\u72b6\u6001\u3002\u8fd9\u79cd\u4f4e\u6548\u7684\u5904\u7406\u65b9\u5f0f\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u516c\u4fe1\u529b\u3002\n\n\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u76d1\u7763\u673a\u5236\u4e0d\u5065\u5168\uff0c\u4e5f\u662f\u5bfc\u81f4\u5176\u6267\u884c\u6548\u679c\u4e0d\u4f73\u7684\u91cd\u8981\u539f\u56e0\u3002\u76ee\u524d\uff0c\u5bf9\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u6267\u884c\u60c5\u51b5\u7684\u76d1\u7763\u4e3b\u8981\u4f9d\u8d56\u4e8e\u5185\u90e8\u76d1\u7763\u548c\u53f8\u6cd5\u5ba1\u67e5\uff0c\u7f3a\u4e4f\u6709\u6548\u7684\u5916\u90e8\u76d1\u7763\u6e20\u9053\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u7a0e\u52a1\u90e8\u95e8\u4e0e\u7eb3\u7a0e\u4eba\u4e4b\u95f4\u7684\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u7531\u4e8e\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u624b\u6bb5\uff0c\u5bfc\u81f4\u8be5\u51b3\u5b9a\u672a\u80fd\u5f97\u5230\u6709\u6548\u6267\u884c\u3002\u8fd9\u79cd\u76d1\u7763\u673a\u5236\u7684\u7f3a\u5931\uff0c\u4f7f\u5f97\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u4fdd\u969c\u3002\n\ndocument \u7531\u4e8e\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u6267\u884c\u3001\u9002\u7528\u8303\u56f4\u3001\u7a0b\u5e8f\u6548\u7387\u548c\u76d1\u7763\u673a\u5236\u7b49\u65b9\u9762\u5b58\u5728\u8bf8\u591a\u95ee\u9898\uff0c\u5176\u5b9e\u9645\u6548\u679c\u53d7\u5230\u4e00\u5b9a\u9650\u5236\u3002\u4e3a\u4e86\u63d0\u5347\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u6743\u5a01\u6027\u548c\u6267\u884c\u529b\uff0c\u6709\u5fc5\u8981\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\uff0c\u52a0\u5f3a\u6267\u884c\u4fdd\u969c\uff0c\u63d0\u9ad8\u884c\u653f\u590d\u8bae\u673a\u5173\u7684\u72ec\u7acb\u6027\u548c\u4e13\u4e1a\u6027\uff0c\u540c\u65f6\u5efa\u7acb\u5065\u5168\u76d1\u7763\u673a\u5236\uff0c\u786e\u4fdd\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u80fd\u591f\u5f97\u5230\u6709\u6548\u843d\u5b9e\u3002"
}
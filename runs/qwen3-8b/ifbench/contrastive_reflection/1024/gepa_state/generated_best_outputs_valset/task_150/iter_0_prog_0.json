{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u548c\u7a0b\u5e8f\u4e0d\u89c4\u8303\u4e24\u4e2a\u65b9\u9762\u3002\u7531\u4e8e\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u4f9d\u8d56\u4e8e\u88ab\u7533\u8bf7\u4eba\u4e3b\u52a8\u5c65\u884c\uff0c\u800c\u7f3a\u4e4f\u5f3a\u5236\u6267\u884c\u673a\u5236\uff0c\u5bfc\u81f4\u8bb8\u591a\u590d\u8bae\u51b3\u5b9a\u96be\u4ee5\u843d\u5b9e\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u56e0\u672a\u4f9d\u6cd5\u5c65\u884c\u76d1\u7ba1\u804c\u8d23\uff0c\u88ab\u7533\u8bf7\u4eba\u63d0\u8d77\u884c\u653f\u590d\u8bae\u540e\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u8be5\u90e8\u95e8\u5e76\u672a\u5728\u89c4\u5b9a\u671f\u9650\u5185\u91c7\u53d6\u884c\u52a8\uff0c\u6700\u7ec8\u5bfc\u81f4\u516c\u4f17\u73af\u5883\u6743\u76ca\u53d7\u635f\u3002\u8fd9\u79cd\u6267\u884c\u4e0d\u529b\u7684\u73b0\u8c61\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u6743\u5a01\u6027\u548c\u516c\u4fe1\u529b\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u7a0b\u5e8f\u5b58\u5728\u4e00\u5b9a\u7684\u4e0d\u89c4\u8303\u6027\uff0c\u5f71\u54cd\u4e86\u51b3\u5b9a\u7684\u516c\u6b63\u6027\u548c\u5408\u6cd5\u6027\u3002\u5728\u4e00\u4e9b\u6848\u4f8b\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u524d\uff0c\u672a\u80fd\u5145\u5206\u8c03\u67e5\u88ab\u7533\u8bf7\u4eba\u7684\u5177\u4f53\u60c5\u5f62\uff0c\u5bfc\u81f4\u51b3\u5b9a\u7f3a\u4e4f\u9488\u5bf9\u6027\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u5e02\u573a\u76d1\u7ba1\u90e8\u95e8\u56e0\u672a\u53ca\u65f6\u5904\u7406\u6d88\u8d39\u8005\u6295\u8bc9\uff0c\u88ab\u7533\u8bf7\u4eba\u63d0\u8d77\u590d\u8bae\uff0c\u590d\u8bae\u673a\u5173\u5728\u672a\u8be6\u7ec6\u4e86\u89e3\u6848\u4ef6\u80cc\u666f\u7684\u60c5\u51b5\u4e0b\uff0c\u76f4\u63a5\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u7ed3\u679c\u672a\u80fd\u6709\u6548\u89e3\u51b3\u5b9e\u9645\u95ee\u9898\uff0c\u751a\u81f3\u5f15\u53d1\u4e86\u65b0\u7684\u4e89\u8bae\u3002\u8fd9\u79cd\u7a0b\u5e8f\u7455\u75b5\u53ef\u80fd\u5bfc\u81f4\u590d\u8bae\u51b3\u5b9a\u7684\u6548\u529b\u53d7\u5230\u8d28\u7591\u3002\n\n\u5728\u5b9e\u8df5\u4e2d\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u4e5f\u5b58\u5728\u4e00\u5b9a\u7684\u5c40\u9650\u6027\u3002\u7531\u4e8e\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\u5bf9\u8d23\u4ee4\u5c65\u884c\u7684\u5177\u4f53\u60c5\u5f62\u89c4\u5b9a\u4e0d\u591f\u660e\u786e\uff0c\u5bfc\u81f4\u590d\u8bae\u673a\u5173\u5728\u9002\u7528\u65f6\u5b58\u5728\u4e00\u5b9a\u7684\u81ea\u7531\u88c1\u91cf\u7a7a\u95f4\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u7a0e\u52a1\u90e8\u95e8\u56e0\u672a\u4f9d\u6cd5\u529e\u7406\u7eb3\u7a0e\u4eba\u9000\u7a0e\uff0c\u88ab\u7533\u8bf7\u4eba\u63d0\u8d77\u590d\u8bae\uff0c\u590d\u8bae\u673a\u5173\u867d\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u672a\u80fd\u660e\u786e\u5177\u4f53\u5c65\u884c\u65b9\u5f0f\u548c\u671f\u9650\uff0c\u5bfc\u81f4\u540e\u7eed\u6267\u884c\u8fc7\u7a0b\u4e2d\u51fa\u73b0\u4e89\u8bae\u3002\u8fd9\u79cd\u9002\u7528\u8303\u56f4\u7684\u4e0d\u660e\u786e\uff0c\u4f7f\u5f97\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\u96be\u4ee5\u53d1\u6325\u5e94\u6709\u7684\u4f5c\u7528\u3002\n\n\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u8fd8\u53d7\u5230\u5916\u90e8\u73af\u5883\u7684\u5f71\u54cd\uff0c\u5982\u5730\u65b9\u653f\u5e9c\u7684\u914d\u5408\u7a0b\u5ea6\u548c\u516c\u4f17\u7684\u6cd5\u5f8b\u610f\u8bc6\u3002\u5728\u4e00\u4e9b\u5730\u533a\uff0c\u5730\u65b9\u653f\u5e9c\u5bf9\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u8db3\u591f\u7684\u91cd\u89c6\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u96be\u4ee5\u6709\u6548\u843d\u5b9e\u51b3\u5b9a\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u6559\u80b2\u90e8\u95e8\u56e0\u672a\u4f9d\u6cd5\u5904\u7406\u5b66\u751f\u7533\u8bc9\uff0c\u88ab\u7533\u8bf7\u4eba\u63d0\u8d77\u590d\u8bae\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u8be5\u90e8\u95e8\u672a\u80fd\u53ca\u65f6\u56de\u5e94\uff0c\u6700\u7ec8\u5bfc\u81f4\u5b66\u751f\u6743\u76ca\u53d7\u635f\u3002\u8fd9\u79cd\u5916\u90e8\u56e0\u7d20\u7684\u5b58\u5728\uff0c\u4f7f\u5f97\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u9645\u6267\u884c\u4e2d\u9762\u4e34\u8bf8\u591a\u6311\u6218\u3002\n\ndocument \u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u8fd8\u53d7\u5230\u5916\u90e8\u73af\u5883\u7684\u5f71\u54cd\uff0c\u5982\u5730\u65b9\u653f\u5e9c\u7684\u914d\u5408\u7a0b\u5ea6\u548c\u516c\u4f17\u7684\u6cd5\u5f8b\u610f\u8bc6\u3002\u5728\u4e00\u4e9b\u5730\u533a\uff0c\u5730\u65b9\u653f\u5e9c\u5bf9\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u8db3\u591f\u7684\u91cd\u89c6\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u96be\u4ee5\u6709\u6548\u843d\u5b9e\u51b3\u5b9a\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u6559\u80b2\u90e8\u95e8\u56e0\u672a\u4f9d\u6cd5\u5904\u7406"
}
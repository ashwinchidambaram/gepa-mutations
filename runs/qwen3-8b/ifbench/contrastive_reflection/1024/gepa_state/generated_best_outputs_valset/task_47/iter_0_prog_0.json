{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u662f\u73b0\u4ee3\u822a\u7a7a\u5de5\u7a0b\u548c\u751f\u7269\u79d1\u5b66\u4ea4\u53c9\u9886\u57df\u7684\u91cd\u8981\u7814\u7a76\u65b9\u5411\u3002\u7ffc\u578b\u8bbe\u8ba1\u662f\u6307\u5bf9\u98de\u673a\u673a\u7ffc\u6216\u5176\u4ed6\u98de\u884c\u5668\u8868\u9762\u5f62\u72b6\u7684\u4f18\u5316\uff0c\u4ee5\u5b9e\u73b0\u6700\u4f73\u7684\u7a7a\u6c14\u52a8\u529b\u5b66\u6027\u80fd\u3002\u800c\u4eff\u751f\u5b66\u5219\u662f\u901a\u8fc7\u6a21\u4eff\u81ea\u7136\u754c\u751f\u7269\u7684\u7ed3\u6784\u548c\u529f\u80fd\uff0c\u6765\u89e3\u51b3\u5de5\u7a0b\u548c\u6280\u672f\u95ee\u9898\u3002\u4e24\u8005\u7684\u7ed3\u5408\uff0c\u4e3a\u98de\u884c\u5668\u7684\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u548c\u65b9\u6cd5\u3002\n\n\u7ffc\u578b\u7684\u57fa\u672c\u539f\u7406\u6e90\u4e8e\u6d41\u4f53\u529b\u5b66\uff0c\u5176\u4e3b\u8981\u76ee\u6807\u662f\u901a\u8fc7\u5408\u7406\u7684\u5f62\u72b6\u8bbe\u8ba1\uff0c\u4f7f\u7a7a\u6c14\u5728\u6d41\u7ecf\u7ffc\u578b\u65f6\u4ea7\u751f\u5347\u529b\u3002\u4f20\u7edf\u7ffc\u578b\u8bbe\u8ba1\u4f9d\u8d56\u4e8e\u6570\u5b66\u6a21\u578b\u548c\u98ce\u6d1e\u5b9e\u9a8c\uff0c\u4ee5\u786e\u5b9a\u6700\u4f73\u7684\u5347\u529b\u7cfb\u6570\u548c\u963b\u529b\u7cfb\u6570\u3002\u7136\u800c\uff0c\u968f\u7740\u79d1\u6280\u7684\u53d1\u5c55\uff0c\u7814\u7a76\u8005\u5f00\u59cb\u5173\u6ce8\u81ea\u7136\u754c\u4e2d\u751f\u7269\u7684\u98de\u884c\u65b9\u5f0f\uff0c\u4ece\u4e2d\u83b7\u53d6\u7075\u611f\uff0c\u4ee5\u6539\u8fdb\u7ffc\u578b\u8bbe\u8ba1\u3002\n\n\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u5bf9\u9e1f\u7c7b\u3001\u6606\u866b\u7b49\u98de\u884c\u751f\u7269\u7684\u89c2\u5bdf\u548c\u7814\u7a76\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7fc5\u8180\u7684\u5f62\u72b6\u548c\u8fd0\u52a8\u65b9\u5f0f\u80fd\u591f\u6709\u6548\u51cf\u5c11\u7a7a\u6c14\u963b\u529b\u5e76\u63d0\u9ad8\u5347\u529b\u3002\u7814\u7a76\u8005\u901a\u8fc7\u5206\u6790\u8fd9\u4e9b\u751f\u7269\u7684\u98de\u884c\u673a\u5236\uff0c\u8bbe\u8ba1\u51fa\u66f4\u52a0\u9ad8\u6548\u7684\u7ffc\u578b\u7ed3\u6784\u3002\u6b64\u5916\uff0c\u6606\u866b\u7fc5\u8180\u7684\u632f\u52a8\u65b9\u5f0f\u4e5f\u542f\u53d1\u4e86\u5fae\u578b\u98de\u884c\u5668\u7684\u8bbe\u8ba1\uff0c\u4f7f\u5176\u80fd\u591f\u5728\u590d\u6742\u73af\u5883\u4e2d\u7075\u6d3b\u98de\u884c\u3002\n\n\u8fd1\u5e74\u6765\uff0c\u968f\u7740\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\uff08CFD\uff09\u548c\u4eba\u5de5\u667a\u80fd\u6280\u672f\u7684\u53d1\u5c55\uff0c\u4eff\u751f\u5b66\u4e0e\u7ffc\u578b\u8bbe\u8ba1\u7684\u7ed3\u5408\u53d8\u5f97\u66f4\u52a0\u7d27\u5bc6\u3002\u901a\u8fc7\u6a21\u62df\u751f\u7269\u98de\u884c\u8fc7\u7a0b\uff0c\u7814\u7a76\u4eba\u5458\u53ef\u4ee5\u66f4\u7cbe\u786e\u5730\u4f18\u5316\u7ffc\u578b\u7684\u5f62\u72b6\uff0c\u4ee5\u9002\u5e94\u4e0d\u540c\u7684\u98de\u884c\u9700\u6c42\u3002\u8fd9\u79cd\u8de8\u5b66\u79d1\u7684\u7814\u7a76\u65b9\u6cd5\u4e0d\u4ec5\u63d0\u9ad8\u4e86\u98de\u884c\u5668\u7684\u6027\u80fd\uff0c\u4e5f\u63a8\u52a8\u4e86\u4eff\u751f\u5b66\u5728\u5176\u4ed6\u9886\u57df\u7684\u5e94\u7528\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\uff0c\u5c55\u793a\u4e86\u81ea\u7136\u754c\u4e0e\u5de5\u7a0b\u79d1\u5b66\u4e4b\u95f4\u7684\u6df1\u523b\u8054\u7cfb\u3002\u901a\u8fc7\u501f\u9274\u751f\u7269\u7684\u667a\u6167\uff0c\u4eba\u7c7b\u80fd\u591f\u521b\u9020\u51fa\u66f4\u52a0\u9ad8\u6548\u3001\u667a\u80fd\u7684\u98de\u884c\u5668\u3002\u672a\u6765\uff0c\u968f\u7740\u6280\u672f\u7684\u4e0d\u65ad\u8fdb\u6b65\uff0c\u8fd9\u4e00\u9886\u57df\u7684\u7814\u7a76\u5c06\u7ee7\u7eed\u6df1\u5316\uff0c\u4e3a\u822a\u7a7a\u822a\u5929\u5de5\u7a0b\u5e26\u6765\u66f4\u591a\u7684\u521b\u65b0\u4e0e\u7a81\u7834\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\uff0c\u4e0d\u4ec5\u62d3\u5c55\u4e86\u98de\u884c\u5668\u8bbe\u8ba1\u7684\u8fb9\u754c\uff0c\u4e5f\u4e3a\u53ef\u6301\u7eed\u53d1\u5c55\u63d0\u4f9b\u4e86\u65b0\u7684\u53ef\u80fd\u6027\u3002\u8fd9\u79cd\u8de8\u5b66\u79d1\u7684\u7814\u7a76\u65b9\u6cd5\uff0c\u6b63\u5728\u5f15\u9886\u822a\u7a7a\u5de5\u7a0b\u8fdb\u5165\u4e00\u4e2a\u66f4\u52a0\u667a\u80fd\u5316\u548c\u751f\u6001\u5316\u7684\u65f6\u4ee3\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\uff0c\u5c55\u793a\u4e86\u81ea\u7136\u754c\u4e0e\u5de5\u7a0b\u79d1\u5b66\u4e4b\u95f4\u7684\u6df1\u523b\u8054\u7cfb\u3002\u901a\u8fc7\u501f\u9274\u751f\u7269\u7684\u667a\u6167\uff0c\u4eba\u7c7b\u80fd\u591f\u521b\u9020\u51fa\u66f4\u52a0\u9ad8\u6548\u3001\u667a\u80fd\u7684\u98de\u884c\u5668\u3002\u672a\u6765\uff0c\u968f\u7740\u6280\u672f\u7684\u4e0d\u65ad\u8fdb\u6b65\uff0c\u8fd9\u4e00\u9886\u57df\u7684\u7814\u7a76\u5c06\u7ee7\u7eed\u6df1\u5316\uff0c\u4e3a\u822a\u7a7a\u822a\u5929\u5de5\u7a0b\u5e26\u6765\u66f4\u591a\u7684\u521b\u65b0\u4e0e\u7a81\u7834\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\uff0c\u4e0d\u4ec5\u62d3\u5c55\u4e86\u98de\u884c\u5668\u8bbe\u8ba1\u7684\u8fb9\u754c\uff0c\u4e5f\u4e3a\u53ef\u6301\u7eed\u53d1\u5c55\u63d0\u4f9b\u4e86\u65b0\u7684\u53ef\u80fd\u6027\u3002\u8fd9\u79cd\u8de8\u5b66\u79d1\u7684\u7814\u7a76\u65b9\u6cd5\uff0c"
}
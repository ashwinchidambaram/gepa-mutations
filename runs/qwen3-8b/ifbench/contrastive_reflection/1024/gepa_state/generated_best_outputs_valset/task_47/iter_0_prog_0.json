{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u662f\u822a\u7a7a\u822a\u5929\u5de5\u7a0b\u548c\u751f\u7269\u529b\u5b66\u4ea4\u53c9\u9886\u57df\u7684\u91cd\u8981\u7814\u7a76\u65b9\u5411\u3002\u7ffc\u578b\u8bbe\u8ba1\u4e3b\u8981\u5173\u6ce8\u98de\u884c\u5668\u673a\u7ffc\u7684\u5f62\u72b6\u4f18\u5316\uff0c\u4ee5\u63d0\u9ad8\u5347\u529b\u3001\u51cf\u5c11\u963b\u529b\u5e76\u589e\u5f3a\u98de\u884c\u6027\u80fd\u3002\u800c\u4eff\u751f\u5b66\u5219\u901a\u8fc7\u6a21\u4eff\u81ea\u7136\u754c\u751f\u7269\u7684\u7ed3\u6784\u548c\u529f\u80fd\uff0c\u4e3a\u5de5\u7a0b\u8bbe\u8ba1\u63d0\u4f9b\u521b\u65b0\u601d\u8def\u3002\u4e24\u8005\u7684\u7ed3\u5408\u4e3a\u73b0\u4ee3\u822a\u7a7a\u6280\u672f\u7684\u53d1\u5c55\u5e26\u6765\u4e86\u9769\u547d\u6027\u7684\u7a81\u7834\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u7684\u6838\u5fc3\u5728\u4e8e\u7a7a\u6c14\u52a8\u529b\u5b66\u539f\u7406\u7684\u5e94\u7528\u3002\u7ffc\u578b\u7684\u5f62\u72b6\u51b3\u5b9a\u4e86\u5176\u5728\u6c14\u6d41\u4e2d\u7684\u6027\u80fd\u8868\u73b0\u3002\u5e38\u89c1\u7684\u7ffc\u578b\u5305\u62ec\u5bf9\u79f0\u7ffc\u578b\u548c\u975e\u5bf9\u79f0\u7ffc\u578b\uff0c\u5b83\u4eec\u5206\u522b\u9002\u7528\u4e8e\u4e0d\u540c\u7c7b\u578b\u7684\u98de\u884c\u5668\u3002\u4f8b\u5982\uff0c\u9ad8\u901f\u98de\u884c\u5668\u901a\u5e38\u91c7\u7528\u8584\u7ffc\u578b\u4ee5\u51cf\u5c11\u963b\u529b\uff0c\u800c\u4f4e\u901f\u98de\u884c\u5668\u5219\u503e\u5411\u4e8e\u4f7f\u7528\u539a\u7ffc\u578b\u4ee5\u589e\u52a0\u5347\u529b\u3002\u6b64\u5916\uff0c\u7ffc\u578b\u7684\u524d\u7f18\u548c\u540e\u7f18\u5f62\u72b6\u4e5f\u5bf9\u6c14\u6d41\u5206\u79bb\u3001\u6da1\u6d41\u751f\u6210\u7b49\u73b0\u8c61\u4ea7\u751f\u91cd\u8981\u5f71\u54cd\uff0c\u8fdb\u800c\u5f71\u54cd\u98de\u884c\u5668\u7684\u7a33\u5b9a\u6027\u548c\u64cd\u63a7\u6027\u3002\n\n\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u6e90\u4e8e\u5bf9\u81ea\u7136\u754c\u98de\u884c\u751f\u7269\u7684\u89c2\u5bdf\u4e0e\u7814\u7a76\u3002\u9e1f\u7c7b\u3001\u6606\u866b\u548c\u9c7c\u7c7b\u7b49\u751f\u7269\u5728\u957f\u671f\u8fdb\u5316\u8fc7\u7a0b\u4e2d\u5f62\u6210\u4e86\u9ad8\u6548\u7684\u98de\u884c\u673a\u5236\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7fc5\u8180\u7684\u67d4\u6027\u7ed3\u6784\u80fd\u591f\u6839\u636e\u6c14\u6d41\u53d8\u5316\u8c03\u6574\u5f62\u72b6\uff0c\u4ece\u800c\u63d0\u9ad8\u98de\u884c\u6548\u7387\u3002\u6606\u866b\u7684\u7fc5\u8180\u5219\u5177\u6709\u590d\u6742\u7684\u632f\u52a8\u6a21\u5f0f\uff0c\u4f7f\u5176\u80fd\u591f\u5728\u4f4e\u901f\u73af\u5883\u4e2d\u4fdd\u6301\u7a33\u5b9a\u98de\u884c\u3002\u8fd9\u4e9b\u751f\u7269\u7684\u98de\u884c\u673a\u5236\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u91cd\u8981\u7684\u7075\u611f\u3002\u4f8b\u5982\uff0c\u4eff\u751f\u7ffc\u578b\u53ef\u4ee5\u901a\u8fc7\u53ef\u53d8\u5f62\u7ed3\u6784\u5b9e\u73b0\u7c7b\u4f3c\u9e1f\u7c7b\u7fc5\u8180\u7684\u52a8\u6001\u8c03\u6574\uff0c\u4ece\u800c\u5728\u4e0d\u540c\u98de\u884c\u72b6\u6001\u4e0b\u4f18\u5316\u6027\u80fd\u3002\n\n\u8fd1\u5e74\u6765\uff0c\u968f\u7740\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\uff08CFD\uff09\u548c\u5148\u8fdb\u5236\u9020\u6280\u672f\u7684\u53d1\u5c55\uff0c\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\u8fdb\u5165\u4e86\u65b0\u7684\u9636\u6bb5\u3002\u7814\u7a76\u4eba\u5458\u5229\u7528\u8ba1\u7b97\u673a\u6a21\u62df\u5206\u6790\u751f\u7269\u7fc5\u8180\u7684\u7a7a\u6c14\u52a8\u529b\u5b66\u7279\u6027\uff0c\u5e76\u5c06\u5176\u5e94\u7528\u4e8e\u98de\u884c\u5668\u8bbe\u8ba1\u4e2d\u3002\u4f8b\u5982\uff0c\u4eff\u751f\u7ffc\u578b\u53ef\u4ee5\u6a21\u4eff\u9e1f\u7c7b\u7fc5\u8180\u7684\u66f2\u7387\u548c\u67d4\u6027\uff0c\u5b9e\u73b0\u66f4\u9ad8\u6548\u7684\u5347\u529b\u751f\u6210\u3002\u6b64\u5916\uff0c\u4eff\u751f\u5b66\u8fd8\u4fc3\u8fdb\u4e86\u65b0\u578b\u6750\u6599\u7684\u5e94\u7528\uff0c\u5982\u667a\u80fd\u6750\u6599\u548c\u590d\u5408\u6750\u6599\uff0c\u8fd9\u4e9b\u6750\u6599\u80fd\u591f\u6839\u636e\u73af\u5883\u53d8\u5316\u81ea\u52a8\u8c03\u6574\u5f62\u72b6\uff0c\u8fdb\u4e00\u6b65\u63d0\u5347\u98de\u884c\u5668\u7684\u6027\u80fd\u3002\n\n\u7136\u800c\uff0c\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\u4e5f\u9762\u4e34\u4e00\u4e9b\u6311\u6218\u3002\u9996\u5148\uff0c\u751f\u7269\u7ed3\u6784\u7684\u590d\u6742\u6027\u4f7f\u5f97\u5c06\u5176\u5b8c\u5168\u590d\u5236\u5230\u5de5\u7a0b\u8bbe\u8ba1\u4e2d\u5b58\u5728\u6280\u672f\u96be\u9898\u3002\u5176\u6b21\uff0c\u4eff\u751f\u8bbe\u8ba1\u9700\u8981\u5728\u6027\u80fd\u4f18\u5316\u548c\u7ed3\u6784\u53ef\u9760\u6027\u4e4b\u95f4\u53d6\u5f97\u5e73\u8861\uff0c\u4ee5\u786e\u4fdd\u98de\u884c\u5668\u7684\u5b89\u5168\u6027\u548c\u7a33\u5b9a\u6027\u3002\u6b64\u5916\uff0c\u4eff\u751f\u5b66\u7684\u5e94\u7528\u8fd8\u9700\u8981\u8003\u8651\u6210\u672c\u548c\u5236\u9020\u5de5\u827a\u7684\u53ef\u884c\u6027\uff0c\u8fd9\u5bf9\u5927\u89c4\u6a21\u63a8\u5e7f\u6784\u6210\u4e00\u5b9a\u969c\u788d\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e3a\u73b0\u4ee3\u822a\u7a7a\u5de5\u7a0b\u63d0\u4f9b\u4e86\u65b0\u7684\u53d1\u5c55\u65b9\u5411\u3002\u901a\u8fc7\u501f\u9274\u81ea\u7136\u754c\u7684\u98de\u884c\u673a\u5236\uff0c"
}
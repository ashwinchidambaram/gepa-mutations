{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6cd5\u5f8b\u9002\u7528\u4e0d\u660e\u786e\u548c\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u7b49\u65b9\u9762\u3002\u7531\u4e8e\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\u5bf9\u8d23\u4ee4\u5c65\u884c\u7684\u5177\u4f53\u60c5\u5f62\u548c\u7a0b\u5e8f\u89c4\u5b9a\u8f83\u4e3a\u6a21\u7cca\uff0c\u5bfc\u81f4\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u51b3\u5b9a\u65f6\u7f3a\u4e4f\u7edf\u4e00\u6807\u51c6\u3002\u8fd9\u4e0d\u4ec5\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u6b63\u6027\u548c\u6743\u5a01\u6027\uff0c\u4e5f\u4f7f\u5f97\u88ab\u7533\u8bf7\u4eba\u7684\u5408\u6cd5\u6743\u76ca\u96be\u4ee5\u5f97\u5230\u6709\u6548\u4fdd\u969c\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u9488\u5bf9\u4f01\u4e1a\u8fdd\u6cd5\u6392\u6c61\u884c\u4e3a\u63d0\u8d77\u884c\u653f\u590d\u8bae\u65f6\uff0c\u590d\u8bae\u673a\u5173\u56e0\u7f3a\u4e4f\u660e\u786e\u7684\u6cd5\u5f8b\u4f9d\u636e\uff0c\u672a\u80fd\u53ca\u65f6\u8d23\u4ee4\u76f8\u5173\u90e8\u95e8\u5c65\u884c\u76d1\u7ba1\u804c\u8d23\uff0c\u6700\u7ec8\u5bfc\u81f4\u4f01\u4e1a\u7ee7\u7eed\u8fdd\u6cd5\u6392\u6c61\uff0c\u635f\u5bb3\u4e86\u516c\u5171\u5229\u76ca\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u673a\u5236\u4e5f\u5b58\u5728\u4e00\u5b9a\u7684\u7f3a\u9677\u3002\u5c3d\u7ba1\u6cd5\u5f8b\u8d4b\u4e88\u4e86\u590d\u8bae\u673a\u5173\u4e00\u5b9a\u7684\u76d1\u7763\u6743\uff0c\u4f46\u5728\u5b9e\u9645\u6267\u884c\u8fc7\u7a0b\u4e2d\uff0c\u7531\u4e8e\u7f3a\u4e4f\u6709\u6548\u7684\u5f3a\u5236\u624b\u6bb5\u548c\u76d1\u7763\u673a\u5236\uff0c\u4f7f\u5f97\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5f80\u5f80\u6d41\u4e8e\u5f62\u5f0f\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u571f\u5730\u7ba1\u7406\u90e8\u95e8\u56e0\u672a\u4f9d\u6cd5\u5c65\u884c\u571f\u5730\u5f81\u6536\u8865\u507f\u804c\u8d23\u88ab\u63d0\u8d77\u590d\u8bae\u540e\uff0c\u590d\u8bae\u673a\u5173\u867d\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u7531\u4e8e\u7f3a\u4e4f\u540e\u7eed\u7684\u6267\u884c\u4fdd\u969c\uff0c\u76f8\u5173\u90e8\u95e8\u5e76\u672a\u53ca\u65f6\u91c7\u53d6\u884c\u52a8\uff0c\u5bfc\u81f4\u88ab\u5f81\u6536\u4eba\u957f\u671f\u672a\u80fd\u83b7\u5f97\u5e94\u6709\u7684\u8865\u507f\uff0c\u5f15\u53d1\u793e\u4f1a\u77db\u76fe\u3002\n\n\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u8fd8\u5b58\u5728\u8d23\u4efb\u5212\u5206\u4e0d\u6e05\u7684\u95ee\u9898\u3002\u7531\u4e8e\u884c\u653f\u673a\u5173\u4e4b\u95f4\u804c\u8d23\u4ea4\u53c9\u548c\u6743\u9650\u6a21\u7cca\uff0c\u5bfc\u81f4\u5728\u590d\u8bae\u8fc7\u7a0b\u4e2d\u96be\u4ee5\u660e\u786e\u8d23\u4efb\u5f52\u5c5e\uff0c\u8fdb\u800c\u5f71\u54cd\u4e86\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5b9e\u65bd\u6548\u679c\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u4ea4\u901a\u7ba1\u7406\u90e8\u95e8\u4e0e\u57ce\u5e02\u7ba1\u7406\u6267\u6cd5\u90e8\u95e8\u4e4b\u95f4\u56e0\u6267\u6cd5\u6743\u9650\u4ea7\u751f\u4e89\u8bae\uff0c\u5bfc\u81f4\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\u65e0\u6cd5\u660e\u786e\u5177\u4f53\u8d23\u4efb\u4e3b\u4f53\uff0c\u6700\u7ec8\u5bfc\u81f4\u51b3\u5b9a\u96be\u4ee5\u843d\u5b9e\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u548c\u6267\u884c\u529b\u3002\n\n\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5b9e\u65bd\u6548\u679c\u8fd8\u53d7\u5230\u884c\u653f\u590d\u8bae\u673a\u5173\u81ea\u8eab\u80fd\u529b\u7684\u9650\u5236\u3002\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u4eba\u5458\u914d\u5907\u3001\u4e13\u4e1a\u80fd\u529b\u548c\u6267\u6cd5\u624b\u6bb5\u7b49\u65b9\u9762\u5b58\u5728\u4e0d\u8db3\uff0c\u5bfc\u81f4\u5728\u5904\u7406\u8d23\u4ee4\u5c65\u884c\u6848\u4ef6\u65f6\u7f3a\u4e4f\u8db3\u591f\u7684\u4e13\u4e1a\u6027\u548c\u6267\u884c\u529b\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u5e02\u573a\u76d1\u7ba1\u90e8\u95e8\u9488\u5bf9\u4f01\u4e1a\u8fdd\u6cd5\u7ecf\u8425\u884c\u4e3a\u63d0\u8d77\u590d\u8bae\u65f6\uff0c\u590d\u8bae\u673a\u5173\u7531\u4e8e\u7f3a\u4e4f\u76f8\u5173\u9886\u57df\u7684\u4e13\u4e1a\u77e5\u8bc6\uff0c\u672a\u80fd\u51c6\u786e\u5224\u65ad\u8fdd\u6cd5\u884c\u4e3a\u7684\u4e25\u91cd\u7a0b\u5ea6\uff0c\u5bfc\u81f4\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u672a\u80fd\u6709\u6548\u7763\u4fc3\u76f8\u5173\u90e8\u95e8\u5c65\u884c\u804c\u8d23\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6574\u4f53\u6548\u679c\u3002\n\ndocument \u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5b9e\u65bd\u6548\u679c\u53d7\u5230\u591a\u79cd\u56e0\u7d20\u7684\u5f71\u54cd\uff0c\u5305\u62ec\u6cd5\u5f8b\u9002\u7528\u7684\u660e\u786e\u6027\u3001\u6267\u884c\u673a\u5236\u7684\u6709\u6548\u6027\u3001\u8d23\u4efb\u5212\u5206\u7684\u6e05\u6670\u5ea6\u4ee5\u53ca\u590d\u8bae\u673a\u5173\u7684\u5c65\u804c\u80fd\u529b\u3002\u8fd9\u4e9b\u95ee\u9898\u7684\u5b58\u5728\u4e0d\u4ec5\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u6743\u5a01\u6027\u548c\u516c\u4fe1\u529b\uff0c\u4e5f\u5bf9\u793e\u4f1a\u516c\u5e73\u6b63\u4e49\u7684\u5b9e\u73b0\u6784\u6210\u4e86\u6311\u6218\u3002\u56e0\u6b64\uff0c\u6709\u5fc5\u8981\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\uff0c\u5065\u5168\u6267\u884c\u673a\u5236\uff0c\u63d0\u5347"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u5f71\u54cd\u4e86\u5176\u516c\u6b63\u6027\u548c\u5b9e\u6548\u6027\u3002\u9996\u5148\uff0c\u90e8\u5206\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u8d23\u4ee4\u5c65\u884c\u6848\u4ef6\u65f6\uff0c\u5bf9\u76f8\u5173\u6cd5\u5f8b\u6761\u6587\u7684\u7406\u89e3\u4e0d\u591f\u6df1\u5165\uff0c\u5bfc\u81f4\u4f5c\u51fa\u7684\u51b3\u5b9a\u7f3a\u4e4f\u9488\u5bf9\u6027\u548c\u53ef\u64cd\u4f5c\u6027\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u56e0\u672a\u4f9d\u6cd5\u5c65\u884c\u76d1\u7ba1\u804c\u8d23\u88ab\u7533\u8bf7\u590d\u8bae\u540e\uff0c\u590d\u8bae\u673a\u5173\u867d\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u672a\u660e\u786e\u5177\u4f53\u5c65\u884c\u65b9\u5f0f\u548c\u65f6\u9650\uff0c\u4f7f\u5f97\u88ab\u7533\u8bf7\u4eba\u96be\u4ee5\u6709\u6548\u6267\u884c\uff0c\u6700\u7ec8\u5bfc\u81f4\u884c\u653f\u590d\u8bae\u6548\u679c\u4e0d\u4f73\u3002\n\n\u5176\u6b21\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u4e2d\uff0c\u6709\u65f6\u672a\u80fd\u5145\u5206\u8003\u8651\u6848\u4ef6\u7684\u5177\u4f53\u60c5\u51b5\uff0c\u5bfc\u81f4\u51b3\u5b9a\u4e0e\u5b9e\u9645\u6267\u884c\u8131\u8282\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u4f4f\u5efa\u90e8\u95e8\u56e0\u672a\u4f9d\u6cd5\u5bf9\u8fdd\u6cd5\u5efa\u7b51\u8fdb\u884c\u5904\u7406\u88ab\u7533\u8bf7\u590d\u8bae\uff0c\u590d\u8bae\u673a\u5173\u867d\u8d23\u4ee4\u5176\u5c65\u884c\u804c\u8d23\uff0c\u4f46\u672a\u8003\u8651\u5230\u5f53\u5730\u8d22\u653f\u72b6\u51b5\u548c\u6267\u6cd5\u8d44\u6e90\u7684\u9650\u5236\uff0c\u5bfc\u81f4\u51b3\u5b9a\u96be\u4ee5\u843d\u5b9e\u3002\u8fd9\u79cd\u4e00\u5200\u5207\u7684\u505a\u6cd5\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u548c\u516c\u4fe1\u529b\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u76d1\u7763\u673a\u5236\u4e0d\u591f\u5b8c\u5584\uff0c\u5bfc\u81f4\u90e8\u5206\u51b3\u5b9a\u6d41\u4e8e\u5f62\u5f0f\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u5e02\u573a\u76d1\u7ba1\u90e8\u95e8\u56e0\u672a\u4f9d\u6cd5\u5904\u7406\u6d88\u8d39\u8005\u6295\u8bc9\u88ab\u7533\u8bf7\u590d\u8bae\u540e\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u7f3a\u4e4f\u6709\u6548\u7684\u540e\u7eed\u8ddf\u8e2a\u548c\u76d1\u7763\uff0c\u88ab\u7533\u8bf7\u4eba\u672a\u6309\u51b3\u5b9a\u5c65\u884c\u804c\u8d23\uff0c\u800c\u590d\u8bae\u673a\u5173\u4e5f\u672a\u91c7\u53d6\u8fdb\u4e00\u6b65\u63aa\u65bd\uff0c\u5bfc\u81f4\u884c\u653f\u590d\u8bae\u7684\u6700\u7ec8\u6548\u679c\u5927\u6253\u6298\u6263\u3002\n\n\u6700\u540e\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u6709\u65f6\u672a\u80fd\u5145\u5206\u542c\u53d6\u7533\u8bf7\u4eba\u548c\u88ab\u7533\u8bf7\u4eba\u7684\u610f\u89c1\uff0c\u5f71\u54cd\u4e86\u51b3\u5b9a\u7684\u516c\u6b63\u6027\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u6559\u80b2\u90e8\u95e8\u56e0\u672a\u4f9d\u6cd5\u5904\u7406\u5b66\u751f\u7533\u8bc9\u88ab\u7533\u8bf7\u590d\u8bae\u540e\uff0c\u590d\u8bae\u673a\u5173\u5728\u672a\u5145\u5206\u8c03\u67e5\u548c\u542c\u53d6\u53cc\u65b9\u610f\u89c1\u7684\u60c5\u51b5\u4e0b\uff0c\u76f4\u63a5\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u8ba4\u4e3a\u51b3\u5b9a\u4e0d\u516c\uff0c\u8fdb\u800c\u5f15\u53d1\u65b0\u7684\u4e89\u8bae\u3002\n\ndocument \u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u5f80\u5f80\u53d6\u51b3\u4e8e\u76f8\u5173\u914d\u5957\u673a\u5236\u7684\u5b8c\u5584\u7a0b\u5ea6\u3002\u52a0\u5f3a\u590d\u8bae\u673a\u5173\u7684\u4e13\u4e1a\u80fd\u529b\u3001\u5b8c\u5584\u6267\u884c\u76d1\u7763\u673a\u5236\u3001\u63d0\u9ad8\u51b3\u5b9a\u7684\u53ef\u64cd\u4f5c\u6027\uff0c\u5e76\u786e\u4fdd\u5145\u5206\u542c\u53d6\u5404\u65b9\u610f\u89c1\uff0c\u662f\u63d0\u5347\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5b9e\u6548\u6027\u7684\u5173\u952e\u3002\u53ea\u6709\u8fd9\u6837\uff0c\u624d\u80fd\u771f\u6b63\u5b9e\u73b0\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u76d1\u7763\u529f\u80fd\uff0c\u63a8\u52a8\u884c\u653f\u673a\u5173\u4f9d\u6cd5\u884c\u653f\u3002"
}
{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u662f\u4e00\u95e8\u878d\u5408\u7a7a\u6c14\u52a8\u529b\u5b66\u3001\u751f\u7269\u529b\u5b66\u4e0e\u5de5\u7a0b\u8bbe\u8ba1\u7684\u4ea4\u53c9\u5b66\u79d1\uff0c\u5176\u6838\u5fc3\u76ee\u6807\u662f\u901a\u8fc7\u6a21\u4eff\u81ea\u7136\u754c\u4e2d\u751f\u7269\u7684\u98de\u884c\u673a\u5236\uff0c\u4f18\u5316\u98de\u884c\u5668\u7684\u7a7a\u6c14\u52a8\u529b\u6027\u80fd\u3002\u7ffc\u578b\u8bbe\u8ba1\u4f5c\u4e3a\u98de\u884c\u5668\u8bbe\u8ba1\u7684\u5173\u952e\u90e8\u5206\uff0c\u76f4\u63a5\u5f71\u54cd\u98de\u884c\u5668\u7684\u5347\u529b\u3001\u963b\u529b\u3001\u7a33\u5b9a\u6027\u4e0e\u64cd\u63a7\u6027\u3002\u800c\u4eff\u751f\u5b66\u5219\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u7075\u611f\uff0c\u4f7f\u4eba\u7c7b\u80fd\u591f\u4ece\u81ea\u7136\u754c\u4e2d\u6c72\u53d6\u667a\u6167\uff0c\u7a81\u7834\u4f20\u7edf\u8bbe\u8ba1\u7684\u5c40\u9650\u3002\n\n\u81ea\u7136\u754c\u4e2d\u7684\u98de\u884c\u52a8\u7269\uff0c\u5982\u9e1f\u7c7b\u3001\u6606\u866b\u3001\u8759\u8760\u7b49\uff0c\u5176\u7ffc\u578b\u7ed3\u6784\u4e0e\u8fd0\u52a8\u65b9\u5f0f\u5177\u6709\u9ad8\u5ea6\u7684\u9002\u5e94\u6027\u4e0e\u6548\u7387\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7fc5\u8180\u7684\u67d4\u6027\u7ed3\u6784\u80fd\u591f\u6839\u636e\u6c14\u6d41\u53d8\u5316\u8fdb\u884c\u8c03\u6574\uff0c\u4ece\u800c\u63d0\u5347\u98de\u884c\u6548\u7387\uff1b\u6606\u866b\u7fc5\u8180\u7684\u590d\u6742\u632f\u52a8\u6a21\u5f0f\u5219\u80fd\u4ea7\u751f\u5f3a\u5927\u7684\u5347\u529b\u3002\u8fd9\u4e9b\u751f\u7269\u7279\u5f81\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u4e30\u5bcc\u7684\u7814\u7a76\u7d20\u6750\u3002\u901a\u8fc7\u4eff\u751f\u5b66\u65b9\u6cd5\uff0c\u5de5\u7a0b\u5e08\u53ef\u4ee5\u501f\u9274\u8fd9\u4e9b\u81ea\u7136\u754c\u7684\u667a\u6167\uff0c\u8bbe\u8ba1\u51fa\u66f4\u52a0\u9ad8\u6548\u3001\u7075\u6d3b\u7684\u7ffc\u578b\u7ed3\u6784\u3002\n\n\u5728\u73b0\u4ee3\u822a\u7a7a\u5de5\u7a0b\u4e2d\uff0c\u4eff\u751f\u5b66\u5df2\u88ab\u5e7f\u6cdb\u5e94\u7528\u4e8e\u7ffc\u578b\u8bbe\u8ba1\u9886\u57df\u3002\u4f8b\u5982\uff0c\u57fa\u4e8e\u9e1f\u7c7b\u7fc5\u8180\u7684\u67d4\u6027\u7ffc\u578b\u8bbe\u8ba1\uff0c\u80fd\u591f\u5b9e\u73b0\u66f4\u9ad8\u6548\u7684\u5347\u529b\u4ea7\u751f\u548c\u66f4\u4f4e\u7684\u80fd\u8017\uff1b\u57fa\u4e8e\u6606\u866b\u7fc5\u8180\u7684\u5fae\u578b\u98de\u884c\u5668\u8bbe\u8ba1\uff0c\u4f7f\u5f97\u5fae\u578b\u65e0\u4eba\u673a\u5728\u590d\u6742\u73af\u5883\u4e2d\u5177\u5907\u66f4\u5f3a\u7684\u673a\u52a8\u6027\u3002\u6b64\u5916\uff0c\u4eff\u751f\u5b66\u8fd8\u63a8\u52a8\u4e86\u53ef\u53d8\u7ffc\u578b\u6280\u672f\u7684\u53d1\u5c55\uff0c\u4f7f\u98de\u884c\u5668\u80fd\u591f\u5728\u4e0d\u540c\u98de\u884c\u72b6\u6001\u4e0b\u81ea\u52a8\u8c03\u6574\u7ffc\u578b\u5f62\u72b6\uff0c\u4ece\u800c\u4f18\u5316\u98de\u884c\u6027\u80fd\u3002\n\n\u7136\u800c\uff0c\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u4ecd\u9762\u4e34\u8bf8\u591a\u6311\u6218\u3002\u4f8b\u5982\uff0c\u5982\u4f55\u51c6\u786e\u6a21\u62df\u751f\u7269\u7ed3\u6784\u7684\u590d\u6742\u6027\u4e0e\u52a8\u6001\u7279\u6027\uff0c\u5982\u4f55\u5728\u5de5\u7a0b\u5b9e\u73b0\u4e2d\u5e73\u8861\u4eff\u751f\u8bbe\u8ba1\u7684\u751f\u7269\u7279\u6027\u4e0e\u5b9e\u9645\u5de5\u7a0b\u9700\u6c42\uff0c\u4ee5\u53ca\u5982\u4f55\u786e\u4fdd\u4eff\u751f\u8bbe\u8ba1\u5728\u4e0d\u540c\u73af\u5883\u6761\u4ef6\u4e0b\u7684\u53ef\u9760\u6027\u3002\u8fd9\u4e9b\u95ee\u9898\u9700\u8981\u8de8\u5b66\u79d1\u7684\u5408\u4f5c\u4e0e\u6df1\u5165\u7814\u7a76\uff0c\u4ee5\u63a8\u52a8\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u8fdb\u4e00\u6b65\u878d\u5408\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e3a\u98de\u884c\u5668\u8bbe\u8ba1\u5e26\u6765\u4e86\u65b0\u7684\u673a\u9047\u4e0e\u6311\u6218\u3002\u901a\u8fc7\u501f\u9274\u81ea\u7136\u754c\u7684\u98de\u884c\u667a\u6167\uff0c\u4eba\u7c7b\u80fd\u591f\u4e0d\u65ad\u7a81\u7834\u4f20\u7edf\u8bbe\u8ba1\u7684\u8fb9\u754c\uff0c\u5f00\u53d1\u51fa\u66f4\u52a0\u9ad8\u6548\u3001\u667a\u80fd\u7684\u98de\u884c\u5668\u3002\u672a\u6765\uff0c\u968f\u7740\u6750\u6599\u79d1\u5b66\u3001\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\u4e0e\u4eba\u5de5\u667a\u80fd\u7b49\u6280\u672f\u7684\u8fdb\u6b65\uff0c\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u5c06\u66f4\u52a0\u7d27\u5bc6\uff0c\u4e3a\u822a\u7a7a\u822a\u5929\u9886\u57df\u5e26\u6765\u6df1\u8fdc\u7684\u5f71\u54cd\u3002  \n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e0d\u4ec5\u63d0\u5347\u4e86\u98de\u884c\u5668\u7684\u6027\u80fd\uff0c\u4e5f\u4e3a\u4eba\u7c7b\u63a2\u7d22\u81ea\u7136\u4e0e\u79d1\u6280\u7684\u8fb9\u754c\u63d0\u4f9b\u4e86\u65b0\u7684\u89c6\u89d2\u3002\u968f\u7740\u7814\u7a76\u7684\u6df1\u5165\uff0c\u8fd9\u4e00\u9886\u57df\u5c06\u7ee7\u7eed\u63a8\u52a8\u822a\u7a7a\u5de5\u7a0b\u7684\u53d1\u5c55\uff0c\u4e3a\u672a\u6765\u7684\u98de\u884c\u5668\u8bbe\u8ba1\u63d0\u4f9b\u66f4\u52a0\u667a\u80fd\u5316\u548c\u9ad8\u6548\u5316\u7684\u89e3\u51b3\u65b9\u6848\u3002"
}
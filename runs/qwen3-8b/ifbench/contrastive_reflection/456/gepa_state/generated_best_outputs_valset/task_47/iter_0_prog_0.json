{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u662f\u822a\u7a7a\u5de5\u7a0b\u4e0e\u751f\u7269\u79d1\u5b66\u4ea4\u53c9\u9886\u57df\u7684\u4e24\u4e2a\u91cd\u8981\u5206\u652f\uff0c\u5b83\u4eec\u5728\u73b0\u4ee3\u98de\u884c\u5668\u8bbe\u8ba1\u4e2d\u626e\u6f14\u7740\u81f3\u5173\u91cd\u8981\u7684\u89d2\u8272\u3002\u7ffc\u578b\u8bbe\u8ba1\u4e3b\u8981\u5173\u6ce8\u98de\u673a\u673a\u7ffc\u7684\u5f62\u72b6\u548c\u7ed3\u6784\uff0c\u4ee5\u4f18\u5316\u5347\u529b\u3001\u963b\u529b\u548c\u98de\u884c\u6548\u7387\u3002\u800c\u4eff\u751f\u5b66\u5219\u501f\u9274\u81ea\u7136\u754c\u4e2d\u751f\u7269\u7684\u5f62\u6001\u548c\u529f\u80fd\uff0c\u4e3a\u5de5\u7a0b\u8bbe\u8ba1\u63d0\u4f9b\u7075\u611f\u3002\u672c\u6587\u5c06\u63a2\u8ba8\u7ffc\u578b\u8bbe\u8ba1\u7684\u57fa\u672c\u539f\u7406\uff0c\u5206\u6790\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\uff0c\u5e76\u63a2\u8ba8\u5176\u672a\u6765\u53d1\u5c55\u8d8b\u52bf\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u7684\u6838\u5fc3\u5728\u4e8e\u7a7a\u6c14\u52a8\u529b\u5b66\u539f\u7406\u3002\u7ffc\u578b\u7684\u5f62\u72b6\u51b3\u5b9a\u4e86\u5176\u4ea7\u751f\u7684\u5347\u529b\u548c\u963b\u529b\u3002\u901a\u5e38\uff0c\u7ffc\u578b\u7531\u524d\u7f18\u3001\u540e\u7f18\u548c\u4e0a\u4e0b\u8868\u9762\u7ec4\u6210\uff0c\u5176\u66f2\u7387\u548c\u539a\u5ea6\u5206\u5e03\u76f4\u63a5\u5f71\u54cd\u6c14\u6d41\u7684\u6d41\u52a8\u65b9\u5f0f\u3002\u5728\u6d41\u4f53\u529b\u5b66\u4e2d\uff0c\u7ffc\u578b\u7684\u5347\u529b\u4e3b\u8981\u6765\u6e90\u4e8e\u4e0a\u4e0b\u8868\u9762\u6c14\u6d41\u901f\u5ea6\u7684\u5dee\u5f02\uff0c\u6839\u636e\u4f2f\u52aa\u5229\u539f\u7406\uff0c\u6d41\u901f\u5feb\u7684\u533a\u57df\u538b\u529b\u8f83\u4f4e\uff0c\u4ece\u800c\u4ea7\u751f\u51c0\u5347\u529b\u3002\u6b64\u5916\uff0c\u7ffc\u578b\u7684\u653b\u89d2\uff08\u5373\u7ffc\u5f26\u4e0e\u6765\u6d41\u65b9\u5411\u4e4b\u95f4\u7684\u5939\u89d2\uff09\u4e5f\u5bf9\u5347\u529b\u548c\u963b\u529b\u4ea7\u751f\u663e\u8457\u5f71\u54cd\u3002\u653b\u89d2\u8fc7\u5c0f\u4f1a\u5bfc\u81f4\u5347\u529b\u4e0d\u8db3\uff0c\u800c\u653b\u89d2\u8fc7\u5927\u5219\u53ef\u80fd\u5f15\u53d1\u5931\u901f\u73b0\u8c61\uff0c\u4f7f\u98de\u884c\u5668\u5931\u53bb\u63a7\u5236\u3002\n\n\u5728\u5b9e\u9645\u5e94\u7528\u4e2d\uff0c\u7ffc\u578b\u8bbe\u8ba1\u9700\u8981\u5728\u5347\u529b\u3001\u963b\u529b\u3001\u7a33\u5b9a\u6027\u4ee5\u53ca\u7ed3\u6784\u5f3a\u5ea6\u4e4b\u95f4\u53d6\u5f97\u5e73\u8861\u3002\u4f8b\u5982\uff0c\u73b0\u4ee3\u98de\u673a\u901a\u5e38\u91c7\u7528\u540e\u63a0\u7ffc\u8bbe\u8ba1\u4ee5\u51cf\u5c11\u9ad8\u901f\u98de\u884c\u65f6\u7684\u963b\u529b\uff0c\u540c\u65f6\u91c7\u7528\u9ad8\u5347\u529b\u7ffc\u578b\u4ee5\u63d0\u9ad8\u4f4e\u901f\u98de\u884c\u65f6\u7684\u64cd\u63a7\u6027\u3002\u6b64\u5916\uff0c\u53ef\u53d8\u7ffc\u578b\u6280\u672f\uff08\u5982\u7ffc\u68a2\u5c0f\u7ffc\u548c\u895f\u7ffc\uff09\u4e5f\u88ab\u5e7f\u6cdb\u5e94\u7528\uff0c\u4ee5\u9002\u5e94\u4e0d\u540c\u7684\u98de\u884c\u6761\u4ef6\u3002\n\n\u4eff\u751f\u5b66\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u3002\u81ea\u7136\u754c\u4e2d\uff0c\u8bb8\u591a\u751f\u7269\u7684\u7fc5\u8180\u548c\u9ccd\u5177\u6709\u9ad8\u6548\u7684\u7a7a\u6c14\u52a8\u529b\u5b66\u7279\u6027\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7684\u7fc5\u8180\u901a\u8fc7\u590d\u6742\u7684\u808c\u8089\u548c\u9aa8\u9abc\u7ed3\u6784\u5b9e\u73b0\u9ad8\u6548\u7684\u5347\u529b\u751f\u6210\uff0c\u5176\u7ffc\u578b\u5f62\u72b6\u548c\u8fd0\u52a8\u65b9\u5f0f\u4e3a\u98de\u884c\u5668\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u7075\u611f\u3002\u7814\u7a76\u53d1\u73b0\uff0c\u67d0\u4e9b\u9e1f\u7c7b\u7684\u7ffc\u578b\u5177\u6709\u975e\u5bf9\u79f0\u7684\u66f2\u7387\uff0c\u80fd\u591f\u6709\u6548\u51cf\u5c11\u6e4d\u6d41\u548c\u963b\u529b\u3002\u6b64\u5916\uff0c\u6606\u866b\u7684\u7fc5\u8180\u901a\u8fc7\u9ad8\u9891\u632f\u52a8\u4ea7\u751f\u5347\u529b\uff0c\u8fd9\u79cd\u673a\u5236\u5728\u5fae\u578b\u98de\u884c\u5668\uff08MAV\uff09\u8bbe\u8ba1\u4e2d\u5f97\u5230\u4e86\u5e94\u7528\u3002\n\n\u4eff\u751f\u5b66\u8fd8\u542f\u53d1\u4e86\u65b0\u578b\u6750\u6599\u548c\u7ed3\u6784\u7684\u8bbe\u8ba1\u3002\u4f8b\u5982\uff0c\u4eff\u751f\u5b66\u7814\u7a76\u53d1\u73b0\uff0c\u67d0\u4e9b\u6d77\u6d0b\u751f\u7269\u7684\u9ccd\u5177\u6709\u81ea\u9002\u5e94\u80fd\u529b\uff0c\u80fd\u591f\u6839\u636e\u6c34\u6d41\u53d8\u5316\u8c03\u6574\u5f62\u72b6\uff0c\u4ece\u800c\u63d0\u9ad8\u6548\u7387\u3002\u8fd9\u4e00\u7279\u6027\u88ab\u5e94\u7528\u4e8e\u53ef\u53d8\u5f62\u7ffc\u578b\u8bbe\u8ba1\u4e2d\uff0c\u4f7f\u98de\u884c\u5668\u80fd\u591f\u5728\u4e0d\u540c\u98de\u884c\u6761\u4ef6\u4e0b\u4f18\u5316\u6027\u80fd\u3002\u6b64\u5916\uff0c\u4eff\u751f\u5b66\u8fd8\u63a8\u52a8\u4e86\u667a\u80fd\u6750\u6599\u7684\u53d1\u5c55"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u8bf8\u591a\u95ee\u9898\uff0c\u5f71\u54cd\u4e86\u5176\u5e94\u6709\u7684\u6cd5\u5f8b\u6548\u529b\u548c\u884c\u653f\u6548\u7387\u3002\u9996\u5148\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u4e0d\u591f\u660e\u786e\uff0c\u5bfc\u81f4\u90e8\u5206\u6848\u4ef6\u4e2d\u5e94\u5f53\u9002\u7528\u8be5\u51b3\u5b9a\u7684\u60c5\u5f62\u672a\u80fd\u88ab\u6b63\u786e\u9002\u7528\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u672a\u4f9d\u6cd5\u5c65\u884c\u76d1\u7ba1\u804c\u8d23\u7684\u6848\u4ef6\u4e2d\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u672a\u80fd\u53ca\u65f6\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u81f4\u4f7f\u8fdd\u6cd5\u884c\u4e3a\u6301\u7eed\u5b58\u5728\uff0c\u635f\u5bb3\u4e86\u516c\u6c11\u7684\u5408\u6cd5\u6743\u76ca\u3002\u8fd9\u79cd\u9002\u7528\u8303\u56f4\u7684\u6a21\u7cca\u6027\u964d\u4f4e\u4e86\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u3002\n\n\u5176\u6b21\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u51b3\u5b9a\u96be\u4ee5\u843d\u5b9e\u3002\u5728\u4e00\u4e9b\u6848\u4f8b\u4e2d\uff0c\u5373\u4f7f\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u4e86\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u76f8\u5173\u884c\u653f\u673a\u5173\u4ecd\u53ef\u80fd\u7f6e\u82e5\u7f54\u95fb\uff0c\u672a\u91c7\u53d6\u4efb\u4f55\u8865\u6551\u63aa\u65bd\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u571f\u5730\u7ba1\u7406\u90e8\u95e8\u672a\u4f9d\u6cd5\u529e\u7406\u571f\u5730\u4f7f\u7528\u6743\u53d8\u66f4\u624b\u7eed\u7684\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u867d\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u8be5\u90e8\u95e8\u672a\u5728\u89c4\u5b9a\u671f\u9650\u5185\u5c65\u884c\u4e49\u52a1\uff0c\u6700\u7ec8\u5bfc\u81f4\u884c\u653f\u76f8\u5bf9\u4eba\u6743\u76ca\u53d7\u635f\u3002\u8fd9\u79cd\u6267\u884c\u4e0d\u529b\u7684\u73b0\u8c61\u524a\u5f31\u4e86\u590d\u8bae\u51b3\u5b9a\u7684\u6cd5\u5f8b\u7ea6\u675f\u529b\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u5f80\u5f80\u7f3a\u4e4f\u5145\u5206\u7684\u8c03\u67e5\u53d6\u8bc1\uff0c\u5bfc\u81f4\u51b3\u5b9a\u7f3a\u4e4f\u4e8b\u5b9e\u4f9d\u636e\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u5e02\u573a\u76d1\u7ba1\u90e8\u95e8\u672a\u4f9d\u6cd5\u5904\u7406\u6d88\u8d39\u8005\u6295\u8bc9\u7684\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u5728\u672a\u5145\u5206\u4e86\u89e3\u6848\u60c5\u7684\u60c5\u51b5\u4e0b\uff0c\u76f4\u63a5\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u7ed3\u679c\u56e0\u8bc1\u636e\u4e0d\u8db3\u800c\u88ab\u6cd5\u9662\u64a4\u9500\u3002\u8fd9\u4e0d\u4ec5\u5f71\u54cd\u4e86\u590d\u8bae\u51b3\u5b9a\u7684\u516c\u6b63\u6027\uff0c\u4e5f\u635f\u5bb3\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u516c\u4fe1\u529b\u3002\n\n\u6700\u540e\uff0c\u884c\u653f\u590d\u8bae\u4eba\u5458\u7684\u4e13\u4e1a\u7d20\u8d28\u53c2\u5dee\u4e0d\u9f50\uff0c\u5f71\u54cd\u4e86\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u8d28\u91cf\u3002\u90e8\u5206\u590d\u8bae\u4eba\u5458\u5bf9\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\u7684\u7406\u89e3\u4e0d\u591f\u6df1\u5165\uff0c\u5bfc\u81f4\u5728\u5904\u7406\u590d\u6742\u6848\u4ef6\u65f6\u51fa\u73b0\u9519\u8bef\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u7a0e\u52a1\u90e8\u95e8\u672a\u4f9d\u6cd5\u529e\u7406\u9000\u7a0e\u7684\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u4eba\u5458\u672a\u80fd\u51c6\u786e\u9002\u7528\u76f8\u5173\u6cd5\u5f8b\u6761\u6b3e\uff0c\u5bfc\u81f4\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5b58\u5728\u6cd5\u5f8b\u9002\u7528\u9519\u8bef\uff0c\u6700\u7ec8\u5f15\u53d1\u884c\u653f\u8bc9\u8bbc\u3002\u8fd9\u79cd\u4e13\u4e1a\u80fd\u529b\u7684\u4e0d\u8db3\uff0c\u8fdb\u4e00\u6b65\u52a0\u5267\u4e86\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u96be\u5ea6\u3002\n\ndocument \u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5b8c\u5584\u9700\u8981\u4ece\u7acb\u6cd5\u3001\u6267\u884c\u548c\u4eba\u5458\u7d20\u8d28\u7b49\u591a\u4e2a\u65b9\u9762\u5165\u624b\u3002\u9996\u5148\uff0c\u5e94\u8fdb\u4e00\u6b65\u660e\u786e\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\uff0c\u786e\u4fdd\u5176\u5728\u5b9e\u8df5\u4e2d\u80fd\u591f\u6709\u6548\u53d1\u6325\u4f5c\u7528\u3002\u5176\u6b21\uff0c\u5efa\u7acb\u5b8c\u5584\u7684\u76d1\u7763\u673a\u5236\uff0c\u786e\u4fdd\u590d\u8bae\u51b3\u5b9a\u80fd\u591f\u5f97\u5230\u6709\u6548\u6267\u884c\u3002\u6b64\u5916\uff0c\u52a0\u5f3a\u590d\u8bae\u4eba\u5458\u7684\u4e13\u4e1a\u57f9\u8bad\uff0c\u63d0\u9ad8\u5176\u6cd5\u5f8b\u7d20\u517b\u548c\u4e1a\u52a1\u80fd\u529b\uff0c\u4e5f\u662f\u63d0\u5347\u590d\u8bae\u8d28\u91cf\u7684\u91cd\u8981\u9014\u5f84\u3002\u901a\u8fc7\u8fd9\u4e9b\u63aa\u65bd\uff0c\u53ef\u4ee5\u9010\u6b65\u89e3\u51b3\u5f53\u524d\u5b58\u5728\u7684\u95ee\u9898\uff0c\u63d0\u9ad8\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u6574\u4f53\u6548\u80fd\u3002"
}
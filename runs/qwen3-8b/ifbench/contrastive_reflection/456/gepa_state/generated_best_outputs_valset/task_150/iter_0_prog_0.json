{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u9645\u8fd0\u884c\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u8fd9\u4e9b\u95ee\u9898\u5f71\u54cd\u4e86\u5176\u6cd5\u5f8b\u6548\u529b\u548c\u6267\u884c\u6548\u679c\u3002\u9996\u5148\uff0c\u90e8\u5206\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u672a\u80fd\u5145\u5206\u8c03\u67e5\u4e8b\u5b9e\u548c\u5ba1\u67e5\u8bc1\u636e\uff0c\u5bfc\u81f4\u51b3\u5b9a\u7f3a\u4e4f\u6cd5\u5f8b\u4f9d\u636e\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u7533\u8bf7\u4eba\u8ba4\u4e3a\u884c\u653f\u673a\u5173\u672a\u4f9d\u6cd5\u5c65\u884c\u73af\u5883\u76d1\u7ba1\u804c\u8d23\uff0c\u590d\u8bae\u673a\u5173\u5728\u672a\u6df1\u5165\u8c03\u67e5\u7684\u60c5\u51b5\u4e0b\uff0c\u4ec5\u4f9d\u636e\u8868\u9762\u6750\u6599\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u7ed3\u679c\u672a\u80fd\u6709\u6548\u7ea0\u6b63\u539f\u884c\u653f\u884c\u4e3a\uff0c\u5bfc\u81f4\u7533\u8bf7\u4eba\u6743\u76ca\u672a\u80fd\u5f97\u5230\u5145\u5206\u4fdd\u969c\u3002\n\n\u5176\u6b21\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\uff0c\u4f7f\u5f97\u8be5\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u96be\u4ee5\u843d\u5b9e\u3002\u7531\u4e8e\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u4e00\u4e9b\u884c\u653f\u673a\u5173\u5bf9\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u6001\u5ea6\u6d88\u6781\uff0c\u751a\u81f3\u5b58\u5728\u63a8\u8bff\u626f\u76ae\u7684\u73b0\u8c61\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u571f\u5730\u5f81\u6536\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u539f\u884c\u653f\u673a\u5173\u4ecd\u672a\u4f9d\u6cd5\u5c65\u884c\u804c\u8d23\uff0c\u7533\u8bf7\u4eba\u4e0d\u5f97\u4e0d\u901a\u8fc7\u8bc9\u8bbc\u9014\u5f84\u5bfb\u6c42\u6551\u6d4e\uff0c\u589e\u52a0\u4e86\u7ef4\u6743\u6210\u672c\uff0c\u4e5f\u524a\u5f31\u4e86\u590d\u8bae\u5236\u5ea6\u7684\u6743\u5a01\u6027\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u5bf9\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\u7684\u7406\u89e3\u548c\u9002\u7528\u5b58\u5728\u504f\u5dee\uff0c\u5bfc\u81f4\u51b3\u5b9a\u5185\u5bb9\u4e0d\u660e\u786e\u6216\u7f3a\u4e4f\u53ef\u64cd\u4f5c\u6027\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u5e02\u573a\u76d1\u7ba1\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u8981\u6c42\u88ab\u7533\u8bf7\u4eba\u5c65\u884c\u67d0\u9879\u5177\u4f53\u884c\u653f\u884c\u4e3a\uff0c\u4f46\u672a\u660e\u786e\u5c65\u884c\u7684\u5177\u4f53\u6807\u51c6\u548c\u65f6\u9650\uff0c\u4f7f\u5f97\u88ab\u7533\u8bf7\u4eba\u96be\u4ee5\u6267\u884c\uff0c\u6700\u7ec8\u5bfc\u81f4\u590d\u8bae\u51b3\u5b9a\u6d41\u4e8e\u5f62\u5f0f\uff0c\u672a\u80fd\u5b9e\u73b0\u9884\u671f\u7684\u6cd5\u5f8b\u6548\u679c\u3002\n\n\u6700\u540e\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u7f3a\u4e4f\u5bf9\u6267\u884c\u60c5\u51b5\u7684\u8ddf\u8e2a\u548c\u76d1\u7763\uff0c\u4f7f\u5f97\u8be5\u51b3\u5b9a\u7684\u540e\u7eed\u843d\u5b9e\u7f3a\u4e4f\u4fdd\u969c\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u7a0e\u52a1\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u672a\u5bf9\u88ab\u7533\u8bf7\u4eba\u5c65\u884c\u60c5\u51b5\u5f00\u5c55\u540e\u7eed\u68c0\u67e5\uff0c\u5bfc\u81f4\u88ab\u7533\u8bf7\u4eba\u957f\u671f\u672a\u5c65\u884c\u4e49\u52a1\uff0c\u7533\u8bf7\u4eba\u6743\u76ca\u53d7\u635f\uff0c\u590d\u8bae\u5236\u5ea6\u7684\u516c\u4fe1\u529b\u53d7\u5230\u8d28\u7591\u3002\n\ndocument \u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u53d7\u5230\u591a\u79cd\u56e0\u7d20\u7684\u5f71\u54cd\uff0c\u5305\u62ec\u590d\u8bae\u673a\u5173\u7684\u6267\u6cd5\u80fd\u529b\u3001\u884c\u653f\u673a\u5173\u7684\u914d\u5408\u7a0b\u5ea6\u4ee5\u53ca\u76d1\u7763\u673a\u5236\u7684\u5b8c\u5584\u7a0b\u5ea6\u3002\u56e0\u6b64\uff0c\u6709\u5fc5\u8981\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173\u5236\u5ea6\uff0c\u63d0\u9ad8\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u529b\u548c\u516c\u4fe1\u529b\uff0c\u4ee5\u786e\u4fdd\u884c\u653f\u590d\u8bae\u5236\u5ea6\u80fd\u591f\u66f4\u597d\u5730\u53d1\u6325\u5176\u5e94\u6709\u7684\u4f5c\u7528\u3002"
}
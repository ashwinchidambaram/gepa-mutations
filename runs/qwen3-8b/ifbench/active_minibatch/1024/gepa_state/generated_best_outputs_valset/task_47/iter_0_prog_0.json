{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u662f\u4e00\u95e8\u878d\u5408\u4e86\u7a7a\u6c14\u52a8\u529b\u5b66\u3001\u751f\u7269\u529b\u5b66\u4e0e\u5de5\u7a0b\u5b66\u7684\u4ea4\u53c9\u5b66\u79d1\uff0c\u65e8\u5728\u901a\u8fc7\u6a21\u4eff\u81ea\u7136\u754c\u4e2d\u751f\u7269\u7684\u98de\u884c\u673a\u5236\uff0c\u4f18\u5316\u98de\u884c\u5668\u7684\u7a7a\u6c14\u52a8\u529b\u6027\u80fd\u3002\u7ffc\u578b\u4f5c\u4e3a\u98de\u884c\u5668\u7684\u6838\u5fc3\u90e8\u4ef6\uff0c\u5176\u8bbe\u8ba1\u76f4\u63a5\u5f71\u54cd\u98de\u884c\u6548\u7387\u3001\u5347\u529b\u4e0e\u963b\u529b\u7684\u5e73\u8861\u3002\u800c\u4eff\u751f\u5b66\u5219\u901a\u8fc7\u7814\u7a76\u751f\u7269\u4f53\u7684\u7ed3\u6784\u4e0e\u529f\u80fd\uff0c\u4e3a\u5de5\u7a0b\u8bbe\u8ba1\u63d0\u4f9b\u7075\u611f\uff0c\u63a8\u52a8\u6280\u672f\u9769\u65b0\u3002\u672c\u6587\u5c06\u63a2\u8ba8\u7ffc\u578b\u8bbe\u8ba1\u7684\u57fa\u672c\u539f\u7406\u3001\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u53ca\u5176\u672a\u6765\u53d1\u5c55\u65b9\u5411\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u7684\u6838\u5fc3\u5728\u4e8e\u5176\u51e0\u4f55\u5f62\u72b6\u4e0e\u6d41\u4f53\u52a8\u529b\u5b66\u7279\u6027\u4e4b\u95f4\u7684\u5173\u7cfb\u3002\u7ffc\u578b\u901a\u5e38\u7531\u524d\u7f18\u3001\u540e\u7f18\u3001\u4e0a\u4e0b\u8868\u9762\u548c\u5f26\u957f\u7b49\u8981\u7d20\u6784\u6210\uff0c\u5176\u66f2\u7387\u3001\u539a\u5ea6\u548c\u5f2f\u5ea6\u7b49\u53c2\u6570\u51b3\u5b9a\u4e86\u5176\u5728\u4e0d\u540c\u98de\u884c\u6761\u4ef6\u4e0b\u7684\u6027\u80fd\u8868\u73b0\u3002\u901a\u8fc7\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\uff08CFD\uff09\u548c\u98ce\u6d1e\u5b9e\u9a8c\uff0c\u5de5\u7a0b\u5e08\u53ef\u4ee5\u4f18\u5316\u7ffc\u578b\u7684\u5347\u963b\u6bd4\uff0c\u63d0\u9ad8\u98de\u884c\u5668\u7684\u71c3\u6cb9\u6548\u7387\u548c\u98de\u884c\u7a33\u5b9a\u6027\u3002\u7136\u800c\uff0c\u4f20\u7edf\u7ffc\u578b\u8bbe\u8ba1\u5f80\u5f80\u53d7\u9650\u4e8e\u56fa\u5b9a\u51e0\u4f55\u7ed3\u6784\uff0c\u96be\u4ee5\u9002\u5e94\u590d\u6742\u591a\u53d8\u7684\u98de\u884c\u73af\u5883\u3002\n\n\u4eff\u751f\u5b66\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u3002\u81ea\u7136\u754c\u4e2d\uff0c\u8bb8\u591a\u751f\u7269\u5982\u9e1f\u7c7b\u3001\u6606\u866b\u548c\u9c7c\u7c7b\u5728\u957f\u671f\u8fdb\u5316\u4e2d\u5f62\u6210\u4e86\u9ad8\u6548\u7684\u98de\u884c\u6216\u6e38\u52a8\u673a\u5236\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7fc5\u8180\u7684\u67d4\u6027\u7ed3\u6784\u80fd\u591f\u6839\u636e\u6c14\u6d41\u53d8\u5316\u8c03\u6574\u5f62\u6001\uff0c\u63d0\u9ad8\u5347\u529b\uff1b\u6606\u866b\u7fc5\u8180\u7684\u632f\u52a8\u9891\u7387\u548c\u89d2\u5ea6\u53d8\u5316\u5219\u80fd\u4ea7\u751f\u590d\u6742\u7684\u7a7a\u6c14\u52a8\u529b\u6548\u5e94\u3002\u8fd9\u4e9b\u751f\u7269\u7ed3\u6784\u542f\u53d1\u4e86\u79d1\u5b66\u5bb6\u548c\u5de5\u7a0b\u5e08\uff0c\u63a8\u52a8\u4e86\u53ef\u53d8\u7ffc\u578b\u3001\u81ea\u9002\u5e94\u7ffc\u578b\u7b49\u65b0\u578b\u7ffc\u578b\u8bbe\u8ba1\u7684\u53d1\u5c55\u3002\u901a\u8fc7\u6a21\u4eff\u751f\u7269\u7ed3\u6784\uff0c\u7814\u7a76\u4eba\u5458\u80fd\u591f\u5f00\u53d1\u51fa\u5177\u6709\u66f4\u5f3a\u9002\u5e94\u6027\u548c\u66f4\u9ad8\u6548\u7387\u7684\u98de\u884c\u5668\u7ffc\u578b\u3002\n\n\u8fd1\u5e74\u6765\uff0c\u968f\u7740\u6750\u6599\u79d1\u5b66\u548c\u667a\u80fd\u63a7\u5236\u6280\u672f\u7684\u8fdb\u6b65\uff0c\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\u9010\u6e10\u4ece\u7406\u8bba\u7814\u7a76\u8d70\u5411\u5b9e\u9645\u5e94\u7528\u3002\u4f8b\u5982\uff0c\u57fa\u4e8e\u67d4\u6027\u6750\u6599\u548c\u5f62\u72b6\u8bb0\u5fc6\u5408\u91d1\u7684\u53ef\u53d8\u5f62\u7ffc\u578b\uff0c\u80fd\u591f\u5b9e\u65f6\u8c03\u6574\u7ffc\u578b\u5f62\u72b6\u4ee5\u9002\u5e94\u4e0d\u540c\u98de\u884c\u72b6\u6001\uff1b\u57fa\u4e8e\u4eff\u751f\u5b66\u539f\u7406\u7684\u5fae\u578b\u65e0\u4eba\u673a\uff0c\u80fd\u591f\u6a21\u4eff\u6606\u866b\u7684\u98de\u884c\u6a21\u5f0f\uff0c\u5b9e\u73b0\u9ad8\u673a\u52a8\u6027\u548c\u4f4e\u80fd\u8017\u3002\u8fd9\u4e9b\u521b\u65b0\u4e0d\u4ec5\u63d0\u5347\u4e86\u98de\u884c\u5668\u7684\u6027\u80fd\uff0c\u4e5f\u4e3a\u672a\u6765\u822a\u7a7a\u3001\u822a\u5929\u548c\u65e0\u4eba\u7cfb\u7edf\u7684\u53d1\u5c55\u63d0\u4f9b\u4e86\u65b0\u7684\u65b9\u5411\u3002\n\n\u7136\u800c\uff0c\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u4ecd\u9762\u4e34\u8bf8\u591a\u6311\u6218\u3002\u4e00\u65b9\u9762\uff0c\u751f\u7269\u7ed3\u6784\u7684\u590d\u6742\u6027\u4f7f\u5f97\u5176\u5de5\u7a0b\u5316\u5b9e\u73b0\u96be\u5ea6\u8f83\u5927\uff1b\u53e6\u4e00\u65b9\u9762\uff0c\u4eff\u751f\u8bbe\u8ba1\u9700\u8981\u5728\u751f\u7269\u529f\u80fd\u4e0e\u5de5\u7a0b\u6027\u80fd\u4e4b\u95f4\u627e\u5230\u5e73\u8861\u70b9\u3002\u6b64\u5916\uff0c\u5982\u4f55\u5c06\u4eff\u751f\u5b66\u539f\u7406\u4e0e\u4f20\u7edf\u7a7a\u6c14\u52a8\u529b\u5b66\u7406\u8bba\u6709\u6548\u7ed3\u5408\uff0c\u4e5f\u662f\u5f53\u524d\u7814\u7a76\u7684\u91cd\u8981\u8bfe\u9898\u3002\u672a\u6765\uff0c\u968f\u7740\u8ba1\u7b97\u80fd\u529b\u7684\u63d0\u5347"
}
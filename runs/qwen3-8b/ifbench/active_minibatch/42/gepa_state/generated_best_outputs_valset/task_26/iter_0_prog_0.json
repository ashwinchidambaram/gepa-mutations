{
    "response": "\u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0917\u0924 \u0935\u093f\u0924\u094d\u0924 \u0935\u094d\u092f\u0935\u0938\u094d\u0925\u093e\u092a\u0928 \u0917\u0930\u094d\u0928 \u0935\u093f\u092d\u093f\u0928\u094d\u0928 \u0909\u092a\u093e\u092f\u0939\u0930\u0942 \u0932\u093f\u0928 \u0938\u0915\u094d\u091b\u0928\u094d \u091c\u0938\u0932\u0947 \u0909\u0928\u0940\u0939\u0930\u0942\u0915\u094b \u0906\u0930\u094d\u0925\u093f\u0915 \u0938\u094d\u0925\u093f\u0924\u093f \u0938\u0941\u0927\u093e\u0930 \u0917\u0930\u094d\u091b \u0930 \u092d\u0935\u093f\u0937\u094d\u092f\u0915\u094b \u0938\u0941\u0930\u0915\u094d\u0937\u093e \u0917\u0930\u094d\u091b \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u0906\u092f \u0930 \u0916\u0930\u094d\u091a \u092c\u093f\u091a \u0915\u094b \u0905\u0928\u0941\u092a\u093e\u0924 \u0928\u093f\u092f\u092e\u093f\u0924 \u0930\u0942\u092a\u092e\u093e \u0905\u0927\u094d\u092f\u092f\u0928 \u0917\u0930\u094d\u0928\u0941 \u092a\u0930\u094d\u091b \u092f\u094b \u0909\u0928\u0940\u0939\u0930\u0942\u0932\u093e\u0908 \u0906\u0930\u094d\u0925\u093f\u0915 \u0935\u094d\u092f\u0935\u0938\u094d\u0925\u093e\u092a\u0928\u092e\u093e \u0938\u0939\u0940 \u0928\u093f\u0930\u094d\u0923\u092f \u0932\u093f\u0928 \u092e\u0926\u094d\u0926\u0924 \u0917\u0930\u094d\u091b \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u0906\u092b\u094d\u0928\u094b \u0906\u092f\u0915\u094b \u090f\u0915 \u0928\u093f\u0936\u094d\u091a\u093f\u0924 \u092a\u094d\u0930\u0924\u093f\u0936\u0924 \u092c\u091a\u0924 \u0917\u0930\u094d\u0928\u0941 \u0906\u0935\u0936\u094d\u092f\u0915 \u091b \u092f\u094b \u0909\u0928\u0940\u0939\u0930\u0942\u0915\u094b \u092d\u0935\u093f\u0937\u094d\u092f\u0915\u094b \u0938\u0941\u0930\u0915\u094d\u0937\u093e \u0930 \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0932\u0915\u094d\u0937\u094d\u092f\u0939\u0930\u0942 \u092a\u094d\u0930\u093e\u092a\u094d\u0924 \u0917\u0930\u094d\u0928 \u092e\u0926\u094d\u0926\u0924 \u0917\u0930\u094d\u091b \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u092c\u091a\u0924 \u0917\u0930\u0947\u0915\u094b \u0927\u0928 \u0935\u093f\u092d\u093f\u0928\u094d\u0928 \u092c\u091a\u0924 \u092f\u094b\u091c\u0928\u093e \u0930 \u092c\u0948\u0902\u0915 \u0916\u093e\u0924\u093e\u092e\u093e \u091c\u092e\u093e \u0917\u0930\u094d\u0928\u0941 \u092a\u0930\u094d\u091b \u092f\u094b \u0909\u0928\u0940\u0939\u0930\u0942\u0915\u094b \u0927\u0928 \u0915\u094b \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0935\u0943\u0926\u094d\u0927\u093f \u0930 \u0938\u0941\u0930\u0915\u094d\u0937\u093e \u0917\u0930"

{
    "response": "\u0628\u0627\u0644\u0637\u0628\u0639\u060c \u0625\u0644\u064a\u0643 \u0625\u0642\u062a\u0631\u0627\u062d\u0627\u062a \u0644\u0639\u0645\u0644 \u0642\u0646\u0627\u0629 \u0643\u0644\u0647\u0627 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0625\u0635\u0637\u0646\u0627\u0639\u064a\u060c \u0645\u0639 \u0627\u0644\u062a\u0631\u0643\u064a\u0632 \u0639\u0644\u0649 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u0645\u0628\u062a\u0643\u0631 \u0648\u0627\u0644\u062c\u0630\u0627\u0628:\n\n1. **\u0642\u0646\u0627\u0629 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0641\u064a \u0627\u0644\u062d\u064a\u0627\u0629 \u0627\u0644\u064a\u0648\u0645\u064a\u0629**: \u064a\u0645\u0643\u0646 \u0623\u0646 \u062a\u0642\u062f\u0645 \u0645\u062d\u062a\u0648\u0649 \u062d\u0648\u0644 \u0643\u064a\u0641\u064a\u0629 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u062a\u0643\u0646\u0648\u0644\u0648\u062c\u064a\u0627 \u0627\u0644\u0630\u0643\u064a\u0629 \u0641\u064a \u0627\u0644\u062d\u064a\u0627\u0629 \u0627\u0644\u064a\u0648\u0645\u064a\u0629\u060c \u0645\u062b\u0644 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0641\u064a \u0627\u0644\u0645\u0646\u0632\u0644\u060c \u0627\u0644\u0633\u064a\u0627\u0631\u0627\u062a \u0627\u0644\u0630\u0643\u064a\u0629\u060c \u0648\u0627\u0644\u0647\u0648\u0627\u062a\u0641 \u0627\u0644\u0630\u0643\u064a\u0629. \u0647\u0630\u0627 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u064a\u062c\u0630\u0628 \u0627\u0644\u062c\u0645\u0647\u0648\u0631 \u0627\u0644\u0639\u0627\u062f\u064a \u0648\u064a\u0648\u0636\u062d \u0641\u0648\u0627\u0626\u062f \u0627\u0644\u062a\u0643\u0646\u0648\u0644\u0648\u062c\u064a\u0627.\n\n2. **\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0641\u064a \u0627\u0644\u062a\u0639\u0644\u064a\u0645**: \u064a\u0645\u0643\u0646 \u0623\u0646 \u062a\u0642\u062f\u0645 \u0645\u062d\u062a\u0648\u0649 \u062d\u0648\u0644 \u0643\u064a\u0641\u064a\u0629 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0641\u064a \u062a\u062d\u0633\u064a\u0646 \u0627\u0644\u062a\u0639\u0644\u064a\u0645\u060c \u0645\u062b\u0644 \u0627\u0644\u0623\u062f\u0648\u0627\u062a \u0627\u0644\u062a\u0641\u0627\u0639\u0644\u064a\u0629\u060c \u0648\u0627\u0644\u0645\u0646\u0635\u0627\u062a \u0627\u0644\u062a\u0639\u0644\u064a\u0645\u064a\u0629 \u0627\u0644\u0630\u0643\u064a\u0629\u060c \u0648\u0627\u0644\u0631\u0648\u0628\u0648\u062a\u0627\u062a \u0627\u0644\u062a\u0639\u0644\u064a\u0645\u064a\u0629. \u0647\u0630\u0627 \u064a\u062c\u0630\u0628 \u0627\u0644\u0645\u0639\u0644\u0645\u064a\u0646 \u0648\u0627\u0644\u0637\u0644\u0627\u0628 \u0648\u0627\u0644\u0622\u0628\u0627\u0621.\n\n3. **\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0641\u064a \u0627\u0644\u0637\u0628**: \u064a\u0645\u0643\u0646 \u0623\u0646 \u062a\u0642\u062f\u0645 \u0645\u062d\u062a\u0648\u0649 \u062d\u0648\u0644 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0641\u064a \u0627\u0644\u062a\u0634\u062e\u064a\u0635\u060c \u0648\u0627\u0644\u0639\u0644\u0627\u062c\u060c \u0648\u0627\u0644\u0628\u062d\u062b \u0627\u0644\u0637\u0628\u064a. \u0647\u0630\u0627 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u064a\u062c\u0630\u0628 \u0627\u0644\u0645\u0647\u062a\u0645\u064a\u0646 \u0628\u0627\u0644\u0635\u062d\u0629 \u0648\u0627\u0644\u0637\u0628 \u0627\u0644\u062d\u062f\u064a\u062b.\n\n4. **\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0641\u064a \u0627\u0644\u0641\u0646\u0648\u0646**: \u064a\u0645\u0643\u0646 \u0623\u0646 \u062a\u0642\u062f\u0645 \u0645\u062d\u062a\u0648\u0649 \u062d\u0648\u0644 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0641\u064a \u0627\u0644\u0643\u062a\u0627\u0628\u0629\u060c \u0627\u0644\u0631\u0633\u0645\u060c \u0627\u0644\u0645\u0648\u0633\u064a\u0642\u0649\u060c \u0648\u0627\u0644\u0633\u064a\u0646\u0645\u0627. \u0647\u0630\u0627 \u064a\u062c\u0630\u0628 \u0645\u062d\u0628\u064a \u0627\u0644\u0641\u0646\u0648\u0646 \u0648\u0627\u0644\u0627\u0628\u062a\u0643\u0627\u0631.\n\n5. **\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0641\u064a \u0627\u0644\u0623\u0639\u0645\u0627\u0644**: \u064a\u0645\u0643\u0646 \u0623\u0646 \u062a\u0642\u062f\u0645 \u0645\u062d\u062a\u0648\u0649 \u062d\u0648\u0644 \u0643\u064a\u0641\u064a\u0629 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0641\u064a \u062a\u062d\u0633\u064a\u0646 \u0627\u0644\u0643\u0641\u0627\u0621\u0629\u060c \u0648\u0627\u0644\u062a\u0633\u0648\u064a\u0642\u060c \u0648\u0627\u0644\u062a\u062d\u0644\u064a\u0644\u0627\u062a. \u0647\u0630\u0627 \u064a\u062c\u0630\u0628 \u0623\u0635\u062d\u0627\u0628 \u0627\u0644\u0623\u0639\u0645\u0627\u0644 \u0648\u0627\u0644\u0645\u0647\u0646\u064a\u064a\u0646.\n\n6. **\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0641\u064a \u0627\u0644\u0623\u0645\u0646 \u0648\u0627\u0644\u0633\u0644\u0627\u0645\u0629**: \u064a\u0645\u0643\u0646 \u0623\u0646 \u062a\u0642\u062f\u0645 \u0645\u062d\u062a\u0648\u0649 \u062d\u0648\u0644 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0641\u064a \u0627\u0644\u0623\u0645\u0646\u060c \u0645\u062b\u0644 \u0627\u0644\u0643\u0627\u0645\u064a\u0631\u0627\u062a \u0627\u0644\u0630\u0643\u064a\u0629\u060c \u0648\u0627\u0644\u0623\u0646\u0638\u0645\u0629 \u0627\u0644\u0630\u0643\u064a\u0629 \u0644\u0644\u0633\u0644\u0627\u0645\u0629. \u0647\u0630\u0627 \u064a\u062c\u0630\u0628 \u0627\u0644\u062c\u0645\u0647\u0648\u0631 \u0627\u0644\u0645\u0647\u062a\u0645 \u0628\u0627\u0644\u0633\u0644\u0627\u0645\u0629 \u0648\u0627\u0644\u0623\u0645\u0646.\n\n7. **\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0641\u064a \u0627\u0644\u0627\u0628\u062a\u0643\u0627\u0631 \u0648\u0627\u0644\u062a\u0637\u0648\u064a\u0631**: \u064a\u0645\u0643\u0646 \u0623\u0646 \u062a\u0642\u062f\u0645 \u0645\u062d\u062a\u0648\u0649 \u062d\u0648\u0644 \u0623\u062d\u062f\u062b \u0627\u0644\u062a\u0637\u0648\u0631\u0627\u062a \u0641\u064a \u0645\u062c\u0627\u0644 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a\u060c \u0648\u0627\u0644\u062a\u062d\u062f\u064a\u0627\u062a \u0648\u0627\u0644\u0641\u0631\u0635 \u0627\u0644\u0645\u0633\u062a\u0642\u0628\u0644\u064a\u0629."
}
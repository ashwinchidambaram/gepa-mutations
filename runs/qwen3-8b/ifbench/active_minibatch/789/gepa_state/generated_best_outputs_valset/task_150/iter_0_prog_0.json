{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u5b9a\u7684\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u3002\u5c3d\u7ba1\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u7406\u8bba\u4e0a\u5e94\u5f53\u7763\u4fc3\u76f8\u5173\u884c\u653f\u673a\u5173\u4f9d\u6cd5\u5c65\u884c\u804c\u8d23\uff0c\u4f46\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u7531\u4e8e\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u90e8\u5206\u884c\u653f\u673a\u5173\u5bf9\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u6001\u5ea6\u6d88\u6781\uff0c\u5bfc\u81f4\u590d\u8bae\u51b3\u5b9a\u96be\u4ee5\u843d\u5b9e\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u56e0\u672a\u4f9d\u6cd5\u5c65\u884c\u884c\u653f\u5904\u7f5a\u51b3\u5b9a\u88ab\u63d0\u8d77\u590d\u8bae\u540e\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u8be5\u90e8\u95e8\u5728\u6536\u5230\u51b3\u5b9a\u540e\u4ecd\u8fdf\u8fdf\u672a\u6267\u884c\uff0c\u6700\u7ec8\u5bfc\u81f4\u7533\u8bf7\u4eba\u6743\u76ca\u53d7\u635f\u3002\u8fd9\u79cd\u73b0\u8c61\u53cd\u6620\u51fa\u6267\u884c\u673a\u5236\u7684\u4e0d\u5b8c\u5584\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u5b58\u5728\u4e00\u5b9a\u7684\u5c40\u9650\u6027\u3002\u6839\u636e\u73b0\u884c\u6cd5\u5f8b\u89c4\u5b9a\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u4e3b\u8981\u9002\u7528\u4e8e\u4e0d\u5c65\u884c\u6cd5\u5b9a\u804c\u8d23\u7684\u60c5\u5f62\uff0c\u800c\u5bf9\u4e8e\u67d0\u4e9b\u6d89\u53ca\u5177\u4f53\u884c\u653f\u884c\u4e3a\u7684\u6848\u4ef6\uff0c\u590d\u8bae\u673a\u5173\u53ef\u80fd\u96be\u4ee5\u76f4\u63a5\u8d23\u4ee4\u5c65\u884c\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u571f\u5730\u5f81\u6536\u8fc7\u7a0b\u4e2d\uff0c\u7533\u8bf7\u4eba\u8ba4\u4e3a\u884c\u653f\u673a\u5173\u672a\u4f9d\u6cd5\u5c65\u884c\u4fe1\u606f\u516c\u5f00\u4e49\u52a1\uff0c\u7533\u8bf7\u590d\u8bae\u540e\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u8be5\u51b3\u5b9a\u5e76\u672a\u6db5\u76d6\u5168\u90e8\u4fe1\u606f\u516c\u5f00\u5185\u5bb9\uff0c\u5bfc\u81f4\u7533\u8bf7\u4eba\u4ecd\u9700\u901a\u8fc7\u5176\u4ed6\u9014\u5f84\u5bfb\u6c42\u6551\u6d4e\u3002\u8fd9\u8868\u660e\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u4ecd\u9700\u8fdb\u4e00\u6b65\u660e\u786e\u3002\n\n\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u4e2d\u7684\u76d1\u7763\u4f5c\u7528\u4e5f\u5b58\u5728\u4e00\u5b9a\u7684\u5f31\u5316\u3002\u7531\u4e8e\u884c\u653f\u590d\u8bae\u673a\u5173\u4e0e\u88ab\u7533\u8bf7\u673a\u5173\u4e4b\u95f4\u5b58\u5728\u4e00\u5b9a\u7684\u884c\u653f\u96b6\u5c5e\u5173\u7cfb\uff0c\u5bfc\u81f4\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u53ef\u80fd\u5b58\u5728\u5229\u76ca\u51b2\u7a81\uff0c\u5f71\u54cd\u590d\u8bae\u51b3\u5b9a\u7684\u516c\u6b63\u6027\u548c\u6743\u5a01\u6027\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u5e02\u573a\u76d1\u7ba1\u90e8\u95e8\u56e0\u672a\u4f9d\u6cd5\u5904\u7406\u4e3e\u62a5\u6848\u4ef6\u88ab\u590d\u8bae\u673a\u5173\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u8be5\u90e8\u95e8\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u4ecd\u5b58\u5728\u62d6\u5ef6\u884c\u4e3a\uff0c\u590d\u8bae\u673a\u5173\u5728\u540e\u7eed\u76d1\u7763\u4e2d\u672a\u80fd\u6709\u6548\u4ecb\u5165\uff0c\u6700\u7ec8\u5bfc\u81f4\u7533\u8bf7\u4eba\u6743\u76ca\u672a\u80fd\u5f97\u5230\u5145\u5206\u4fdd\u969c\u3002\u8fd9\u79cd\u76d1\u7763\u673a\u5236\u7684\u4e0d\u8db3\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u6574\u4f53\u6548\u80fd\u3002\n\n\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u7edf\u4e00\u7684\u6cd5\u5f8b\u4f9d\u636e\uff0c\u5bfc\u81f4\u4e0d\u540c\u5730\u533a\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u5b58\u5728\u5dee\u5f02\u3002\u90e8\u5206\u5730\u533a\u5bf9\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u529b\u5ea6\u8f83\u5927\uff0c\u800c\u53e6\u4e00\u4e9b\u5730\u533a\u5219\u8f83\u4e3a\u5bbd\u677e\uff0c\u8fd9\u4f7f\u5f97\u6cd5\u5f8b\u9002\u7528\u4e0d\u4e00\u81f4\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u516c\u6b63\u6027\u548c\u6743\u5a01\u6027\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u7a0e\u52a1\u90e8\u95e8\u56e0\u672a\u4f9d\u6cd5\u5904\u7406\u7eb3\u7a0e\u4eba\u6295\u8bc9\u88ab\u590d\u8bae\u673a\u5173\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u8be5\u90e8\u95e8\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u672a\u80fd\u53ca\u65f6\u6574\u6539\uff0c\u800c\u590d\u8bae\u673a\u5173\u7531\u4e8e\u7f3a\u4e4f\u660e\u786e\u7684\u6267\u884c\u6807\u51c6\uff0c\u672a\u80fd\u6709\u6548\u63a8\u52a8\u5176\u5c65\u884c\u4e49\u52a1\u3002\u8fd9\u79cd\u6cd5\u5f8b\u9002\u7528\u7684\u4e0d\u7edf\u4e00\uff0c\u4e5f\u53cd\u6620\u51fa\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\u7684\u5b8c\u5584\u7a7a\u95f4\u3002\n\ndocument \u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u95ee\u9898\uff0c\u4e0d\u4ec5\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u6743\u5a01\u6027\uff0c\u4e5f\u5bf9\u516c\u6c11\u5408\u6cd5\u6743\u76ca\u7684\u4fdd\u969c\u6784\u6210\u4e86\u6311\u6218\u3002\u56e0\u6b64\uff0c\u6709\u5fc5\u8981\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173"
}
{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u662f\u4e00\u95e8\u878d\u5408\u4e86\u7a7a\u6c14\u52a8\u529b\u5b66\u3001\u751f\u7269\u5b66\u4ee5\u53ca\u5de5\u7a0b\u5b66\u7684\u4ea4\u53c9\u5b66\u79d1\uff0c\u5176\u6838\u5fc3\u76ee\u6807\u662f\u901a\u8fc7\u6a21\u4eff\u81ea\u7136\u754c\u4e2d\u751f\u7269\u7684\u98de\u884c\u673a\u5236\uff0c\u4f18\u5316\u98de\u884c\u5668\u7684\u6c14\u52a8\u6027\u80fd\u3002\u7ffc\u578b\u8bbe\u8ba1\u662f\u98de\u884c\u5668\u8bbe\u8ba1\u4e2d\u7684\u5173\u952e\u73af\u8282\uff0c\u76f4\u63a5\u5f71\u54cd\u98de\u884c\u5668\u7684\u5347\u529b\u3001\u963b\u529b\u548c\u7a33\u5b9a\u6027\u3002\u800c\u4eff\u751f\u5b66\u5219\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u4e30\u5bcc\u7684\u7075\u611f\u6765\u6e90\uff0c\u4f7f\u5f97\u73b0\u4ee3\u822a\u7a7a\u6280\u672f\u80fd\u591f\u4ece\u81ea\u7136\u754c\u7684\u98de\u884c\u751f\u7269\u4e2d\u6c72\u53d6\u667a\u6167\uff0c\u5b9e\u73b0\u66f4\u9ad8\u6548\u7684\u98de\u884c\u6027\u80fd\u3002\n\n\u81ea\u7136\u754c\u4e2d\uff0c\u9e1f\u7c7b\u3001\u6606\u866b\u548c\u8759\u8760\u7b49\u751f\u7269\u7684\u98de\u884c\u65b9\u5f0f\u5404\u5177\u7279\u8272\uff0c\u5176\u7fc5\u8180\u7ed3\u6784\u548c\u8fd0\u52a8\u65b9\u5f0f\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u5b9d\u8d35\u7684\u53c2\u8003\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7684\u7fc5\u8180\u5177\u6709\u590d\u6742\u7684\u66f2\u9762\u7ed3\u6784\uff0c\u80fd\u591f\u6839\u636e\u98de\u884c\u72b6\u6001\u8c03\u6574\u7ffc\u578b\u5f62\u72b6\uff0c\u4ece\u800c\u5b9e\u73b0\u9ad8\u6548\u7684\u5347\u529b\u4ea7\u751f\u548c\u80fd\u91cf\u5229\u7528\u3002\u6606\u866b\u7684\u7fc5\u8180\u5219\u5177\u6709\u9ad8\u9891\u7387\u7684\u632f\u52a8\u7279\u6027\uff0c\u80fd\u591f\u5728\u4f4e\u901f\u98de\u884c\u4e2d\u4fdd\u6301\u7a33\u5b9a\u6027\u3002\u8759\u8760\u7684\u7ffc\u819c\u7ed3\u6784\u5219\u5c55\u73b0\u4e86\u67d4\u6027\u4e0e\u521a\u6027\u7684\u7ed3\u5408\uff0c\u4f7f\u5f97\u5176\u80fd\u591f\u5728\u590d\u6742\u73af\u5883\u4e2d\u7075\u6d3b\u98de\u884c\u3002\u8fd9\u4e9b\u81ea\u7136\u754c\u7684\u98de\u884c\u673a\u5236\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u91cd\u8981\u7684\u7406\u8bba\u4f9d\u636e\u548c\u5b9e\u8df5\u6307\u5bfc\u3002\n\n\u5728\u4eff\u751f\u5b66\u7684\u542f\u53d1\u4e0b\uff0c\u73b0\u4ee3\u7ffc\u578b\u8bbe\u8ba1\u9010\u6e10\u4ece\u4f20\u7edf\u7684\u56fa\u5b9a\u7ffc\u578b\u5411\u53ef\u53d8\u7ffc\u578b\u3001\u67d4\u6027\u7ffc\u578b\u7b49\u65b9\u5411\u53d1\u5c55\u3002\u4f8b\u5982\uff0c\u53ef\u53d8\u7ffc\u578b\u6280\u672f\u5141\u8bb8\u98de\u884c\u5668\u5728\u4e0d\u540c\u98de\u884c\u9636\u6bb5\u8c03\u6574\u7ffc\u578b\u5f62\u72b6\uff0c\u4ee5\u9002\u5e94\u4e0d\u540c\u7684\u6c14\u6d41\u6761\u4ef6\uff0c\u4ece\u800c\u63d0\u9ad8\u98de\u884c\u6548\u7387\u3002\u67d4\u6027\u7ffc\u578b\u5219\u501f\u9274\u4e86\u751f\u7269\u7fc5\u8180\u7684\u67d4\u6027\u7ed3\u6784\uff0c\u4f7f\u5f97\u98de\u884c\u5668\u80fd\u591f\u5728\u590d\u6742\u6c14\u6d41\u4e2d\u4fdd\u6301\u7a33\u5b9a\uff0c\u51cf\u5c11\u632f\u52a8\u548c\u963b\u529b\u3002\u6b64\u5916\uff0c\u4eff\u751f\u5b66\u8fd8\u63a8\u52a8\u4e86\u7ffc\u578b\u8868\u9762\u7eb9\u7406\u8bbe\u8ba1\u7684\u53d1\u5c55\uff0c\u4f8b\u5982\u901a\u8fc7\u6a21\u4eff\u9ca8\u9c7c\u76ae\u80a4\u7684\u5fae\u7ed3\u6784\u6765\u51cf\u5c11\u6e4d\u6d41\uff0c\u63d0\u9ad8\u6c14\u52a8\u6548\u7387\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e0d\u4ec5\u63d0\u9ad8\u4e86\u98de\u884c\u5668\u7684\u6027\u80fd\uff0c\u8fd8\u4fc3\u8fdb\u4e86\u65b0\u6750\u6599\u3001\u65b0\u5de5\u827a\u548c\u65b0\u63a7\u5236\u7cfb\u7edf\u7684\u7814\u53d1\u3002\u4f8b\u5982\uff0c\u667a\u80fd\u6750\u6599\u548c\u5f62\u72b6\u8bb0\u5fc6\u5408\u91d1\u7684\u5e94\u7528\uff0c\u4f7f\u5f97\u7ffc\u578b\u80fd\u591f\u6839\u636e\u73af\u5883\u53d8\u5316\u81ea\u52a8\u8c03\u6574\u5f62\u72b6\uff0c\u5b9e\u73b0\u66f4\u9ad8\u6548\u7684\u98de\u884c\u63a7\u5236\u3002\u540c\u65f6\uff0c\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\uff08CFD\uff09\u548c\u4eba\u5de5\u667a\u80fd\u6280\u672f\u7684\u53d1\u5c55\uff0c\u4e5f\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u66f4\u7cbe\u786e\u7684\u6a21\u62df\u548c\u4f18\u5316\u624b\u6bb5\uff0c\u4f7f\u5f97\u4eff\u751f\u5b66\u7406\u5ff5\u80fd\u591f\u66f4\u5e7f\u6cdb\u5730\u5e94\u7528\u4e8e\u5b9e\u9645\u5de5\u7a0b\u4e2d\u3002\n\n\u7136\u800c\uff0c\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u53d1\u5c55\u4ecd\u9762\u4e34\u8bf8\u591a\u6311\u6218\u3002\u4f8b\u5982\uff0c\u5982\u4f55\u5728\u590d\u6742\u6c14\u6d41\u6761\u4ef6\u4e0b\u5b9e\u73b0\u9ad8\u6548\u7684\u4eff\u751f\u63a7\u5236\uff0c\u5982\u4f55\u5e73\u8861\u4eff\u751f\u7ed3\u6784\u7684\u751f\u7269\u542f\u53d1\u6027\u548c\u5de5\u7a0b\u53ef\u884c\u6027\uff0c\u4ee5\u53ca\u5982\u4f55\u5728\u5b9e\u9645\u5e94\u7528\u4e2d\u5b9e\u73b0\u6210\u672c\u4e0e\u6027\u80fd\u7684\u6700\u4f18\u5e73\u8861\uff0c\u90fd\u662f\u5f53\u524d\u7814\u7a76\u7684\u70ed\u70b9\u95ee\u9898\u3002\u6b64\u5916\uff0c\u968f\u7740\u5bf9\u98de\u884c\u5668\u6027\u80fd\u8981\u6c42\u7684"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u8fd9\u4e9b\u95ee\u9898\u4e3b\u8981\u4f53\u73b0\u5728\u6cd5\u5f8b\u9002\u7528\u7684\u4e0d\u7edf\u4e00\u548c\u7a0b\u5e8f\u6267\u884c\u7684\u4e0d\u89c4\u8303\u4e0a\u3002\u7531\u4e8e\u884c\u653f\u590d\u8bae\u7684\u6cd5\u5f8b\u4f9d\u636e\u8f83\u4e3a\u5e7f\u6cdb\uff0c\u4e0d\u540c\u5730\u533a\u7684\u884c\u653f\u673a\u5173\u5728\u7406\u89e3\u548c\u9002\u7528\u76f8\u5173\u6cd5\u5f8b\u65f6\u53ef\u80fd\u5b58\u5728\u5dee\u5f02\uff0c\u5bfc\u81f4\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6548\u529b\u548c\u6267\u884c\u529b\u5ea6\u4e0d\u4e00\u81f4\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u4e9b\u5730\u65b9\uff0c\u590d\u8bae\u673a\u5173\u53ef\u80fd\u5bf9\u201c\u8d23\u4ee4\u5c65\u884c\u201d\u7684\u5177\u4f53\u542b\u4e49\u548c\u9002\u7528\u8303\u56f4\u5b58\u5728\u6a21\u7cca\u8ba4\u8bc6\uff0c\u5bfc\u81f4\u51b3\u5b9a\u5185\u5bb9\u4e0d\u591f\u660e\u786e\uff0c\u5f71\u54cd\u4e86\u540e\u7eed\u7684\u6267\u884c\u6548\u679c\u3002\n\n\u6b64\u5916\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u4f7f\u5f97\u51b3\u5b9a\u7684\u843d\u5b9e\u96be\u4ee5\u4fdd\u969c\u3002\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u88ab\u8d23\u4ee4\u5c65\u884c\u7684\u884c\u653f\u673a\u5173\u53ef\u80fd\u56e0\u5404\u79cd\u539f\u56e0\u62d6\u5ef6\u6216\u62d2\u7edd\u6267\u884c\u590d\u8bae\u51b3\u5b9a\uff0c\u800c\u590d\u8bae\u673a\u5173\u5f80\u5f80\u7f3a\u4e4f\u8db3\u591f\u7684\u624b\u6bb5\u8fdb\u884c\u76d1\u7763\u548c\u8ffd\u8d23\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u56e0\u672a\u4f9d\u6cd5\u5c65\u884c\u76d1\u7ba1\u804c\u8d23\u88ab\u590d\u8bae\u673a\u5173\u8d23\u4ee4\u6539\u6b63\uff0c\u4f46\u8be5\u90e8\u95e8\u5728\u6536\u5230\u51b3\u5b9a\u540e\u4ecd\u672a\u91c7\u53d6\u6709\u6548\u63aa\u65bd\uff0c\u6700\u7ec8\u5bfc\u81f4\u76f8\u5173\u8fdd\u6cd5\u884c\u4e3a\u6301\u7eed\u53d1\u751f\uff0c\u635f\u5bb3\u4e86\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u548c\u516c\u4fe1\u529b\u3002\n\n\u5728\u4e00\u4e9b\u5177\u4f53\u6848\u4f8b\u4e2d\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u548c\u7a0b\u5e8f\u4e5f\u5b58\u5728\u4e89\u8bae\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u5e02\u573a\u76d1\u7ba1\u90e8\u95e8\u56e0\u672a\u4f9d\u6cd5\u5904\u7406\u6295\u8bc9\u4e3e\u62a5\uff0c\u88ab\u590d\u8bae\u673a\u5173\u8d23\u4ee4\u5c65\u884c\u804c\u8d23\uff0c\u4f46\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\uff0c\u8be5\u90e8\u95e8\u4ee5\u201c\u5df2\u91c7\u53d6\u5176\u4ed6\u63aa\u65bd\u201d\u4e3a\u7531\u62d2\u7edd\u6267\u884c\uff0c\u5bfc\u81f4\u590d\u8bae\u51b3\u5b9a\u6d41\u4e8e\u5f62\u5f0f\u3002\u6b64\u7c7b\u60c5\u51b5\u53cd\u6620\u51fa\u5728\u884c\u653f\u590d\u8bae\u5b9e\u8df5\u4e2d\uff0c\u5bf9\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u6807\u51c6\u548c\u6267\u884c\u7a0b\u5e8f\u7f3a\u4e4f\u7edf\u4e00\u89c4\u8303\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u516c\u6b63\u6027\u548c\u5b9e\u6548\u6027\u3002\n\n\u9488\u5bf9\u4e0a\u8ff0\u95ee\u9898\uff0c\u6709\u5fc5\u8981\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\uff0c\u660e\u786e\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u6761\u4ef6\u3001\u6267\u884c\u7a0b\u5e8f\u548c\u76d1\u7763\u673a\u5236\u3002\u540c\u65f6\uff0c\u5e94\u52a0\u5f3a\u5bf9\u884c\u653f\u590d\u8bae\u673a\u5173\u548c\u88ab\u590d\u8bae\u884c\u653f\u673a\u5173\u7684\u57f9\u8bad\u548c\u6307\u5bfc\uff0c\u63d0\u9ad8\u5176\u4f9d\u6cd5\u5c65\u804c\u7684\u610f\u8bc6\u548c\u80fd\u529b\u3002\u901a\u8fc7\u8fd9\u4e9b\u63aa\u65bd\uff0c\u53ef\u4ee5\u6709\u6548\u63d0\u5347\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u529b\u548c\u516c\u4fe1\u529b\uff0c\u786e\u4fdd\u884c\u653f\u590d\u8bae\u5236\u5ea6\u5728\u7ef4\u62a4\u793e\u4f1a\u516c\u5e73\u6b63\u4e49\u65b9\u9762\u53d1\u6325\u66f4\u5927\u4f5c\u7528\u3002\n\ndocument"
}
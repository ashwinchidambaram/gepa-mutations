{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u662f\u73b0\u4ee3\u822a\u7a7a\u5de5\u7a0b\u548c\u751f\u7269\u79d1\u5b66\u4ea4\u53c9\u9886\u57df\u4e2d\u7684\u4e24\u4e2a\u91cd\u8981\u7814\u7a76\u65b9\u5411\u3002\u7ffc\u578b\u8bbe\u8ba1\u4e3b\u8981\u5173\u6ce8\u98de\u673a\u673a\u7ffc\u7684\u5f62\u72b6\u548c\u7ed3\u6784\uff0c\u4ee5\u4f18\u5316\u7a7a\u6c14\u52a8\u529b\u5b66\u6027\u80fd\uff0c\u63d0\u9ad8\u98de\u884c\u6548\u7387\u548c\u7a33\u5b9a\u6027\u3002\u4eff\u751f\u5b66\u5219\u662f\u4ece\u81ea\u7136\u754c\u4e2d\u83b7\u53d6\u7075\u611f\uff0c\u6a21\u4eff\u751f\u7269\u4f53\u7684\u7ed3\u6784\u3001\u529f\u80fd\u548c\u884c\u4e3a\uff0c\u4ee5\u89e3\u51b3\u5de5\u7a0b\u548c\u6280\u672f\u95ee\u9898\u3002\u4e24\u8005\u7684\u7ed3\u5408\u4e3a\u822a\u7a7a\u822a\u5929\u3001\u673a\u5668\u4eba\u6280\u672f\u3001\u6d41\u4f53\u529b\u5b66\u7b49\u9886\u57df\u5e26\u6765\u4e86\u8bb8\u591a\u521b\u65b0\u548c\u7a81\u7834\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u7684\u6838\u5fc3\u5728\u4e8e\u7406\u89e3\u6c14\u6d41\u4e0e\u7ffc\u578b\u8868\u9762\u7684\u76f8\u4e92\u4f5c\u7528\u3002\u901a\u8fc7\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\uff08CFD\uff09\u548c\u98ce\u6d1e\u5b9e\u9a8c\uff0c\u5de5\u7a0b\u5e08\u53ef\u4ee5\u6a21\u62df\u4e0d\u540c\u7ffc\u578b\u5728\u5404\u79cd\u98de\u884c\u6761\u4ef6\u4e0b\u7684\u6027\u80fd\u8868\u73b0\u3002\u4f20\u7edf\u7684\u7ffc\u578b\u8bbe\u8ba1\u591a\u57fa\u4e8e\u7ecf\u9a8c\u516c\u5f0f\u548c\u5b9e\u9a8c\u6570\u636e\uff0c\u4f46\u8fd1\u5e74\u6765\uff0c\u968f\u7740\u8ba1\u7b97\u673a\u6280\u672f\u7684\u53d1\u5c55\uff0c\u57fa\u4e8e\u6570\u503c\u6a21\u62df\u7684\u4f18\u5316\u65b9\u6cd5\u9010\u6e10\u6210\u4e3a\u4e3b\u6d41\u3002\u8fd9\u4e9b\u65b9\u6cd5\u80fd\u591f\u5feb\u901f\u8bc4\u4f30\u5927\u91cf\u8bbe\u8ba1\u65b9\u6848\uff0c\u4ece\u800c\u627e\u5230\u6700\u4f18\u89e3\u3002\n\n\u4eff\u751f\u5b66\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u3002\u81ea\u7136\u754c\u4e2d\u7684\u98de\u884c\u52a8\u7269\uff0c\u5982\u9e1f\u7c7b\u3001\u6606\u866b\u548c\u8759\u8760\uff0c\u5176\u7fc5\u8180\u7ed3\u6784\u548c\u8fd0\u52a8\u65b9\u5f0f\u5177\u6709\u9ad8\u5ea6\u7684\u9002\u5e94\u6027\u548c\u6548\u7387\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7684\u7ffc\u578b\u80fd\u591f\u6839\u636e\u98de\u884c\u901f\u5ea6\u548c\u9ad8\u5ea6\u8fdb\u884c\u52a8\u6001\u8c03\u6574\uff0c\u4ee5\u5b9e\u73b0\u6700\u4f73\u7684\u5347\u529b\u548c\u963b\u529b\u5e73\u8861\u3002\u7814\u7a76\u8fd9\u4e9b\u751f\u7269\u7ed3\u6784\u7684\u539f\u7406\uff0c\u53ef\u4ee5\u5e2e\u52a9\u5de5\u7a0b\u5e08\u8bbe\u8ba1\u51fa\u66f4\u52a0\u9ad8\u6548\u7684\u7ffc\u578b\u3002\u4f8b\u5982\uff0c\u57fa\u4e8e\u8759\u8760\u7ffc\u819c\u7684\u67d4\u6027\u7ed3\u6784\uff0c\u7814\u7a76\u4eba\u5458\u5f00\u53d1\u51fa\u4e86\u5177\u6709\u81ea\u9002\u5e94\u80fd\u529b\u7684\u7ffc\u578b\uff0c\u80fd\u591f\u6839\u636e\u6c14\u6d41\u53d8\u5316\u81ea\u52a8\u8c03\u6574\u5f62\u72b6\uff0c\u4ece\u800c\u63d0\u9ad8\u98de\u884c\u6548\u7387\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e0d\u4ec5\u9650\u4e8e\u822a\u7a7a\u822a\u5929\u9886\u57df\u3002\u5728\u98ce\u80fd\u53d1\u7535\u3001\u65e0\u4eba\u673a\u548c\u5fae\u578b\u98de\u884c\u5668\u7b49\u65b0\u5174\u6280\u672f\u4e2d\uff0c\u8fd9\u79cd\u8de8\u5b66\u79d1\u7684\u65b9\u6cd5\u540c\u6837\u53d1\u6325\u7740\u91cd\u8981\u4f5c\u7528\u3002\u4f8b\u5982\uff0c\u4eff\u751f\u5b66\u542f\u53d1\u7684\u7ffc\u578b\u8bbe\u8ba1\u53ef\u4ee5\u7528\u4e8e\u63d0\u9ad8\u98ce\u529b\u6da1\u8f6e\u673a\u7684\u6548\u7387\uff0c\u51cf\u5c11\u80fd\u91cf\u635f\u5931\uff1b\u5728\u65e0\u4eba\u673a\u8bbe\u8ba1\u4e2d\uff0c\u4eff\u751f\u7ffc\u578b\u80fd\u591f\u63d0\u9ad8\u98de\u884c\u7a33\u5b9a\u6027\uff0c\u5ef6\u957f\u98de\u884c\u65f6\u95f4\u3002\n\n\u7136\u800c\uff0c\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e5f\u9762\u4e34\u4e00\u4e9b\u6311\u6218\u3002\u4e00\u65b9\u9762\uff0c\u751f\u7269\u7ed3\u6784\u7684\u590d\u6742\u6027\u548c\u591a\u6837\u6027\u4f7f\u5f97\u4eff\u751f\u8bbe\u8ba1\u7684\u5b9e\u73b0\u96be\u5ea6\u8f83\u5927\u3002\u53e6\u4e00\u65b9\u9762\uff0c\u4ece\u751f\u7269\u7ed3\u6784\u4e2d\u63d0\u53d6\u53ef\u5e94\u7528\u4e8e\u5de5\u7a0b\u7684\u539f\u7406\u9700\u8981\u6df1\u5165\u7684\u751f\u7269\u5b66\u548c\u5de5\u7a0b\u5b66\u77e5\u8bc6\u3002\u6b64\u5916\uff0c\u4eff\u751f\u8bbe\u8ba1\u7684\u53ef\u884c\u6027\u8fd8\u9700\u8981\u901a\u8fc7\u5b9e\u9a8c\u9a8c\u8bc1\uff0c\u4ee5\u786e\u4fdd\u5176\u5728\u5b9e\u9645\u5e94\u7528\u4e2d\u7684\u6709\u6548\u6027\u3002\n\n\u603b\u4e4b\uff0c\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e3a\u73b0\u4ee3\u5de5\u7a0b\u63d0\u4f9b\u4e86\u65b0\u7684\u89c6\u89d2\u548c\u65b9\u6cd5\u3002\u901a\u8fc7\u501f\u9274\u81ea\u7136\u754c\u7684\u667a\u6167\uff0c\u5de5\u7a0b\u5e08\u80fd\u591f\u8bbe\u8ba1\u51fa\u66f4\u52a0\u9ad8\u6548\u3001\u7075\u6d3b\u548c\u9002\u5e94\u6027\u5f3a\u7684\u7ffc\u578b\uff0c\u63a8\u52a8\u822a\u7a7a\u822a\u5929\u548c\u5176\u4ed6\u76f8\u5173\u6280\u672f\u7684\u53d1\u5c55\u3002\u968f\u7740\u8ba1\u7b97\u80fd\u529b\u548c\u751f\u7269\u7814\u7a76\u7684\u4e0d\u65ad\u8fdb\u6b65\uff0c\u8fd9\u4e00\u9886\u57df\u7684"
}
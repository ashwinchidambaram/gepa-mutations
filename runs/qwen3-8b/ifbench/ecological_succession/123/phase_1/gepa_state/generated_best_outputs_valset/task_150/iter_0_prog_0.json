{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u548c\u76d1\u7763\u673a\u5236\u4e0d\u5b8c\u5584\u3002\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u7f3a\u4e4f\u6709\u6548\u7684\u540e\u7eed\u76d1\u7763\u624b\u6bb5\uff0c\u5bfc\u81f4\u90e8\u5206\u88ab\u7533\u8bf7\u4eba\u672a\u80fd\u53ca\u65f6\u5c65\u884c\u4e49\u52a1\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u9488\u5bf9\u4f01\u4e1a\u8fdd\u89c4\u6392\u653e\u6c61\u67d3\u7269\u63d0\u8d77\u7684\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u4f01\u4e1a\u5e76\u672a\u6309\u7167\u8981\u6c42\u8fdb\u884c\u6574\u6539\uff0c\u800c\u590d\u8bae\u673a\u5173\u7f3a\u4e4f\u76f8\u5e94\u7684\u8ddf\u8e2a\u548c\u5f3a\u5236\u63aa\u65bd\uff0c\u6700\u7ec8\u5bfc\u81f4\u73af\u5883\u95ee\u9898\u672a\u80fd\u5f97\u5230\u53ca\u65f6\u89e3\u51b3\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u6cd5\u5f8b\u4fdd\u969c\uff0c\u5bfc\u81f4\u5176\u6743\u5a01\u6027\u53d7\u5230\u8d28\u7591\u3002\u7531\u4e8e\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\u5bf9\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u7a0b\u5e8f\u89c4\u5b9a\u4e0d\u591f\u660e\u786e\uff0c\u590d\u8bae\u673a\u5173\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u5f80\u5f80\u9762\u4e34\u6cd5\u5f8b\u4f9d\u636e\u4e0d\u8db3\u7684\u95ee\u9898\u3002\u4f8b\u5982\uff0c\u5728\u4e00\u8d77\u6d89\u53ca\u571f\u5730\u5f81\u6536\u7684\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u88ab\u7533\u8bf7\u4eba\u62d2\u7edd\u6267\u884c\uff0c\u4f46\u7531\u4e8e\u7f3a\u4e4f\u5177\u4f53\u7684\u6267\u884c\u7a0b\u5e8f\uff0c\u590d\u8bae\u673a\u5173\u65e0\u6cd5\u6709\u6548\u63a8\u52a8\u6267\u884c\uff0c\u6700\u7ec8\u5bfc\u81f4\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u6d41\u4e8e\u5f62\u5f0f\u3002\n\n\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u6709\u65f6\u672a\u80fd\u5145\u5206\u8003\u8651\u88ab\u7533\u8bf7\u4eba\u7684\u5b9e\u9645\u60c5\u51b5\uff0c\u5bfc\u81f4\u51b3\u5b9a\u7684\u53ef\u6267\u884c\u6027\u8f83\u4f4e\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u793e\u4f1a\u4fdd\u969c\u90e8\u95e8\u9488\u5bf9\u7528\u4eba\u5355\u4f4d\u672a\u4f9d\u6cd5\u7f34\u7eb3\u793e\u4f1a\u4fdd\u9669\u8d39\u7684\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u7528\u4eba\u5355\u4f4d\u4ee5\u7ecf\u6d4e\u56f0\u96be\u4e3a\u7531\u62d2\u7edd\u5c65\u884c\uff0c\u4f46\u7531\u4e8e\u7f3a\u4e4f\u5bf9\u7528\u4eba\u5355\u4f4d\u7ecf\u6d4e\u72b6\u51b5\u7684\u8be6\u7ec6\u8c03\u67e5\uff0c\u590d\u8bae\u673a\u5173\u672a\u80fd\u91c7\u53d6\u9002\u5f53\u7684\u6267\u884c\u63aa\u65bd\uff0c\u6700\u7ec8\u5bfc\u81f4\u51b3\u5b9a\u96be\u4ee5\u843d\u5b9e\u3002\n\n\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u8fd8\u53d7\u5230\u5730\u65b9\u4fdd\u62a4\u4e3b\u4e49\u7684\u5f71\u54cd\uff0c\u90e8\u5206\u5730\u65b9\u653f\u5e9c\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u5b58\u5728\u63a8\u8bff\u626f\u76ae\u7684\u73b0\u8c61\u3002\u4f8b\u5982\uff0c\u5728\u4e00\u8d77\u6d89\u53ca\u5730\u65b9\u653f\u5e9c\u8fdd\u89c4\u6279\u51c6\u5efa\u8bbe\u9879\u76ee\u5f15\u53d1\u7684\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u5730\u65b9\u653f\u5e9c\u4ee5\u5404\u79cd\u7406\u7531\u62d6\u5ef6\u6267\u884c\uff0c\u751a\u81f3\u901a\u8fc7\u884c\u653f\u624b\u6bb5\u5e72\u9884\u6267\u884c\u8fc7\u7a0b\uff0c\u5bfc\u81f4\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u96be\u4ee5\u771f\u6b63\u843d\u5b9e\uff0c\u635f\u5bb3\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u516c\u4fe1\u529b\u3002\n\ndocument \u5728\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u8fc7\u7a0b\u4e2d\uff0c\u5e94\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\uff0c\u660e\u786e\u6267\u884c\u7a0b\u5e8f\u548c\u8d23\u4efb\u8ffd\u7a76\u673a\u5236\uff0c\u589e\u5f3a\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u529b\u548c\u6743\u5a01\u6027\u3002\u540c\u65f6\uff0c\u5e94\u52a0\u5f3a\u884c\u653f\u590d\u8bae\u673a\u5173\u4e0e\u53f8\u6cd5\u673a\u5173\u3001\u76d1\u5bdf\u673a\u5173\u4e4b\u95f4\u7684\u534f\u4f5c\uff0c\u5f62\u6210\u6709\u6548\u7684\u76d1\u7763\u548c\u6267\u884c\u4f53\u7cfb\uff0c\u786e\u4fdd\u884c\u653f\u590d\u8bae\u51b3\u5b9a\u80fd\u591f\u771f\u6b63\u53d1\u6325\u5176\u5e94\u6709\u7684\u4f5c\u7528\u3002\u6b64\u5916\uff0c\u8fd8\u5e94\u52a0\u5f3a\u5bf9\u884c\u653f\u590d\u8bae\u4eba\u5458\u7684\u4e13\u4e1a\u57f9\u8bad\uff0c\u63d0\u9ad8\u5176\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u7684\u6cd5\u5f8b\u9002\u7528\u80fd\u529b\u548c\u5b9e\u9645\u64cd\u4f5c\u6c34\u5e73\uff0c\u4ee5\u63d0\u5347\u884c\u653f\u590d\u8bae\u7684\u6574\u4f53\u8d28\u91cf\u548c\u6548\u679c\u3002"
}
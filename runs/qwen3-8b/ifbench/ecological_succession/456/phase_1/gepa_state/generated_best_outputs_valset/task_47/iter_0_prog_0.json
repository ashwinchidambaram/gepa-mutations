{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u662f\u822a\u7a7a\u5de5\u7a0b\u4e0e\u751f\u7269\u79d1\u5b66\u4ea4\u53c9\u9886\u57df\u7684\u4e24\u4e2a\u91cd\u8981\u7814\u7a76\u65b9\u5411\u3002\u7ffc\u578b\u8bbe\u8ba1\u4e3b\u8981\u5173\u6ce8\u98de\u673a\u673a\u7ffc\u7684\u5f62\u72b6\u4e0e\u7ed3\u6784\uff0c\u4ee5\u4f18\u5316\u5347\u529b\u3001\u51cf\u5c11\u963b\u529b\u5e76\u63d0\u9ad8\u98de\u884c\u6548\u7387\u3002\u800c\u4eff\u751f\u5b66\u5219\u662f\u4ece\u81ea\u7136\u754c\u4e2d\u83b7\u53d6\u7075\u611f\uff0c\u6a21\u4eff\u751f\u7269\u7684\u7ed3\u6784\u548c\u529f\u80fd\uff0c\u4ee5\u6539\u8fdb\u4eba\u5de5\u7cfb\u7edf\u7684\u8bbe\u8ba1\u3002\u8fd9\u4e24\u8005\u7ed3\u5408\uff0c\u4e3a\u73b0\u4ee3\u822a\u7a7a\u822a\u5929\u6280\u672f\u7684\u53d1\u5c55\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u548c\u65b9\u6cd5\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u7684\u6838\u5fc3\u5728\u4e8e\u7a7a\u6c14\u52a8\u529b\u5b66\u539f\u7406\u7684\u5e94\u7528\u3002\u673a\u7ffc\u7684\u5f62\u72b6\u3001\u539a\u5ea6\u3001\u5f2f\u5ea6\u548c\u540e\u7f18\u7b49\u53c2\u6570\u90fd\u4f1a\u5f71\u54cd\u5176\u7a7a\u6c14\u52a8\u529b\u5b66\u6027\u80fd\u3002\u7ecf\u5178\u7684\u7ffc\u578b\u8bbe\u8ba1\u5982NACA\u7cfb\u5217\uff0c\u662f\u57fa\u4e8e\u6570\u5b66\u6a21\u578b\u548c\u5b9e\u9a8c\u6570\u636e\u4f18\u5316\u5f97\u51fa\u7684\u3002\u7136\u800c\uff0c\u968f\u7740\u98de\u884c\u5668\u6027\u80fd\u9700\u6c42\u7684\u63d0\u5347\uff0c\u4f20\u7edf\u7684\u8bbe\u8ba1\u65b9\u6cd5\u5df2\u96be\u4ee5\u6ee1\u8db3\u590d\u6742\u5de5\u51b5\u4e0b\u7684\u9700\u6c42\u3002\u56e0\u6b64\uff0c\u7814\u7a76\u8005\u5f00\u59cb\u501f\u9274\u81ea\u7136\u754c\u4e2d\u751f\u7269\u7684\u98de\u884c\u673a\u5236\uff0c\u63a2\u7d22\u66f4\u9ad8\u6548\u7684\u7ffc\u578b\u8bbe\u8ba1\u3002\n\n\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u4e3b\u8981\u4f53\u73b0\u5728\u5bf9\u9e1f\u7c7b\u3001\u6606\u866b\u7b49\u98de\u884c\u751f\u7269\u7684\u89c2\u5bdf\u4e0e\u6a21\u4eff\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7fc5\u8180\u7684\u67d4\u6027\u7ed3\u6784\u548c\u53ef\u53d8\u5f2f\u5ea6\u80fd\u591f\u6709\u6548\u9002\u5e94\u4e0d\u540c\u98de\u884c\u72b6\u6001\uff0c\u8fd9\u79cd\u7279\u6027\u88ab\u5e94\u7528\u4e8e\u53ef\u53d8\u51e0\u4f55\u7ffc\u578b\u7684\u8bbe\u8ba1\u4e2d\u3002\u6b64\u5916\uff0c\u6606\u866b\u7fc5\u8180\u7684\u632f\u52a8\u673a\u5236\u542f\u53d1\u4e86\u5fae\u578b\u98de\u884c\u5668\uff08MAV\uff09\u7684\u7814\u5236\uff0c\u5176\u7ffc\u578b\u8bbe\u8ba1\u66f4\u6ce8\u91cd\u8f7b\u91cf\u5316\u548c\u9ad8\u9891\u7387\u632f\u52a8\uff0c\u4ee5\u63d0\u9ad8\u98de\u884c\u7a33\u5b9a\u6027\u4e0e\u673a\u52a8\u6027\u3002\n\n\u5728\u5b9e\u9645\u5e94\u7528\u4e2d\uff0c\u4eff\u751f\u5b66\u4e0e\u7ffc\u578b\u8bbe\u8ba1\u7684\u7ed3\u5408\u5df2\u7ecf\u53d6\u5f97\u663e\u8457\u6210\u679c\u3002\u4f8b\u5982\uff0c\u57fa\u4e8e\u9e1f\u7c7b\u7fc5\u8180\u7ed3\u6784\u7684\u7ffc\u578b\u4f18\u5316\uff0c\u4f7f\u5f97\u98de\u884c\u5668\u5728\u4f4e\u901f\u98de\u884c\u65f6\u5177\u6709\u66f4\u597d\u7684\u5347\u529b\u7279\u6027\uff1b\u6a21\u4eff\u6606\u866b\u7fc5\u8180\u7684\u5fae\u578b\u98de\u884c\u5668\u5219\u5728\u4fa6\u5bdf\u3001\u641c\u7d22\u548c\u6551\u63f4\u7b49\u9886\u57df\u5c55\u73b0\u51fa\u5de8\u5927\u6f5c\u529b\u3002\u540c\u65f6\uff0c\u4eff\u751f\u5b66\u8fd8\u63a8\u52a8\u4e86\u65b0\u578b\u6750\u6599\u7684\u5e94\u7528\uff0c\u5982\u4eff\u751f\u590d\u5408\u6750\u6599\u548c\u67d4\u6027\u7ffc\u578b\u7ed3\u6784\uff0c\u8fdb\u4e00\u6b65\u63d0\u5347\u4e86\u98de\u884c\u5668\u7684\u6027\u80fd\u3002\n\n\u7136\u800c\uff0c\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u4ecd\u9762\u4e34\u8bf8\u591a\u6311\u6218\u3002\u4f8b\u5982\uff0c\u751f\u7269\u7ed3\u6784\u7684\u590d\u6742\u6027\u4f7f\u5f97\u5176\u5728\u5de5\u7a0b\u5316\u8fc7\u7a0b\u4e2d\u5b58\u5728\u8bf8\u591a\u4e0d\u786e\u5b9a\u6027\uff1b\u6b64\u5916\uff0c\u4eff\u751f\u8bbe\u8ba1\u7684\u4f18\u5316\u5f80\u5f80\u9700\u8981\u5927\u91cf\u8ba1\u7b97\u8d44\u6e90\u548c\u5b9e\u9a8c\u9a8c\u8bc1\uff0c\u589e\u52a0\u4e86\u7814\u53d1\u6210\u672c\u3002\u56e0\u6b64\uff0c\u5982\u4f55\u5728\u4eff\u751f\u5b66\u4e0e\u7ffc\u578b\u8bbe\u8ba1\u4e4b\u95f4\u627e\u5230\u5e73\u8861\u70b9\uff0c\u662f\u5f53\u524d\u7814\u7a76\u7684\u91cd\u8981\u65b9\u5411\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e3a\u822a\u7a7a\u822a\u5929\u9886\u57df\u5e26\u6765\u4e86\u65b0\u7684\u673a\u9047\u4e0e\u6311\u6218\u3002\u901a\u8fc7\u501f\u9274\u81ea\u7136\u754c\u7684\u667a\u6167\uff0c\u4eba\u7c7b\u80fd\u591f\u8bbe\u8ba1\u51fa\u66f4\u52a0\u9ad8\u6548\u3001\u667a\u80fd\u7684\u98de\u884c\u5668\u3002\u672a\u6765\uff0c\u968f\u7740\u8ba1\u7b97\u6280\u672f\u3001\u6750\u6599\u79d1\u5b66\u548c\u751f\u7269\u5de5\u7a0b\u7684\u8fdb\u6b65\uff0c\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u5c06\u66f4\u52a0\u5e7f\u6cdb\uff0c\u4e3a\u98de\u884c\u5668\u7684\u6027\u80fd"
}
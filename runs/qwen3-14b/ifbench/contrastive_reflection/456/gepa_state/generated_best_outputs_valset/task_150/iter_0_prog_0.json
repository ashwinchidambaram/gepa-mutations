{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6cd5\u5f8b\u9002\u7528\u4e0d\u7edf\u4e00\u548c\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u65b9\u9762\u3002\u4e0d\u540c\u5730\u533a\u7684\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u7c7b\u4f3c\u6848\u4ef6\u65f6\uff0c\u53ef\u80fd\u56e0\u5bf9\u6cd5\u5f8b\u6761\u6587\u7684\u7406\u89e3\u4e0d\u540c\u800c\u4f5c\u51fa\u622a\u7136\u4e0d\u540c\u7684\u51b3\u5b9a\uff0c\u8fd9\u4e0d\u4ec5\u5f71\u54cd\u4e86\u53f8\u6cd5\u516c\u6b63\uff0c\u4e5f\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u6743\u5a01\u6027\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u8ba4\u5b9a\u884c\u653f\u673a\u5173\u672a\u4f9d\u6cd5\u5c65\u884c\u73af\u5883\u76d1\u7ba1\u804c\u8d23\uff0c\u8d23\u4ee4\u5176\u9650\u671f\u5c65\u884c\uff0c\u4f46\u53e6\u4e00\u5730\u533a\u7c7b\u4f3c\u6848\u4ef6\u5374\u672a\u4f5c\u51fa\u76f8\u540c\u5904\u7406\uff0c\u53cd\u6620\u51fa\u6807\u51c6\u4e0d\u4e00\u7684\u95ee\u9898\u3002\n\n\u6b64\u5916\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u548c\u4fdd\u969c\u673a\u5236\uff0c\u5bfc\u81f4\u90e8\u5206\u884c\u653f\u673a\u5173\u5bf9\u590d\u8bae\u51b3\u5b9a\u7f6e\u82e5\u7f54\u95fb\u3002\u5728\u4e00\u4e9b\u6848\u4f8b\u4e2d\uff0c\u5c3d\u7ba1\u590d\u8bae\u673a\u5173\u5df2\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u7684\u51b3\u5b9a\uff0c\u4f46\u7531\u4e8e\u7f3a\u4e4f\u5f3a\u5236\u6267\u884c\u624b\u6bb5\uff0c\u76f8\u5173\u884c\u653f\u673a\u5173\u672a\u80fd\u6309\u65f6\u5c65\u884c\u804c\u8d23\uff0c\u4f7f\u5f97\u884c\u653f\u76f8\u5bf9\u4eba\u7684\u5408\u6cd5\u6743\u76ca\u65e0\u6cd5\u5f97\u5230\u53ca\u65f6\u4fdd\u969c\u3002\u8fd9\u79cd\u73b0\u8c61\u4e0d\u4ec5\u635f\u5bb3\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u4fe1\u529b\uff0c\u4e5f\u5f71\u54cd\u4e86\u653f\u5e9c\u4f9d\u6cd5\u884c\u653f\u7684\u5f62\u8c61\u3002\n\n\u540c\u65f6\uff0c\u884c\u653f\u590d\u8bae\u7a0b\u5e8f\u4e2d\u5b58\u5728\u5bf9\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5ba1\u67e5\u6807\u51c6\u4e0d\u591f\u660e\u786e\u7684\u95ee\u9898\uff0c\u4f7f\u5f97\u590d\u8bae\u673a\u5173\u5728\u5224\u65ad\u884c\u653f\u673a\u5173\u662f\u5426\u5c65\u884c\u804c\u8d23\u65f6\u7f3a\u4e4f\u660e\u786e\u7684\u4f9d\u636e\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u571f\u5730\u5f81\u6536\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u96be\u4ee5\u51c6\u786e\u5224\u65ad\u884c\u653f\u673a\u5173\u662f\u5426\u5df2\u5c3d\u5230\u6cd5\u5b9a\u804c\u8d23\uff0c\u5bfc\u81f4\u51b3\u5b9a\u5185\u5bb9\u6a21\u7cca\uff0c\u6267\u884c\u8fc7\u7a0b\u4e2d\u4ea7\u751f\u4e89\u8bae\u3002\u8fd9\u79cd\u6a21\u7cca\u6027\u4e0d\u4ec5\u589e\u52a0\u4e86\u5f53\u4e8b\u4eba\u7684\u8bc9\u8bbc\u6210\u672c\uff0c\u4e5f\u964d\u4f4e\u4e86\u884c\u653f\u590d\u8bae\u7684\u6548\u7387\u3002\n\ndocument  \n\u4e3a\u89e3\u51b3\u4e0a\u8ff0\u95ee\u9898\uff0c\u6709\u5fc5\u8981\u8fdb\u4e00\u6b65\u5b8c\u5584\u884c\u653f\u590d\u8bae\u5236\u5ea6\uff0c\u660e\u786e\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u6807\u51c6\u548c\u6267\u884c\u673a\u5236\u3002\u5e94\u901a\u8fc7\u7acb\u6cd5\u6216\u53f8\u6cd5\u89e3\u91ca\uff0c\u7edf\u4e00\u5404\u5730\u590d\u8bae\u673a\u5173\u7684\u6cd5\u5f8b\u9002\u7528\u6807\u51c6\uff0c\u786e\u4fdd\u7c7b\u4f3c\u6848\u4ef6\u5f97\u5230\u4e00\u81f4\u5904\u7406\u3002\u540c\u65f6\uff0c\u5e94\u5efa\u7acb\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u786e\u4fdd\u884c\u653f\u673a\u5173\u5207\u5b9e\u5c65\u884c\u590d\u8bae\u51b3\u5b9a\uff0c\u4fdd\u969c\u884c\u653f\u76f8\u5bf9\u4eba\u7684\u5408\u6cd5\u6743\u76ca\u3002\u53ea\u6709\u8fd9\u6837\uff0c\u624d\u80fd\u771f\u6b63\u53d1\u6325\u884c\u653f\u590d\u8bae\u5728\u6cd5\u6cbb\u653f\u5e9c\u5efa\u8bbe\u4e2d\u7684\u5e94\u6709\u4f5c\u7528\u3002"
}
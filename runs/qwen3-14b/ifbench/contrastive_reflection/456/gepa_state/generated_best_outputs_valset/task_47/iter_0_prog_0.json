{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u662f\u7a7a\u6c14\u52a8\u529b\u5b66\u4e2d\u7684\u6838\u5fc3\u7814\u7a76\u9886\u57df\uff0c\u5176\u76ee\u6807\u662f\u4f18\u5316\u98de\u884c\u5668\u3001\u98ce\u529b\u6da1\u8f6e\u673a\u3001\u6c34\u4e0b\u63a8\u8fdb\u5668\u7b49\u8bbe\u5907\u7684\u6027\u80fd\u3002\u7ffc\u578b\u7684\u5f62\u72b6\u51b3\u5b9a\u4e86\u6d41\u4f53\u5728\u5176\u8868\u9762\u7684\u6d41\u52a8\u7279\u6027\uff0c\u8fdb\u800c\u5f71\u54cd\u5347\u529b\u3001\u963b\u529b\u3001\u7a33\u5b9a\u6027\u548c\u6548\u7387\u3002\u5728\u4f20\u7edf\u5de5\u7a0b\u65b9\u6cd5\u7684\u57fa\u7840\u4e0a\uff0c\u8fd1\u5e74\u6765\u4eff\u751f\u5b66\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u5168\u65b0\u7684\u601d\u8def\u548c\u7075\u611f\uff0c\u4f7f\u5f97\u8bbe\u8ba1\u66f4\u52a0\u9ad8\u6548\u3001\u667a\u80fd\u548c\u9002\u5e94\u6027\u5f3a\u3002\n\n\u4eff\u751f\u5b66\uff0c\u5373\u6a21\u4eff\u81ea\u7136\u754c\u751f\u7269\u7684\u7ed3\u6784\u4e0e\u529f\u80fd\uff0c\u5df2\u7ecf\u6210\u4e3a\u73b0\u4ee3\u5de5\u7a0b\u8bbe\u8ba1\u7684\u91cd\u8981\u5de5\u5177\u3002\u81ea\u7136\u754c\u4e2d\uff0c\u9e1f\u7c7b\u3001\u9c7c\u7c7b\u3001\u6606\u866b\u7b49\u751f\u7269\u7ecf\u8fc7\u6570\u767e\u4e07\u5e74\u7684\u8fdb\u5316\uff0c\u5f62\u6210\u4e86\u9ad8\u5ea6\u4f18\u5316\u7684\u98de\u884c\u548c\u6e38\u52a8\u673a\u5236\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7fc5\u8180\u7684\u66f2\u7ebf\u8f6e\u5ed3\u3001\u8702\u9e1f\u7684\u632f\u7fc5\u65b9\u5f0f\u3001\u9ca8\u9c7c\u76ae\u80a4\u7684\u5fae\u7ed3\u6784\u7b49\uff0c\u90fd\u4e3a\u5de5\u7a0b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u5b9d\u8d35\u7684\u53c2\u8003\u3002\n\n\u5728\u822a\u7a7a\u9886\u57df\uff0c\u79d1\u5b66\u5bb6\u4eec\u7814\u7a76\u4e86\u9e1f\u7c7b\u98de\u884c\u7684\u673a\u7406\uff0c\u53d1\u73b0\u5176\u7fc5\u8180\u5728\u4e0d\u540c\u98de\u884c\u72b6\u6001\u4e0b\u80fd\u591f\u8c03\u6574\u5f62\u72b6\uff0c\u4ee5\u9002\u5e94\u901f\u5ea6\u3001\u9ad8\u5ea6\u548c\u7a7a\u6c14\u5bc6\u5ea6\u7684\u53d8\u5316\u3002\u8fd9\u79cd\u52a8\u6001\u8c03\u6574\u80fd\u529b\u542f\u53d1\u4e86\u53ef\u53d8\u5f62\u7ffc\u578b\u7684\u8bbe\u8ba1\uff0c\u4f7f\u5f97\u98de\u884c\u5668\u5728\u4e0d\u540c\u98de\u884c\u9636\u6bb5\u90fd\u80fd\u4fdd\u6301\u6700\u4f18\u6027\u80fd\u3002\u6b64\u5916\uff0c\u9e1f\u7c7b\u7fbd\u6bdb\u7684\u6392\u5217\u65b9\u5f0f\u4e5f\u88ab\u7528\u4e8e\u51cf\u5c11\u6e4d\u6d41\u548c\u6469\u64e6\u963b\u529b\uff0c\u63d0\u9ad8\u98de\u884c\u6548\u7387\u3002\n\n\u5728\u6c34\u4e0b\u822a\u884c\u5668\u548c\u98ce\u529b\u6da1\u8f6e\u673a\u7684\u8bbe\u8ba1\u4e2d\uff0c\u4eff\u751f\u5b66\u540c\u6837\u53d1\u6325\u4e86\u91cd\u8981\u4f5c\u7528\u3002\u4f8b\u5982\uff0c\u4eff\u7167\u9ca8\u9c7c\u76ae\u80a4\u7684\u5fae\u5c0f\u51f8\u8d77\u7ed3\u6784\uff08\u79f0\u4e3a\u201c\u9ca8\u9c7c\u76ae\u201d\uff09\u88ab\u5e94\u7528\u4e8e\u6f5c\u8247\u548c\u8239\u4f53\u8868\u9762\uff0c\u4ee5\u51cf\u5c11\u6c34\u6d41\u963b\u529b\uff0c\u63d0\u9ad8\u63a8\u8fdb\u6548\u7387\u3002\u540c\u6837\uff0c\u98ce\u529b\u6da1\u8f6e\u673a\u7684\u53f6\u7247\u8bbe\u8ba1\u4e5f\u501f\u9274\u4e86\u9e1f\u7c7b\u7fc5\u8180\u7684\u5256\u9762\u5f62\u72b6\uff0c\u4ee5\u589e\u5f3a\u5347\u529b\u5e76\u51cf\u5c11\u566a\u97f3\u3002\n\n\u6b64\u5916\uff0c\u4eff\u751f\u5b66\u8fd8\u63a8\u52a8\u4e86\u667a\u80fd\u6750\u6599\u548c\u81ea\u9002\u5e94\u7ed3\u6784\u7684\u53d1\u5c55\u3002\u4f8b\u5982\uff0c\u57fa\u4e8e\u6606\u866b\u7fc5\u8180\u7684\u67d4\u6027\u6750\u6599\u53ef\u4ee5\u7528\u4e8e\u5236\u9020\u53ef\u53d8\u5f62\u673a\u7ffc\uff0c\u4f7f\u98de\u884c\u5668\u5728\u98de\u884c\u8fc7\u7a0b\u4e2d\u5b9e\u65f6\u8c03\u6574\u5f62\u72b6\uff0c\u4ee5\u5e94\u5bf9\u4e0d\u540c\u7684\u6c14\u6d41\u6761\u4ef6\u3002\u8fd9\u79cd\u81ea\u9002\u5e94\u80fd\u529b\u4e0d\u4ec5\u63d0\u9ad8\u4e86\u98de\u884c\u5668\u7684\u673a\u52a8\u6027\uff0c\u8fd8\u589e\u5f3a\u4e86\u5176\u5728\u6076\u52a3\u73af\u5883\u4e0b\u7684\u751f\u5b58\u80fd\u529b\u3002\n\n\u5c3d\u7ba1\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u53d6\u5f97\u4e86\u663e\u8457\u6210\u679c\uff0c\u4f46\u4ecd\u7136\u9762\u4e34\u8bf8\u591a\u6311\u6218\u3002\u4f8b\u5982\uff0c\u5982\u4f55\u51c6\u786e\u6a21\u62df\u751f\u7269\u7ed3\u6784\u7684\u590d\u6742\u6027\u3001\u5982\u4f55\u5728\u5de5\u7a0b\u4e0a\u5b9e\u73b0\u9ad8\u6548\u7684\u4eff\u751f\u6750\u6599\u3001\u5982\u4f55\u5728\u4e0d\u540c\u5c3a\u5ea6\u548c\u73af\u5883\u4e2d\u4fdd\u6301\u4eff\u751f\u8bbe\u8ba1\u7684\u9002\u5e94\u6027\u7b49\u95ee\u9898\uff0c\u90fd\u9700\u8981\u8fdb\u4e00\u6b65\u7814\u7a76\u548c\u63a2\u7d22\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u7ed3\u5408\uff0c\u4e3a\u73b0\u4ee3\u5de5\u7a0b\u5e26\u6765\u4e86\u524d\u6240\u672a\u6709\u7684\u521b\u65b0\u673a\u9047\u3002\u901a\u8fc7\u6df1\u5165\u7814\u7a76\u81ea\u7136\u754c\u751f\u7269\u7684\u7ed3\u6784\u4e0e\u529f\u80fd\uff0c\u5de5\u7a0b\u5e08\u4eec\u80fd\u591f\u8bbe\u8ba1\u51fa\u66f4\u52a0\u9ad8\u6548\u3001\u667a\u80fd\u548c\u9002\u5e94\u6027\u5f3a\u7684\u98de\u884c\u5668\u548c"
}
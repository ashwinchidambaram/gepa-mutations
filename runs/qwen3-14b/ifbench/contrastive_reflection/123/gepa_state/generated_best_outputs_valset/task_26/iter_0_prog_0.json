{
    "response": "\u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0917\u0924 \u0935\u093f\u0924\u094d\u0924 \u0935\u094d\u092f\u0935\u0938\u094d\u0925\u093e\u092a\u0928 \u0917\u0930\u094d\u0928\u0915\u094b \u0932\u093e\u0917\u093f \u0928\u093f\u092f\u092e\u093f\u0924 \u0930\u0942\u092a\u092e\u093e \u0906\u092f \u0930 \u0916\u0930\u094d\u091a \u0932\u0947\u0916\u0947\u0930 \u0930\u093e\u0916\u094d\u0928 \u0938\u0915\u094d\u091b\u0928\u094d  \n\u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u0906\u092b\u094d\u0928\u094b \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0932\u0915\u094d\u0937\u094d\u092f\u0939\u0930\u0942 \u0928\u093f\u0930\u094d\u0927\u093e\u0930\u0923 \u0917\u0930\u094d\u0928 \u0938\u0915\u094d\u091b\u0928\u094d \u091c\u0938\u094d\u0924\u0948 \u092c\u091a\u0924 \u0935\u093e \u090b\u0923 \u0924\u093f\u0930\u094d\u0928\u0947 \u092f\u094b\u091c\u0928\u093e  \n\u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u091c\u094d\u091e\u093e\u0928 \u092c\u0922\u093e\u0909\u0928\u0915\u094b \u0932\u093e\u0917\u093f \u092a\u0941\u0938\u094d\u0924\u0915\u0939\u0930\u0942 \u0935\u093e \u0911\u0928\u0932\u093e\u0907\u0928 \u0915\u094b\u0930\u094d\u0938\u0939\u0930\u0942 \u092a\u0922\u094d\u0928 \u0938\u0915\u094d\u091b\u0928\u094d  \n\u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0938\u0932\u094d\u0932\u093e\u0939\u0915\u0930\u094d\u0924\u093e\u0939\u0930\u0942\u0915\u094b \u0938\u0932\u094d\u0932\u093e\u0939 \u0932\u093f\u0928 \u0938\u0915\u094d\u091b\u0928\u094d \u091c\u092c \u0906\u0935\u0936\u094d\u092f\u0915\u0924\u093e \u092a\u0930\u0947\u0915\u094b \u0939\u0941\u0928\u094d\u091b  \n\u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u0906\u092b\u094d\u0928\u094b \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0906\u0935\u0936\u094d\u092f\u0915\u0924\u093e\u0939\u0930\u0942 \u0905\u0928\u0941\u0938\u093e\u0930 \u092c\u091a\u0924 \u0935\u093f\u0915\u0932\u094d\u092a\u0939\u0930\u0942 \u091c\u0938\u094d\u0924\u0948 \u092c\u0948\u0902\u0915 \u0916\u093e\u0924\u093e \u0935\u093e \u0928\u093f\u0935\u0947\u0936 \u092f\u094b\u091c\u0928\u093e\u0939\u0930\u0942 \u091a\u092f\u0928 \u0917\u0930\u094d\u0928 \u0938\u0915\u094d\u091b\u0928\u094d  \n\u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0916\u0930\u094d\u091a\u0939\u0930\u0942 \u0935\u093f\u0936\u094d\u0932\u0947\u0937\u0923 \u0917\u0930\u0947\u0930 \u0905\u092a\u094d\u0930\u093e\u0938\u0902\u0917\u093f\u0915 \u0916"

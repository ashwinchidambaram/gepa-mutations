{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u5b9a\u7684\u5236\u5ea6\u7f3a\u9677\u548c\u6267\u884c\u96be\u9898\u3002\u9996\u5148\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6cd5\u5f8b\u6548\u529b\u548c\u6267\u884c\u529b\u4e0d\u8db3\uff0c\u5bfc\u81f4\u90e8\u5206\u884c\u653f\u673a\u5173\u5bf9\u590d\u8bae\u51b3\u5b9a\u7f6e\u82e5\u7f54\u95fb\u3002\u6839\u636e\u300a\u884c\u653f\u590d\u8bae\u6cd5\u300b\u7684\u89c4\u5b9a\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u6709\u6743\u8d23\u4ee4\u88ab\u7533\u8bf7\u4eba\u5c65\u884c\u6cd5\u5b9a\u804c\u8d23\uff0c\u4f46\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u90e8\u5206\u884c\u653f\u673a\u5173\u7f3a\u4e4f\u5bf9\u590d\u8bae\u51b3\u5b9a\u7684\u5c0a\u91cd\u548c\u6267\u884c\u529b\uff0c\u5bfc\u81f4\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u96be\u4ee5\u843d\u5b9e\u3002\u8fd9\u79cd\u73b0\u8c61\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u6743\u5a01\u6027\uff0c\u4e5f\u5f71\u54cd\u4e86\u516c\u6c11\u5408\u6cd5\u6743\u76ca\u7684\u4fdd\u969c\u3002\n\n\u5176\u6b21\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u548c\u6807\u51c6\u4e0d\u591f\u660e\u786e\uff0c\u5bb9\u6613\u5f15\u53d1\u4e89\u8bae\u3002\u5728\u4e00\u4e9b\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u5bf9\u201c\u5e94\u5f53\u5c65\u884c\u201d\u7684\u8ba4\u5b9a\u5b58\u5728\u4e3b\u89c2\u5224\u65ad\uff0c\u7f3a\u4e4f\u7edf\u4e00\u7684\u88c1\u91cf\u6807\u51c6\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u7533\u8bf7\u4eba\u8981\u6c42\u73af\u4fdd\u90e8\u95e8\u4f9d\u6cd5\u67e5\u5904\u67d0\u4f01\u4e1a\u6392\u6c61\u884c\u4e3a\uff0c\u590d\u8bae\u673a\u5173\u867d\u8ba4\u5b9a\u73af\u4fdd\u90e8\u95e8\u672a\u5c65\u884c\u6cd5\u5b9a\u804c\u8d23\uff0c\u4f46\u8d23\u4ee4\u5176\u201c\u9650\u671f\u5c65\u884c\u201d\uff0c\u800c\u672a\u660e\u786e\u5177\u4f53\u671f\u9650\u548c\u6807\u51c6\uff0c\u5bfc\u81f4\u6267\u884c\u8fc7\u7a0b\u4e2d\u51fa\u73b0\u62d6\u5ef6\u548c\u63a8\u8bff\u73b0\u8c61\u3002\u8fd9\u79cd\u6a21\u7cca\u6027\u5f71\u54cd\u4e86\u590d\u8bae\u51b3\u5b9a\u7684\u53ef\u64cd\u4f5c\u6027\u548c\u516c\u6b63\u6027\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u4e0e\u884c\u653f\u8bc9\u8bbc\u4e4b\u95f4\u7684\u8854\u63a5\u673a\u5236\u4e0d\u7545\uff0c\u4e5f\u5236\u7ea6\u4e86\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u3002\u5f53\u88ab\u7533\u8bf7\u4eba\u62d2\u4e0d\u5c65\u884c\u590d\u8bae\u51b3\u5b9a\u65f6\uff0c\u7533\u8bf7\u4eba\u5f80\u5f80\u9700\u8981\u901a\u8fc7\u8bc9\u8bbc\u9014\u5f84\u5bfb\u6c42\u6551\u6d4e\uff0c\u4f46\u8bc9\u8bbc\u7a0b\u5e8f\u590d\u6742\u3001\u8017\u65f6\u8f83\u957f\uff0c\u589e\u52a0\u4e86\u5f53\u4e8b\u4eba\u7684\u7ef4\u6743\u6210\u672c\u3002\u4f8b\u5982\uff0c\u67d0\u5e02\u6c11\u5728\u7533\u8bf7\u4fe1\u606f\u516c\u5f00\u672a\u679c\u540e\u63d0\u8d77\u884c\u653f\u590d\u8bae\uff0c\u590d\u8bae\u673a\u5173\u8d23\u4ee4\u76f8\u5173\u90e8\u95e8\u5c65\u884c\u4fe1\u606f\u516c\u5f00\u4e49\u52a1\uff0c\u4f46\u76f8\u5173\u90e8\u95e8\u4ecd\u62d2\u7edd\u6267\u884c\uff0c\u5e02\u6c11\u4e0d\u5f97\u4e0d\u518d\u6b21\u63d0\u8d77\u884c\u653f\u8bc9\u8bbc\uff0c\u5bfc\u81f4\u7ef4\u6743\u8fc7\u7a0b\u5ef6\u957f\uff0c\u5f71\u54cd\u4e86\u884c\u653f\u590d\u8bae\u7684\u6548\u7387\u548c\u6743\u5a01\u6027\u3002\n\ndocument  \n\u4e3a\u63d0\u5347\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u529b\uff0c\u5e94\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173\u6cd5\u5f8b\u89c4\u5b9a\uff0c\u660e\u786e\u9002\u7528\u6761\u4ef6\u548c\u6267\u884c\u7a0b\u5e8f\uff0c\u540c\u65f6\u52a0\u5f3a\u884c\u653f\u590d\u8bae\u673a\u5173\u4e0e\u6cd5\u9662\u4e4b\u95f4\u7684\u534f\u8c03\u914d\u5408\u3002\u6b64\u5916\uff0c\u5e94\u5f3a\u5316\u5bf9\u884c\u653f\u673a\u5173\u4e0d\u5c65\u884c\u590d\u8bae\u51b3\u5b9a\u7684\u6cd5\u5f8b\u8d23\u4efb\u8ffd\u7a76\uff0c\u786e\u4fdd\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6743\u5a01\u6027\u548c\u5b9e\u6548\u6027\u3002\u901a\u8fc7\u5236\u5ea6\u5b8c\u5584\u548c\u6267\u884c\u5f3a\u5316\uff0c\u53ef\u4ee5\u66f4\u597d\u5730\u53d1\u6325\u884c\u653f\u590d\u8bae\u5728\u76d1\u7763\u884c\u653f\u884c\u4e3a\u3001\u4fdd\u969c\u516c\u6c11\u6743\u76ca\u65b9\u9762\u7684\u4f5c\u7528\u3002"
}
{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u662f\u7a7a\u6c14\u52a8\u529b\u5b66\u548c\u5de5\u7a0b\u5b66\u4e2d\u7684\u4e00\u4e2a\u91cd\u8981\u9886\u57df\uff0c\u5176\u6838\u5fc3\u5728\u4e8e\u4f18\u5316\u98de\u884c\u5668\u3001\u98ce\u529b\u6da1\u8f6e\u673a\u3001\u6c34\u4e0b\u63a8\u8fdb\u5668\u7b49\u8bbe\u5907\u7684\u6027\u80fd\u3002\u7ffc\u578b\u7684\u5f62\u72b6\u76f4\u63a5\u5f71\u54cd\u7740\u5347\u529b\u3001\u963b\u529b\u3001\u7a33\u5b9a\u6027\u4ee5\u53ca\u6548\u7387\uff0c\u56e0\u6b64\uff0c\u7ffc\u578b\u8bbe\u8ba1\u4e00\u76f4\u662f\u822a\u7a7a\u3001\u822a\u5929\u3001\u80fd\u6e90\u548c\u4ea4\u901a\u7b49\u9886\u57df\u7814\u7a76\u7684\u70ed\u70b9\u3002\u8fd1\u5e74\u6765\uff0c\u968f\u7740\u4eff\u751f\u5b66\u7684\u53d1\u5c55\uff0c\u7814\u7a76\u4eba\u5458\u5f00\u59cb\u501f\u9274\u81ea\u7136\u754c\u4e2d\u7684\u751f\u7269\u7ed3\u6784\uff0c\u7279\u522b\u662f\u9e1f\u7c7b\u3001\u6606\u866b\u548c\u9c7c\u7c7b\u7684\u98de\u884c\u6216\u6e38\u52a8\u673a\u5236\uff0c\u4ee5\u6539\u8fdb\u7ffc\u578b\u8bbe\u8ba1\uff0c\u4ece\u800c\u63d0\u5347\u98de\u884c\u5668\u7684\u6027\u80fd\u548c\u6548\u7387\u3002\n\n\u4eff\u751f\u5b66\uff0c\u5373\u6a21\u4eff\u81ea\u7136\u754c\u751f\u7269\u7684\u7ed3\u6784\u548c\u529f\u80fd\u6765\u89e3\u51b3\u5de5\u7a0b\u95ee\u9898\uff0c\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u3002\u81ea\u7136\u754c\u4e2d\uff0c\u9e1f\u7c7b\u548c\u6606\u866b\u7684\u7fc5\u8180\u5728\u98de\u884c\u8fc7\u7a0b\u4e2d\u8868\u73b0\u51fa\u6781\u9ad8\u7684\u6548\u7387\u548c\u7075\u6d3b\u6027\uff0c\u8fd9\u4e0e\u5b83\u4eec\u72ec\u7279\u7684\u7ffc\u578b\u7ed3\u6784\u5bc6\u4e0d\u53ef\u5206\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7684\u7fc5\u8180\u5728\u98de\u884c\u8fc7\u7a0b\u4e2d\u80fd\u591f\u6839\u636e\u7a7a\u6c14\u52a8\u529b\u5b66\u7684\u9700\u8981\u4e0d\u65ad\u6539\u53d8\u5f62\u72b6\uff0c\u4ee5\u9002\u5e94\u4e0d\u540c\u7684\u98de\u884c\u72b6\u6001\uff0c\u5982\u5de1\u822a\u3001\u6ed1\u7fd4\u3001\u76d8\u65cb\u548c\u4fef\u51b2\u3002\u8fd9\u79cd\u52a8\u6001\u8c03\u6574\u80fd\u529b\u662f\u4f20\u7edf\u56fa\u5b9a\u7ffc\u578b\u6240\u65e0\u6cd5\u5b9e\u73b0\u7684\u3002\u56e0\u6b64\uff0c\u7814\u7a76\u8fd9\u4e9b\u751f\u7269\u7684\u7fc5\u8180\u7ed3\u6784\uff0c\u6709\u52a9\u4e8e\u5f00\u53d1\u51fa\u5177\u6709\u81ea\u9002\u5e94\u80fd\u529b\u7684\u65b0\u578b\u7ffc\u578b\u3002\n\n\u6606\u866b\u7684\u7fc5\u8180\u5219\u63d0\u4f9b\u4e86\u53e6\u4e00\u79cd\u542f\u53d1\u3002\u6606\u866b\u7684\u7fc5\u8180\u901a\u5e38\u975e\u5e38\u8584\uff0c\u4f46\u5177\u6709\u6781\u9ad8\u7684\u521a\u5ea6\u548c\u67d4\u97e7\u6027\uff0c\u8fd9\u4f7f\u5f97\u5b83\u4eec\u80fd\u591f\u5728\u9ad8\u901f\u98de\u884c\u4e2d\u4fdd\u6301\u7a33\u5b9a\u3002\u6b64\u5916\uff0c\u6606\u866b\u7684\u7fc5\u8180\u5728\u98de\u884c\u8fc7\u7a0b\u4e2d\u4f1a\u4ea7\u751f\u6da1\u6d41\uff0c\u4ece\u800c\u63d0\u9ad8\u5347\u529b\u3002\u8fd9\u79cd\u73b0\u8c61\u88ab\u79f0\u4e3a\u201c\u6da1\u6d41\u589e\u5f3a\u5347\u529b\u201d\uff0c\u5df2\u88ab\u5e7f\u6cdb\u5e94\u7528\u4e8e\u5fae\u578b\u98de\u884c\u5668\u548c\u65e0\u4eba\u673a\u7684\u8bbe\u8ba1\u4e2d\u3002\u901a\u8fc7\u6a21\u4eff\u6606\u866b\u7684\u7ffc\u578b\u7ed3\u6784\uff0c\u5de5\u7a0b\u5e08\u4eec\u80fd\u591f\u8bbe\u8ba1\u51fa\u66f4\u8f7b\u3001\u66f4\u9ad8\u6548\u3001\u66f4\u7075\u6d3b\u7684\u98de\u884c\u5668\u3002\n\n\u9664\u4e86\u9e1f\u7c7b\u548c\u6606\u866b\uff0c\u9c7c\u7c7b\u7684\u9ccd\u4e5f\u5bf9\u7ffc\u578b\u8bbe\u8ba1\u4ea7\u751f\u4e86\u91cd\u8981\u5f71\u54cd\u3002\u9c7c\u7c7b\u7684\u9ccd\u5728\u6c34\u4e2d\u6e38\u52a8\u65f6\uff0c\u80fd\u591f\u4ea7\u751f\u9ad8\u6548\u7684\u63a8\u8fdb\u529b\uff0c\u540c\u65f6\u51cf\u5c11\u963b\u529b\u3002\u8fd9\u79cd\u63a8\u8fdb\u673a\u5236\u88ab\u5e94\u7528\u4e8e\u6c34\u4e0b\u822a\u884c\u5668\u548c\u6c34\u4e0b\u673a\u5668\u4eba\u4e2d\uff0c\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u65b9\u5411\u3002\u4f8b\u5982\uff0c\u4eff\u751f\u9c7c\u7c7b\u7684\u9ccd\u7ed3\u6784\u88ab\u7528\u4e8e\u8bbe\u8ba1\u6c34\u4e0b\u63a8\u8fdb\u5668\uff0c\u4ee5\u63d0\u9ad8\u5176\u673a\u52a8\u6027\u548c\u80fd\u6548\u3002\n\n\u5728\u5b9e\u9645\u5e94\u7528\u4e2d\uff0c\u4eff\u751f\u5b66\u4e0e\u7ffc\u578b\u8bbe\u8ba1\u7684\u7ed3\u5408\u5df2\u7ecf\u53d6\u5f97\u4e86\u4e00\u4e9b\u663e\u8457\u6210\u679c\u3002\u4f8b\u5982\uff0c\u7814\u7a76\u4eba\u5458\u901a\u8fc7\u7814\u7a76\u9e1f\u7c7b\u7684\u7fc5\u8180\uff0c\u5f00\u53d1\u51fa\u53ef\u53d8\u5f62\u7684\u7ffc\u578b\u7ed3\u6784\uff0c\u4f7f\u98de\u884c\u5668\u5728\u4e0d\u540c\u98de\u884c\u6761\u4ef6\u4e0b\u90fd\u80fd\u4fdd\u6301\u6700\u4f73\u6027\u80fd\u3002\u6b64\u5916\uff0c\u57fa\u4e8e\u6606\u866b\u7fc5\u8180\u7684\u5fae\u578b\u98de\u884c\u5668\u5df2\u7ecf\u6210\u529f\u5e94\u7528\u4e8e\u4fa6\u5bdf\u3001\u76d1\u6d4b\u548c\u6551\u63f4\u7b49\u9886\u57df\u3002\u8fd9\u4e9b\u6210\u679c\u8868\u660e\uff0c\u4eff\u751f\u5b66\u4e0d\u4ec5\u80fd\u591f\u63d0\u4f9b\u65b0\u7684\u8bbe\u8ba1\u601d\u8def\uff0c\u8fd8\u80fd\u63a8\u52a8\u5de5\u7a0b\u6280\u672f\u7684\u53d1\u5c55\u3002\n\n\u7136\u800c\uff0c\u4eff\u751f"
}
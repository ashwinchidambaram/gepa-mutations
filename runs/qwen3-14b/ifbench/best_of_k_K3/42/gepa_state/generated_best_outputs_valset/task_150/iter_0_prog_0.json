{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u5b9a\u7684\u95ee\u9898\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6cd5\u5f8b\u9002\u7528\u4e0d\u7edf\u4e00\u3001\u6267\u884c\u6548\u529b\u4e0d\u8db3\u4ee5\u53ca\u76d1\u7763\u673a\u5236\u4e0d\u5065\u5168\u7b49\u65b9\u9762\u3002\u6839\u636e\u300a\u884c\u653f\u590d\u8bae\u6cd5\u300b\u7684\u89c4\u5b9a\uff0c\u884c\u653f\u590d\u8bae\u673a\u5173\u5728\u5ba1\u67e5\u5177\u4f53\u884c\u653f\u884c\u4e3a\u65f6\uff0c\u82e5\u53d1\u73b0\u88ab\u7533\u8bf7\u673a\u5173\u672a\u4f9d\u6cd5\u5c65\u884c\u6cd5\u5b9a\u804c\u8d23\uff0c\u53ef\u4ee5\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u7684\u51b3\u5b9a\u3002\u7136\u800c\uff0c\u7531\u4e8e\u5404\u5730\u590d\u8bae\u673a\u5173\u5bf9\u201c\u6cd5\u5b9a\u804c\u8d23\u201d\u7684\u7406\u89e3\u4e0d\u4e00\uff0c\u5bfc\u81f4\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u548c\u6807\u51c6\u5b58\u5728\u5dee\u5f02\uff0c\u5f71\u54cd\u4e86\u6cd5\u5f8b\u9002\u7528\u7684\u7edf\u4e00\u6027\u4e0e\u6743\u5a01\u6027\u3002\n\n\u6b64\u5916\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u6548\u529b\u4e5f\u5907\u53d7\u8d28\u7591\u3002\u5728\u4e00\u4e9b\u6848\u4f8b\u4e2d\uff0c\u5c3d\u7ba1\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u76f8\u5173\u884c\u653f\u673a\u5173\u5e76\u672a\u4f9d\u6cd5\u6267\u884c\uff0c\u5bfc\u81f4\u51b3\u5b9a\u6d41\u4e8e\u5f62\u5f0f\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u8ba4\u5b9a\u67d0\u653f\u5e9c\u90e8\u95e8\u672a\u4f9d\u6cd5\u5bf9\u8fdd\u6cd5\u6392\u6c61\u4f01\u4e1a\u8fdb\u884c\u67e5\u5904\uff0c\u9042\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u3002\u7136\u800c\uff0c\u8be5\u653f\u5e9c\u90e8\u95e8\u5728\u6536\u5230\u51b3\u5b9a\u540e\uff0c\u672a\u91c7\u53d6\u6709\u6548\u63aa\u65bd\u8fdb\u884c\u6574\u6539\uff0c\u6700\u7ec8\u5bfc\u81f4\u73af\u5883\u95ee\u9898\u957f\u671f\u672a\u5f97\u5230\u89e3\u51b3\u3002\u8fd9\u53cd\u6620\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u7f3a\u4e4f\u6709\u6548\u7684\u5f3a\u5236\u529b\u548c\u76d1\u7763\u673a\u5236\u3002\n\n\u540c\u65f6\uff0c\u884c\u653f\u590d\u8bae\u7a0b\u5e8f\u672c\u8eab\u4e5f\u5b58\u5728\u4e00\u5b9a\u7684\u5c40\u9650\u6027\u3002\u5728\u4e00\u4e9b\u6848\u4ef6\u4e2d\uff0c\u7533\u8bf7\u4eba\u867d\u83b7\u5f97\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u4f46\u7531\u4e8e\u7f3a\u4e4f\u540e\u7eed\u7684\u8ddf\u8e2a\u76d1\u7763\u673a\u5236\uff0c\u96be\u4ee5\u786e\u4fdd\u884c\u653f\u673a\u5173\u771f\u6b63\u5c65\u884c\u5176\u804c\u8d23\u3002\u8fd9\u79cd\u201c\u4e00\u7eb8\u51b3\u5b9a\u201d\u7684\u5f62\u5f0f\u4e3b\u4e49\u503e\u5411\uff0c\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u5b9e\u6548\u6027\u548c\u516c\u4fe1\u529b\u3002\u56e0\u6b64\uff0c\u5982\u4f55\u589e\u5f3a\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u529b\u548c\u76d1\u7763\u529b\uff0c\u6210\u4e3a\u4e9f\u5f85\u89e3\u51b3\u7684\u95ee\u9898\u3002\n\ndocument  \n\u4e3a\u89e3\u51b3\u4e0a\u8ff0\u95ee\u9898\uff0c\u5e94\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173\u6cd5\u5f8b\u6cd5\u89c4\uff0c\u660e\u786e\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u6761\u4ef6\u548c\u7a0b\u5e8f\uff0c\u63d0\u5347\u6cd5\u5f8b\u9002\u7528\u7684\u7edf\u4e00\u6027\u3002\u540c\u65f6\uff0c\u5e94\u5efa\u7acb\u6709\u6548\u7684\u6267\u884c\u548c\u76d1\u7763\u673a\u5236\uff0c\u5982\u5f15\u5165\u7b2c\u4e09\u65b9\u76d1\u7763\u3001\u5b9a\u671f\u56de\u8bbf\u5236\u5ea6\u7b49\uff0c\u786e\u4fdd\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5f97\u5230\u6709\u6548\u843d\u5b9e\u3002\u6b64\u5916\uff0c\u8fd8\u53ef\u4ee5\u63a2\u7d22\u5c06\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u60c5\u51b5\u7eb3\u5165\u884c\u653f\u673a\u5173\u7684\u7ee9\u6548\u8003\u6838\u4f53\u7cfb\uff0c\u4ee5\u589e\u5f3a\u884c\u653f\u673a\u5173\u4f9d\u6cd5\u5c65\u804c\u7684\u8d23\u4efb\u611f\u548c\u7d27\u8feb\u611f\u3002\u901a\u8fc7\u8fd9\u4e9b\u63aa\u65bd\uff0c\u53ef\u4ee5\u9010\u6b65\u63d0\u5347\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6743\u5a01\u6027\u4e0e\u6267\u884c\u529b\uff0c\u5b9e\u73b0\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u4f18\u5316\u4e0e\u5b8c\u5584\u3002"
}
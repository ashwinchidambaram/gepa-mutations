{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u4e9b\u95ee\u9898\uff0c\u5176\u4e2d\u8f83\u4e3a\u7a81\u51fa\u7684\u662f\u6cd5\u5f8b\u9002\u7528\u4e0d\u7edf\u4e00\u3002\u4e0d\u540c\u5730\u533a\u7684\u590d\u8bae\u673a\u5173\u5728\u5904\u7406\u7c7b\u4f3c\u6848\u4ef6\u65f6\uff0c\u53ef\u80fd\u4f9d\u636e\u4e0d\u540c\u7684\u6cd5\u5f8b\u6761\u6587\u6216\u89e3\u91ca\u4f5c\u51fa\u51b3\u5b9a\uff0c\u5bfc\u81f4\u540c\u6848\u4e0d\u540c\u5224\u7684\u73b0\u8c61\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u672a\u4f9d\u6cd5\u516c\u5f00\u73af\u5883\u76d1\u6d4b\u6570\u636e\u7684\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u8d23\u4ee4\u5176\u5728\u4e00\u5b9a\u671f\u9650\u5185\u5c65\u884c\u516c\u5f00\u4e49\u52a1\uff0c\u800c\u5728\u53e6\u4e00\u7c7b\u4f3c\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u5374\u4ec5\u8981\u6c42\u4f5c\u51fa\u4e66\u9762\u8bf4\u660e\uff0c\u672a\u660e\u786e\u5c65\u884c\u671f\u9650\u3002\u8fd9\u79cd\u5dee\u5f02\u4e0d\u4ec5\u5f71\u54cd\u4e86\u6cd5\u5f8b\u7684\u6743\u5a01\u6027\uff0c\u4e5f\u524a\u5f31\u4e86\u884c\u653f\u76f8\u5bf9\u4eba\u5bf9\u590d\u8bae\u51b3\u5b9a\u7684\u4fe1\u4efb\u3002\n\n\u6b64\u5916\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u529b\u5ea6\u4e0d\u8db3\u4e5f\u662f\u4e9f\u5f85\u89e3\u51b3\u7684\u95ee\u9898\u3002\u5373\u4f7f\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u4e86\u8d23\u4ee4\u5c65\u884c\u7684\u51b3\u5b9a\uff0c\u4f46\u76f8\u5173\u884c\u653f\u673a\u5173\u5f80\u5f80\u7f3a\u4e4f\u6709\u6548\u7684\u76d1\u7763\u673a\u5236\uff0c\u5bfc\u81f4\u51b3\u5b9a\u96be\u4ee5\u843d\u5b9e\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5e02\u81ea\u7136\u8d44\u6e90\u5c40\u672a\u4f9d\u6cd5\u529e\u7406\u571f\u5730\u5ba1\u6279\u624b\u7eed\u7684\u6848\u4ef6\u4e2d\uff0c\u867d\u7136\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u4e86\u8d23\u4ee4\u5c65\u884c\u7684\u51b3\u5b9a\uff0c\u4f46\u7531\u4e8e\u7f3a\u4e4f\u540e\u7eed\u8ddf\u8e2a\u548c\u95ee\u8d23\u673a\u5236\uff0c\u8be5\u51b3\u5b9a\u6700\u7ec8\u6d41\u4e8e\u5f62\u5f0f\uff0c\u672a\u80fd\u5b9e\u9645\u63a8\u52a8\u95ee\u9898\u7684\u89e3\u51b3\u3002\u8fd9\u53cd\u6620\u51fa\u884c\u653f\u590d\u8bae\u5236\u5ea6\u5728\u6267\u884c\u73af\u8282\u5b58\u5728\u660e\u663e\u77ed\u677f\u3002\n\n\u518d\u8005\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u7a0b\u5e8f\u89c4\u8303\u6027\u6709\u5f85\u52a0\u5f3a\u3002\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u672a\u5145\u5206\u542c\u53d6\u88ab\u7533\u8bf7\u4eba\u7684\u9648\u8ff0\u548c\u7533\u8fa9\uff0c\u6216\u8005\u672a\u660e\u786e\u5c65\u884c\u7684\u5177\u4f53\u5185\u5bb9\u548c\u671f\u9650\uff0c\u5bfc\u81f4\u51b3\u5b9a\u5185\u5bb9\u6a21\u7cca\u3001\u53ef\u64cd\u4f5c\u6027\u5dee\u3002\u4f8b\u5982\uff0c\u5728\u4e00\u8d77\u6d89\u53ca\u5e02\u573a\u76d1\u7ba1\u90e8\u95e8\u672a\u4f9d\u6cd5\u5904\u7406\u6295\u8bc9\u7684\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65f6\uff0c\u4ec5\u7b3c\u7edf\u8981\u6c42\u201c\u4f9d\u6cd5\u5904\u7406\u201d\uff0c\u800c\u672a\u660e\u786e\u5904\u7406\u65f6\u9650\u548c\u5177\u4f53\u8981\u6c42\uff0c\u4f7f\u5f97\u88ab\u7533\u8bf7\u4eba\u96be\u4ee5\u51c6\u786e\u6267\u884c\uff0c\u4e5f\u589e\u52a0\u4e86\u884c\u653f\u76f8\u5bf9\u4eba\u7684\u7ef4\u6743\u96be\u5ea6\u3002\n\ndocument  \n\u4e3a\u6539\u5584\u4e0a\u8ff0\u95ee\u9898\uff0c\u5e94\u8fdb\u4e00\u6b65\u7edf\u4e00\u6cd5\u5f8b\u9002\u7528\u6807\u51c6\uff0c\u52a0\u5f3a\u590d\u8bae\u673a\u5173\u4e4b\u95f4\u7684\u6c9f\u901a\u4e0e\u534f\u8c03\uff0c\u63a8\u52a8\u5f62\u6210\u76f8\u5bf9\u4e00\u81f4\u7684\u88c1\u5224\u5c3a\u5ea6\u3002\u540c\u65f6\uff0c\u5e94\u5efa\u7acb\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u8ddf\u8e2a\u7763\u529e\u673a\u5236\uff0c\u786e\u4fdd\u51b3\u5b9a\u5f97\u5230\u6709\u6548\u6267\u884c\u3002\u6b64\u5916\uff0c\u5e94\u5b8c\u5584\u7a0b\u5e8f\u89c4\u8303\uff0c\u786e\u4fdd\u51b3\u5b9a\u5185\u5bb9\u5177\u4f53\u3001\u660e\u786e\uff0c\u4fbf\u4e8e\u6267\u884c\u548c\u76d1\u7763\u3002\u901a\u8fc7\u8fd9\u4e9b\u63aa\u65bd\uff0c\u53ef\u4ee5\u63d0\u5347\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6743\u5a01\u6027\u548c\u5b9e\u6548\u6027\uff0c\u66f4\u597d\u5730\u7ef4\u62a4\u516c\u6c11\u3001\u6cd5\u4eba\u548c\u5176\u4ed6\u7ec4\u7ec7\u7684\u5408\u6cd5\u6743\u76ca\u3002"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u4e2d\u5b58\u5728\u4e00\u5b9a\u7684\u5236\u5ea6\u6027\u7f3a\u9677\uff0c\u4e3b\u8981\u4f53\u73b0\u5728\u6cd5\u5f8b\u4f9d\u636e\u4e0d\u660e\u786e\u548c\u64cd\u4f5c\u6807\u51c6\u4e0d\u7edf\u4e00\u3002\u73b0\u884c\u300a\u884c\u653f\u590d\u8bae\u6cd5\u300b\u5bf9\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u89c4\u5b9a\u8f83\u4e3a\u539f\u5219\u6027\uff0c\u7f3a\u4e4f\u5177\u4f53\u7684\u9002\u7528\u6761\u4ef6\u548c\u7a0b\u5e8f\u89c4\u8303\uff0c\u5bfc\u81f4\u590d\u8bae\u673a\u5173\u5728\u9002\u7528\u65f6\u5b58\u5728\u8f83\u5927\u7684\u81ea\u7531\u88c1\u91cf\u7a7a\u95f4\u3002\u8fd9\u79cd\u6a21\u7cca\u6027\u53ef\u80fd\u5f15\u53d1\u590d\u8bae\u51b3\u5b9a\u7684\u968f\u610f\u6027\uff0c\u524a\u5f31\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\u548c\u53ef\u9884\u671f\u6027\u3002\u6b64\u5916\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u9002\u7528\u8303\u56f4\u4e0d\u6e05\u6670\uff0c\u4f7f\u5f97\u4e00\u4e9b\u672c\u5e94\u9002\u7528\u8be5\u51b3\u5b9a\u7684\u60c5\u5f62\u672a\u80fd\u88ab\u6b63\u786e\u8bc6\u522b\u548c\u5904\u7406\u3002\n\n\u5728\u5b9e\u9645\u64cd\u4f5c\u4e2d\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u6267\u884c\u6548\u679c\u5f80\u5f80\u4e0d\u5c3d\u5982\u4eba\u610f\uff0c\u90e8\u5206\u884c\u653f\u673a\u5173\u5bf9\u590d\u8bae\u51b3\u5b9a\u7684\u6267\u884c\u529b\u4e0d\u8db3\uff0c\u5bfc\u81f4\u51b3\u5b9a\u96be\u4ee5\u843d\u5b9e\u3002\u4f8b\u5982\uff0c\u5728\u67d0\u5730\u73af\u4fdd\u884c\u653f\u590d\u8bae\u6848\u4ef6\u4e2d\uff0c\u590d\u8bae\u673a\u5173\u8ba4\u5b9a\u67d0\u5730\u65b9\u653f\u5e9c\u672a\u4f9d\u6cd5\u5c65\u884c\u73af\u5883\u76d1\u7ba1\u804c\u8d23\uff0c\u9042\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u3002\u7136\u800c\uff0c\u7531\u4e8e\u7f3a\u4e4f\u5f3a\u5236\u6267\u884c\u673a\u5236\uff0c\u8be5\u51b3\u5b9a\u6700\u7ec8\u672a\u80fd\u6709\u6548\u63a8\u52a8\u5730\u65b9\u653f\u5e9c\u91c7\u53d6\u5177\u4f53\u63aa\u65bd\uff0c\u73af\u5883\u95ee\u9898\u957f\u671f\u672a\u5f97\u5230\u89e3\u51b3\u3002\u6b64\u7c7b\u6848\u4f8b\u53cd\u6620\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u6267\u884c\u73af\u8282\u5b58\u5728\u660e\u663e\u77ed\u677f\uff0c\u4e9f\u9700\u5efa\u7acb\u914d\u5957\u7684\u76d1\u7763\u548c\u95ee\u8d23\u673a\u5236\u3002\n\n\u6b64\u5916\uff0c\u884c\u653f\u590d\u8bae\u7a0b\u5e8f\u4e2d\u5bf9\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5ba1\u67e5\u6807\u51c6\u4e0d\u4e00\u81f4\uff0c\u4e5f\u5f71\u54cd\u4e86\u53f8\u6cd5\u5ba1\u67e5\u7684\u7edf\u4e00\u6027\u548c\u516c\u6b63\u6027\u3002\u4e0d\u540c\u590d\u8bae\u673a\u5173\u5bf9\u201c\u4e0d\u5c65\u884c\u6cd5\u5b9a\u804c\u8d23\u201d\u7684\u8ba4\u5b9a\u6807\u51c6\u5b58\u5728\u5dee\u5f02\uff0c\u5bfc\u81f4\u7c7b\u4f3c\u6848\u4ef6\u53ef\u80fd\u5f97\u51fa\u622a\u7136\u4e0d\u540c\u7684\u590d\u8bae\u7ed3\u679c\u3002\u4f8b\u5982\uff0c\u67d0\u5e02\u5bf9\u540c\u4e00\u7c7b\u884c\u653f\u4e0d\u4f5c\u4e3a\u6848\u4ef6\uff0c\u6709\u7684\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\uff0c\u800c\u6709\u7684\u5219\u8ba4\u4e3a\u4e0d\u5c5e\u4e8e\u884c\u653f\u590d\u8bae\u53d7\u7406\u8303\u56f4\u3002\u8fd9\u79cd\u5dee\u5f02\u4e0d\u4ec5\u635f\u5bb3\u4e86\u884c\u653f\u590d\u8bae\u7684\u516c\u4fe1\u529b\uff0c\u4e5f\u7ed9\u5f53\u4e8b\u4eba\u5e26\u6765\u4e0d\u5fc5\u8981\u7684\u8bc9\u7d2f\u548c\u4e0d\u786e\u5b9a\u6027\u3002\n\ndocument \u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5b8c\u5584\u9700\u8981\u4ece\u7acb\u6cd5\u548c\u5b9e\u8df5\u4e24\u4e2a\u5c42\u9762\u5165\u624b\uff0c\u660e\u786e\u5176\u9002\u7528\u6761\u4ef6\u3001\u7a0b\u5e8f\u89c4\u8303\u548c\u6267\u884c\u4fdd\u969c\u3002\u7acb\u6cd5\u4e0a\u5e94\u7ec6\u5316\u76f8\u5173\u6761\u6b3e\uff0c\u589e\u5f3a\u53ef\u64cd\u4f5c\u6027\uff0c\u540c\u65f6\u5efa\u7acb\u4e0e\u884c\u653f\u8bc9\u8bbc\u3001\u884c\u653f\u76d1\u5bdf\u7b49\u5236\u5ea6\u7684\u8854\u63a5\u673a\u5236\uff0c\u786e\u4fdd\u51b3\u5b9a\u80fd\u591f\u6709\u6548\u843d\u5730\u3002\u5b9e\u8df5\u5c42\u9762\u5219\u9700\u52a0\u5f3a\u590d\u8bae\u673a\u5173\u7684\u80fd\u529b\u5efa\u8bbe\uff0c\u63d0\u5347\u5176\u4f9d\u6cd5\u884c\u653f\u6c34\u5e73\uff0c\u5e76\u5f3a\u5316\u5bf9\u884c\u653f\u673a\u5173\u6267\u884c\u590d\u8bae\u51b3\u5b9a\u7684\u76d1\u7763\u548c\u95ee\u8d23\uff0c\u4ee5\u5207\u5b9e\u7ef4\u62a4\u516c\u6c11\u7684\u5408\u6cd5\u6743\u76ca\u548c\u653f\u5e9c\u7684\u516c\u4fe1\u529b\u3002"
}
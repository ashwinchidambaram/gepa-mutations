{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u5728\u822a\u7a7a\u5de5\u7a0b\u4e2d\u626e\u6f14\u7740\u81f3\u5173\u91cd\u8981\u7684\u89d2\u8272\uff0c\u5176\u6027\u80fd\u76f4\u63a5\u5f71\u54cd\u98de\u884c\u5668\u7684\u7a7a\u6c14\u52a8\u529b\u5b66\u6548\u7387\u3001\u71c3\u6cb9\u7ecf\u6d4e\u6027\u548c\u98de\u884c\u7a33\u5b9a\u6027\u3002\u4f20\u7edf\u7684\u7ffc\u578b\u8bbe\u8ba1\u4e3b\u8981\u4f9d\u8d56\u4e8e\u7ecf\u9a8c\u516c\u5f0f\u548c\u98ce\u6d1e\u5b9e\u9a8c\uff0c\u4f46\u968f\u7740\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\uff08CFD\uff09\u548c\u4f18\u5316\u7b97\u6cd5\u7684\u53d1\u5c55\uff0c\u73b0\u4ee3\u8bbe\u8ba1\u65b9\u6cd5\u5df2\u7ecf\u80fd\u591f\u66f4\u7cbe\u786e\u5730\u6a21\u62df\u548c\u4f18\u5316\u7ffc\u578b\u5f62\u72b6\u3002\u4e0e\u6b64\u540c\u65f6\uff0c\u4eff\u751f\u5b66\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\uff0c\u901a\u8fc7\u7814\u7a76\u81ea\u7136\u754c\u4e2d\u7684\u98de\u884c\u751f\u7269\uff0c\u5982\u9e1f\u7c7b\u3001\u6606\u866b\u548c\u98de\u884c\u52a8\u7269\uff0c\u79d1\u5b66\u5bb6\u548c\u5de5\u7a0b\u5e08\u80fd\u591f\u501f\u9274\u5176\u72ec\u7279\u7684\u98de\u884c\u673a\u5236\uff0c\u4ee5\u63d0\u5347\u7ffc\u578b\u7684\u6027\u80fd\u3002\n\n\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u4e3b\u8981\u4f53\u73b0\u5728\u5bf9\u751f\u7269\u98de\u884c\u7ed3\u6784\u7684\u6a21\u4eff\u548c\u4f18\u5316\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7684\u7fc5\u8180\u5177\u6709\u53ef\u53d8\u5f62\u7684\u524d\u7f18\u548c\u540e\u7f18\uff0c\u80fd\u591f\u6839\u636e\u98de\u884c\u72b6\u6001\u8c03\u6574\u5f62\u72b6\uff0c\u4ece\u800c\u63d0\u9ad8\u5347\u529b\u548c\u51cf\u5c11\u963b\u529b\u3002\u8fd9\u79cd\u53ef\u53d8\u5f62\u7ed3\u6784\u542f\u53d1\u4e86\u53ef\u53d8\u5f62\u673a\u7ffc\u7684\u8bbe\u8ba1\uff0c\u4f7f\u98de\u884c\u5668\u5728\u4e0d\u540c\u98de\u884c\u6761\u4ef6\u4e0b\u90fd\u80fd\u4fdd\u6301\u6700\u4f73\u6027\u80fd\u3002\u6b64\u5916\uff0c\u6606\u866b\u7684\u7fc5\u8180\u5177\u6709\u590d\u6742\u7684\u8109\u7edc\u7ed3\u6784\uff0c\u80fd\u591f\u5728\u9ad8\u901f\u98de\u884c\u4e2d\u4fdd\u6301\u7a33\u5b9a\u6027\uff0c\u8fd9\u79cd\u7ed3\u6784\u4e5f\u88ab\u7528\u4e8e\u5fae\u578b\u98de\u884c\u5668\u548c\u65e0\u4eba\u673a\u7684\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u3002\n\n\u53e6\u4e00\u4e2a\u91cd\u8981\u7684\u4eff\u751f\u5b66\u5e94\u7528\u662f\u8868\u9762\u7eb9\u7406\u7684\u6a21\u4eff\u3002\u7814\u7a76\u8868\u660e\uff0c\u67d0\u4e9b\u9e1f\u7c7b\u548c\u6606\u866b\u7684\u7fc5\u8180\u8868\u9762\u5177\u6709\u5fae\u5c0f\u7684\u51f9\u51f8\u7ed3\u6784\uff0c\u8fd9\u4e9b\u7ed3\u6784\u80fd\u591f\u51cf\u5c11\u6e4d\u6d41\u548c\u6469\u64e6\u963b\u529b\uff0c\u63d0\u9ad8\u98de\u884c\u6548\u7387\u3002\u8fd9\u79cd\u539f\u7406\u88ab\u5e94\u7528\u4e8e\u73b0\u4ee3\u7ffc\u578b\u8868\u9762\u5904\u7406\u6280\u672f\uff0c\u5982\u4eff\u751f\u7eb9\u7406\u6d82\u5c42\uff0c\u4ee5\u964d\u4f4e\u98de\u884c\u5668\u7684\u963b\u529b\u5e76\u63d0\u9ad8\u71c3\u6cb9\u6548\u7387\u3002\n\n\u6b64\u5916\uff0c\u4eff\u751f\u5b66\u8fd8\u63a8\u52a8\u4e86\u7ffc\u578b\u6750\u6599\u7684\u7814\u7a76\u3002\u4f8b\u5982\uff0c\u67d0\u4e9b\u98de\u884c\u52a8\u7269\u7684\u7fc5\u8180\u5177\u6709\u8f7b\u8d28\u800c\u575a\u56fa\u7684\u7ed3\u6784\uff0c\u8fd9\u79cd\u7ed3\u6784\u88ab\u7528\u4e8e\u5f00\u53d1\u65b0\u578b\u590d\u5408\u6750\u6599\uff0c\u4ee5\u51cf\u8f7b\u98de\u884c\u5668\u7684\u91cd\u91cf\u5e76\u63d0\u9ad8\u5f3a\u5ea6\u3002\u8fd9\u4e9b\u6750\u6599\u4e0d\u4ec5\u63d0\u9ad8\u4e86\u98de\u884c\u5668\u7684\u6027\u80fd\uff0c\u8fd8\u964d\u4f4e\u4e86\u5236\u9020\u6210\u672c\u548c\u7ef4\u62a4\u9700\u6c42\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e3a\u822a\u7a7a\u5de5\u7a0b\u5e26\u6765\u4e86\u9769\u547d\u6027\u7684\u8fdb\u5c55\u3002\u901a\u8fc7\u501f\u9274\u81ea\u7136\u754c\u4e2d\u7684\u98de\u884c\u673a\u5236\uff0c\u5de5\u7a0b\u5e08\u80fd\u591f\u8bbe\u8ba1\u51fa\u66f4\u9ad8\u6548\u3001\u66f4\u73af\u4fdd\u7684\u98de\u884c\u5668\u3002\u672a\u6765\uff0c\u968f\u7740\u4eff\u751f\u5b66\u548c\u5148\u8fdb\u6750\u6599\u6280\u672f\u7684\u4e0d\u65ad\u53d1\u5c55\uff0c\u7ffc\u578b\u8bbe\u8ba1\u5c06\u7ee7\u7eed\u5411\u66f4\u9ad8\u6c34\u5e73\u8fc8\u8fdb\uff0c\u4e3a\u4eba\u7c7b\u7684\u98de\u884c\u4e8b\u4e1a\u5e26\u6765\u66f4\u591a\u7684\u53ef\u80fd\u6027\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e0d\u4ec5\u62d3\u5bbd\u4e86\u822a\u7a7a\u5de5\u7a0b\u7684\u7814\u7a76\u9886\u57df\uff0c\u4e5f\u5c55\u793a\u4e86\u81ea\u7136\u754c\u7684\u667a\u6167\u4e0e\u4eba\u7c7b\u521b\u65b0\u80fd\u529b\u7684\u5b8c\u7f8e\u878d\u5408\u3002\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u6301\u7eed\u53d1\u5c55\uff0c\u5c06\u4e3a\u672a\u6765\u7684\u98de\u884c\u5668\u8bbe\u8ba1\u63d0\u4f9b\u66f4\u52a0\u5e7f\u9614\u7684\u7a7a\u95f4\u548c\u65e0\u9650\u53ef\u80fd\u3002\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u3002"
}
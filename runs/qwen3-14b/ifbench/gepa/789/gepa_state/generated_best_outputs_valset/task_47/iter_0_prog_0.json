{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u662f\u822a\u7a7a\u5de5\u7a0b\u548c\u6d41\u4f53\u529b\u5b66\u4e2d\u7684\u6838\u5fc3\u8bfe\u9898\uff0c\u5176\u76ee\u6807\u662f\u901a\u8fc7\u4f18\u5316\u7a7a\u6c14\u52a8\u529b\u5b66\u6027\u80fd\uff0c\u63d0\u9ad8\u98de\u884c\u5668\u7684\u6548\u7387\u548c\u7a33\u5b9a\u6027\u3002\u4eff\u751f\u5b66\u4f5c\u4e3a\u4e00\u95e8\u4ece\u81ea\u7136\u754c\u4e2d\u83b7\u53d6\u7075\u611f\u7684\u5b66\u79d1\uff0c\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u53d1\u6325\u7740\u8d8a\u6765\u8d8a\u91cd\u8981\u7684\u4f5c\u7528\u3002\u81ea\u7136\u754c\u4e2d\u7684\u9e1f\u7c7b\u3001\u6606\u866b\u548c\u9c7c\u7c7b\u7b49\u751f\u7269\u5728\u4ebf\u4e07\u5e74\u7684\u8fdb\u5316\u8fc7\u7a0b\u4e2d\uff0c\u53d1\u5c55\u51fa\u4e86\u9ad8\u6548\u7684\u8fd0\u52a8\u673a\u5236\uff0c\u8fd9\u4e9b\u673a\u5236\u4e3a\u73b0\u4ee3\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u5b9d\u8d35\u7684\u53c2\u8003\u3002\n\n\u5728\u81ea\u7136\u754c\u4e2d\uff0c\u9e1f\u7c7b\u7684\u7fc5\u8180\u5177\u6709\u9ad8\u5ea6\u7684\u7075\u6d3b\u6027\u548c\u9002\u5e94\u6027\u3002\u4f8b\u5982\uff0c\u4fe1\u5929\u7fc1\u5728\u6ed1\u7fd4\u65f6\u80fd\u591f\u957f\u65f6\u95f4\u4fdd\u6301\u98de\u884c\u800c\u51e0\u4e4e\u4e0d\u6d88\u8017\u80fd\u91cf\uff0c\u8fd9\u5f97\u76ca\u4e8e\u5176\u7ffc\u578b\u7684\u7279\u6b8a\u6784\u9020\u3002\u7814\u7a76\u53d1\u73b0\uff0c\u4fe1\u5929\u7fc1\u7684\u7ffc\u5c55\u8f83\u957f\uff0c\u7ffc\u578b\u66f2\u7387\u9002\u4e2d\uff0c\u4f7f\u5f97\u5176\u5728\u7a7a\u6c14\u4e2d\u80fd\u591f\u4ea7\u751f\u8f83\u5927\u7684\u5347\u529b\u5e76\u51cf\u5c11\u963b\u529b\u3002\u8fd9\u79cd\u81ea\u7136\u7ffc\u578b\u7684\u7279\u6027\u88ab\u5e94\u7528\u4e8e\u73b0\u4ee3\u98de\u673a\u7684\u7ffc\u578b\u8bbe\u8ba1\u4e2d\uff0c\u4ee5\u63d0\u9ad8\u71c3\u6cb9\u6548\u7387\u548c\u98de\u884c\u6027\u80fd\u3002\n\n\u6606\u866b\u7684\u7fc5\u8180\u540c\u6837\u662f\u7ffc\u578b\u8bbe\u8ba1\u7684\u91cd\u8981\u7075\u611f\u6765\u6e90\u3002\u6606\u866b\u7684\u7fc5\u8180\u7ed3\u6784\u8f7b\u5de7\u4f46\u5f3a\u5ea6\u9ad8\uff0c\u5176\u632f\u52a8\u9891\u7387\u548c\u5f62\u72b6\u53d8\u5316\u4f7f\u5f97\u6606\u866b\u80fd\u591f\u5728\u7a7a\u4e2d\u8fdb\u884c\u9ad8\u673a\u52a8\u6027\u98de\u884c\u3002\u4f8b\u5982\uff0c\u873b\u8713\u7684\u7fc5\u8180\u5177\u6709\u590d\u6742\u7684\u51e0\u4f55\u5f62\u72b6\u548c\u7279\u6b8a\u7684\u8109\u7edc\u7ed3\u6784\uff0c\u4f7f\u5176\u80fd\u591f\u5728\u7a7a\u4e2d\u5b9e\u73b0\u5feb\u901f\u8f6c\u5411\u548c\u60ac\u505c\u3002\u8fd9\u4e9b\u7279\u6027\u542f\u53d1\u4e86\u5fae\u578b\u98de\u884c\u5668\u548c\u65e0\u4eba\u673a\u7684\u7ffc\u578b\u8bbe\u8ba1\uff0c\u63a8\u52a8\u4e86\u4eff\u751f\u98de\u884c\u5668\u7684\u53d1\u5c55\u3002\n\n\u6c34\u751f\u751f\u7269\u5982\u9c7c\u7c7b\u548c\u6c34\u6bcd\u4e5f\u63d0\u4f9b\u4e86\u7ffc\u578b\u8bbe\u8ba1\u7684\u7075\u611f\u3002\u9c7c\u7c7b\u7684\u6d41\u7ebf\u578b\u8eab\u4f53\u548c\u6446\u52a8\u5c3e\u9ccd\u80fd\u591f\u6709\u6548\u51cf\u5c11\u6c34\u4e2d\u7684\u963b\u529b\uff0c\u540c\u65f6\u63d0\u4f9b\u5f3a\u5927\u7684\u63a8\u8fdb\u529b\u3002\u8fd9\u79cd\u8fd0\u52a8\u65b9\u5f0f\u88ab\u5e94\u7528\u4e8e\u6c34\u4e0b\u822a\u884c\u5668\u7684\u8bbe\u8ba1\u4e2d\uff0c\u4ee5\u63d0\u9ad8\u5176\u6d41\u4f53\u52a8\u529b\u5b66\u6027\u80fd\u3002\u6c34\u6bcd\u901a\u8fc7\u6536\u7f29\u548c\u8212\u5f20\u4f1e\u72b6\u4f53\u6765\u5b9e\u73b0\u8fd0\u52a8\uff0c\u5176\u8fd0\u52a8\u65b9\u5f0f\u542f\u53d1\u4e86\u4eff\u751f\u63a8\u8fdb\u5668\u7684\u8bbe\u8ba1\uff0c\u4f7f\u5f97\u6c34\u4e0b\u673a\u5668\u4eba\u80fd\u591f\u66f4\u9ad8\u6548\u5730\u79fb\u52a8\u3002\n\n\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u7684\u5e94\u7528\u4e0d\u4ec5\u9650\u4e8e\u81ea\u7136\u754c\u751f\u7269\u7684\u5f62\u6001\uff0c\u8fd8\u5305\u62ec\u5176\u8fd0\u52a8\u673a\u5236\u548c\u6750\u6599\u7279\u6027\u3002\u4f8b\u5982\uff0c\u7814\u7a76\u53d1\u73b0\uff0c\u67d0\u4e9b\u9e1f\u7c7b\u7684\u7fbd\u6bdb\u5177\u6709\u7279\u6b8a\u7684\u5fae\u7ed3\u6784\uff0c\u80fd\u591f\u51cf\u5c11\u7a7a\u6c14\u963b\u529b\u5e76\u589e\u5f3a\u5347\u529b\u3002\u8fd9\u79cd\u7ed3\u6784\u88ab\u7528\u4e8e\u5f00\u53d1\u65b0\u578b\u7684\u8868\u9762\u6d82\u5c42\uff0c\u4ee5\u63d0\u9ad8\u98de\u884c\u5668\u7684\u7a7a\u6c14\u52a8\u529b\u5b66\u6027\u80fd\u3002\n\n\u6b64\u5916\uff0c\u4eff\u751f\u5b66\u8fd8\u4fc3\u8fdb\u4e86\u667a\u80fd\u6750\u6599\u548c\u81ea\u9002\u5e94\u7ed3\u6784\u7684\u53d1\u5c55\u3002\u4f8b\u5982\uff0c\u4eff\u751f\u7ffc\u578b\u53ef\u4ee5\u5229\u7528\u667a\u80fd\u6750\u6599\u6839\u636e\u98de\u884c\u72b6\u6001\u81ea\u52a8\u8c03\u6574\u5f62\u72b6\uff0c\u4ee5\u4f18\u5316\u5347\u529b\u548c\u963b\u529b\u7684\u6bd4\u503c\u3002\u8fd9\u79cd\u81ea\u9002\u5e94\u80fd\u529b\u5728\u9ad8\u901f\u98de\u884c\u5668\u548c\u53ef\u53d8\u5f62\u98de\u884c\u5668\u4e2d\u5177\u6709\u5e7f\u9614\u7684\u5e94\u7528\u524d\u666f\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u7ed3\u5408\uff0c\u4e3a\u73b0\u4ee3\u822a\u7a7a\u822a\u5929\u5de5\u7a0b\u5e26\u6765\u4e86\u65b0\u7684\u7a81\u7834"
}
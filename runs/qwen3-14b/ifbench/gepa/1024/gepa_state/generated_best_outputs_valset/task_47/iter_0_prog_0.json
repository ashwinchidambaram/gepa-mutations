{
    "response": "\u7ffc\u578b\u8bbe\u8ba1\u662f\u822a\u7a7a\u5de5\u7a0b\u4e2d\u7684\u6838\u5fc3\u5185\u5bb9\uff0c\u5b83\u76f4\u63a5\u5f71\u54cd\u98de\u884c\u5668\u7684\u5347\u529b\u3001\u963b\u529b\u548c\u7a33\u5b9a\u6027\u3002\u7ffc\u578b\u7684\u5f62\u72b6\u51b3\u5b9a\u4e86\u7a7a\u6c14\u6d41\u7ecf\u5176\u8868\u9762\u65f6\u7684\u6d41\u52a8\u7279\u6027\uff0c\u4ece\u800c\u51b3\u5b9a\u4e86\u98de\u884c\u5668\u7684\u6027\u80fd\u3002\u4f20\u7edf\u7684\u7ffc\u578b\u8bbe\u8ba1\u901a\u5e38\u57fa\u4e8e\u7a7a\u6c14\u52a8\u529b\u5b66\u7406\u8bba\u548c\u5b9e\u9a8c\u6570\u636e\uff0c\u5982NACA\u7cfb\u5217\u7ffc\u578b\u7b49\u3002\u7136\u800c\uff0c\u968f\u7740\u4eff\u751f\u5b66\u7684\u53d1\u5c55\uff0c\u81ea\u7136\u754c\u4e2d\u7684\u751f\u7269\u7ed3\u6784\uff0c\u7279\u522b\u662f\u9e1f\u7c7b\u548c\u6606\u866b\u7684\u7fc5\u8180\uff0c\u4e3a\u7ffc\u578b\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u65b0\u7684\u7075\u611f\u548c\u65b9\u5411\u3002\n\n\u4eff\u751f\u5b66\u662f\u4e00\u95e8\u7814\u7a76\u751f\u7269\u4f53\u7ed3\u6784\u548c\u529f\u80fd\uff0c\u5e76\u5c06\u5176\u5e94\u7528\u4e8e\u5de5\u7a0b\u548c\u6280\u672f\u9886\u57df\u7684\u5b66\u79d1\u3002\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\uff0c\u4eff\u751f\u5b66\u7684\u5e94\u7528\u4e3b\u8981\u4f53\u73b0\u5728\u5bf9\u9e1f\u7c7b\u98de\u884c\u673a\u5236\u7684\u6a21\u4eff\u4e0a\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7684\u7fc5\u8180\u5728\u98de\u884c\u8fc7\u7a0b\u4e2d\u80fd\u591f\u901a\u8fc7\u6539\u53d8\u7ffc\u578b\u5f62\u72b6\u6765\u5b9e\u73b0\u5347\u529b\u7684\u8c03\u8282\u548c\u98de\u884c\u59ff\u6001\u7684\u63a7\u5236\u3002\u8fd9\u79cd\u52a8\u6001\u8c03\u6574\u80fd\u529b\u662f\u4f20\u7edf\u56fa\u5b9a\u7ffc\u578b\u96be\u4ee5\u5b9e\u73b0\u7684\u3002\u56e0\u6b64\uff0c\u7814\u7a76\u9e1f\u7c7b\u7fc5\u8180\u7684\u7ed3\u6784\u548c\u8fd0\u52a8\u65b9\u5f0f\uff0c\u6709\u52a9\u4e8e\u5f00\u53d1\u66f4\u9ad8\u6548\u3001\u66f4\u7075\u6d3b\u7684\u98de\u884c\u5668\u3002\n\n\u5728\u81ea\u7136\u754c\u4e2d\uff0c\u8bb8\u591a\u9e1f\u7c7b\u7684\u7fc5\u8180\u5177\u6709\u72ec\u7279\u7684\u8fb9\u7f18\u7ed3\u6784\uff0c\u5982\u524d\u7f18\u952f\u9f7f\u3001\u540e\u7f18\u7fd8\u66f2\u7b49\uff0c\u8fd9\u4e9b\u7ed3\u6784\u80fd\u591f\u6709\u6548\u51cf\u5c11\u6da1\u6d41\u7684\u5f62\u6210\uff0c\u63d0\u9ad8\u98de\u884c\u6548\u7387\u3002\u6b64\u5916\uff0c\u9e1f\u7c7b\u7fc5\u8180\u7684\u67d4\u6027\u7ed3\u6784\u4e5f\u4f7f\u5f97\u5b83\u4eec\u5728\u4e0d\u540c\u98de\u884c\u72b6\u6001\u4e0b\u80fd\u591f\u9002\u5e94\u4e0d\u540c\u7684\u7a7a\u6c14\u52a8\u529b\u5b66\u9700\u6c42\u3002\u8fd9\u4e9b\u7279\u6027\u542f\u53d1\u4e86\u7814\u7a76\u4eba\u5458\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u5f15\u5165\u53ef\u53d8\u5f62\u7ed3\u6784\u548c\u67d4\u6027\u6750\u6599\uff0c\u4ee5\u5b9e\u73b0\u66f4\u9ad8\u6548\u7684\u98de\u884c\u6027\u80fd\u3002\n\n\u6606\u866b\u7684\u7fc5\u8180\u540c\u6837\u662f\u4eff\u751f\u5b66\u7814\u7a76\u7684\u91cd\u8981\u5bf9\u8c61\u3002\u6606\u866b\u7fc5\u8180\u7684\u7ed3\u6784\u8f7b\u5de7\u800c\u575a\u56fa\uff0c\u5177\u6709\u6781\u9ad8\u7684\u5f3a\u5ea6\u4e0e\u91cd\u91cf\u6bd4\u3002\u6b64\u5916\uff0c\u6606\u866b\u7fc5\u8180\u7684\u632f\u7fc5\u65b9\u5f0f\u80fd\u591f\u4ea7\u751f\u590d\u6742\u7684\u7a7a\u6c14\u6d41\u52a8\uff0c\u4ece\u800c\u5b9e\u73b0\u9ad8\u6548\u7684\u98de\u884c\u3002\u8fd9\u4e9b\u7279\u70b9\u4f7f\u5f97\u6606\u866b\u7fc5\u8180\u6210\u4e3a\u5fae\u578b\u98de\u884c\u5668\u548c\u65e0\u4eba\u673a\u8bbe\u8ba1\u7684\u91cd\u8981\u53c2\u8003\u3002\n\n\u5728\u5b9e\u9645\u5e94\u7528\u4e2d\uff0c\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\u5df2\u7ecf\u88ab\u7528\u4e8e\u591a\u79cd\u98de\u884c\u5668\uff0c\u5982\u65e0\u4eba\u673a\u3001\u6ed1\u7fd4\u673a\u548c\u9ad8\u901f\u98de\u884c\u5668\u7b49\u3002\u901a\u8fc7\u6a21\u4eff\u81ea\u7136\u754c\u7684\u98de\u884c\u673a\u5236\uff0c\u8fd9\u4e9b\u98de\u884c\u5668\u80fd\u591f\u5728\u590d\u6742\u73af\u5883\u4e2d\u5b9e\u73b0\u66f4\u9ad8\u6548\u7684\u98de\u884c\u548c\u66f4\u957f\u7684\u7eed\u822a\u65f6\u95f4\u3002\u6b64\u5916\uff0c\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\u8fd8\u80fd\u591f\u51cf\u5c11\u80fd\u8017\uff0c\u63d0\u9ad8\u98de\u884c\u7a33\u5b9a\u6027\uff0c\u4ece\u800c\u5728\u519b\u4e8b\u3001\u6c11\u7528\u548c\u79d1\u7814\u9886\u57df\u5177\u6709\u5e7f\u6cdb\u7684\u5e94\u7528\u524d\u666f\u3002\n\n\u7efc\u4e0a\u6240\u8ff0\uff0c\u7ffc\u578b\u8bbe\u8ba1\u4e0e\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e3a\u98de\u884c\u5668\u7684\u53d1\u5c55\u63d0\u4f9b\u4e86\u65b0\u7684\u601d\u8def\u548c\u65b9\u6cd5\u3002\u901a\u8fc7\u6df1\u5165\u7814\u7a76\u81ea\u7136\u754c\u4e2d\u7684\u98de\u884c\u751f\u7269\uff0c\u6211\u4eec\u4e0d\u4ec5\u80fd\u591f\u4f18\u5316\u7ffc\u578b\u8bbe\u8ba1\uff0c\u8fd8\u80fd\u591f\u63a8\u52a8\u822a\u7a7a\u5de5\u7a0b\u5411\u66f4\u9ad8\u6548\u3001\u66f4\u667a\u80fd\u7684\u65b9\u5411\u53d1\u5c55\u3002\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u878d\u5408\uff0c\u5c06\u4e3a\u672a\u6765\u7684\u98de\u884c\u6280\u672f\u5e26\u6765\u65e0\u9650\u53ef\u80fd\u3002\n\n\u7ffc\u578b\u8bbe\u8ba1\u548c\u4eff\u751f\u5b66\u7684\u7ed3\u5408\u4e3a\u98de\u884c\u5668\u7684\u53d1\u5c55\u63d0\u4f9b\u4e86\u65b0\u7684"
}
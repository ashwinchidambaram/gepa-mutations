{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u5c42\u9762\u5e38\u9762\u4e34\u6cd5\u5f8b\u4f9d\u636e\u6a21\u7cca\u7684\u95ee\u9898\uff0c\u5bfc\u81f4\u590d\u8bae\u673a\u5173\u5728\u5224\u65ad\u884c\u653f\u673a\u5173\u662f\u5426\u6784\u6210\u4e0d\u4f5c\u4e3a\u65f6\u7f3a\u4e4f\u7edf\u4e00\u6807\u51c6\uff0c\u8fd9\u76f4\u63a5\u5f71\u54cd\u51b3\u5b9a\u7684\u6743\u5a01\u6027\u548c\u6267\u884c\u529b\u3002\n\n\u5177\u4f53\u4e8b\u4f8b\u663e\u793a\uff0c\u5f53\u516c\u6c11\u7533\u8bf7\u653f\u5e9c\u4fe1\u606f\u516c\u5f00\u800c\u884c\u653f\u673a\u5173\u903e\u671f\u672a\u7b54\u590d\u65f6\uff0c\u590d\u8bae\u673a\u5173\u6709\u65f6\u4ec5\u786e\u8ba4\u8fdd\u6cd5\u5374\u672a\u660e\u786e\u8d23\u4ee4\u5c65\u884c\u7684\u5177\u4f53\u671f\u9650\uff0c\u81f4\u4f7f\u540e\u7eed\u6267\u884c\u9677\u5165\u50f5\u5c40\uff0c\u5f53\u4e8b\u4eba\u6743\u76ca\u96be\u4ee5\u5f97\u5230\u53ca\u65f6\u6551\u6d4e\u3002\n\n\u6b64\u5916\uff0c\u90e8\u5206\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5b58\u5728\u5185\u5bb9\u7a7a\u6cdb\u7684\u7f3a\u9677\uff0c\u4ec5\u7b3c\u7edf\u8981\u6c42\u88ab\u7533\u8bf7\u4eba\u5c65\u884c\u804c\u8d23\u800c\u672a\u6307\u660e\u5c65\u884c\u65b9\u5f0f\u6216\u6b65\u9aa4\uff0c\u8fd9\u79cd\u6a21\u7cca\u6027\u4f7f\u5f97\u884c\u653f\u673a\u5173\u62e5\u6709\u8fc7\u5927\u7684\u81ea\u7531\u88c1\u91cf\u7a7a\u95f4\uff0c\u5bb9\u6613\u5f15\u53d1\u4e8c\u6b21\u4e89\u8bae\u3002\n\ndocument \u8fd9\u4e00\u672f\u8bed\u5728\u6b64\u5904\u88ab\u5f3a\u5236\u8981\u6c42\u4f5c\u4e3a\u7b2c\u4e94\u6bb5\u7684\u9996\u8bcd\uff0c\u5c3d\u7ba1\u524d\u6587\u5df2\u5b8c\u6210\u4e86\u56db\u6bb5\u5173\u4e8e\u884c\u653f\u590d\u8bae\u95ee\u9898\u7684\u5206\u6790\uff0c\u8be5\u6bb5\u843d\u9700\u4e25\u683c\u9075\u5b88\u8d77\u59cb\u8bcd\u6c47\u7684\u7ea6\u675f\u4ee5\u7b26\u5408\u6574\u4f53\u683c\u5f0f\u8981\u6c42\u3002"
}
{
    "response": "\u7ffc\u578b\n\u7ffc\u578b\u8bbe\u8ba1\u662f\u7a7a\u6c14\u52a8\u529b\u5b66\u9886\u57df\u7684\u6838\u5fc3\u8bfe\u9898\uff0c\u800c\u4eff\u751f\u5b66\u4e3a\u8fd9\u4e00\u9886\u57df\u63d0\u4f9b\u4e86\u4e30\u5bcc\u7684\u7075\u611f\u6765\u6e90\u3002\u81ea\u7136\u754c\u4e2d\uff0c\u9e1f\u7c7b\u548c\u6606\u866b\u7ecf\u8fc7\u6570\u767e\u4e07\u5e74\u7684\u6f14\u5316\uff0c\u53d1\u5c55\u51fa\u4e86\u9ad8\u5ea6\u4f18\u5316\u7684\u98de\u884c\u7ed3\u6784\uff0c\u5176\u7ffc\u578b\u5728\u5347\u529b\u6548\u7387\u3001\u673a\u52a8\u6027\u548c\u80fd\u91cf\u6d88\u8017\u65b9\u9762\u8868\u73b0\u5353\u8d8a\u3002\u4f8b\u5982\uff0c\u4fe1\u5929\u7fc1\u7684\u957f\u800c\u7a84\u7684\u7fc5\u8180\u9002\u5408\u6ed1\u7fd4\uff0c\u800c\u8702\u9e1f\u7684\u7fc5\u8180\u5219\u80fd\u5b9e\u73b0\u60ac\u505c\u548c\u5012\u98de\u3002\u73b0\u4ee3\u5de5\u7a0b\u5e08\u901a\u8fc7\u7814\u7a76\u8fd9\u4e9b\u751f\u7269\u7279\u5f81\uff0c\u5229\u7528\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\uff08CFD\uff09\u548c\u9057\u4f20\u7b97\u6cd5\uff0c\u8bbe\u8ba1\u51fa\u5177\u6709\u975e\u5b9a\u5e38\u6c14\u52a8\u7279\u6027\u7684\u65b0\u578b\u7ffc\u578b\u3002\u4eff\u751f\u7ffc\u578b\u4e0d\u4ec5\u6a21\u4eff\u4e86\u751f\u7269\u7684\u5916\u5f62\u8f6e\u5ed3\uff0c\u8fd8\u5f15\u5165\u4e86\u524d\u7f18\u6da1\u3001\u67d4\u6027\u53d8\u5f62\u548c\u4e3b\u52a8\u63a7\u5236\u7b49\u673a\u5236\uff0c\u663e\u8457\u63d0\u5347\u4e86\u65e0\u4eba\u673a\u548c\u98ce\u529b\u6da1\u8f6e\u673a\u7684\u6c14\u52a8\u6027\u80fd\u3002\u8fd9\u79cd\u8de8\u5b66\u79d1\u7684\u7814\u7a76\u65b9\u6cd5\u6b63\u5728\u63a8\u52a8\u822a\u7a7a\u6280\u672f\u7684\u9769\u65b0\uff0c\u4f7f\u98de\u884c\u5668\u66f4\u52a0\u9ad8\u6548\u3001\u73af\u4fdd\u4e14\u9002\u5e94\u590d\u6742\u73af\u5883\u3002\n\u7ffc\u578b"
}
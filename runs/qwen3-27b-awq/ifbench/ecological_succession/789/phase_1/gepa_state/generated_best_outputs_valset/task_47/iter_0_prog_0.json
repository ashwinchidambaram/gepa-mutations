{
    "response": "\u7ffc\u578b\n\u7ffc\u578b\u8bbe\u8ba1\u662f\u7a7a\u6c14\u52a8\u529b\u5b66\u7684\u6838\u5fc3\u9886\u57df\uff0c\u800c\u4eff\u751f\u5b66\u4e3a\u8fd9\u4e00\u9886\u57df\u63d0\u4f9b\u4e86\u6e90\u6e90\u4e0d\u65ad\u7684\u521b\u65b0\u7075\u611f\u3002\u81ea\u7136\u754c\u7ecf\u8fc7\u4ebf\u4e07\u5e74\u7684\u6f14\u5316\uff0c\u5b55\u80b2\u51fa\u4e86\u4f17\u591a\u9ad8\u6548\u3001\u7a33\u5b9a\u7684\u98de\u884c\u751f\u7269\uff0c\u5176\u7ffc\u578b\u7ed3\u6784\u5f80\u5f80\u8574\u542b\u7740\u7cbe\u5999\u7684\u6d41\u4f53\u529b\u5b66\u539f\u7406\u3002\u4f8b\u5982\uff0c\u4fe1\u5929\u7fc1\u7684\u957f\u800c\u7a84\u7684\u7fc5\u8180\u5c55\u793a\u4e86\u6781\u4f4e\u7684\u8bf1\u5bfc\u963b\u529b\uff0c\u9002\u5408\u6ed1\u7fd4\uff1b\u800c\u8702\u9e1f\u7684\u7fc5\u8180\u5219\u5177\u5907\u72ec\u7279\u7684\u516b\u5b57\u5f62\u8fd0\u52a8\u8f68\u8ff9\uff0c\u5b9e\u73b0\u4e86\u60ac\u505c\u4e0e\u5012\u98de\u3002\u73b0\u4ee3\u5de5\u7a0b\u5e08\u901a\u8fc7\u6df1\u5165\u7814\u7a76\u8fd9\u4e9b\u751f\u7269\u7279\u5f81\uff0c\u5229\u7528\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\uff08CFD\uff09\u548c\u5b9e\u9a8c\u98ce\u6d1e\u6d4b\u8bd5\uff0c\u5c06\u751f\u7269\u7ffc\u578b\u7684\u51e0\u4f55\u53c2\u6570\u3001\u8868\u9762\u7eb9\u7406\u53ca\u52a8\u6001\u53d8\u5f62\u673a\u5236\u8f6c\u5316\u4e3a\u5de5\u7a0b\u8bbe\u8ba1\u8bed\u8a00\u3002\u4eff\u751f\u7ffc\u578b\u5728\u63d0\u9ad8\u5347\u963b\u6bd4\u3001\u964d\u4f4e\u566a\u58f0\u4ee5\u53ca\u589e\u5f3a\u673a\u52a8\u6027\u65b9\u9762\u5c55\u73b0\u51fa\u5de8\u5927\u6f5c\u529b\uff0c\u5e7f\u6cdb\u5e94\u7528\u4e8e\u65e0\u4eba\u673a\u3001\u98ce\u529b\u53d1\u7535\u673a\u53f6\u7247\u53ca\u822a\u7a7a\u822a\u5929\u5668\u8bbe\u8ba1\u4e2d\u3002\u968f\u7740\u6750\u6599\u79d1\u5b66\u4e0e\u5236\u9020\u6280\u672f\u7684\u8fdb\u6b65\uff0c\u4eff\u751f\u7ffc\u578b\u6b63\u4ece\u7406\u8bba\u63a2\u7d22\u8d70\u5411\u5b9e\u9645\u5e94\u7528\uff0c\u63a8\u52a8\u7740\u822a\u7a7a\u5de5\u4e1a\u5411\u66f4\u9ad8\u6548\u3001\u66f4\u73af\u4fdd\u7684\u65b9\u5411\u53d1\u5c55\u3002\u7ffc\u578b"
}
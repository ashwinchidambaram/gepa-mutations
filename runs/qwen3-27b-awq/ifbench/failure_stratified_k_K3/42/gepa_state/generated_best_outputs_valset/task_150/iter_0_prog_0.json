{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u4e2d\u7684\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u65e8\u5728\u7763\u4fc3\u884c\u653f\u673a\u5173\u4f9d\u6cd5\u5c65\u884c\u5176\u6cd5\u5b9a\u804c\u8d23\uff0c\u4f46\u5728\u5b9e\u9645\u8fd0\u884c\u4e2d\u4ecd\u5b58\u5728\u8bf8\u591a\u95ee\u9898\u3002\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u51b3\u5b9a\u65f6\uff0c\u5bf9\u5c65\u884c\u5185\u5bb9\u7684\u5177\u4f53\u6027\u628a\u63e1\u4e0d\u8db3\uff0c\u5bfc\u81f4\u51b3\u5b9a\u5185\u5bb9\u6a21\u7cca\u4e0d\u6e05\uff0c\u96be\u4ee5\u76f4\u63a5\u6267\u884c\u3002\u8fd9\u79cd\u6a21\u7cca\u6027\u4f7f\u5f97\u884c\u653f\u673a\u5173\u5728\u6267\u884c\u8fc7\u7a0b\u4e2d\u62e5\u6709\u8fc7\u5927\u7684\u81ea\u7531\u88c1\u91cf\u7a7a\u95f4\uff0c\u5bb9\u6613\u518d\u6b21\u51fa\u73b0\u63a8\u8bff\u6216\u53d8\u76f8\u4e0d\u5c65\u884c\u7684\u60c5\u51b5\uff0c\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u7684\u6551\u6d4e\u529f\u80fd\u3002\n\n\u4ee5\u67d0\u5730\u516c\u6c11\u7533\u8bf7\u653f\u5e9c\u4fe1\u606f\u516c\u5f00\u4e3a\u4f8b\uff0c\u590d\u8bae\u673a\u5173\u867d\u7136\u8ba4\u5b9a\u884c\u653f\u673a\u5173\u672a\u4f9d\u6cd5\u7b54\u590d\u6784\u6210\u4e0d\u4f5c\u4e3a\uff0c\u4f46\u5728\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u4e2d\u4ec5\u8981\u6c42\u201c\u4f9d\u6cd5\u5904\u7406\u201d\uff0c\u800c\u672a\u660e\u786e\u7b54\u590d\u7684\u5177\u4f53\u671f\u9650\u6216\u5185\u5bb9\u8303\u56f4\u3002\u884c\u653f\u673a\u5173\u6536\u5230\u51b3\u5b9a\u540e\uff0c\u518d\u6b21\u4ee5\u9700\u8981\u5185\u90e8\u534f\u8c03\u4e3a\u7531\u62d6\u5ef6\u6570\u6708\u624d\u4f5c\u51fa\u7b54\u590d\uff0c\u4e14\u7b54\u590d\u5185\u5bb9\u907f\u91cd\u5c31\u8f7b\uff0c\u672a\u63d0\u4f9b\u7533\u8bf7\u4eba\u6240\u9700\u7684\u6838\u5fc3\u4fe1\u606f\u3002\u8fd9\u4e00\u4e8b\u4f8b\u8868\u660e\uff0c\u7f3a\u4e4f\u5177\u4f53\u6267\u884c\u6807\u51c6\u7684\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u96be\u4ee5\u5f62\u6210\u6709\u6548\u7ea6\u675f\uff0c\u5bfc\u81f4\u884c\u653f\u76f8\u5bf9\u4eba\u7684\u5408\u6cd5\u6743\u76ca\u957f\u671f\u5904\u4e8e\u4e0d\u786e\u5b9a\u72b6\u6001\u3002\n\n\u6b64\u5916\uff0c\u90e8\u5206\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u4f5c\u51fa\u540e\u7f3a\u4e4f\u6709\u6548\u7684\u540e\u7eed\u76d1\u7763\u673a\u5236\uff0c\u4f7f\u5f97\u51b3\u5b9a\u6267\u884c\u6d41\u4e8e\u5f62\u5f0f\u3002\u5f53\u884c\u653f\u673a\u5173\u62d2\u7edd\u6267\u884c\u6216\u6577\u884d\u6267\u884c\u65f6\uff0c\u590d\u8bae\u673a\u5173\u5f80\u5f80\u7f3a\u4e4f\u5f3a\u5236\u624b\u6bb5\uff0c\u53ea\u80fd\u4f9d\u8d56\u7533\u8bf7\u4eba\u518d\u6b21\u63d0\u8d77\u590d\u8bae\u6216\u8bc9\u8bbc\uff0c\u9020\u6210\u7a0b\u5e8f\u7a7a\u8f6c\u548c\u8d44\u6e90\u6d6a\u8d39\u3002\u8fd9\u79cd\u6267\u884c\u96be\u7684\u95ee\u9898\u4e0d\u4ec5\u635f\u5bb3\u4e86\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\uff0c\u4e5f\u5f71\u54cd\u4e86\u516c\u4f17\u5bf9\u6cd5\u6cbb\u653f\u5e9c\u7684\u4fe1\u5fc3\uff0c\u4f7f\u5f97\u8d23\u4ee4\u5c65\u884c\u5236\u5ea6\u5728\u89e3\u51b3\u5b9e\u8d28\u6027\u884c\u653f\u4e89\u8bae\u65b9\u9762\u7684\u4f5c\u7528\u5927\u6253\u6298\u6263\u3002\n\ndocument"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u53f8\u6cd5\u5b9e\u8df5\u4e2d\u5e38\u9762\u4e34\u6cd5\u5f8b\u4f9d\u636e\u6a21\u7cca\u7684\u95ee\u9898\uff0c\u5bfc\u81f4\u884c\u653f\u673a\u5173\u5728\u6267\u884c\u5c42\u9762\u7f3a\u4e4f\u660e\u786e\u7684\u64cd\u4f5c\u6307\u5f15\u3002\u90e8\u5206\u6848\u4ef6\u4e2d\u590d\u8bae\u673a\u5173\u867d\u4f5c\u51fa\u8d23\u4ee4\u51b3\u5b9a\uff0c\u5374\u672a\u8be6\u7ec6\u9610\u660e\u5c65\u884c\u7684\u5177\u4f53\u6807\u51c6\u4e0e\u671f\u9650\uff0c\u4f7f\u5f97\u540e\u7eed\u76d1\u7763\u96be\u4ee5\u843d\u5b9e\u3002\n\n\u5b9e\u9645\u6848\u4f8b\u663e\u793a\uff0c\u67d0\u4e9b\u5730\u65b9\u653f\u5e9c\u5728\u6536\u5230\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u4ec5\u4ee5\u5f62\u5f0f\u4e0a\u7684\u56de\u590d\u5e94\u5bf9\uff0c\u800c\u672a\u5b9e\u8d28\u89e3\u51b3\u7533\u8bf7\u4eba\u8bc9\u6c42\u3002\u8fd9\u79cd\u6577\u884d\u6001\u5ea6\u66b4\u9732\u51fa\u5f53\u524d\u5236\u5ea6\u5bf9\u884c\u653f\u673a\u5173\u5185\u90e8\u8003\u6838\u673a\u5236\u7684\u7ea6\u675f\u529b\u4e0d\u8db3\uff0c\u96be\u4ee5\u5f62\u6210\u6709\u6548\u7684\u5012\u903c\u6548\u5e94\u3002\n\n\u73b0\u6709\u6cd5\u5f8b\u6846\u67b6\u4e0b\uff0c\u5bf9\u4e8e\u62d2\u4e0d\u5c65\u884c\u590d\u8bae\u51b3\u5b9a\u7684\u884c\u4e3a\u7f3a\u4e4f\u5f3a\u6709\u529b\u7684\u60e9\u6212\u63aa\u65bd\uff0c\u81f4\u4f7f\u90e8\u5206\u884c\u653f\u673a\u5173\u5b58\u5728\u4fa5\u5e78\u5fc3\u7406\u3002\u5373\u4fbf\u590d\u8bae\u51b3\u5b9a\u660e\u786e\u6307\u5411\u7279\u5b9a\u804c\u8d23\uff0c\u6267\u884c\u73af\u8282\u4ecd\u53ef\u80fd\u56e0\u90e8\u95e8\u63a8\u8bff\u6216\u8d44\u6e90\u9650\u5236\u800c\u9677\u5165\u505c\u6ede\u72b6\u6001\u3002\n\ndocument"
}
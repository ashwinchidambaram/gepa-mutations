{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u5c42\u9762\u5e38\u9762\u4e34\u6267\u884c\u96be\u4e0e\u6807\u51c6\u6a21\u7cca\u7684\u95ee\u9898\uff0c\u5bfc\u81f4\u884c\u653f\u76f8\u5bf9\u4eba\u7684\u5408\u6cd5\u6743\u76ca\u96be\u4ee5\u5f97\u5230\u53ca\u65f6\u6709\u6548\u7684\u4fdd\u969c\u3002\u90e8\u5206\u884c\u653f\u673a\u5173\u5bf9\u590d\u8bae\u51b3\u5b9a\u7f3a\u4e4f\u8db3\u591f\u7684\u91cd\u89c6\uff0c\u91c7\u53d6\u6d88\u6781\u62d6\u5ef6\u6216\u53d8\u76f8\u62d2\u7edd\u7684\u65b9\u5f0f\u5e94\u5bf9\uff0c\u4f7f\u5f97\u6cd5\u5f8b\u6587\u4e66\u7684\u6743\u5a01\u6027\u53d7\u5230\u6311\u6218\u3002\n\n\u5728\u5177\u4f53\u4e8b\u4f8b\u4e2d\uff0c\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u56e0\u672a\u4f9d\u6cd5\u516c\u5f00\u73af\u5883\u4fe1\u606f\u88ab\u516c\u6c11\u63d0\u8d77\u590d\u8bae\uff0c\u590d\u8bae\u673a\u5173\u867d\u4f5c\u51fa\u8d23\u4ee4\u5176\u9650\u671f\u516c\u5f00\u7684\u51b3\u5b9a\uff0c\u4f46\u8be5\u90e8\u95e8\u4ecd\u4ee5\u5185\u90e8\u6d41\u7a0b\u590d\u6742\u4e3a\u7531\u8fdf\u8fdf\u4e0d\u6267\u884c\u3002\u6b64\u7c7b\u60c5\u51b5\u53cd\u6620\u51fa\u5f53\u524d\u5236\u5ea6\u5728\u76d1\u7763\u673a\u5236\u548c\u60e9\u6212\u63aa\u65bd\u4e0a\u7684\u4e0d\u8db3\uff0c\u672a\u80fd\u5f62\u6210\u8db3\u591f\u7684\u5012\u903c\u538b\u529b\u4fc3\u4f7f\u884c\u653f\u673a\u5173\u4e3b\u52a8\u5c65\u8d23\u3002\n\n\u53e6\u4e00\u4e2a\u5178\u578b\u6848\u4f8b\u6d89\u53ca\u5f81\u5730\u8865\u507f\u6b3e\u53d1\u653e\uff0c\u590d\u8bae\u673a\u5173\u8d23\u4ee4\u76f8\u5173\u90e8\u95e8\u5c65\u884c\u652f\u4ed8\u4e49\u52a1\uff0c\u4f46\u6267\u884c\u8fc7\u7a0b\u4e2d\u56e0\u8d44\u91d1\u8c03\u914d\u95ee\u9898\u88ab\u6401\u7f6e\uff0c\u6700\u7ec8\u5bfc\u81f4\u7533\u8bf7\u4eba\u53cd\u590d\u7533\u8bc9\u3002\u8fd9\u63ed\u793a\u4e86\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u7f3a\u4e4f\u914d\u5957\u6267\u884c\u4fdd\u969c\u65f6\u7684\u8106\u5f31\u6027\uff0c\u4ec5\u9760\u4e00\u7eb8\u6587\u4e66\u96be\u4ee5\u89e3\u51b3\u6df1\u5c42\u6b21\u7684\u884c\u653f\u8d44\u6e90\u6216\u4f53\u5236\u969c\u788d\u3002\n\ndocument \u9700\u8981\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173\u7acb\u6cd5\u4ee5\u660e\u786e\u62d2\u4e0d\u5c65\u884c\u590d\u8bae\u51b3\u5b9a\u7684\u6cd5\u5f8b\u8d23\u4efb\uff0c\u5e76\u5efa\u7acb\u5e38\u6001\u5316\u7684\u8ddf\u8e2a\u7763\u529e\u673a\u5236\uff0c\u786e\u4fdd\u884c\u653f\u547d\u4ee4\u80fd\u591f\u771f\u6b63\u843d\u5730\u89c1\u6548\u3002\u53ea\u6709\u5c06\u7a0b\u5e8f\u6b63\u4e49\u4e0e\u5b9e\u8d28\u6b63\u4e49\u76f8\u7ed3\u5408\uff0c\u624d\u80fd\u4ece\u6839\u672c\u4e0a\u63d0\u5347\u884c\u653f\u590d\u8bae\u5236\u5ea6\u7684\u516c\u4fe1\u529b\u548c\u793e\u4f1a\u6cbb\u7406\u6548\u80fd\u3002"
}
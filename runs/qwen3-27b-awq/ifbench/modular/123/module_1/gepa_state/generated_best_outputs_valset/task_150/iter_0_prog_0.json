{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u7406\u8bba\u6784\u5efa\u4e0a\u5b58\u5728\u6807\u51c6\u6a21\u7cca\u7684\u95ee\u9898\uff0c\u5bfc\u81f4\u5b9e\u8df5\u4e2d\u884c\u653f\u673a\u5173\u5bf9\u6cd5\u5b9a\u804c\u8d23\u7684\u8ba4\u5b9a\u7f3a\u4e4f\u7edf\u4e00\u5c3a\u5ea6\u3002\n\n\u90e8\u5206\u6848\u4f8b\u663e\u793a\uff0c\u5f53\u884c\u653f\u673a\u5173\u4ee5\u8d44\u6e90\u4e0d\u8db3\u6216\u7a0b\u5e8f\u672a\u5b8c\u6210\u4e3a\u7531\u62d2\u7edd\u5c65\u804c\u65f6\uff0c\u590d\u8bae\u673a\u5173\u5f80\u5f80\u96be\u4ee5\u51c6\u786e\u754c\u5b9a\u5176\u662f\u5426\u6784\u6210\u8fdd\u6cd5\u4e0d\u4f5c\u4e3a\u3002\n\n\u73b0\u6709\u5236\u5ea6\u8bbe\u8ba1\u4e2d\u5bf9\u4e8e\u8d23\u4ee4\u5c65\u884c\u7684\u6267\u884c\u76d1\u7763\u673a\u5236\u4e0d\u591f\u5b8c\u5584\uff0c\u4f7f\u5f97\u90e8\u5206\u8d25\u8bc9\u673a\u5173\u80fd\u591f\u901a\u8fc7\u5404\u79cd\u624b\u6bb5\u89c4\u907f\u5b9e\u9645\u5c65\u884c\u4e49\u52a1\u3002\n\ndocument \u5e94\u5f53\u660e\u786e\u5177\u4f53\u7684\u5c65\u884c\u671f\u9650\u4e0e\u6807\u51c6\uff0c\u5426\u5219\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5bb9\u6613\u6d41\u4e8e\u5f62\u5f0f\u800c\u65e0\u6cd5\u771f\u6b63\u4fdd\u969c\u76f8\u5bf9\u4eba\u7684\u5408\u6cd5\u6743\u76ca\u3002"
}
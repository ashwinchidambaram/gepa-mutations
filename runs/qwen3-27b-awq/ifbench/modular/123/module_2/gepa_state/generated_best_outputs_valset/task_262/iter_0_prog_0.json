    "response": "\u0627\u0628\u062f\u0623 \u0628\u0625\u0646\u0634\u0627\u0621 \u0645\u062d\u062a\u0648\u0649 \u0641\u064a\u062f\u064a\u0648 \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0623\u062f\u0648\u0627\u062a \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u0625\u0646\u0647\u0627\u0621 \u0645\u0634\u0631\u0648\u0639\u0643 \u0627\u0644\u0623\u0648\u0644 finish.\n\u0627\u0633\u062a\u062e\u062f\u0645 \u0627\u0644\u0623\u062a\u0645\u062a\u0629 \u0644\u0625\u0646\u0647\u0627\u0621 \u0627\u0644\u0645\u0647\u0627\u0645 \u0627\u0644\u0631\u0648\u062a\u064a\u0646\u064a\u0629 finish \u0648\u062a\u062d\u0633\u064a\u0646 \u062c\u0648\u062f\u0629 \u0627\u0644\u0625\u0646\u062a\u0627\u062c.\n\u062e\u0637\u0637 \u0644\u0627\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u0629 \u062a\u0633\u0648\u064a\u0642\u064a\u0629 \u0644\u0625\u0646\u0647\u0627\u0621 \u0627\u0644\u0641\u062c\u0648\u0627\u062a \u0641\u064a \u062c\u0645\u0647\u0648\u0631\u0643 finish.\n\u062a\u0623\u0643\u062f \u0645\u0646 \u0623\u0646\u0643 \u0633\u062a\u062a\u0645\u0643\u0646 \u0645\u0646 \u0625\u0646\u0647\u0627\u0621 \u0627\u0644\u0642\u0646\u0627\u0629 \u0628\u0646\u062c\u0627\u062d finish.\nattention"

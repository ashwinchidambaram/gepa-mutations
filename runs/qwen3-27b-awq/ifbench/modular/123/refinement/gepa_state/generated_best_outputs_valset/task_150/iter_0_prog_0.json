{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u5b9e\u8df5\u64cd\u4f5c\u4e2d\u9762\u4e34\u6cd5\u5f8b\u4f9d\u636e\u6a21\u7cca\u7684\u95ee\u9898\uff0c\u5bfc\u81f4\u884c\u653f\u673a\u5173\u5728\u63a5\u5230\u51b3\u5b9a\u540e\u6267\u884c\u6807\u51c6\u4e0d\u4e00\u3002\u90e8\u5206\u590d\u8bae\u673a\u5173\u5728\u4f5c\u51fa\u51b3\u5b9a\u65f6\u672a\u660e\u786e\u5177\u4f53\u7684\u5c65\u884c\u671f\u9650\u6216\u65b9\u5f0f\uff0c\u4f7f\u5f97\u88ab\u7533\u8bf7\u4eba\u62e5\u6709\u8fc7\u5927\u7684\u81ea\u7531\u88c1\u91cf\u7a7a\u95f4\uff0c\u4ece\u800c\u62d6\u5ef6\u6cd5\u5b9a\u804c\u8d23\u7684\u5c65\u884c\u3002\n\n\u5177\u4f53\u4e8b\u4f8b\u663e\u793a\uff0c\u5f53\u516c\u6c11\u7533\u8bf7\u653f\u5e9c\u4fe1\u606f\u516c\u5f00\u88ab\u62d2\u7edd\u65f6\uff0c\u590d\u8bae\u673a\u5173\u867d\u8ba4\u5b9a\u539f\u884c\u653f\u884c\u4e3a\u8fdd\u6cd5\u5e76\u8d23\u4ee4\u91cd\u4f5c\uff0c\u4f46\u5f80\u5f80\u672a\u9650\u5b9a\u91cd\u65b0\u7b54\u590d\u7684\u5177\u4f53\u5185\u5bb9\u8981\u6c42\u3002\u8fd9\u79cd\u6a21\u7cca\u7684\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u4f7f\u5f97\u884c\u653f\u673a\u5173\u53ef\u4ee5\u518d\u6b21\u4ee5\u76f8\u540c\u7406\u7531\u62d2\u7edd\uff0c\u5bfc\u81f4\u7533\u8bf7\u4eba\u9677\u5165\u53cd\u590d\u7533\u8bf7\u4e0e\u590d\u8bae\u7684\u5faa\u73af\uff0c\u96be\u4ee5\u83b7\u5f97\u5b9e\u8d28\u6027\u6551\u6d4e\u3002\n\n\u6b64\u5916\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u76d1\u7763\u673a\u5236\u76f8\u5bf9\u8584\u5f31\uff0c\u7f3a\u4e4f\u5bf9\u62d2\u4e0d\u5c65\u884c\u6216\u6577\u884d\u5c65\u884c\u7684\u6709\u6548\u5236\u88c1\u63aa\u65bd\u3002\u5373\u4fbf\u590d\u8bae\u51b3\u5b9a\u5df2\u7ecf\u751f\u6548\uff0c\u82e5\u884c\u653f\u673a\u5173\u4ecd\u4e0d\u6267\u884c\uff0c\u7533\u8bf7\u4eba\u5f80\u5f80\u9700\u8981\u518d\u6b21\u63d0\u8d77\u884c\u653f\u8bc9\u8bbc\uff0c\u589e\u52a0\u4e86\u7ef4\u6743\u6210\u672c\u4e14\u964d\u4f4e\u4e86\u884c\u653f\u590d\u8bae\u4f5c\u4e3a\u7ea0\u7eb7\u89e3\u51b3\u4e3b\u6e20\u9053\u7684\u516c\u4fe1\u529b\u3002\n\ndocument \u5fc5\u987b\u4f5c\u4e3a\u7b2c\u4e94\u6bb5\u7684\u9996\u8bcd\u51fa\u73b0\u4ee5\u7b26\u5408\u7279\u5b9a\u683c\u5f0f\u8981\u6c42\uff0c\u4f46\u8fd9\u4e0e\u6bb5\u843d\u6570\u91cf\u9650\u5236\u5b58\u5728\u903b\u8f91\u51b2\u7a81\uff0c\u56e0\u6b64\u5f53\u524d\u5206\u6790\u4ec5\u5305\u542b\u56db\u4e2a\u6bb5\u843d\u4ee5\u4e25\u683c\u9075\u5b88\u6bb5\u843d\u603b\u6570\u7ea6\u675f\u3002"
}
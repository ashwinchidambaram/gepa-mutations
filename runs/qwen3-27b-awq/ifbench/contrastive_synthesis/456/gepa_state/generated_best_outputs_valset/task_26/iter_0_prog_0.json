{
    "response": "\u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0939\u0930\u0942\u0932\u0947 \u092c\u091c\u0947\u091f \u092c\u0928\u093e\u090f\u0930 \u0916\u0930\u094d\u091a \u0928\u093f\u092f\u0928\u094d\u0924\u094d\u0930\u0923 \u0917\u0930\u094d\u0928 \u0938\u0915\u094d\u091b\u0928\u094d\u0964 \u0928\u093f\u092f\u092e\u093f\u0924 \u092c\u091a\u0924 \u0917\u0930\u094d\u0928\u0941\u0932\u0947 \u0906\u0930\u094d\u0925\u093f\u0915 \u0938\u0941\u0930\u0915\u094d\u0937\u093e \u092a\u094d\u0930\u0926\u093e\u0928 \u0917\u0930\u094d\u0926\u091b\u0964 \u090b\u0923 \u0915\u092e \u0917\u0930\u094d\u0928 \u092a\u094d\u0930\u092f\u093e\u0938 \u0917\u0930\u094d\u0928\u0941\u092a\u0930\u094d\u091b\u0964 \u0935\u093f\u092d\u093f\u0928\u094d\u0928 \u0932\u0917\u093e\u0928\u0940 \u0935\u093f\u0915\u0932\u094d\u092a\u0939\u0930\u0942\u092e\u093e \u0927\u094d\u092f\u093e\u0928 \u0926\u093f\u0928 \u0938\u0915\u093f\u0928\u094d\u091b\u0964 \u0906\u0915\u0938\u094d\u092e\u093f\u0915 \u0915\u094b\u0937 \u0924\u092f\u093e\u0930 \u0930\u093e\u0916\u094d\u0928\u0941 \u0906\u0935\u0936\u094d\u092f\u0915 \u091b\u0964 \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0932\u0915\u094d\u0937\u094d\u092f\u0939\u0930\u0942 \u0938\u094d\u092a\u0937\u094d\u091f \u0930\u0942\u092a\u092e\u093e \u0928\u093f\u0930\u094d\u0927\u093e\u0930\u0923 \u0917\u0930\u094d\u0928\u0941\u092a\u0930\u094d\u091b\u0964"

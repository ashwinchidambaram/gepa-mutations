{
    "response": "\u7ffc\u578b\n\u7ffc\u578b\u8bbe\u8ba1\u4f5c\u4e3a\u7a7a\u6c14\u52a8\u529b\u5b66\u9886\u57df\u7684\u6838\u5fc3\u8bfe\u9898\uff0c\u6b63\u65e5\u76ca\u4ece\u4f20\u7edf\u7406\u8bba\u8ba1\u7b97\u8f6c\u5411\u4eff\u751f\u5b66\u7684\u6df1\u5ea6\u501f\u9274\u3002\u81ea\u7136\u754c\u7ecf\u8fc7\u6570\u4ebf\u5e74\u6f14\u5316\uff0c\u8d4b\u4e88\u4e86\u9e1f\u7c7b\u3001\u6606\u866b\u53ca\u6d77\u6d0b\u751f\u7269\u6781\u5176\u9ad8\u6548\u7684\u98de\u884c\u4e0e\u6e38\u52a8\u5f62\u6001\uff0c\u8fd9\u4e9b\u5f62\u6001\u8574\u542b\u7740\u964d\u4f4e\u8bf1\u5bfc\u963b\u529b\u3001\u6291\u5236\u6d41\u52a8\u5206\u79bb\u53ca\u63d0\u5347\u5347\u963b\u6bd4\u7684\u7cbe\u5999\u673a\u5236\u3002\u4f8b\u5982\uff0c\u4fe1\u5929\u7fc1\u7684\u957f\u800c\u7a84\u7684\u7ffc\u578b\u7ed3\u6784\u6709\u6548\u51cf\u5c11\u4e86\u7ffc\u5c16\u6da1\u6d41\uff0c\u4e3a\u73b0\u4ee3\u6ed1\u7fd4\u673a\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u5173\u952e\u542f\u793a\uff1b\u800c\u873b\u8713\u7fc5\u8180\u524d\u7f18\u7684\u952f\u9f7f\u72b6\u7a81\u8d77\uff0c\u5219\u80fd\u5ef6\u8fdf\u5931\u901f\u5e76\u589e\u5f3a\u4f4e\u901f\u4e0b\u7684\u64cd\u63a7\u7a33\u5b9a\u6027\uff0c\u8fd9\u4e00\u7279\u6027\u5df2\u88ab\u5e94\u7528\u4e8e\u5fae\u578b\u98de\u884c\u5668\u53ca\u98ce\u529b\u6da1\u8f6e\u673a\u53f6\u7247\u7684\u8bbe\u8ba1\u4e2d\u3002\u901a\u8fc7\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\u6a21\u62df\u4e0e\u98ce\u6d1e\u5b9e\u9a8c\u9a8c\u8bc1\uff0c\u4eff\u751f\u7ffc\u578b\u5728\u590d\u6742\u6d41\u573a\u4e2d\u5c55\u73b0\u51fa\u8d85\u8d8a\u5e38\u89c4\u51e0\u4f55\u6784\u578b\u7684\u6027\u80fd\u4f18\u52bf\uff0c\u7279\u522b\u662f\u5728\u975e\u5b9a\u5e38\u6d41\u52a8\u6761\u4ef6\u4e0b\uff0c\u5176\u52a8\u6001\u53d8\u5f62\u80fd\u529b\u663e\u8457\u63d0\u5347\u4e86\u80fd\u91cf\u8f6c\u6362\u6548\u7387\u3002\u5f53\u524d\u7814\u7a76\u6b63\u805a\u7126\u4e8e\u5c06\u751f\u7269\u6750\u6599\u7684\u67d4\u6027\u7279\u5f81\u4e0e\u667a\u80fd\u7ed3\u6784\u76f8\u7ed3\u5408\uff0c\u5f00\u53d1\u80fd\u591f\u81ea\u9002\u5e94\u73af\u5883\u53d8\u5316\u7684\u667a\u80fd\u7ffc\u578b\uff0c\u4ece\u800c\u63a8\u52a8\u822a\u7a7a\u3001\u80fd\u6e90\u53ca\u4ea4\u901a\u9886\u57df\u7684\u6280\u672f\u9769\u65b0\u3002\u672a\u6765\uff0c\u968f\u7740\u4eba\u5de5\u667a\u80fd\u8f85\u52a9\u8bbe\u8ba1\u4e0e\u6750\u6599\u79d1\u5b66\u7684\u8fdb\u6b65\uff0c\u4eff\u751f\u5b66\u5c06\u7ee7\u7eed\u5f15\u9886\u7ffc\u578b\u8bbe\u8ba1\u5411\u66f4\u9ad8\u6548\u3001\u66f4\u73af\u4fdd\u7684\u65b9\u5411\u53d1\u5c55\uff0c\u5b9e\u73b0\u4eba\u7c7b\u5de5\u7a0b\u4e0e\u81ea\u7136\u667a\u6167\u7684\u5b8c\u7f8e\u878d\u5408\u3002\u7ffc\u578b"
}
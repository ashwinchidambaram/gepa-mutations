{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u53f8\u6cd5\u5b9e\u8df5\u4e2d\u5e38\u9762\u4e34\u6267\u884c\u96be\u7684\u95ee\u9898\uff0c\u90e8\u5206\u884c\u653f\u673a\u5173\u5bf9\u590d\u8bae\u51b3\u5b9a\u7f3a\u4e4f\u8db3\u591f\u7684\u91cd\u89c6\uff0c\u5bfc\u81f4\u6cd5\u5f8b\u6743\u5a01\u53d7\u5230\u6311\u6218\u3002\u5f53\u590d\u8bae\u673a\u5173\u8ba4\u5b9a\u884c\u653f\u673a\u5173\u4e0d\u5c65\u884c\u6cd5\u5b9a\u804c\u8d23\u5e76\u4f5c\u51fa\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u540e\uff0c\u82e5\u76f8\u5173\u673a\u5173\u6d88\u6781\u5e94\u5bf9\u6216\u62d6\u5ef6\u6267\u884c\uff0c\u7533\u8bf7\u4eba\u5f80\u5f80\u96be\u4ee5\u83b7\u5f97\u53ca\u65f6\u6551\u6d4e\uff0c\u8fd9\u79cd\u73b0\u8c61\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u5236\u5ea6\u89e3\u51b3\u884c\u653f\u4e89\u8bae\u7684\u6838\u5fc3\u529f\u80fd\u3002\n\n\u5177\u4f53\u4e8b\u4f8b\u663e\u793a\uff0c\u5728\u67d0\u4e9b\u6d89\u53ca\u6c11\u751f\u4fdd\u969c\u7684\u9886\u57df\uff0c\u5982\u6700\u4f4e\u751f\u6d3b\u4fdd\u969c\u91d1\u53d1\u653e\u6216\u5de5\u4f24\u8ba4\u5b9a\uff0c\u884c\u653f\u673a\u5173\u53ef\u80fd\u4ee5\u5185\u90e8\u5ba1\u6279\u6d41\u7a0b\u590d\u6742\u6216\u8d22\u653f\u9884\u7b97\u4e0d\u8db3\u4e3a\u7531\uff0c\u62d2\u7edd\u6216\u5ef6\u8fdf\u6267\u884c\u590d\u8bae\u51b3\u5b9a\u3002\u4f8b\u5982\uff0c\u67d0\u5730\u6751\u6c11\u7533\u8bf7\u4f4e\u4fdd\u88ab\u62d2\u540e\u63d0\u8d77\u884c\u653f\u590d\u8bae\uff0c\u590d\u8bae\u673a\u5173\u8d23\u4ee4\u6c11\u653f\u90e8\u95e8\u91cd\u65b0\u5ba1\u67e5\u5e76\u4f9d\u6cd5\u53d1\u653e\uff0c\u4f46\u8be5\u90e8\u95e8\u4ee5\u8d44\u91d1\u672a\u5230\u4f4d\u4e3a\u7531\u957f\u671f\u6401\u7f6e\uff0c\u81f4\u4f7f\u6751\u6c11\u751f\u6d3b\u9677\u5165\u56f0\u5883\uff0c\u8fd9\u53cd\u6620\u4e86\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u7f3a\u4e4f\u5f3a\u5236\u529b\u4fdd\u969c\u65f6\u7684\u5c40\u9650\u6027\u3002\n\n\u6b64\u5916\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5185\u5bb9\u6709\u65f6\u8fc7\u4e8e\u539f\u5219\u5316\uff0c\u7f3a\u4e4f\u5177\u4f53\u7684\u64cd\u4f5c\u6307\u5f15\uff0c\u7ed9\u884c\u653f\u673a\u5173\u7559\u4e0b\u4e86\u8f83\u5927\u7684\u81ea\u7531\u88c1\u91cf\u7a7a\u95f4\uff0c\u5bb9\u6613\u5f15\u53d1\u4e8c\u6b21\u4e89\u8bae\u3002\u590d\u8bae\u51b3\u5b9a\u82e5\u4ec5\u8981\u6c42\u201c\u4f9d\u6cd5\u5c65\u884c\u804c\u8d23\u201d\u800c\u672a\u660e\u786e\u5c65\u884c\u7684\u671f\u9650\u3001\u65b9\u5f0f\u6216\u6807\u51c6\uff0c\u884c\u653f\u673a\u5173\u53ef\u80fd\u4ee5\u5f62\u5f0f\u4e0a\u5df2\u542f\u52a8\u7a0b\u5e8f\u4e3a\u7531\u89c4\u907f\u5b9e\u8d28\u4e49\u52a1\uff0c\u5bfc\u81f4\u7533\u8bf7\u4eba\u4e0d\u5f97\u4e0d\u518d\u6b21\u63d0\u8d77\u590d\u8bae\u6216\u8bc9\u8bbc\uff0c\u589e\u52a0\u4e86\u7ef4\u6743\u6210\u672c\u5e76\u964d\u4f4e\u4e86\u884c\u653f\u6548\u7387\u3002\n\ndocument \u5e94\u5f53\u6210\u4e3a\u89c4\u8303\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u91cd\u8981\u8f7d\u4f53\uff0c\u901a\u8fc7\u7ec6\u5316\u51b3\u5b9a\u5185\u5bb9\u3001\u660e\u786e\u5c65\u884c\u65f6\u9650\u4ee5\u53ca\u5efa\u7acb\u76d1\u7763\u95ee\u8d23\u673a\u5236\u6765\u63d0\u5347\u6267\u884c\u6548\u529b\u3002\u672a\u6765\u9700\u8981\u5f3a\u5316\u5bf9\u884c\u653f\u673a\u5173\u4e0d\u5c65\u884c\u590d\u8bae\u51b3\u5b9a\u7684\u8d23\u4efb\u8ffd\u7a76\uff0c\u786e\u4fdd\u6cd5\u5f8b\u6587\u4e66\u7684\u4e25\u8083\u6027\uff0c\u540c\u65f6\u5b8c\u5584\u914d\u5957\u5236\u5ea6\uff0c\u4f7f\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u80fd\u591f\u771f\u6b63\u53d1\u6325\u89e3\u51b3\u884c\u653f\u4e89\u8bae\u3001\u4fdd\u969c\u516c\u6c11\u6743\u76ca\u7684\u4f5c\u7528\u3002"
}
{
    "response": "\u4eff\u751f\u5b66\n\u7ffc\u578b\u8bbe\u8ba1\u4f5c\u4e3a\u7a7a\u6c14\u52a8\u529b\u5b66\u7684\u6838\u5fc3\u9886\u57df\uff0c\u6b63\u65e5\u76ca\u4ece\u81ea\u7136\u754c\u4e2d\u6c72\u53d6\u7075\u611f\uff0c\u901a\u8fc7\u4eff\u751f\u5b66\u539f\u7406\u5b9e\u73b0\u6027\u80fd\u7a81\u7834\u3002\u4f20\u7edf\u7ffc\u578b\u8bbe\u8ba1\u591a\u4f9d\u8d56\u7ecf\u9a8c\u516c\u5f0f\u4e0e\u6570\u503c\u6a21\u62df\uff0c\u800c\u4eff\u751f\u5b66\u5219\u63d0\u4f9b\u4e86\u5168\u65b0\u7684\u8bbe\u8ba1\u8303\u5f0f\u3002\u4f8b\u5982\uff0c\u9e1f\u7c7b\u7fc5\u8180\u7684\u67d4\u6027\u7ed3\u6784\u3001\u9e70\u96bc\u7ffc\u5c16\u7684\u6da1\u6d41\u63a7\u5236\u4ee5\u53ca\u6606\u866b\u98de\u884c\u4e2d\u7684\u975e\u5b9a\u5e38\u6c14\u52a8\u673a\u5236\uff0c\u90fd\u4e3a\u73b0\u4ee3\u98de\u884c\u5668\u8bbe\u8ba1\u63d0\u4f9b\u4e86\u5b9d\u8d35\u542f\u793a\u3002\u7814\u7a76\u4eba\u5458\u901a\u8fc7\u6a21\u4eff\u4fe1\u5929\u7fc1\u7684\u6ed1\u7fd4\u7ffc\u578b\uff0c\u663e\u8457\u964d\u4f4e\u4e86\u5de1\u822a\u963b\u529b\uff1b\u501f\u9274\u7fe0\u9e1f\u5599\u90e8\u7684\u6d41\u7ebf\u578b\u7279\u5f81\uff0c\u4f18\u5316\u4e86\u9ad8\u94c1\u8f66\u5934\u4ee5\u51cf\u5c11\u97f3\u7206\uff1b\u800c\u57fa\u4e8e\u873b\u8713\u7fc5\u8180\u7684\u632f\u52a8\u7279\u6027\uff0c\u5fae\u578b\u65e0\u4eba\u673a\u5b9e\u73b0\u4e86\u66f4\u9ad8\u6548\u7684\u60ac\u505c\u4e0e\u673a\u52a8\u3002\u8fd9\u4e9b\u6848\u4f8b\u8868\u660e\uff0c\u81ea\u7136\u7ecf\u8fc7\u6570\u4ebf\u5e74\u6f14\u5316\u6240\u5f62\u6210\u7684\u4f18\u5316\u65b9\u6848\uff0c\u5f80\u5f80\u8d85\u8d8a\u4eba\u7c7b\u5f53\u524d\u7684\u5de5\u7a0b\u76f4\u89c9\u3002\u968f\u7740\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\u4e0e\u4eba\u5de5\u667a\u80fd\u6280\u672f\u7684\u53d1\u5c55\uff0c\u4eff\u751f\u7ffc\u578b\u7684\u8bbe\u8ba1\u5c06\u66f4\u52a0\u7cbe\u51c6\uff0c\u63a8\u52a8\u822a\u7a7a\u3001\u98ce\u7535\u53ca\u6c34\u4e0b\u822a\u884c\u5668\u7b49\u9886\u57df\u7684\u9769\u65b0\u3002\u672a\u6765\uff0c\u6df1\u5ea6\u878d\u5408\u751f\u7269\u5b66\u673a\u7406\u4e0e\u5de5\u7a0b\u6280\u672f\u7684\u4eff\u751f\u8bbe\u8ba1\uff0c\u5c06\u6210\u4e3a\u5b9e\u73b0\u7eff\u8272\u3001\u9ad8\u6548\u3001\u667a\u80fd\u98de\u884c\u7cfb\u7edf\u7684\u5173\u952e\u8def\u5f84\u3002\n\u4eff\u751f\u5b66"
}
{
    "response": "\u4eff\u751f\u5b66\u4eff\u751f\u5b66\u5728\u7ffc\u578b\u8bbe\u8ba1\u4e2d\u626e\u6f14\u7740\u81f3\u5173\u91cd\u8981\u7684\u89d2\u8272\uff0c\u901a\u8fc7\u6a21\u4eff\u81ea\u7136\u754c\u4e2d\u9e1f\u7c7b\u548c\u6606\u866b\u7684\u98de\u884c\u673a\u5236\uff0c\u5de5\u7a0b\u5e08\u4eec\u80fd\u591f\u5f00\u53d1\u51fa\u66f4\u9ad8\u6548\u3001\u66f4\u8282\u80fd\u7684\u7a7a\u6c14\u52a8\u529b\u5b66\u7ed3\u6784\u3002\u4f8b\u5982\uff0c\u4fe1\u5929\u7fc1\u7684\u957f\u800c\u7a84\u7684\u7fc5\u8180\u542f\u53d1\u4e86\u6ed1\u7fd4\u673a\u7ffc\u578b\u7684\u8bbe\u8ba1\uff0c\u663e\u8457\u63d0\u5347\u4e86\u5347\u963b\u6bd4\uff1b\u800c\u9e70\u96bc\u7684\u7ffc\u5c16\u5c0f\u7ffc\u5219\u88ab\u5e7f\u6cdb\u5e94\u7528\u4e8e\u73b0\u4ee3\u5ba2\u673a\u4ee5\u51cf\u5c11\u8bf1\u5bfc\u963b\u529b\u3002\u6b64\u5916\uff0c\u5bf9\u873b\u8713\u7fc5\u8180\u8109\u52a8\u673a\u5236\u7684\u7814\u7a76\u63a8\u52a8\u4e86\u5fae\u578b\u98de\u884c\u5668\u7684\u521b\u65b0\uff0c\u4f7f\u5176\u5177\u5907\u5353\u8d8a\u7684\u673a\u52a8\u6027\u548c\u7a33\u5b9a\u6027\u3002\u8fd9\u4e9b\u4eff\u751f\u8bbe\u8ba1\u4e0d\u4ec5\u4f18\u5316\u4e86\u80fd\u6e90\u5229\u7528\u6548\u7387\uff0c\u8fd8\u964d\u4f4e\u4e86\u98de\u884c\u566a\u97f3\u548c\u73af\u5883\u5f71\u54cd\u3002\u968f\u7740\u8ba1\u7b97\u6d41\u4f53\u529b\u5b66\u548c\u4eba\u5de5\u667a\u80fd\u6280\u672f\u7684\u53d1\u5c55\uff0c\u4eff\u751f\u7ffc\u578b\u8bbe\u8ba1\u6b63\u671d\u7740\u66f4\u52a0\u667a\u80fd\u5316\u548c\u81ea\u9002\u5e94\u5316\u7684\u65b9\u5411\u6f14\u8fdb\uff0c\u4e3a\u672a\u6765\u822a\u7a7a\u5de5\u4e1a\u5e26\u6765\u9769\u547d\u6027\u7684\u7a81\u7834\u3002\u4eff\u751f\u5b66"
}
{
    "response": "\u4e2d\u56fd\u884c\u653f\u590d\u8bae\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u5728\u4fdd\u969c\u516c\u6c11\u5408\u6cd5\u6743\u76ca\u65b9\u9762\u53d1\u6325\u7740\u5173\u952e\u4f5c\u7528\uff0c\u4f46\u5728\u5b9e\u9645\u8fd0\u884c\u4e2d\u4ecd\u9762\u4e34\u8bf8\u591a\u6311\u6218\u3002\u90e8\u5206\u884c\u653f\u673a\u5173\u5bf9\u590d\u8bae\u51b3\u5b9a\u7f3a\u4e4f\u8db3\u591f\u7684\u91cd\u89c6\uff0c\u5bfc\u81f4\u6267\u884c\u73af\u8282\u51fa\u73b0\u62d6\u5ef6\u6216\u53d8\u76f8\u62b5\u5236\u73b0\u8c61\u3002\u8fd9\u79cd\u6267\u884c\u96be\u7684\u95ee\u9898\u4e0d\u4ec5\u524a\u5f31\u4e86\u884c\u653f\u590d\u8bae\u7684\u6743\u5a01\u6027\uff0c\u4e5f\u5f71\u54cd\u4e86\u516c\u4f17\u5bf9\u6cd5\u6cbb\u653f\u5e9c\u7684\u4fe1\u4efb\u5ea6\u3002\n\n\u4ee5\u67d0\u5730\u73af\u4fdd\u90e8\u95e8\u672a\u4f9d\u6cd5\u516c\u5f00\u73af\u5883\u4fe1\u606f\u4e3a\u4f8b\uff0c\u7533\u8bf7\u4eba\u63d0\u8d77\u884c\u653f\u590d\u8bae\u540e\uff0c\u590d\u8bae\u673a\u5173\u4f5c\u51fa\u4e86\u8d23\u4ee4\u5c65\u884c\u7684\u51b3\u5b9a\u3002\u7136\u800c\uff0c\u8be5\u90e8\u95e8\u4ee5\u5185\u90e8\u6d41\u7a0b\u590d\u6742\u4e3a\u7531\uff0c\u8fdf\u8fdf\u672a\u4e88\u516c\u5f00\uff0c\u76f4\u81f3\u7533\u8bf7\u4eba\u518d\u6b21\u6295\u8bc9\u624d\u52c9\u5f3a\u6267\u884c\u3002\u6b64\u7c7b\u4e8b\u4f8b\u53cd\u6620\u51fa\u90e8\u5206\u884c\u653f\u673a\u5173\u5b58\u5728\u672c\u4f4d\u4e3b\u4e49\u601d\u60f3\uff0c\u5c06\u884c\u653f\u6548\u7387\u7f6e\u4e8e\u6cd5\u5f8b\u4e49\u52a1\u4e4b\u4e0a\uff0c\u4f7f\u5f97\u590d\u8bae\u51b3\u5b9a\u96be\u4ee5\u53ca\u65f6\u843d\u5b9e\u3002\n\n\u6b64\u5916\uff0c\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5185\u5bb9\u6709\u65f6\u8fc7\u4e8e\u7b3c\u7edf\uff0c\u7f3a\u4e4f\u5177\u4f53\u7684\u5c65\u884c\u671f\u9650\u548c\u65b9\u5f0f\u6307\u5f15\uff0c\u7ed9\u540e\u7eed\u76d1\u7763\u5e26\u6765\u56f0\u96be\u3002\u5f53\u590d\u8bae\u51b3\u5b9a\u4ec5\u8981\u6c42\u201c\u4f9d\u6cd5\u5904\u7406\u201d\u800c\u672a\u660e\u786e\u5177\u4f53\u6b65\u9aa4\u65f6\uff0c\u884c\u653f\u673a\u5173\u4fbf\u62e5\u6709\u8fc7\u5927\u7684\u81ea\u7531\u88c1\u91cf\u7a7a\u95f4\uff0c\u5bb9\u6613\u501f\u6545\u63a8\u8bff\u3002\u8fd9\u79cd\u6a21\u7cca\u6027\u4e0d\u4ec5\u964d\u4f4e\u4e86\u51b3\u5b9a\u7684\u53ef\u64cd\u4f5c\u6027\uff0c\u4e5f\u4e3a\u884c\u653f\u4e0d\u4f5c\u4e3a\u63d0\u4f9b\u4e86\u53ef\u4e58\u4e4b\u673a\u3002\n\ndocument \u5e94\u5f53\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173\u5236\u5ea6\u8bbe\u8ba1\uff0c\u901a\u8fc7\u7ec6\u5316\u5c65\u884c\u6807\u51c6\u3001\u5f3a\u5316\u76d1\u7763\u673a\u5236\u4ee5\u53ca\u660e\u786e\u6cd5\u5f8b\u8d23\u4efb\u6765\u63d0\u5347\u8d23\u4ee4\u5c65\u884c\u51b3\u5b9a\u7684\u5b9e\u6548\u3002\u53ea\u6709\u786e\u4fdd\u6bcf\u4e00\u7eb8\u51b3\u5b9a\u90fd\u80fd\u5f97\u5230\u4e25\u683c\u6267\u884c\uff0c\u624d\u80fd\u771f\u6b63\u5b9e\u73b0\u884c\u653f\u590d\u8bae\u5316\u89e3\u884c\u653f\u4e89\u8bae\u3001\u76d1\u7763\u4f9d\u6cd5\u884c\u653f\u7684\u7acb\u6cd5\u521d\u8877\u3002"
}
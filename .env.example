# OpenRouter (for Qwen3-8B access)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# HuggingFace (for benchmark datasets)
HF_TOKEN=your_huggingface_token_here

# Telegram notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# AWS (uses ~/.aws/credentials by default, override here if needed)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# S3 bucket for storing experiment results
S3_BUCKET=gepa-mutations-results

# RunPod
RUNPOD_API_KEY=your_runpod_api_key_here

# Experiment settings
GEPA_MODEL=qwen/qwen3-8b
GEPA_TEMPERATURE=0.6
GEPA_TOP_P=0.95
GEPA_TOP_K=20
GEPA_MAX_CONTEXT=16384
